###> symfony/framework-bundle ###
APP_ENV=test
APP_SECRET=2aa9c6e4e6404b3f83a845799d6dc31a
APP_DEBUG=0
KERNEL_CLASS=App\Kernel
# Base de données test (SQLite en mémoire ou fichier)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=test
DB_USER=root
DB_PASSWORD=
DATABASE_URL="sqlite:///%kernel.project_dir%/var/cache/test/test.db"
APP_URL=https://localhost
DEFAULT_URI=https://localhost
MAILER_DSN=null://null
###< symfony/framework-bundle ###

###> symfony/messenger ###
# En test : sync ou in-memory selon phpunit.xml
MESSENGER_TRANSPORT_DSN=in-memory://
###< symfony/messenger ###

###> symfony/brevo-mailer ###
# BREVO_API_KEY non utilisé en test (MAILER_DSN=null)
###< symfony/brevo-mailer ###

###> mautic ###
# Ne jamais appeler l'API Mautic réelle en tests (CI / local) : laisser l'URL vide (no-op dans MauticClient).
MAUTIC_URL=
MAUTIC_USER=
MAUTIC_PASSWORD=
MAUTIC_FORM_NEWSLETTER_ID=0
MAUTIC_FORM_DOWNLOAD_5M_ID=0
###< mautic ###

###> download (obligatoire pour le conteneur même si non utilisé par tous les tests) ###
DOWNLOAD_SECRET=test_download_secret_for_phpunit_only
DOWNLOAD_BASE_PATH=/tmp
DOWNLOAD_AUTHORIZE_API_KEY=
###< download ###
