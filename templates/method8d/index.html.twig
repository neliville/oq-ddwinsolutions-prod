{% extends (app.user ? 'base_with_sidebar.html.twig' : 'base.html.twig') %}

{% block head %}
    {{ parent() }}
    {% include 'components/turbo_newsletter_no_cache_meta.html.twig' %}
{% endblock %}

{% block title %}Méthode 8D en Ligne — Résolution de Problèmes Structurée | Outils-Qualité{% endblock %}

{% block meta_description %}Pilotez vos résolutions de problèmes avec la méthode 8D en ligne. 8 disciplines, suivi de progression, export PDF et JSON. Outil gratuit.{% endblock %}

{% block meta_keywords %}méthode 8d, 8 disciplines, résolution de problème, containment, plan d'action, qualité{% endblock %}

{% block og_title %}Méthode 8D - Outil Gratuit | OUTILS-QUALITÉ{% endblock %}

{% block og_description %}Suivez les 8 disciplines (8D) pour résoudre durablement vos problèmes terrain et capitaliser vos apprentissages.{% endblock %}

{% block schema_type %}{{ parent() }},SoftwareApplication{% endblock %}

{% block schema_data %}
{
    "name": "Outil Méthode 8D",
    "description": "Application complète pour piloter une démarche 8D (Eight Disciplines).",
    "url": "{{ absolute_url(path('app_eightd_index')) }}",
    "screenshot": "{{ app.request.schemeAndHttpHost ~ asset('img/og-default.jpg') }}"
}
{% endblock %}

{% block schema_webapp_json %}
{"@context":"https://schema.org","@type":"WebApplication","name":"Méthode 8D en ligne","url":{{ absolute_url(path('app_eightd_index'))|json_encode|raw }},"applicationCategory":"BusinessApplication","operatingSystem":"Web","offers":{"@type":"Offer","price":"0","priceCurrency":"EUR"},"description":"Pilotez vos résolutions de problèmes avec la méthode 8D en ligne. 8 disciplines, suivi de progression, export PDF et JSON. Outil gratuit.","featureList":["8 disciplines","Suivi de progression","Export PDF et JSON","Gratuit"]}
{% endblock %}

{% block schema_breadcrumb_json %}
{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Accueil","item":{{ absolute_url(path('app_home_index'))|json_encode|raw }}},{"@type":"ListItem","position":2,"name":"Outils","item":{{ absolute_url(path('app_outils_index'))|json_encode|raw }}},{"@type":"ListItem","position":3,"name":"Méthode 8D","item":{{ absolute_url(path('app_eightd_index'))|json_encode|raw }}}]}
{% endblock %}

{% block content %}
<main class="eightd-page{% if not app.user %} eightd-page--guest{% endif %}">
    <div class="container">
        {% include 'components/tool_breadcrumb.html.twig' with { tool_name: "Méthode 8D" } %}
        {% include 'components/tool_page_header.html.twig' with {
            tool_icon: 'layers',
            tool_name: 'Méthode 8D',
            tool_tagline: 'Résolvez durablement vos problèmes en 8 disciplines structurées',
            tool_color: 'warning'
        } %}
        <input type="hidden" id="eightdAnalysisId" value="{{ analysisId ?? '' }}">

        <header class="eightd-header" data-aos="fade-up">
            <h1>Méthode 8D</h1>
            <p class="lead">Structurez votre résolution de problème de façon professionnelle et collaborative : équipe, containment, causes racines, plan d'actions et capitalisation.</p>
            {% set meta = tool_meta('eightd') %}
            {% if meta %}
            <div class="d-flex flex-wrap gap-2 mb-2" role="list">
                <span class="badge bg-secondary" role="listitem">Niveau : {{ meta.level }}</span>
                {% for tag in meta.tags %}
                <span class="badge bg-light text-dark" role="listitem">{{ tag }}</span>
                {% endfor %}
            </div>
            {% endif %}
        </header>

        {% if not app.user %}
        <div class="alert alert-warning text-center mb-3" role="alert" aria-live="polite" data-aos="fade-up" data-aos-delay="40">
            <i data-lucide="info" width="18" height="18" class="me-2" aria-hidden="true"></i>
            <strong>Vous n'êtes pas connecté.</strong>
            <a href="{{ path('app_login') }}" class="alert-link">Connectez-vous</a> pour sauvegarder vos analyses 8D, les partager et les reprendre plus tard.
        </div>
        {% endif %}

        <section class="eightd-notice" data-aos="fade-up" data-aos-delay="60">
            <h2>🛠️ Pourquoi utiliser la méthode 8D ?</h2>
            <p>La méthode 8D (Eight Disciplines) est la démarche standard industrialisée par Ford pour éradiquer un problème à la source. Elle structure la résolution autour d'une équipe pluridisciplinaire, des actions de containment, de l'analyse des causes racines et d'une capitalisation finale. Elle est très utilisée dans l'automobile (IATF 16949), l'aéronautique, le manufacturing et tout environnement orienté client.</p>
        </section>

        <section class="mb-4" aria-labelledby="eightd-when-heading" data-aos="fade-up" data-aos-delay="65">
            <h2 id="eightd-when-heading" class="h5 fw-bold mb-2">Quand utiliser cette méthode en QSE ?</h2>
            <ul class="mb-0">
                <li><strong>Pour quel type de problème :</strong> réclamation client, non-conformité récurrente, incident majeur, demande de résolution structurée (IATF, aéronautique)</li>
                <li>Niveau requis : <strong>Intermédiaire</strong></li>
            </ul>
        </section>
        <section class="mb-4 p-3 bg-light rounded" aria-labelledby="eightd-example-heading" data-aos="fade-up" data-aos-delay="68">
            <h2 id="eightd-example-heading" class="h6 fw-bold mb-2">Exemple concret</h2>
            <p class="mb-0">Défaut de collage sur panneau porte : D0 préparation → D1 équipe 8D constituée → D2 problème décrit (quoi, où, quand, combien) → D3 containment client/process → D4 causes racines (5M, 5P) → D5 actions correctives → D6 validation → D7 prévention → D8 félicitations et partage. Plan d'action généré et suivi dans l'outil.</p>
        </section>

        <section class="eightd-overview" data-aos="fade-up" data-aos-delay="70">
            {% set steps = {
                'D0': 'Préparer',
                'D1': 'Former l’équipe',
                'D2': 'Décrire le problème',
                'D3': 'Contenir',
                'D4': 'Analyser les causes',
                'D5': 'Définir les actions',
                'D6': 'Valider l’efficacité',
                'D7': 'Prévenir la récidive',
                'D8': 'Féliciter & capitaliser'
            } %}
            {% for code, label in steps %}
            <article class="eightd-overview__card" aria-label="Discipline {{ loop.index0 }}">
                <h3>{{ code }}</h3>
                <p>{{ label }}</p>
            </article>
            {% endfor %}
        </section>

        <nav class="eightd-step-nav d-flex flex-wrap gap-2 mb-4" aria-label="Navigation par étapes 8D" data-aos="fade-up" data-aos-delay="72">
            <span class="me-2 align-self-center small text-muted">Aller à l'étape :</span>
            <a href="#d0" class="btn btn-sm btn-outline-primary">D0</a>
            <a href="#d1" class="btn btn-sm btn-outline-primary">D1</a>
            <a href="#d2" class="btn btn-sm btn-outline-primary">D2</a>
            <a href="#d3" class="btn btn-sm btn-outline-primary">D3</a>
            <a href="#d4" class="btn btn-sm btn-outline-primary">D4</a>
            <a href="#d5" class="btn btn-sm btn-outline-primary">D5</a>
            <a href="#d6" class="btn btn-sm btn-outline-primary">D6</a>
            <a href="#d7" class="btn btn-sm btn-outline-primary">D7</a>
            <a href="#d8" class="btn btn-sm btn-outline-primary">D8</a>
        </nav>

        <section class="eightd-timeline-visual mb-4 p-3 bg-light rounded small" aria-hidden="true" data-aos="fade-up" data-aos-delay="74">
            <div class="d-flex flex-wrap align-items-center gap-1 gap-md-2">
                <span class="fw-bold">D0</span><span class="text-muted">Préparer</span>
                <span aria-hidden="true">→</span>
                <span class="fw-bold">D1</span><span class="text-muted">Équipe</span>
                <span aria-hidden="true">→</span>
                <span class="fw-bold">D2</span><span class="text-muted">Problème</span>
                <span aria-hidden="true">→</span>
                <span class="fw-bold">D3</span><span class="text-muted">Contenir</span>
                <span aria-hidden="true">→</span>
                <span class="fw-bold">D4</span><span class="text-muted">Causes</span>
                <span aria-hidden="true">→</span>
                <span class="fw-bold">D5</span><span class="text-muted">Actions</span>
                <span aria-hidden="true">→</span>
                <span class="fw-bold">D6</span><span class="text-muted">Valider</span>
                <span aria-hidden="true">→</span>
                <span class="fw-bold">D7</span><span class="text-muted">Prévenir</span>
                <span aria-hidden="true">→</span>
                <span class="fw-bold">D8</span><span class="text-muted">Capitaliser</span>
            </div>
        </section>

        <section class="eightd-controls tool-actions-bar d-flex flex-wrap align-items-center gap-2 mb-3" data-aos="fade-up" data-aos-delay="100" role="toolbar" aria-label="Actions disponibles">
            <button class="btn btn-primary btn-sm" type="button" onclick="newEightDAnalysis()" aria-label="Initialiser un exemple de rapport 8D">
                <i class="fas fa-sync-alt me-2"></i>Nouvelle analyse
            </button>
            <button class="btn btn-info btn-sm" type="button" onclick="generateEightDReport()" aria-label="Générer le rapport 8D">
                <i class="fas fa-clipboard-check me-2"></i>Générer le rapport
            </button>
            <button class="btn btn-outline-danger btn-sm" type="button" onclick="resetEightDForm()" aria-label="Réinitialiser le formulaire 8D">
                <i class="fas fa-eraser me-2"></i>Réinitialiser
            </button>
            {% if app.user %}
            <button class="btn btn-success btn-sm" type="button" onclick="saveEightD()" aria-label="Sauvegarder l'analyse 8D">
                <i class="fas fa-save me-2"></i>Sauvegarder
            </button>
            <button class="btn btn-outline-secondary btn-sm" type="button" onclick="openEightDSaved()" aria-label="Charger une analyse 8D sauvegardée">
                <i class="fas fa-folder-open me-2"></i>Mes analyses
            </button>
            <div class="dropdown export-dropdown" data-controller="dropdown-basic">
                <button class="btn btn-info btn-sm dropdown-toggle" type="button" id="eightdExportDropdown" data-dropdown-basic-target="button" data-action="click->dropdown-basic#toggle keydown.enter->dropdown-basic#toggle keydown.space->dropdown-basic#toggle keydown.arrow-down->dropdown-basic#openWithKeyboard keydown.arrow-up->dropdown-basic#openWithKeyboard" aria-haspopup="true" aria-expanded="false" aria-label="Options d'export">
                    <i class="fas fa-download me-2"></i>Exporter
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="eightdExportDropdown" data-dropdown-basic-target="menu" hidden>
                    <li><button class="dropdown-item" type="button" onclick="exportEightD('png')">Exporter en PNG</button></li>
                    <li><button class="dropdown-item" type="button" onclick="exportEightD('pdf')">Exporter en PDF</button></li>
                    <li><button class="dropdown-item" type="button" onclick="exportEightD('json')">Exporter en JSON</button></li>
                </ul>
            </div>
            {% else %}
            {% include 'components/tool_actions_login.html.twig' %}
            {% endif %}
        </section>

        <section class="eightd-problem-card" data-aos="fade-up" data-aos-delay="140">
            <h2>Informations générales</h2>
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="eightd-form-group">
                        <label for="eightdTitle">Intitulé du problème / Référence 8D</label>
                        <input type="text" id="eightdTitle" placeholder="Ex : 8D-2025-017 - Défaut de collage panneau porte" oninput="updateEightDField('title', this.value)">
                    </div>
                </div>
                <div class="col-lg-3 col-sm-6">
                    <div class="eightd-form-group">
                        <label for="eightdOpenedAt">Date d'ouverture</label>
                        <input type="date" id="eightdOpenedAt" oninput="updateEightDField('openDate', this.value)">
                    </div>
                </div>
                <div class="col-lg-3 col-sm-6">
                    <div class="eightd-form-group">
                        <label for="eightdClosedAt">Date de clôture</label>
                        <input type="date" id="eightdClosedAt" oninput="updateEightDField('closeDate', this.value)">
                    </div>
                </div>
                <div class="col-12">
                    <div class="eightd-form-group">
                        <label for="eightdContext">Description courte / contexte</label>
                        <textarea id="eightdContext" placeholder="Contexte général, périmètre concerné..." oninput="updateEightDField('description', this.value)"></textarea>
                    </div>
                </div>
            </div>
        </section>

        <section id="eightdDisciplines" data-aos="fade-up" data-aos-delay="160" aria-live="polite"></section>

        <section id="eightdResults" class="eightd-results" style="display:none;" data-aos="fade-up" data-aos-delay="220">
            <div class="eightd-progress">
                <h3>Progression de la démarche 8D</h3>
                <div class="eightd-progress__bar">
                    <div class="eightd-progress__fill" id="eightdProgressBar" style="width:0%">0%</div>
                </div>
            </div>

            <div class="eightd-timeline" id="eightdTimeline"></div>

            <div class="eightd-summary">
                <h3 id="eightdSummaryTitle">Résumé de la démarche</h3>
                <ul id="eightdSummaryList"></ul>
            </div>
        </section>

        {% include 'components/tool_lead_cta.html.twig' %}
        {% include 'components/cta_ddwin.html.twig' %}

        <section class="seo-content">
            <h2>Qu'est-ce que la méthode 8D ?</h2>
            <p>Méthode structurée de résolution de problèmes en 8 disciplines, développée par Ford Motor Company. Approche collaborative qui couvre toute la chaîne de traitement d'un problème, du containment immédiat jusqu'à la capitalisation.</p>

            <h2>Comment utiliser la méthode 8D ?</h2>
            <p>Les 8 disciplines : D1 Constitution de l'équipe, D2 Description du problème, D3 Actions de containment, D4 Analyse des causes racines, D5 Actions correctives permanentes, D6 Implémentation et validation, D7 Actions préventives, D8 Félicitations de l'équipe.</p>

            <h2>Quand utiliser la méthode 8D ?</h2>
            <p>Réclamation client grave, non-conformité récurrente, incident sécurité, retour fournisseur.</p>

            <h2>Pourquoi utiliser notre outil en ligne ?</h2>
            <p>Gratuit, sans installation, export PDF et JSON, conforme ISO, RGPD, sauvegarde.</p>
        </section>
    </div>

    {# Modal pour afficher les analyses 8D sauvegardées #}
    {% if app.user %}
    {% component EightDAnalysesModal with {
        id: 'eightDLoadModal'
    } %}
    {% endcomponent %}
    {% endif %}
</main>
{% endblock %}

{% block stylesheets %}
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<link rel="stylesheet" href="{{ asset('styles/tools/method8d.scss') }}" data-turbo-track="reload">
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="{{ asset('js/main.js') }}"></script>
<script src="{{ asset('js/method8d.js') }}"></script>
<script>
    window.eightDAppConfig = {
        isAuthenticated: {{ app.user ? 'true' : 'false' }},
        analysisId: {{ analysisId is defined and analysisId ? analysisId : 'null' }},
        currentAnalysisId: null
    };

    window.eightDRoutes = {
        save: '{{ path('app_api_eightd_save') }}',
        list: '{{ path('app_api_eightd_list') }}',
        get: '{{ path('app_api_eightd_get', {id: 0}) }}',
        delete: '{{ path('app_api_eightd_delete', {id: 0}) }}',
        login: '{{ path('app_login') }}'
    };
</script>
{% endblock %}


