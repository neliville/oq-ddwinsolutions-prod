{% extends (app.user ? 'base_with_sidebar.html.twig' : 'base.html.twig') %}

{% block head %}
    {{ parent() }}
    {% include 'components/turbo_newsletter_no_cache_meta.html.twig' %}
{% endblock %}

{% block title %}Méthode 8D en Ligne — Résolution de Problèmes Structurée | Outils-Qualité{% endblock %}

{% block meta_description %}Pilotez vos résolutions de problèmes avec la méthode 8D en ligne. 8 disciplines, suivi de progression, export PDF et JSON. Outil gratuit.{% endblock %}

{% block meta_keywords %}méthode 8d, 8 disciplines, résolution de problème, containment, plan d'action, qualité{% endblock %}

{% block og_title %}Méthode 8D - Outil Gratuit | OUTILS-QUALITÉ{% endblock %}

{% block og_description %}Suivez les 8 disciplines (8D) pour résoudre durablement vos problèmes terrain et capitaliser vos apprentissages.{% endblock %}

{% block schema_type %}{{ parent() }},SoftwareApplication{% endblock %}

{% block schema_data %}
{
    "name": "Outil Méthode 8D",
    "description": "Application complète pour piloter une démarche 8D (Eight Disciplines).",
    "url": "{{ absolute_url(path('app_eightd_index')) }}",
    "screenshot": "{{ app.request.schemeAndHttpHost ~ asset('img/og-default.jpg') }}"
}
{% endblock %}

{% block schema_webapp_json %}
{"@context":"https://schema.org","@type":"WebApplication","name":"Méthode 8D en ligne","url":{{ absolute_url(path('app_eightd_index'))|json_encode|raw }},"applicationCategory":"BusinessApplication","operatingSystem":"Web","offers":{"@type":"Offer","price":"0","priceCurrency":"EUR"},"description":"Pilotez vos résolutions de problèmes avec la méthode 8D en ligne. 8 disciplines, suivi de progression, export PDF et JSON. Outil gratuit.","featureList":["8 disciplines","Suivi de progression","Export PDF et JSON","Gratuit"]}
{% endblock %}

{% block schema_breadcrumb_json %}
{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Accueil","item":{{ absolute_url(path('app_home_index'))|json_encode|raw }}},{"@type":"ListItem","position":2,"name":"Outils","item":{{ absolute_url(path('app_outils_index'))|json_encode|raw }}},{"@type":"ListItem","position":3,"name":"Méthode 8D","item":{{ absolute_url(path('app_eightd_index'))|json_encode|raw }}}]}
{% endblock %}

{% block content %}
<main class="eightd-page{% if not app.user %} eightd-page--guest{% endif %}">
    <div class="container">
        {% include 'components/tool_breadcrumb.html.twig' with { tool_name: "Méthode 8D" } %}
        {% include 'components/tool_page_header.html.twig' with {
            tool_icon: 'layers',
            tool_name: 'Méthode 8D',
            tool_tagline: 'Résolvez durablement vos problèmes en 8 disciplines structurées',
            tool_color: 'warning',
            tool_seo_route: 'app_tool_seo_8d'
        } %}
        <input type="hidden" id="eightdAnalysisId" value="{{ analysisId ?? '' }}">

        <div class="page-header tool-page-header--compact">
            <h1 class="page-title">Méthode 8D</h1>
            <p class="lead">Structurez votre résolution de problème de façon professionnelle et collaborative : équipe, containment, causes racines, plan d'actions et capitalisation.</p>
            {% include 'components/tool_meta_hints.html.twig' with {
                tool_slug: 'eightd',
                hint_id_prefix: 'eightd',
                meta_intro: 'Survolez ou mettez le focus sur une pastille pour un court descriptif. L’aide détaillée est dans l’encadré juste en dessous ; le formulaire 8D suit.',
                tag_hints: {
                    'Résolution de problèmes': 'Cadre éprouvé pour traiter les dossiers clients ou internes jusqu’à la preuve d’efficacité.',
                    "Plan d'action": 'Relier chaque discipline à des actions datées et responsabilisées.',
                    'IATF 16949': 'Attendu fréquent en automotive pour les dossiers de réclamation et sécurisation des livraisons.',
                    'Amélioration continue': 'Capitalisation en D8 pour éviter la récidive et enrichir le système qualité.',
                },
            } %}
        </div>

        {% if not app.user %}
        <div class="flex items-center justify-center gap-2 rounded-lg bg-yellow-50 border border-yellow-200 text-yellow-800 px-4 py-3 mb-4 text-center" role="alert" aria-live="polite">
            <i data-lucide="info" width="18" height="18" class="mr-2 shrink-0" aria-hidden="true"></i>
            <span><strong>Vous n'êtes pas connecté.</strong>
            <a href="{{ path('app_login') }}" class="font-medium underline hover:no-underline text-yellow-900">Connectez-vous</a> pour sauvegarder vos analyses 8D, les partager et les reprendre plus tard.</span>
        </div>
        {% endif %}

        {% include 'components/tool_help/eightd_accordion.html.twig' %}

        {% set eightd_journey = [
            { code: 'D0', slug: 'd0', short: 'Préparer', title: 'Contexte et lancement' },
            { code: 'D1', slug: 'd1', short: 'Équipe', title: 'Équipe pluridisciplinaire' },
            { code: 'D2', slug: 'd2', short: 'Problème', title: 'Description factuelle' },
            { code: 'D3', slug: 'd3', short: 'Contenir', title: 'Protection client' },
            { code: 'D4', slug: 'd4', short: 'Causes', title: 'Causes racines' },
            { code: 'D5', slug: 'd5', short: 'Actions', title: 'Actions correctives' },
            { code: 'D6', slug: 'd6', short: 'Valider', title: 'Efficacité' },
            { code: 'D7', slug: 'd7', short: 'Prévenir', title: 'Standardisation' },
            { code: 'D8', slug: 'd8', short: 'Capitaliser', title: 'Clôture & leçons' },
        ] %}
        <section class="eightd-journey" aria-labelledby="eightd-journey-title">
            <div class="eightd-journey__intro">
                <h2 id="eightd-journey-title" class="eightd-journey__title">Parcours des disciplines</h2>
                <p class="eightd-journey__lede">Neuf étapes de <strong>D0</strong> à <strong>D8</strong> — une seule navigation : choisissez l’étape à remplir, le formulaire correspondant se trouve plus bas.</p>
            </div>
            <div class="eightd-journey__rail" role="navigation" aria-label="Aller à une discipline 8D">
                <ol class="eightd-journey__list">
                    {% for step in eightd_journey %}
                        <li class="eightd-journey__item">
                            {% if not loop.first %}
                                <span class="eightd-journey__connector" aria-hidden="true"></span>
                            {% endif %}
                            <a href="#{{ step.slug }}" class="eightd-journey__step" aria-label="{{ step.code }} {{ step.short }} — {{ step.title }}">
                                <span class="eightd-journey__code" aria-hidden="true">{{ step.code }}</span>
                                <span class="eightd-journey__short" aria-hidden="true">{{ step.short }}</span>
                            </a>
                        </li>
                    {% endfor %}
                </ol>
            </div>
        </section>

        <section class="eightd-controls tool-actions-bar flex flex-wrap items-center gap-2 mb-4" role="toolbar" aria-label="Actions disponibles">
            <button class="inline-flex items-center justify-center gap-1.5 bg-primary text-primary-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="newEightDAnalysis()" aria-label="Initialiser un exemple de rapport 8D">
                <i class="fas fa-sync-alt mr-2"></i>Nouvelle analyse
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 bg-sky-500 text-white px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="generateEightDReport()" aria-label="Générer le rapport 8D">
                <i class="fas fa-clipboard-check mr-2"></i>Générer le rapport
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 bg-destructive text-destructive-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="resetEightDForm()" aria-label="Réinitialiser le formulaire 8D">
                <i class="fas fa-eraser mr-2"></i>Réinitialiser
            </button>
            {% if app.user %}
            <button class="inline-flex items-center justify-center gap-1.5 bg-green-600 text-white px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="saveEightD()" aria-label="Sauvegarder l'analyse 8D">
                <i class="fas fa-save mr-2"></i>Sauvegarder
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors" type="button" onclick="openEightDSaved()" aria-label="Charger une analyse 8D sauvegardée">
                <i class="fas fa-folder-open mr-2"></i>Mes analyses
            </button>
            {% include 'components/tool_export_dropdown.html.twig' with {
                button_id: 'eightdExportDropdown',
                items: [
                    { icon: 'fas fa-image', label: 'Exporter en PNG', onclick: 'exportEightD("png")' },
                    { icon: 'fas fa-file-pdf', label: 'Exporter en PDF', onclick: 'exportEightD("pdf")' },
                    { icon: 'fas fa-file-code', label: 'Exporter en JSON', onclick: 'exportEightD("json")' },
                ],
            } %}
            {% else %}
            {% include 'components/tool_actions_login.html.twig' %}
            {% endif %}
        </section>

        <section class="eightd-problem-card">
            <h2>Informations générales</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-4">
                <div class="sm:col-span-2 lg:col-span-6">
                    <div class="eightd-form-group">
                        <label for="eightdTitle">Intitulé du problème / Référence 8D</label>
                        <input type="text" id="eightdTitle" placeholder="Ex : 8D-2025-017 - Défaut de collage panneau porte" oninput="updateEightDField('title', this.value)">
                    </div>
                </div>
                <div class="lg:col-span-3">
                    <div class="eightd-form-group">
                        <label for="eightdOpenedAt">Date d'ouverture</label>
                        <div class="oq-date-field" data-controller="date-field">
                            <div class="oq-date-field__control">
                                <span class="oq-date-field__icon" aria-hidden="true">
                                    <i data-lucide="calendar" width="16" height="16"></i>
                                </span>
                                <input type="date" id="eightdOpenedAt" data-date-field-target="input" class="oq-date-field__input">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="lg:col-span-3">
                    <div class="eightd-form-group">
                        <label for="eightdClosedAt">Date de clôture</label>
                        <div class="oq-date-field" data-controller="date-field">
                            <div class="oq-date-field__control">
                                <span class="oq-date-field__icon" aria-hidden="true">
                                    <i data-lucide="calendar" width="16" height="16"></i>
                                </span>
                                <input type="date" id="eightdClosedAt" data-date-field-target="input" class="oq-date-field__input">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="sm:col-span-2 lg:col-span-12">
                    <div class="eightd-form-group">
                        <label for="eightdContext">Description courte / contexte</label>
                        <textarea id="eightdContext" placeholder="Contexte général, périmètre concerné..." oninput="updateEightDField('description', this.value)"></textarea>
                    </div>
                </div>
            </div>
        </section>

        <section id="eightdDisciplines" aria-live="polite"></section>

        <section id="eightdResults" class="eightd-results" style="display:none;">
            <div class="eightd-progress">
                <h3>Progression de la démarche 8D</h3>
                <div class="eightd-progress__bar">
                    <div class="eightd-progress__fill" id="eightdProgressBar" style="width:0%">0%</div>
                </div>
            </div>

            <div class="eightd-timeline" id="eightdTimeline"></div>

            <div class="eightd-summary">
                <h3 id="eightdSummaryTitle">Résumé de la démarche</h3>
                <ul id="eightdSummaryList"></ul>
            </div>
        </section>

        {% include 'components/qse/capa_soft_cta.html.twig' with { tool: 'eight_d' } %}

        {% include 'components/tool_lead_cta.html.twig' %}
        {% include 'components/cta_ddwin.html.twig' %}

        <section class="seo-content">
            <h2>Qu'est-ce que la méthode 8D ?</h2>
            <p>Méthode structurée de résolution de problèmes en 8 disciplines, développée par Ford Motor Company. Approche collaborative qui couvre toute la chaîne de traitement d'un problème, du containment immédiat jusqu'à la capitalisation.</p>

            <h2>Comment utiliser la méthode 8D ?</h2>
            <p>Les 8 disciplines : D1 Constitution de l'équipe, D2 Description du problème, D3 Actions de containment, D4 Analyse des causes racines, D5 Actions correctives permanentes, D6 Implémentation et validation, D7 Actions préventives, D8 Félicitations de l'équipe.</p>

            <h2>Quand utiliser la méthode 8D ?</h2>
            <p>Réclamation client grave, non-conformité récurrente, incident sécurité, retour fournisseur.</p>

            <h2>Pourquoi utiliser notre outil en ligne ?</h2>
            <p>Gratuit, sans installation, export PDF et JSON, conforme ISO, RGPD, sauvegarde.</p>
        </section>
    </div>

    {# Modal pour afficher les analyses 8D sauvegardées #}
    {% if app.user %}
    {% component EightDAnalysesModal with {
        id: 'eightDLoadModal'
    } %}
    {% endcomponent %}
    {% endif %}
</main>
{% endblock %}

{% block stylesheets %}
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<link rel="stylesheet" href="{{ asset('styles/tools/method8d.css') }}" data-turbo-track="reload">
{% endblock %}

{% block javascripts %}
<script type="module">
    import { scanAndInitDateFields } from 'oq/flatpickr-config';
    window.oqInitDateFields = scanAndInitDateFields;
    document.dispatchEvent(new CustomEvent('oq:date-fields-ready'));
</script>
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="{{ asset('js/export-branding.js') }}"></script>
<script src="{{ asset('js/main.js') }}"></script>
<script src="{{ asset('js/method8d.js') }}"></script>
<script>
    window.eightDAppConfig = {
        isAuthenticated: {{ app.user ? 'true' : 'false' }},
        analysisId: {{ analysisId is defined and analysisId ? analysisId : 'null' }},
        currentAnalysisId: null
    };

    window.eightDRoutes = {
        save: '{{ path('app_api_eightd_save') }}',
        list: '{{ path('app_api_eightd_list') }}',
        get: '{{ path('app_api_eightd_get', {id: 0}) }}',
        delete: '{{ path('app_api_eightd_delete', {id: 0}) }}',
        login: '{{ path('app_login') }}'
    };
</script>
{% endblock %}


