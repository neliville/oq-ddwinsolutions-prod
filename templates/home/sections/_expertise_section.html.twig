<section id="accompagnement" class="expertise-section home-section-premium home-section-premium--expertise" aria-labelledby="accompagnement-heading">
    <div class="home-section-bridge" data-home-section-bridge aria-hidden="true"></div>
    <div class="home-section-premium__glow home-section-premium__glow--expertise" aria-hidden="true"></div>
    <div class="container">
        <div class="expertise-content">
            <div class="expertise-text">
                <header class="expertise-section__intro" data-home-section-intro>
                    <span class="section-badge">Accompagnement</span>
                    <h2 id="accompagnement-heading">Besoin d'aller plus loin ? L'équipe DDWin vous accompagne</h2>
                    <p class="lead">
                        <strong>Outils-Qualite.com</strong> est un produit self-service gratuit pour le terrain.
                        <a href="https://ddwinsolutions.fr" target="_blank" rel="noopener noreferrer">DDWin Solutions</a>
                        vous accompagne sur la digitalisation QSE, les systèmes de management et l'excellence opérationnelle.
                    </p>
                </header>

                <div class="expertise-grid" role="list">
                    <article class="expertise-card motion-card" role="listitem" data-home-reveal>
                        <div class="expertise-card__icon expertise-card__icon--indigo" aria-hidden="true">
                            <i data-lucide="wrench"></i>
                        </div>
                        <div class="expertise-card__body">
                            <h3 class="expertise-card__title">Digitalisation des processus QSE</h3>
                            <p>Transformation digitale de vos démarches qualité, sécurité et environnement.</p>
                        </div>
                    </article>
                    <article class="expertise-card motion-card" role="listitem" data-home-reveal>
                        <div class="expertise-card__icon expertise-card__icon--sky" aria-hidden="true">
                            <i data-lucide="monitor"></i>
                        </div>
                        <div class="expertise-card__body">
                            <h3 class="expertise-card__title">Solutions informatiques sur mesure</h3>
                            <p>Développement d'applications métier adaptées à vos besoins spécifiques.</p>
                        </div>
                    </article>
                    <article class="expertise-card motion-card" role="listitem" data-home-reveal>
                        <div class="expertise-card__icon expertise-card__icon--violet" aria-hidden="true">
                            <i data-lucide="clipboard-list"></i>
                        </div>
                        <div class="expertise-card__body">
                            <h3 class="expertise-card__title">Conseil en systèmes de management</h3>
                            <p>Expertise ISO 9001, 14001, 45001, 55001 et amélioration continue.</p>
                        </div>
                    </article>
                    <article class="expertise-card motion-card" role="listitem" data-home-reveal>
                        <div class="expertise-card__icon expertise-card__icon--rose" aria-hidden="true">
                            <i data-lucide="rocket"></i>
                        </div>
                        <div class="expertise-card__body">
                            <h3 class="expertise-card__title">Lean Manufacturing &amp; excellence opérationnelle</h3>
                            <p>Outils et méthodes pour l'amélioration continue de vos processus.</p>
                        </div>
                    </article>
                </div>

                <div class="expertise-section__actions mt-8 flex flex-col sm:flex-row flex-wrap gap-3" data-home-reveal>
                    <twig:Button as="a" href="{{ path('app_contact_index') }}" size="lg" class="no-underline">
                        Parler à un expert QSE
                    </twig:Button>
                    <twig:Button as="a" href="https://ddwinsolutions.fr" target="_blank" rel="noopener noreferrer" variant="outline" size="lg" class="no-underline">
                        Découvrir DDWin Solutions
                    </twig:Button>
                </div>

                <p class="expertise-section__footnote" data-home-reveal>
                    Découvrez aussi
                    <a href="https://duerpilot.fr" target="_blank" rel="noopener noreferrer">DUERPilot</a>,
                    notre solution SaaS dédiée au DUERP pour les TPE/PME françaises.
                </p>
            </div>
        </div>
    </div>
</section>
