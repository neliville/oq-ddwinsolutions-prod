<section id="hero" class="hero hero--tools-v2" aria-labelledby="home-hero-heading">
    <div class="container">
        <div class="hero-grid">
            <div class="hero-content">
                <div class="home-hero-badges mb-4 flex flex-wrap items-center gap-2">
                    <span class="badge-dot shrink-0" aria-hidden="true"></span>
                    <twig:Badge variant="secondary" class="font-normal">6 outils qualité</twig:Badge>
                    <twig:Badge variant="secondary" class="font-normal">Gratuits</twig:Badge>
                    <twig:Badge variant="secondary" class="font-normal">Sans inscription pour démarrer</twig:Badge>
                </div>
                <h1 id="home-hero-heading" class="hero-title js-hero-title">Analysez vos problèmes qualité en ligne, gratuitement et tout de suite</h1>
                <p class="hero-subtitle js-hero-subtitle">
                    Ishikawa, 5 Pourquoi, Pareto, AMDEC… Créez, exportez en PDF et retrouvez vos analyses quand vous créez un compte gratuit.
                </p>
                <p class="hero-usp-note m-0 mt-3 text-sm text-muted-foreground">
                    Sans inscription pour essayer · Export PDF · Compte gratuit pour sauvegarder en ligne
                </p>

                <div class="hero-actions">
                <div class="hero-cta js-hero-cta flex flex-col sm:flex-row flex-wrap gap-3">
                    {% if is_granted('ROLE_USER') %}
                        <twig:Button as="a" href="{{ path('app_ishikawa_index') }}" size="lg" class="no-underline h-11 px-5 sm:h-10">
                            Continuer sur Ishikawa
                        </twig:Button>
                        <twig:Button as="a" href="{{ path('app_dashboard_index') }}" variant="outline" size="lg" class="no-underline h-11 px-5 sm:h-10 bg-background/80">
                            Ouvrir mon cockpit QHSE
                        </twig:Button>
                    {% else %}
                        <twig:Button as="a" href="{{ path('app_ishikawa_index') }}" size="lg" class="no-underline h-11 px-5 sm:h-10">
                            Essayer Ishikawa gratuitement
                        </twig:Button>
                        <twig:Button as="a" href="#outils" variant="outline" size="lg" class="no-underline h-11 px-5 sm:h-10 bg-background/80">
                            Voir les 6 outils
                        </twig:Button>
                    {% endif %}
                </div>
                {% if not is_granted('ROLE_USER') %}
                    <p class="hero-login-hint m-0 text-sm">
                        <a href="{{ path('app_register') }}" class="font-medium text-primary underline underline-offset-4">Créer un compte gratuit</a>
                        <span class="text-muted-foreground"> · </span>
                        <a href="{{ path('app_login') }}" class="text-muted-foreground underline underline-offset-4">Déjà un compte ? Se connecter</a>
                    </p>
                {% endif %}
                </div>

                <div class="hero-stats js-kpi-card mt-8">
                    <div class="stat-item">
                        <span class="stat-value">6 outils</span>
                        <span class="stat-label">Méthodes terrain QSE</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-value">0 €</span>
                        <span class="stat-label">Pas de carte bancaire</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-value">PDF</span>
                        <span class="stat-label">Exports prêts pour l'audit</span>
                    </div>
                </div>

                <nav class="hero-tools-strip mt-8" aria-label="Accès rapide aux outils">
                    <ul class="hero-tools-strip__list m-0 p-0 list-none flex flex-wrap gap-2">
                        <li><a href="{{ path('app_ishikawa_index') }}" class="hero-tools-strip__link">Ishikawa</a></li>
                        <li><a href="{{ path('app_fivewhy_index') }}" class="hero-tools-strip__link">5 Pourquoi</a></li>
                        <li><a href="{{ path('app_pareto_index') }}" class="hero-tools-strip__link">Pareto</a></li>
                        <li><a href="{{ path('app_qqoqccp_index') }}" class="hero-tools-strip__link">QQOQCCP</a></li>
                        <li><a href="{{ path('app_amdec_index') }}" class="hero-tools-strip__link">AMDEC</a></li>
                        <li><a href="{{ path('app_eightd_index') }}" class="hero-tools-strip__link">8D</a></li>
                    </ul>
                </nav>
            </div>

