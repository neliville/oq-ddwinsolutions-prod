<section id="dashboard-focus" class="home-landing-section py-14 sm:py-16" aria-labelledby="home-dashboard-heading">
    <div class="container max-w-6xl mx-auto px-4">
        <div class="grid gap-10 lg:grid-cols-2 lg:gap-14 items-center">
            <div data-aos="fade-up">
                <twig:Badge variant="outline" class="mb-3">Récurrence</twig:Badge>
                <h2 id="home-dashboard-heading" class="text-2xl sm:text-3xl font-bold tracking-tight m-0">
                    Le cockpit qui garde vos priorités visibles au quotidien
                </h2>
                <p class="text-muted-foreground mt-3 text-base m-0">
                    Votre point de passage quotidien puis hebdomadaire réduit la charge mentale :
                    les audits à préparer, les CAPA à relancer, les risques à arbitrer
                    et les échéances à revoir restent visibles dans le même cockpit.
                </p>
                <ul class="mt-6 space-y-2 text-sm text-foreground list-none m-0 p-0">
                    <li class="flex gap-2"><span class="text-primary font-semibold shrink-0">·</span> Priorités du jour et de la semaine au même endroit</li>
                    <li class="flex gap-2"><span class="text-primary font-semibold shrink-0">·</span> Audits à préparer sans refaire le tour de vos fichiers</li>
                    <li class="flex gap-2"><span class="text-primary font-semibold shrink-0">·</span> CAPA à relancer avant qu'elles sortent du radar</li>
                    <li class="flex gap-2"><span class="text-primary font-semibold shrink-0">·</span> Risques visibles pour arbitrer plus vite</li>
                    <li class="flex gap-2"><span class="text-primary font-semibold shrink-0">·</span> Échéances, alertes et avancement PDCA dans une seule revue</li>
                </ul>
                <div class="mt-8">
                    {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('app_dashboard_index') }}" class="text-sm font-medium text-primary underline underline-offset-4">
                            Ouvrir mon cockpit
                        </a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="text-sm font-medium text-primary underline underline-offset-4">
                            Me connecter au cockpit
                        </a>
                    {% endif %}
                </div>
            </div>

            <div class="js-dashboard-preview rounded-xl border border-border/80 bg-card shadow-sm p-4 sm:p-6" data-aos="fade-up" data-aos-delay="60" aria-hidden="true">
                <div class="flex items-center justify-between border-b border-border/60 pb-3 mb-4">
                    <span class="text-sm font-semibold">Cockpit</span>
                    <twig:Badge variant="secondary" class="text-xs">Aujourd’hui</twig:Badge>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div class="rounded-lg bg-destructive/10 border border-destructive/20 p-3">
                        <p class="text-xs text-muted-foreground m-0">En retard</p>
                        <p class="text-2xl font-bold text-destructive m-0 mt-1">3</p>
                    </div>
                    <div class="rounded-lg bg-muted/80 p-3">
                        <p class="text-xs text-muted-foreground m-0">CAPA ouvertes</p>
                        <p class="text-2xl font-bold m-0 mt-1">12</p>
                    </div>
                    <div class="rounded-lg bg-muted/80 p-3 col-span-2">
                        <p class="text-xs text-muted-foreground m-0">Prochain audit</p>
                        <p class="text-sm font-medium m-0 mt-1">ISO 9001 — revue dans 9 jours</p>
                        <twig:Separator class="my-3" />
                        <div class="flex gap-2 flex-wrap">
                            <twig:Badge variant="outline" class="text-xs">Risques</twig:Badge>
                            <twig:Badge variant="outline" class="text-xs">PDCA</twig:Badge>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
