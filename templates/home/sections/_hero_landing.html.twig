<section id="hero" class="hero" aria-labelledby="home-hero-heading">
    <div class="container">
        <div class="hero-grid">
            <div class="hero-content">
                <div class="home-hero-badges mb-4 flex flex-wrap items-center gap-2">
                    <span class="badge-dot shrink-0" aria-hidden="true"></span>
                    <twig:Badge variant="secondary" class="font-normal">Plateforme QHSE</twig:Badge>
                    <twig:Badge variant="secondary" class="font-normal">Cockpit de pilotage</twig:Badge>
                    <twig:Badge variant="secondary" class="font-normal">Priorités et alertes</twig:Badge>
                </div>
                <p class="hero-problem mt-4">
                    Sans cockpit, la charge mentale monte vite: audits, CAPA, risques et échéances se dispersent jusqu'à faire perdre la maîtrise des priorités.
                </p>
                <h1 id="home-hero-heading" class="hero-title js-hero-title">Le cockpit QHSE pour reprendre le contrôle de vos priorités</h1>
                <p class="hero-subtitle js-hero-subtitle">
                    Le point de passage quotidien qui réduit la charge mentale : audits, CAPA, risques et échéances restent enfin dans une même vue.
                </p>

                <div class="hero-cta js-hero-cta flex flex-col sm:flex-row flex-wrap gap-3">
                    {% if is_granted('ROLE_USER') %}
                        <twig:Button as="a" href="{{ path('app_dashboard_index') }}" size="lg" class="no-underline h-11 px-5 sm:h-10">
                            Ouvrir mon cockpit QHSE
                        </twig:Button>
                    {% else %}
                        <twig:Button as="a" href="{{ path('app_register') }}" size="lg" class="no-underline h-11 px-5 sm:h-10">
                            Reprendre le contrôle de mon QHSE
                        </twig:Button>
                        <twig:Button as="a" href="{{ path('app_login') }}" variant="outline" size="lg" class="no-underline h-11 px-5 sm:h-10 bg-background/80">
                            Voir mon cockpit
                        </twig:Button>
                    {% endif %}
                </div>

                <div class="hero-stats js-kpi-card mt-8">
                    <div class="stat-item">
                        <span class="stat-value">1 vue</span>
                        <span class="stat-label">Priorités, alertes et échéances</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-value">4 flux</span>
                        <span class="stat-label">Audit ISO, CAPA, Risques, PDCA</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-value">0 oubli</span>
                        <span class="stat-label">Moins de dispersion, plus de maîtrise</span>
                    </div>
                </div>
            </div>

            <div class="hero-landing-preview js-hero-preview home-hero-preview" data-aos="fade-up" data-aos-delay="80" aria-hidden="true">
                <div class="home-hero-preview__browser">
                    <div class="home-hero-preview__browser-bar">
                        <span class="home-hero-preview__dots" aria-hidden="true"><span></span><span></span><span></span></span>
                        <span class="home-hero-preview__url text-muted-foreground text-xs truncate">cockpit.outils-qualite.com</span>
                    </div>
                    <article class="rounded-[1.5rem] border border-border/70 bg-background/95 p-4 shadow-sm sm:p-5">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="m-0 text-[11px] font-semibold uppercase tracking-[0.24em] text-muted-foreground">Cockpit QHSE</p>
                                <p class="m-0 mt-1 text-sm font-semibold text-foreground">Priorités, échéances et alertes sous contrôle</p>
                            </div>
                            <twig:Badge variant="destructive" class="text-[10px] px-2 py-0.5">3 alertes critiques</twig:Badge>
                        </div>

                        <div class="mt-4 grid gap-3 lg:grid-cols-[1.2fr_0.8fr]">
                            <div class="rounded-2xl border border-border/70 bg-muted/30 p-3 js-hero-cockpit-priority">
                                <p class="m-0 text-xs font-semibold text-foreground">Priorités de la semaine</p>
                                <div class="mt-3 space-y-2">
                                    <div class="rounded-xl border border-border/60 bg-background/90 px-3 py-2">
                                        <p class="m-0 text-[11px] font-medium text-foreground">Audit ISO 9001 interne</p>
                                        <p class="m-0 mt-1 text-[11px] text-muted-foreground">J-3 · checklist incomplète · relance équipe</p>
                                    </div>
                                    <div class="rounded-xl border border-border/60 bg-background/90 px-3 py-2">
                                        <p class="m-0 text-[11px] font-medium text-foreground">CAPA fournisseur critique</p>
                                        <p class="m-0 mt-1 text-[11px] text-muted-foreground">Échéance 48h · propriétaire à confirmer</p>
                                    </div>
                                    <div class="rounded-xl border border-border/60 bg-background/90 px-3 py-2">
                                        <p class="m-0 text-[11px] font-medium text-foreground">Risque maintenance</p>
                                        <p class="m-0 mt-1 text-[11px] text-muted-foreground">Criticité haute · action préventive attendue</p>
                                    </div>
                                </div>
                            </div>

                            <div class="space-y-3 js-hero-cockpit-kpis">
                                <div class="rounded-2xl border border-border/70 bg-muted/30 p-3">
                                    <p class="m-0 text-xs font-semibold text-foreground">Modules visibles</p>
                                    <div class="mt-3 grid grid-cols-2 gap-2 text-[11px]">
                                        <div class="rounded-xl border border-border/60 bg-background/90 px-3 py-2">
                                            <p class="m-0 font-medium text-foreground">Audit ISO</p>
                                            <p class="m-0 mt-1 text-muted-foreground">2 audits à préparer</p>
                                        </div>
                                        <div class="rounded-xl border border-border/60 bg-background/90 px-3 py-2">
                                            <p class="m-0 font-medium text-foreground">CAPA</p>
                                            <p class="m-0 mt-1 text-muted-foreground">5 actions ouvertes</p>
                                        </div>
                                        <div class="rounded-xl border border-border/60 bg-background/90 px-3 py-2">
                                            <p class="m-0 font-medium text-foreground">Risques</p>
                                            <p class="m-0 mt-1 text-muted-foreground">3 critiques à traiter</p>
                                        </div>
                                        <div class="rounded-xl border border-border/60 bg-background/90 px-3 py-2">
                                            <p class="m-0 font-medium text-foreground">PDCA</p>
                                            <p class="m-0 mt-1 text-muted-foreground">Cycle hebdo aligné</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="rounded-2xl border border-border/70 bg-primary/5 p-3 js-hero-cockpit-summary">
                                    <div class="flex items-center justify-between gap-3">
                                        <p class="m-0 text-xs font-semibold text-foreground">Synthèse PDCA</p>
                                        <span class="text-[11px] font-medium text-primary">2 plans à relancer</span>
                                    </div>
                                    <div class="mt-3 space-y-2 text-[11px] text-muted-foreground">
                                        <div class="flex items-center justify-between gap-3">
                                            <span>Charge mentale réduite</span>
                                            <span class="font-medium text-foreground">Vue unique</span>
                                        </div>
                                        <div class="flex items-center justify-between gap-3">
                                            <span>Dispersion limitée</span>
                                            <span class="font-medium text-foreground">Priorités claires</span>
                                        </div>
                                        <div class="flex items-center justify-between gap-3">
                                            <span>Perte de maîtrise évitée</span>
                                            <span class="font-medium text-foreground">Alertes suivies</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </div>
</section>
