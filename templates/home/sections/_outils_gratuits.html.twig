<section id="outils" class="tools-section home-section-premium home-section-premium--tools" aria-labelledby="home-outils-heading">
    <div class="home-section-bridge" data-home-section-bridge aria-hidden="true"></div>
    <div class="home-section-premium__glow" aria-hidden="true"></div>
    <div class="container">
        <header class="section-header max-w-3xl mx-auto text-center" data-home-section-intro>
            <span class="section-badge">Outils gratuits</span>
            <h2 id="home-outils-heading">Choisissez votre outil et démarrez en 30 secondes</h2>
            <p>6 méthodes QSE en ligne : gratuit, export PDF, sans inscription obligatoire pour commencer.</p>
        </header>

        <div class="tools-showcase max-w-6xl mx-auto">
            <div class="tools-grid">
                <article class="tool-card motion-card tool-card--featured home-tool-card" data-home-reveal>
                    <span class="tool-card__featured-badge">
                        <i data-lucide="sparkles" class="tool-card__featured-badge-icon" aria-hidden="true"></i>
                        Le plus utilisé
                    </span>
                    {% include 'home/partials/_tool_icon.html.twig' with { tool: 'ishikawa' } %}
                    <h3 class="home-tool-card__title">Diagramme d'Ishikawa</h3>
                    <p class="home-tool-card__desc">Structurez vos causes possibles avec un cadre visuel 5M / 6M, prêt pour vos revues d'écart.</p>
                    <div class="tool-card__tags">
                        <span class="home-tool-tag">Sans inscription</span>
                        <span class="home-tool-tag">Export PDF</span>
                        <span class="home-tool-tag">Démarrage immédiat</span>
                    </div>
                    <a href="{{ path('app_ishikawa_index') }}" aria-label="Créer un diagramme d'Ishikawa" class="home-tool-card__cta">
                        <span>Utiliser gratuitement</span>
                        <span class="home-tool-card__cta-hint">Sans inscription · PDF</span>
                        <i data-lucide="arrow-right" class="home-tool-card__cta-arrow" aria-hidden="true"></i>
                    </a>
                </article>

                <article class="tool-card motion-card home-tool-card" data-home-reveal>
                    {% include 'home/partials/_tool_icon.html.twig' with { tool: 'fivewhy' } %}
                    <h3 class="home-tool-card__title">Méthode 5 Pourquoi</h3>
                    <p class="home-tool-card__desc">Remontez à l'origine d'un problème avec un questionnement simple et directement exploitable.</p>
                    <div class="tool-card__tags">
                        <span class="home-tool-tag">Sans inscription</span>
                        <span class="home-tool-tag">Export PDF</span>
                        <span class="home-tool-tag">Guide intégré</span>
                    </div>
                    <a href="{{ path('app_fivewhy_index') }}" aria-label="Utiliser la méthode 5 Pourquoi" class="home-tool-card__cta">
