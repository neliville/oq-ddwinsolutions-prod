                        <i data-lucide="arrow-right" class="home-tool-card__cta-arrow" aria-hidden="true"></i>
                    </a>
                </article>

                <article class="tool-card motion-card home-tool-card" data-home-reveal>
                    {% include 'home/partials/_tool_icon.html.twig' with { tool: 'eightd' } %}
                    <h3 class="home-tool-card__title">Méthode 8D</h3>
                    <p class="home-tool-card__desc">Suivez une résolution structurée en 8 étapes pour un cadre formel dès le départ.</p>
