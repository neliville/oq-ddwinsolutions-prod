                <article class="tool-card motion-card home-tool-card" data-home-reveal>
                    {% include 'home/partials/_tool_icon.html.twig' with { tool: 'amdec' } %}
                    <h3 class="home-tool-card__title">Analyse AMDEC</h3>
                    <p class="home-tool-card__desc">Repérez vos risques prioritaires et hiérarchisez vos actions sur un cas concret.</p>
                    <div class="tool-card__tags">
