<section id="workflow" class="home-landing-section py-16 sm:py-20 bg-muted/25" aria-labelledby="home-workflow-heading">
    <div class="container max-w-6xl mx-auto px-4">
        <header class="text-center max-w-3xl mx-auto mb-12" data-aos="fade-up">
            <h2 id="home-workflow-heading" class="text-2xl sm:text-3xl font-bold tracking-tight m-0">Un flux simple : analyser, agir, vérifier, piloter</h2>
        </header>

        <ol class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5 list-none m-0 p-0">
            <li class="workflow-step-1 js-workflow-step" data-aos="fade-up" data-aos-delay="0">
                <twig:Card class="h-full border-border/80 shadow-sm">
                    <twig:Card:Header class="pb-2">
                        <twig:Badge variant="secondary" class="mb-2 w-8 h-8 rounded-full p-0 flex items-center justify-center shrink-0">1</twig:Badge>
                        <twig:Card:Title class="text-base">Analysez</twig:Card:Title>
                    </twig:Card:Header>
                    <twig:Card:Content class="text-sm text-muted-foreground pt-0">
                        Outils qualité : Ishikawa, 5 Pourquoi, Pareto, AMDEC, QQOQCCP, 8D.
                    </twig:Card:Content>
                </twig:Card>
            </li>
            <li class="workflow-step-2 js-workflow-step" data-aos="fade-up" data-aos-delay="40">
                <twig:Card class="h-full border-border/80 shadow-sm">
                    <twig:Card:Header class="pb-2">
                        <twig:Badge variant="secondary" class="mb-2 w-8 h-8 rounded-full p-0 flex items-center justify-center shrink-0">2</twig:Badge>
                        <twig:Card:Title class="text-base">Auditez</twig:Card:Title>
                    </twig:Card:Header>
                    <twig:Card:Content class="text-sm text-muted-foreground pt-0">
                        Lancez un audit ISO 9001, 14001 ou 45001.
                    </twig:Card:Content>
                </twig:Card>
            </li>
            <li class="workflow-step-3 js-workflow-step" data-aos="fade-up" data-aos-delay="80">
                <twig:Card class="h-full border-border/80 shadow-sm">
                    <twig:Card:Header class="pb-2">
                        <twig:Badge variant="secondary" class="mb-2 w-8 h-8 rounded-full p-0 flex items-center justify-center shrink-0">3</twig:Badge>
                        <twig:Card:Title class="text-base">Créez vos CAPA</twig:Card:Title>
                    </twig:Card:Header>
                    <twig:Card:Content class="text-sm text-muted-foreground pt-0">
                        Transformez les écarts et causes en actions suivies.
                    </twig:Card:Content>
                </twig:Card>
            </li>
            <li class="workflow-step-4 js-workflow-step" data-aos="fade-up" data-aos-delay="120">
                <twig:Card class="h-full border-border/80 shadow-sm">
                    <twig:Card:Header class="pb-2">
                        <twig:Badge variant="secondary" class="mb-2 w-8 h-8 rounded-full p-0 flex items-center justify-center shrink-0">4</twig:Badge>
                        <twig:Card:Title class="text-base">Maîtrisez vos risques</twig:Card:Title>
                    </twig:Card:Header>
                    <twig:Card:Content class="text-sm text-muted-foreground pt-0">
                        Priorisez les risques critiques.
                    </twig:Card:Content>
                </twig:Card>
            </li>
            <li class="workflow-step-5 js-workflow-step sm:col-span-2 lg:col-span-1" data-aos="fade-up" data-aos-delay="160">
                <twig:Card class="h-full border-primary/25 bg-card shadow-sm ring-1 ring-primary/10">
                    <twig:Card:Header class="pb-2">
                        <twig:Badge class="mb-2 w-8 h-8 rounded-full p-0 flex items-center justify-center shrink-0">5</twig:Badge>
                        <twig:Card:Title class="text-base">Pilotez</twig:Card:Title>
                    </twig:Card:Header>
                    <twig:Card:Content class="text-sm text-muted-foreground pt-0">
                        Suivez tout depuis votre dashboard.
                    </twig:Card:Content>
                </twig:Card>
            </li>
        </ol>
    </div>
</section>
