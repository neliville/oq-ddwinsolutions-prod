<section class="faq-section home-section-premium home-section-premium--faq" id="faq">
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "Les outils sont-ils vraiment gratuits ?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Oui. Les six outils (Ishikawa, 5 Pourquoi, QQOQCCP, AMDEC, 8D et Pareto) sont gratuits. Vous pouvez démarrer sans inscription ; un compte gratuit permet de sauvegarder en ligne et d'accéder au cockpit QHSE. Aucune carte bancaire n'est requise pour commencer."
                }
            },
            {
                "@type": "Question",
                "name": "Mes données sont-elles sécurisées et exportables ?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Vos analyses sont stockées sur des serveurs sécurisés en France. Vous pouvez exporter vos diagrammes au format PDF, JPEG ou JSON à tout moment pour vos audits ou vos archives."
                }
            },
            {
                "@type": "Question",
                "name": "Puis-je utiliser les outils sans créer de compte ?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Oui. Vous pouvez essayer les outils immédiatement sans inscription. La création d'un compte gratuit permet de sauvegarder vos travaux dans le cloud et de les retrouver sur tous vos appareils."
                }
            },
            {
                "@type": "Question",
                "name": "Proposez-vous un accompagnement ou une formation ?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Notre équipe QSE répond à vos questions par email. DDWin Solutions propose également des ateliers de prise en main et des formations personnalisées sur demande."
                }
            }
        ]
    }
    </script>
    <div class="home-section-bridge" data-home-section-bridge aria-hidden="true"></div>
    <div class="home-section-premium__glow home-section-premium__glow--faq" aria-hidden="true"></div>
    <div class="container">
        <header class="section-header" data-home-section-intro>
            <span class="section-badge">FAQ</span>
            <h2>{{ homepage_slots['faq_section_title']|default('Questions fréquentes') }}</h2>
            <p>{{ homepage_slots['faq_section_subtitle']|default("Tout ce qu'il faut savoir pour bien démarrer avec OUTILS-QUALITÉ.") }}</p>
        </header>

        {% set faq_items = [
            {
                value: 'gratuit',
                title: 'Les outils sont-ils vraiment gratuits ?',
                body: "Oui. Les six outils (Ishikawa, 5 Pourquoi, QQOQCCP, AMDEC, 8D et Pareto) sont gratuits. Vous pouvez démarrer sans inscription ; un compte gratuit permet de sauvegarder en ligne et d'accéder au cockpit QHSE. Aucune carte bancaire n'est requise pour commencer."
            },
            {
                value: 'donnees',
                title: 'Mes données sont-elles sécurisées et exportables ?',
                body: "Vos analyses sont stockées sur des serveurs sécurisés en France. Vous pouvez exporter vos diagrammes au format PDF, JPEG ou JSON à tout moment pour vos audits ou vos archives."
            },
            {
                value: 'sans-compte',
                title: 'Puis-je utiliser les outils sans créer de compte ?',
                body: "Oui. Vous pouvez essayer les outils immédiatement sans inscription. La création d'un compte gratuit permet de sauvegarder vos travaux dans le cloud et de les retrouver sur tous vos appareils."
            },
            {
                value: 'formation',
                title: 'Proposez-vous un accompagnement ou une formation ?',
                body: "Notre équipe QSE répond à vos questions par email. DDWin Solutions propose également des ateliers de prise en main et des formations personnalisées sur demande."
            },
        ] %}

        <div class="home-faq-accordion-wrap" data-home-reveal>
        <twig:Accordion id="home-faq" class="home-faq-accordion">
            {% for item in faq_items %}
                <twig:Accordion:Item value="{{ item.value }}" class="home-faq-accordion__item border-0">
                    <twig:Accordion:Trigger class="home-faq-accordion__trigger !rounded-none">{{ item.title }}</twig:Accordion:Trigger>
                    <twig:Accordion:Content class="home-faq-accordion__content !pt-0">
                        <p class="m-0">{{ item.body }}</p>
                    </twig:Accordion:Content>
                </twig:Accordion:Item>
            {% endfor %}
        </twig:Accordion>
        </div>
    </div>
</section>
