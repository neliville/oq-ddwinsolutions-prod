<section id="fonctionnalites" class="home-landing-section py-16 sm:py-20 bg-muted/30" aria-labelledby="home-value-heading">
    <div class="container max-w-6xl mx-auto px-4">
        <header class="text-center max-w-3xl mx-auto mb-12 sm:mb-14" data-aos="fade-up">
            <twig:Badge variant="outline" class="mb-3">Plateforme</twig:Badge>
            <h2 id="home-value-heading" class="text-2xl sm:text-3xl font-bold tracking-tight text-foreground m-0">
                Ce que centralise le cockpit pour piloter votre QHSE
            </h2>
            <p class="text-muted-foreground mt-3 text-base sm:text-lg m-0">
                Analyses, audits ISO, CAPA et risques restent reliés dans un même cockpit pour arbitrer les priorités sans recréer quatre parcours séparés.
            </p>
        </header>

        <div class="grid gap-4 sm:gap-5 sm:grid-cols-2 xl:grid-cols-4 js-kpi-card">
            <twig:Card class="border-border/80 shadow-sm js-kpi-card" data-aos="fade-up" data-aos-delay="0">
                <twig:Card:Header class="space-y-1 pb-3">
                    <twig:Card:Title class="text-lg">Analyses</twig:Card:Title>
                    <twig:Card:Description>Reliez les causes, les écarts et les signaux faibles pour comprendre ce qui doit être traité en premier.</twig:Card:Description>
                </twig:Card:Header>
            </twig:Card>

            <twig:Card class="border-border/80 shadow-sm js-kpi-card" data-aos="fade-up" data-aos-delay="50">
                <twig:Card:Header class="space-y-1 pb-3">
                    <twig:Card:Title class="text-lg">Audits ISO</twig:Card:Title>
                    <twig:Card:Description>Gardez les référentiels, constats et échéances visibles dans le même cockpit pour préparer et suivre la conformité.</twig:Card:Description>
                </twig:Card:Header>
            </twig:Card>

            <twig:Card class="border-border/80 shadow-sm js-kpi-card" data-aos="fade-up" data-aos-delay="100">
                <twig:Card:Header class="space-y-1 pb-3">
                    <twig:Card:Title class="text-lg">CAPA</twig:Card:Title>
                    <twig:Card:Description>Transformez chaque constat en actions suivies, responsables clairs et boucles de progression continues.</twig:Card:Description>
                </twig:Card:Header>
            </twig:Card>

            <twig:Card class="border-border/80 shadow-sm js-kpi-card" data-aos="fade-up" data-aos-delay="0">
                <twig:Card:Header class="space-y-1 pb-3">
                    <twig:Card:Title class="text-lg">Risques</twig:Card:Title>
                    <twig:Card:Description>Priorisez les expositions critiques et reliez prévention, surveillance et décisions au pilotage global.</twig:Card:Description>
                </twig:Card:Header>
            </twig:Card>
        </div>
    </div>
</section>
