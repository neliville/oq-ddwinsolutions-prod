<section class="hero-section relative overflow-hidden" id="hero">
    <div class="hero-gradient"></div>
    <div class="max-w-7xl mx-auto px-4 relative">
        <div class="reassurance-bar">
            <span>🔒 Conforme RGPD</span>
            <span>💾 Aucune installation</span>
            <span>📱 Compatible mobile</span>
        </div>
        <div class="grid grid-cols-12 items-center hero-row">
            <div class="lg:col-span-6 xl:col-span-5">
                <span class="hero-badge">Suite QSE complète</span>
                <h1 class="hero-title">Vos outils qualité professionnels, <span>100% gratuits</span></h1>
                <p class="hero-text">
                    Préparez vos revues de processus, identifiez vos causes racines et exportez des rapports prêts
                    pour vos audits ISO 9001 en quelques clics.
                </p>
                <div class="hero-actions">
                    <a class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-5 py-3 rounded-lg font-medium hover:opacity-90 transition-opacity hero-btn shadow-lg" href="#outils">
                        <i data-lucide="rocket" class="mr-2" aria-hidden="true"></i>
                        Commencer maintenant
                    </a>
                    <a class="inline-flex items-center gap-2 border border-white/80 text-white px-5 py-3 rounded-lg font-medium hover:bg-white/10 transition-colors hero-btn hero-btn--ghost" href="#avantages">
                        <i data-lucide="sparkles" class="mr-2" aria-hidden="true"></i>
                        Découvrir les avantages
                    </a>
                </div>
                <ul class="hero-stats">
                    <li>
                        <strong>6 500+</strong>
                        <span>diagrammes générés</span>
                    </li>
                    <li>
                        <strong>2 800+</strong>
                        <span>professionnels QSE inscrits</span>
                    </li>
                    <li>
                        <strong>ISO 9001</strong>
                        <span>exports prêts à l'audit</span>
                    </li>
                </ul>
            </div>
            <div class="lg:col-span-6 xl:col-start-2">
                <div class="hero-visual shadow-xl">
                    {% include 'components/media/responsive_picture.html.twig' with {
                        path: 'img/hero.webp',
                        alt: 'Mockup tableau de bord OUTILS-QUALITÉ',
                        class: 'w-full h-auto rounded-2xl',
                        width: 1280,
                        height: 800,
                        webp_filter: 'hero_webp',
                        fallback_filter: 'hero_jpeg'
                    } %}
                    <div class="hero-chip hero-chip--trust shadow hero-chip--floating">
                        <i data-lucide="shield-check" class="text-success" aria-hidden="true"></i>
                        <div>
                            <p class="title">Sécurité RGPD</p>
                            <p class="subtitle">Données hébergées en France</p>
                        </div>
                    </div>
                    <div class="hero-chip hero-chip--assistant shadow hero-chip--floating delay-2000">
                        <i data-lucide="star" class="text-primary" aria-hidden="true"></i>
                        <div>
                            <p class="title">Professionnel</p>
                            <p class="subtitle">Exports prêts pour vos audits</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

