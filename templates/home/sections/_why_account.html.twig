<section id="pourquoi-compte" class="home-landing-section bg-background" aria-labelledby="home-why-account-heading">
    <div class="container max-w-6xl mx-auto">
        <header class="text-center max-w-3xl mx-auto mb-10 sm:mb-12" data-aos="fade-up">
            <twig:Badge variant="outline" class="mb-3">Compte gratuit</twig:Badge>
            <h2 id="home-why-account-heading" class="text-2xl sm:text-3xl font-bold tracking-tight m-0">
                Pourquoi créer un compte gratuit ?
            </h2>
            <p class="text-muted-foreground mt-3 text-base m-0">
                Vous pouvez démarrer sans inscription. Le compte débloque la sauvegarde cloud et le passage au cockpit QHSE quand vous en avez besoin.
            </p>
        </header>

        <div class="grid gap-5 sm:grid-cols-3 max-w-5xl mx-auto">
            <twig:Card class="border-border/80 shadow-sm h-full" data-aos="fade-up" data-aos-delay="0">
                <twig:Card:Header class="space-y-2 pb-2">
                    <twig:Card:Title class="text-lg">Sauvegarde cloud sécurisée</twig:Card:Title>
                    <twig:Card:Description>Vos analyses sont hébergées en France et retrouvables sur tous vos appareils.</twig:Card:Description>
                </twig:Card:Header>
            </twig:Card>
            <twig:Card class="border-border/80 shadow-sm h-full" data-aos="fade-up" data-aos-delay="50">
                <twig:Card:Header class="space-y-2 pb-2">
                    <twig:Card:Title class="text-lg">Historique et exports</twig:Card:Title>
                    <twig:Card:Description>Reprenez vos travaux, exportez en PDF pour vos dossiers et audits ISO.</twig:Card:Description>
                </twig:Card:Header>
            </twig:Card>
            <twig:Card class="border-border/80 shadow-sm h-full" data-aos="fade-up" data-aos-delay="100">
                <twig:Card:Header class="space-y-2 pb-2">
                    <twig:Card:Title class="text-lg">Cockpit QHSE optionnel</twig:Card:Title>
                    <twig:Card:Description>Audits ISO, CAPA et risques dans une même vue de priorités quand vous structurez votre pilotage.</twig:Card:Description>
                </twig:Card:Header>
            </twig:Card>
        </div>

        <div class="mt-10 text-center" data-aos="fade-up">
            {% if is_granted('ROLE_USER') %}
                <twig:Button as="a" href="{{ path('app_dashboard_index') }}" size="lg" class="no-underline">
                    Ouvrir mon cockpit QHSE
                </twig:Button>
            {% else %}
                <twig:Button as="a" href="{{ path('app_register') }}" size="lg" class="no-underline">
                    Créer mon compte gratuit
                </twig:Button>
                <p class="m-0 mt-3 text-sm text-muted-foreground">2 minutes · Toujours gratuit pour démarrer · Pas de carte bancaire</p>
            {% endif %}
        </div>
    </div>
</section>
