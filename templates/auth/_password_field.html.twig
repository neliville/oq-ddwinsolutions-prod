{# Wrapper mot de passe : toggle + force optionnelle. Variables : field (FormView), strength (bool), show_compromised (bool) #}
{% set has_errors = field.vars.errors|length > 0 %}
{% set input_class = 'flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 pr-10' ~ (has_errors ? ' border-destructive' : '') %}
{% set widget_attr = {
    class: input_class,
    'data-password-toggle-target': 'input',
} %}
{% if strength|default(false) %}
    {% set widget_attr = widget_attr|merge({ 'data-password-strength-target': 'input' }) %}
{% endif %}

<div
    class="auth-password-field"
    {% if strength|default(false) %}data-controller="password-toggle password-strength"{% else %}data-controller="password-toggle"{% endif %}
>
    <div class="auth-password-field__inner">
        {{ form_widget(field, { attr: widget_attr }) }}
        <button
            type="button"
            class="auth-password-field__toggle"
            data-action="password-toggle#toggle"
            data-password-toggle-target="toggle"
            aria-pressed="false"
            aria-label="Afficher le mot de passe"
        >
            <i data-lucide="eye" width="18" height="18" data-password-toggle-target="iconShow" aria-hidden="true"></i>
            <i data-lucide="eye-off" width="18" height="18" class="hidden" data-password-toggle-target="iconHide" aria-hidden="true"></i>
        </button>
    </div>

    {% if strength|default(false) %}
        <twig:AuthPasswordHelper :showCompromised="show_compromised|default(false)" />
    {% endif %}
</div>
