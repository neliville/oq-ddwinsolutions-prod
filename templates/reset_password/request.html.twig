{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - OUTILS-QUALITÉ{% endblock %}
{% block meta_description %}Réinitialisez votre mot de passe OUTILS-QUALITÉ en recevant un lien sécurisé par email.{% endblock %}
{% block seo_robots %}noindex, follow{% endblock %}

{% block body %}
{% embed 'reset_password/_shell.html.twig' with { brand_icon: 'key-round', requestForm: requestForm } only %}
    {% block brand_baseline %}
        Un lien sécurisé vous permet de définir un nouveau mot de passe et de retrouver l’accès à votre cockpit QSE.
    {% endblock %}

    {% block form_panel %}
        <header>
            <h1 class="auth-card__title">Réinitialiser votre mot de passe</h1>
            <p class="auth-card__subtitle">
                Saisissez l’adresse email associée à votre compte. Nous vous enverrons un lien de réinitialisation valable 1 heure.
            </p>
        </header>

        {% for message in app.flashes('reset_password_error') %}
            <twig:Alert variant="destructive" class="mb-3 px-4 py-3 shadow-sm" role="alert">
                <twig:Alert:Description class="!text-current text-sm self-center grow">
                    {{ message }}
                </twig:Alert:Description>
                <twig:Alert:Action>
                    <twig:Button variant="ghost" size="icon" type="button" class="text-current opacity-70 hover:opacity-100" onclick="this.closest('[data-slot=alert]').remove()" aria-label="Fermer le message">
                        <i data-lucide="x" width="16" height="16" aria-hidden="true"></i>
                    </twig:Button>
                </twig:Alert:Action>
            </twig:Alert>
        {% endfor %}

        {{ form_start(requestForm, { attr: { class: 'auth-form space-y-4' } }) }}
            <div class="space-y-2">
                {{ form_label(requestForm.email, 'Adresse email', {'label_attr': {'class': 'text-sm font-medium leading-none text-foreground'}}) }}
                {{ form_widget(requestForm.email, { attr: { class: 'flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm', placeholder: 'votre.email@exemple.com', autocomplete: 'email' } }) }}
                {{ form_errors(requestForm.email) }}
            </div>

            <p class="auth-form__hint">
                Vous recevrez immédiatement un email contenant un lien sécurisé. Pensez à vérifier votre dossier indésirables.
            </p>

            <twig:Button type="submit" name="reset_password_request_submit" value="1" class="w-full min-h-[44px] gap-2">
                <i data-lucide="send" width="18" height="18" aria-hidden="true"></i>
                Envoyer le lien sécurisé
            </twig:Button>
        {{ form_end(requestForm) }}

        <div class="auth-card__footer">
            Vous vous souvenez de votre mot de passe ?
            <a href="{{ path('app_login') }}">Retour à la connexion</a>
        </div>
    {% endblock %}

    {% block info_panel %}
        <twig:AuthFeaturePanel variant="reset" />
    {% endblock %}
{% endembed %}
{% endblock %}
