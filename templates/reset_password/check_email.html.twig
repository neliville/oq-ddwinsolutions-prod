{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/bundles/auth.css') }}">
{% endblock %}

{% block title %}Email de réinitialisation envoyé - OUTILS-QUALITÉ{% endblock %}
{% block meta_description %}Consultez votre messagerie pour finaliser la réinitialisation de votre mot de passe OUTILS-QUALITÉ.{% endblock %}
{% block seo_robots %}noindex, follow{% endblock %}

{% block body %}
{% embed 'reset_password/_shell.html.twig' with { brand_icon: 'mail-check', resetToken: resetToken } only %}
    {% block brand_baseline %}
        Si votre adresse est enregistrée, un email vient de partir. Suivez les étapes ci-dessous pour retrouver l’accès à votre cockpit QSE.
    {% endblock %}

    {% block auth_card_modifier %} auth-card--status{% endblock %}
    {% block form_panel_modifier %} reset-password-status-panel{% endblock %}

    {% block form_panel %}
        {% set expiry_message = 'Ce lien expire dans ' ~ (resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle')) %}
        <twig:AuthSuccessState
            icon="mail-open"
            title="Vérifiez votre messagerie"
            lead="Si une adresse correspond dans notre base, un email contenant un lien sécurisé vient d’être envoyé. Ouvrez-le et cliquez sur le bouton de réinitialisation pour continuer."
            expiry="{{ expiry_message }}"
            :steps="[
                'Ouvrez l’email OUTILS-QUALITÉ (vérifiez indésirables et Promotions).',
                'Cliquez sur le lien sécurisé pour accéder au formulaire de nouveau mot de passe.',
                'Choisissez un mot de passe robuste, puis connectez-vous à votre cockpit QSE.',
            ]"
            tip="Pas reçu l’email ? Attendez quelques minutes, vérifiez les filtres anti-spam ou demandez un nouvel envoi. Besoin d’aide : support@outils-qualite.com."
            primaryHref="{{ path('app_login') }}"
            primaryLabel="Retour à la connexion"
            secondaryHref="{{ path('app_forgot_password_request') }}"
            secondaryLabel="Renvoyer l’email"
        />
    {% endblock %}

    {% block info_panel %}
        <twig:AuthFeaturePanel variant="status" />
    {% endblock %}
{% endembed %}
{% endblock %}
