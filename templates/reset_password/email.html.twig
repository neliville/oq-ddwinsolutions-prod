{% extends 'emails/base_transactional.html.twig' %}

{% block email_html_title %}Réinitialisation du mot de passe{% endblock %}

{% block email_body %}
<p style="margin:0 0 20px 0;font-size:18px;font-weight:bold;color:#1a3a5c;">Bonjour,</p>
<p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;color:#374151;">Nous avons reçu une demande de réinitialisation de mot de passe pour votre compte <strong>{{ app_name|default('OUTILS-QUALITÉ') }}</strong>. Utilisez le bouton ci-dessous pour en définir un nouveau.</p>
{% set _reset = url('app_reset_password', { token: resetToken.token }) %}
{% include 'emails/_email_cta.html.twig' with { cta_href: _reset, cta_label: 'Réinitialiser mon mot de passe' } %}
<p style="margin:16px 0 0 0;font-size:14px;line-height:1.65;color:#64748b;">Ce lien est valable {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}. Si vous n’êtes pas à l’origine de cette demande, ignorez cet email : votre mot de passe actuel reste inchangé.</p>
{% endblock %}

{% block email_signature %}
<p style="margin:0 0 8px 0;font-size:14px;color:#374151;">À très vite,</p>
<p style="margin:0 0 4px 0;font-size:15px;font-weight:bold;color:#1a3a5c;">L’équipe {{ app_name|default('OUTILS-QUALITÉ') }}</p>
<p style="margin:0;font-size:13px;color:#64748b;"><a href="mailto:{{ app_email }}" style="color:#2563eb;text-decoration:underline;">{{ app_email }}</a></p>
{% endblock %}
