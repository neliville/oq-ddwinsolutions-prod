{% extends (app.user ? 'base_with_sidebar.html.twig' : 'base.html.twig') %}

{% block head %}
    {{ parent() }}
    {% include 'components/turbo_newsletter_no_cache_meta.html.twig' %}
{% endblock %}

{% block title %}Analyse QQOQCCP en Ligne Gratuite — Outil 5W2H Complet | Outils-Qualité{% endblock %}

{% block meta_description %}Structurez votre diagnostic avec l'analyse QQOQCCP (5W2H) en ligne. 7 questions fondamentales, rapport PDF généré automatiquement. Gratuit.{% endblock %}

{% block meta_keywords %}qqoqccp, 5w2h, outil qualité, méthode qqoqccp, analyse complète, résolution de problème{% endblock %}

{% block og_title %}Méthode QQOQCCP - Outil Gratuit | OUTILS-QUALITÉ{% endblock %}

{% block og_description %}Utilisez la méthode QQOQCCP (5W2H) pour réaliser un questionnement complet de vos projets et problèmes.{% endblock %}

{% block schema_type %}{{ parent() }},SoftwareApplication{% endblock %}

{% block schema_data %}
{
    "name": "Outil QQOQCCP",
    "description": "Questionnement 5W2H interactif pour analyser vos projets et vos problèmes.",
    "url": "{{ absolute_url(path('app_qqoqccp_index')) }}",
    "screenshot": "{{ app.request.schemeAndHttpHost ~ asset('img/og-default.jpg') }}"
}
{% endblock %}

{% block schema_webapp_json %}
{"@context":"https://schema.org","@type":"WebApplication","name":"Analyse QQOQCCP en ligne","url":{{ absolute_url(path('app_qqoqccp_index'))|json_encode|raw }},"applicationCategory":"BusinessApplication","operatingSystem":"Web","offers":{"@type":"Offer","price":"0","priceCurrency":"EUR"},"description":"Structurez votre diagnostic avec l'analyse QQOQCCP (5W2H) en ligne. 7 questions fondamentales, rapport PDF généré automatiquement. Gratuit.","featureList":["7 questions QQOQCCP","Rapport PDF automatique","Gratuit","Conforme ISO 9001"]}
{% endblock %}

{% block schema_breadcrumb_json %}
{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Accueil","item":{{ absolute_url(path('app_home_index'))|json_encode|raw }}},{"@type":"ListItem","position":2,"name":"Outils","item":{{ absolute_url(path('app_outils_index'))|json_encode|raw }}},{"@type":"ListItem","position":3,"name":"Analyse QQOQCCP","item":{{ absolute_url(path('app_qqoqccp_index'))|json_encode|raw }}}]}
{% endblock %}

{% block content %}
<main class="qqoqccp-page{% if not app.user %} qqoqccp-page--guest{% endif %}">
    <div class="container">
        {% include 'components/tool_breadcrumb.html.twig' with { tool_name: "Analyse QQOQCCP (5W2H)" } %}
        {% include 'components/tool_page_header.html.twig' with {
            tool_icon: 'list-checks',
            tool_name: 'Analyse QQOQCCP (5W2H)',
            tool_tagline: 'Cadrez tout projet ou problème avec les 7 questions fondamentales',
            tool_color: 'secondary',
            tool_seo_route: 'app_tool_seo_qqoqccp'
        } %}
        <input type="hidden" id="qqoqccpAnalysisId" value="{{ analysisId ?? '' }}">

        <div class="page-header tool-page-header--compact" data-aos="fade-up">
            <h1 class="page-title">Analyse QQOQCCP (5W2H)</h1>
            <p class="lead">Checklist complète pour cadrer tout projet ou problème : Qui, Quoi, Où, Quand, Comment, Combien, Pourquoi — avec suggestions selon votre contexte.</p>
            {% include 'components/tool_meta_hints.html.twig' with {
                tool_slug: 'qqoqccp',
                hint_id_prefix: 'qqoqccp',
                meta_intro: 'Survolez ou mettez le focus sur une pastille pour un court descriptif. L’aide détaillée est dans l’encadré juste en dessous ; le questionnaire suit.',
                tag_hints: {
                    'Reporting': 'Structurer les faits avant synthèse ou restitution hiérarchique.',
                    'Audit': 'Préparer constats, questions et preuves attendues.',
                    'Questionnement 5W2H': 'Couverture systématique des dimensions du sujet.',
                    'ISO 9001': 'Appui pour maîtrise documentaire, revues et traitement des écarts.',
                },
            } %}
        </div>

        {% if not app.user %}
        <div class="flex items-center justify-center gap-2 rounded-lg bg-yellow-50 border border-yellow-200 text-yellow-800 px-4 py-3 mb-4 text-center" role="alert" aria-live="polite" data-aos="fade-up" data-aos-delay="50">
            <i data-lucide="info" width="18" height="18" class="mr-2 shrink-0" aria-hidden="true"></i>
            <span><strong>Vous n'êtes pas connecté.</strong>
            <a href="{{ path('app_login') }}" class="font-medium underline hover:no-underline text-yellow-900">Connectez-vous</a> pour sauvegarder vos analyses et les retrouver facilement.</span>
        </div>
        {% endif %}

        {% include 'components/tool_help/qqoqccp_accordion.html.twig' %}

        <section class="qqoqccp-controls tool-actions-bar flex flex-wrap items-center gap-2 mb-4" data-aos="fade-up" data-aos-delay="120" role="toolbar" aria-label="Actions disponibles">
            <button class="inline-flex items-center justify-center gap-1.5 bg-primary text-primary-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="newQqoqccpAnalysis()" aria-label="Réinitialiser l'analyse QQOQCCP">
                <i class="fas fa-sync-alt mr-2"></i>Nouvelle analyse
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 bg-sky-500 text-white px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="generateQqoqccpReport()" aria-label="Générer le rapport QQOQCCP">
                <i class="fas fa-file-alt mr-2"></i>Générer le rapport
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 bg-destructive text-destructive-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="resetQqoqccpForm()" aria-label="Effacer le formulaire QQOQCCP">
                <i class="fas fa-eraser mr-2"></i>Réinitialiser
            </button>
            {% if app.user %}
            <button class="inline-flex items-center justify-center gap-1.5 bg-green-600 text-white px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="saveQqoqccp()" aria-label="Sauvegarder l'analyse QQOQCCP">
                <i class="fas fa-save mr-2"></i>Sauvegarder
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors" type="button" onclick="openQqoqccpSaved()" aria-label="Voir mes analyses QQOQCCP">
                <i class="fas fa-folder-open mr-2"></i>Mes analyses
            </button>
            {% include 'components/tool_export_dropdown.html.twig' with {
                button_id: 'qqoqccpExportDropdown',
                items: [
                    { icon: 'fas fa-image', label: 'Exporter en PNG', onclick: 'exportQqoqccp("png")' },
                    { icon: 'fas fa-file-pdf', label: 'Exporter en PDF', onclick: 'exportQqoqccp("pdf")' },
                    { icon: 'fas fa-file-code', label: 'Exporter en JSON', onclick: 'exportQqoqccp("json")' },
                ],
            } %}
            {% else %}
            {% include 'components/tool_actions_login.html.twig' %}
            {% endif %}
        </section>

        <div class="mb-3">
            {% include 'components/coming_soon_download.html.twig' %}
        </div>

        <section class="qqoqccp-form" data-aos="fade-up" data-aos-delay="200" id="qqoqccpForm">
            <div class="qqoqccp-question qqoqccp-question--subject">
                <label class="qqoqccp-question__label" for="qqoqccpSubject">Sujet ou titre de l'analyse</label>
                <input type="text" id="qqoqccpSubject" class="form-control" placeholder="Ex : Retards de livraison aux clients" oninput="updateQqoqccpField('subject', this.value)">
            </div>

            <div class="qqoqccp-question">
                <div class="qqoqccp-question__header">
                    <span class="qqoqccp-question__icon">🙋</span>
                    <div>
                        <h3>Qui ?</h3>
                        <p class="qqoqccp-question__helper">Qui est concerné ? Qui agit ? Qui est responsable ?</p>
                    </div>
                </div>
                <textarea id="qqoqccpQui" placeholder="Décrivez les acteurs impliqués..." oninput="updateQqoqccpField('qui', this.value)"></textarea>
            </div>

            <div class="qqoqccp-question">
                <div class="qqoqccp-question__header">
                    <span class="qqoqccp-question__icon">📋</span>
                    <div>
                        <h3>Quoi ?</h3>
                        <p class="qqoqccp-question__helper">De quoi s'agit-il ? Quelle est la nature du problème ou du projet ?</p>
                    </div>
                </div>
                <textarea id="qqoqccpQuoi" placeholder="Décrivez précisément le sujet..." oninput="updateQqoqccpField('quoi', this.value)"></textarea>
            </div>

            <div class="qqoqccp-question">
                <div class="qqoqccp-question__header">
                    <span class="qqoqccp-question__icon">📍</span>
                    <div>
                        <h3>Où ?</h3>
                        <p class="qqoqccp-question__helper">Où cela se passe-t-il ? Dans quel service, zone ou processus ?</p>
                    </div>
                </div>
                <textarea id="qqoqccpOu" placeholder="Précisez les lieux ou services concernés..." oninput="updateQqoqccpField('ou', this.value)"></textarea>
            </div>

            <div class="qqoqccp-question">
                <div class="qqoqccp-question__header">
                    <span class="qqoqccp-question__icon">⏰</span>
                    <div>
                        <h3>Quand ?</h3>
                        <p class="qqoqccp-question__helper">Quand cela se produit-il ? Depuis quand ? À quelle fréquence ?</p>
                    </div>
                </div>
                <textarea id="qqoqccpQuand" placeholder="Indiquez la période ou la fréquence..." oninput="updateQqoqccpField('quand', this.value)"></textarea>
            </div>

            <div class="qqoqccp-question">
                <div class="qqoqccp-question__header">
                    <span class="qqoqccp-question__icon">🔧</span>
                    <div>
                        <h3>Comment ?</h3>
                        <p class="qqoqccp-question__helper">Comment cela se passe-t-il ? Quels sont les processus utilisés ?</p>
                    </div>
                </div>
                <textarea id="qqoqccpComment" placeholder="Expliquez le déroulement ou le processus..." oninput="updateQqoqccpField('comment', this.value)"></textarea>
            </div>

            <div class="qqoqccp-question">
                <div class="qqoqccp-question__header">
                    <span class="qqoqccp-question__icon">💰</span>
                    <div>
                        <h3>Combien ?</h3>
                        <p class="qqoqccp-question__helper">Quels sont les volumes, coûts, quantités ou ressources en jeu ?</p>
                    </div>
                </div>
                <textarea id="qqoqccpCombien" placeholder="Précisez les quantités, coûts ou ressources..." oninput="updateQqoqccpField('combien', this.value)"></textarea>
            </div>

            <div class="qqoqccp-question">
                <div class="qqoqccp-question__header">
                    <span class="qqoqccp-question__icon">🎯</span>
                    <div>
                        <h3>Pourquoi ?</h3>
                        <p class="qqoqccp-question__helper">Quelles sont les causes possibles ou objectifs recherchés ?</p>
                    </div>
                </div>
                <textarea id="qqoqccpPourquoi" placeholder="Listez les causes et finalités..." oninput="updateQqoqccpField('pourquoi', this.value)"></textarea>
            </div>
        </section>

        <section id="qqoqccpResults" class="qqoqccp-results" style="display:none;" data-aos="fade-up" data-aos-delay="240">
            <div id="qqoqccpReportContainer" class="qqoqccp-report">
                <div class="qqoqccp-report__header">
                    <h2 id="qqoqccpReportTitle">Rapport QQOQCCP</h2>
                    <p id="qqoqccpReportDate" class="text-muted-foreground"></p>
                </div>
                <div class="qqoqccp-report__section">
                    <h3>🎯 Sujet analysé</h3>
                    <p id="qqoqccpReportSubject"></p>
                </div>
                <div class="qqoqccp-report__section">
                    <h3>🙋 Qui ?</h3>
                    <p id="qqoqccpReportQui"></p>
                </div>
                <div class="qqoqccp-report__section">
                    <h3>📋 Quoi ?</h3>
                    <p id="qqoqccpReportQuoi"></p>
                </div>
                <div class="qqoqccp-report__section">
                    <h3>📍 Où ?</h3>
                    <p id="qqoqccpReportOu"></p>
                </div>
                <div class="qqoqccp-report__section">
                    <h3>⏰ Quand ?</h3>
                    <p id="qqoqccpReportQuand"></p>
                </div>
                <div class="qqoqccp-report__section">
                    <h3>🔧 Comment ?</h3>
                    <p id="qqoqccpReportComment"></p>
                </div>
                <div class="qqoqccp-report__section">
                    <h3>💰 Combien ?</h3>
                    <p id="qqoqccpReportCombien"></p>
                </div>
                <div class="qqoqccp-report__section">
                    <h3>🎯 Pourquoi ?</h3>
                    <p id="qqoqccpReportPourquoi"></p>
                </div>
                <div class="qqoqccp-report__summary">
                    <h3>💡 Synthèse</h3>
                    <div id="qqoqccpReportSummary"></div>
                </div>
                <div id="qqoqccpSuggestions" class="qqoqccp-report__section mt-4 p-4 bg-muted rounded-lg" style="display:none;">
                    <h3>📌 Actions recommandées / Modèles utiles</h3>
                    <ul id="qqoqccpSuggestionsList" class="mb-0"></ul>
                </div>
            </div>
        </section>

        {% include 'components/qse/capa_soft_cta.html.twig' with { tool: 'qqoqccp' } %}

        {% include 'components/tool_lead_cta.html.twig' %}
        {% include 'components/cta_ddwin.html.twig' %}

        <section class="seo-content">
            <h2>Qu'est-ce que l'analyse QQOQCCP ?</h2>
            <p>Méthode de questionnement systématique (Qui, Quoi, Où, Quand, Comment, Combien, Pourquoi), aussi connue sous le nom 5W2H. Permet de caractériser complètement une situation ou un problème avant de passer à l'analyse des causes.</p>

            <h2>Comment utiliser l'analyse QQOQCCP ?</h2>
            <p>Répondre méthodiquement à chacune des 7 questions pour cadrer le problème de manière exhaustive.</p>

            <h2>Quand utiliser l'analyse QQOQCCP ?</h2>
            <p>Cadrage initial d'une non-conformité, rédaction d'une fiche d'action, briefing d'équipe projet, préparation d'une analyse de risques.</p>

            <h2>Pourquoi utiliser notre outil en ligne ?</h2>
            <p>Gratuit, sans installation, export PDF, conforme ISO, RGPD, sauvegarde.</p>
        </section>
    </div>

    {# Modal pour afficher les analyses QQOQCCP sauvegardées #}
    {% if app.user %}
    {% component QqoqccpAnalysesModal with {
        id: 'qqoqccpLoadModal'
    } %}
    {% endcomponent %}
    {% endif %}
</main>
{% endblock %}

{% block stylesheets %}
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link rel="stylesheet" href="{{ asset('styles/tools/qqoqccp.css') }}" data-turbo-track="reload">
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="{{ asset('js/main.js') }}"></script>
<script src="{{ asset('js/qqoqccp.js') }}"></script>

<script>
    window.qqoqccpAppConfig = {
        isAuthenticated: {{ app.user ? 'true' : 'false' }},
        analysisId: {{ analysisId is defined and analysisId ? analysisId : 'null' }},
        currentAnalysisId: null,
    };

    window.qqoqccpRoutes = {
        save: '{{ path('app_api_qqoqccp_save') }}',
        list: '{{ path('app_api_qqoqccp_list') }}',
        get: '{{ path('app_api_qqoqccp_get', {id: 0}) }}',
        delete: '{{ path('app_api_qqoqccp_delete', {id: 0}) }}',
        login: '{{ path('app_login') }}'
    };
</script>
{% endblock %}


