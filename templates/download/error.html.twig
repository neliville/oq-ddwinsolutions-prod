{% extends 'base.html.twig' %}

{% block title %}Lien de téléchargement invalide — {{ app_name|default('Outils-Qualité') }}{% endblock %}

{% block meta_description %}Ce lien de téléchargement a expiré ou est invalide.{% endblock %}

{% block body %}
<section class="py-12 bg-muted" style="margin-top: 76px;">
    <div class="max-w-7xl mx-auto px-4 py-12">
        <div class="flex justify-center">
            <div class="w-full max-w-lg">
                <div class="rounded-lg bg-card shadow-sm">
                    <div class="p-10 text-center">
                        <div class="mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-yellow-500 mx-auto" viewBox="0 0 16 16" aria-hidden="true">
                                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                            </svg>
                        </div>
                        <h1 class="text-xl font-bold mb-3">Lien de téléchargement invalide</h1>
                        <p class="text-muted-foreground mb-4">{{ message }}</p>
                        <a href="{{ path('app_home_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">Retour à l'accueil</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
