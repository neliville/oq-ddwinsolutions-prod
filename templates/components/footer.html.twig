            </div>
        </div>

        <div class="border-t border-slate-700 text-center py-3 mt-8 text-sm">
            © {{ 'now'|date('Y') }} <a href="https://ddwinsolutions.fr" target="_blank" rel="noopener noreferrer" class="text-slate-300 hover:text-white transition-colors no-underline">DDWin Solutions</a>. Tous droits réservés.
            <span class="block md:inline">| Outils d'analyse gratuits et conseils informatiques</span> |
            <a href="{{ path('app_legal_politique_confidentialite') }}" class="text-slate-300 hover:text-white transition-colors no-underline">Politique de confidentialité</a> |
            <a href="{{ path('app_legal_conditions_utilisation') }}" class="text-slate-300 hover:text-white transition-colors no-underline">Conditions d'utilisation</a> |
            <a href="{{ path('app_legal_mentions_legales') }}" class="text-slate-300 hover:text-white transition-colors no-underline">Mentions légales</a>
        </div>
    </footer>
