{# footer_full_marketing (passé depuis base) : accueil = pied complet même si connecté. #}
{% if app.user and not (footer_full_marketing ?? false) %}
    {# Footer minimal pour utilisateurs connectés (hors accueil marketing). #}
    {# Classe site-footer--minimal-app : exclut ce pied des styles globaux footer { background dark } (_footer.css, _custom.css). #}
    <footer class="site-footer--minimal-app border-t border-slate-200/80 bg-slate-50 text-slate-600">
        <div class="max-w-screen-lg mx-auto px-4 py-2.5">
            <p class="text-center text-xs sm:text-sm leading-relaxed m-0">
                <span class="font-semibold text-slate-800">{{ app_name }}</span>
                <span class="mx-1.5 text-slate-300 hidden sm:inline" aria-hidden="true">·</span>
                <span class="block sm:inline">© {{ 'now'|date('Y') }} — Tous droits réservés.</span>
                <span class="mx-1.5 text-slate-300 hidden sm:inline" aria-hidden="true">·</span>
                <span class="text-slate-500 tabular-nums">v{{ app_version }}</span>
            </p>
        </div>
    </footer>
{% else %}
    {# Footer marketing complet : invités, ou page d’accueil pour utilisateurs connectés. #}
    <footer class="bg-slate-900 text-slate-400 pt-10 border-t border-slate-700">
        <div class="max-w-screen-lg mx-auto px-4">
            <div class="grid grid-cols-2 md:grid-cols-12 gap-8">

                <!-- Col 1 : présentation courte -->
                <div class="col-span-2 md:col-span-3">
                    <h6 class="text-white font-semibold mb-3">
                        <a href="https://ddwinsolutions.fr" target="_blank" rel="noopener noreferrer" class="text-white no-underline">DDWin Solutions</a>
                    </h6>
                    <p class="text-sm">
                        <a href="https://ddwinsolutions.fr" target="_blank" rel="noopener noreferrer" class="text-slate-300 hover:text-white transition-colors no-underline">DDWin Solutions</a> c'est l'envie de rendre les outils digitaux plus accessibles aux entreprises qui
                        veulent gagner en efficacité. Conseil, développement, automatisation : on avance à votre rythme,
                        avec des solutions adaptées à votre terrain.
                    </p>

                    <div class="flex gap-2 flex-wrap items-center">
                        <h6 class="text-white w-full mb-2 text-sm font-medium">LinkedIn</h6>
                        <a href="https://www.linkedin.com/company/ddwin-solutions"
                            target="_blank" rel="noopener noreferrer" title="DDWin Solutions sur LinkedIn"
                            class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-slate-600 text-slate-300 hover:text-white hover:border-white transition-colors"
                            aria-label="LinkedIn — DDWin Solutions">
                            <svg viewBox="0 0 24 24" fill="currentColor" class="w-[15px] h-[15px]" aria-hidden="true">
                                <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.26 2.37 4.26 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Col 2 : Outils -->
                <div class="col-span-1 md:col-span-2">
                    <h6 class="text-white font-semibold mb-3">Outils d'Analyse Gratuits</h6>
                    <ul class="list-none p-0 text-sm leading-loose space-y-1">
                        <li><a class="text-slate-400 hover:text-slate-200 transition-colors no-underline" href="{{ path('app_ishikawa_index') }}">Analyse des causes</a></li>
                        <li><a class="text-slate-400 hover:text-slate-200 transition-colors no-underline" href="{{ path('app_fivewhy_index') }}">Méthode des pourquoi</a></li>
                        <li><a class="text-slate-400 hover:text-slate-200 transition-colors no-underline" href="{{ path('app_qqoqccp_index') }}">Analyse QQOQCCP</a></li>
                        <li><a class="text-slate-400 hover:text-slate-200 transition-colors no-underline" href="{{ path('app_amdec_index') }}">Analyse AMDEC</a></li>
                        <li><a class="text-slate-400 hover:text-slate-200 transition-colors no-underline" href="{{ path('app_pareto_index') }}">Diagramme Pareto</a></li>
                        <li><a class="text-slate-400 hover:text-slate-200 transition-colors no-underline" href="{{ path('app_eightd_index') }}">Méthode 8D</a></li>
                        <li><a class="text-slate-400 hover:text-slate-200 transition-colors no-underline" href="{{ path('app_outils_index') }}">Suite d'outils</a></li>
                    </ul>
                </div>

                <div class="col-span-1 md:col-span-2">
                    <h6 class="text-white font-semibold mb-3 text-sm">Nos projets</h6>
                    <ul class="space-y-1 text-sm">
                        <li><a class="text-gray-400 hover:text-white transition-colors"
                               href="https://ddwinsolutions.fr" target="_blank" rel="noopener">DDWin Solutions</a></li>
                        <li><a class="text-gray-400 hover:text-white transition-colors"
                               href="https://duerpilot.fr" target="_blank" rel="noopener">DUERPilot</a></li>
                    </ul>
                </div>

                <!-- Col 3 : Services -->
                <div class="col-span-1 md:col-span-2">
                    <h6 class="text-white font-semibold mb-3">Services Informatiques</h6>
                    <ul class="list-none p-0 text-sm leading-loose space-y-1">
                        <li>Analyse &amp; Conception</li>
                        <li>Développement sur mesure</li>
                        <li>Maintenance et support</li>
                        <li>Formation et accompagnement</li>
                    </ul>
                </div>

                <!-- Col 4 : Contact -->
                <div class="col-span-2 md:col-span-3">
                    <h6 class="text-white font-semibold mb-3">Contact</h6>
                    <ul class="list-none p-0 text-sm leading-loose space-y-2">
                        <li class="flex items-start gap-3"><span class="mt-0.5 text-slate-500 shrink-0" aria-hidden="true"><i data-lucide="mail" width="16" height="16"></i></span><span>contact@outils-qualite.com</span></li>
                        <li class="flex items-start gap-3"><span class="mt-0.5 text-slate-500 shrink-0" aria-hidden="true"><i data-lucide="globe" width="16" height="16"></i></span><a href="https://www.outils-qualite.com" class="text-slate-400 hover:text-slate-200 transition-colors no-underline">www.outils-qualite.com</a></li>
                        <li class="flex items-start gap-3"><span class="mt-0.5 text-slate-500 shrink-0" aria-hidden="true"><i data-lucide="globe" width="16" height="16"></i></span><a href="https://ddwinsolutions.fr" target="_blank" rel="noopener noreferrer" class="text-slate-300 hover:text-white transition-colors no-underline">ddwinsolutions.fr</a></li>
                        <li class="flex items-start gap-3"><span class="mt-0.5 text-slate-500 shrink-0" aria-hidden="true"><i data-lucide="clock" width="16" height="16"></i></span><span>Lun-Ven : 9h00-18h00</span></li>
                        <li class="flex items-start gap-3"><span class="mt-0.5 text-slate-500 shrink-0" aria-hidden="true"><i data-lucide="zap" width="16" height="16"></i></span><span>Réponse sous 24 h</span></li>
                    </ul>
                </div>

            </div>
        </div>

        <div class="border-t border-slate-700 text-center py-3 mt-8 text-sm">
            © {{ 'now'|date('Y') }} <a href="https://ddwinsolutions.fr" target="_blank" rel="noopener noreferrer" class="text-slate-300 hover:text-white transition-colors no-underline">DDWin Solutions</a>. Tous droits réservés.
            <span class="block md:inline">| Outils d'analyse gratuits et conseils informatiques</span> |
            <a href="{{ path('app_legal_politique_confidentialite') }}" class="text-slate-300 hover:text-white transition-colors no-underline">Politique de confidentialité</a> |
            <a href="{{ path('app_legal_conditions_utilisation') }}" class="text-slate-300 hover:text-white transition-colors no-underline">Conditions d'utilisation</a> |
            <a href="{{ path('app_legal_mentions_legales') }}" class="text-slate-300 hover:text-white transition-colors no-underline">Mentions légales</a>
        </div>
    </footer>
{% endif %}
