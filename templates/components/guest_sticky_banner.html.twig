{% if not app.user %}
<div
    data-controller="guest-banner"
    data-guest-banner-delay-value="4000"
    class="guest-sticky-banner"
    role="complementary"
    aria-label="Invitation à créer un compte"
>
    <div class="max-w-screen-xl mx-auto px-4">
        <div class="flex items-center justify-between gap-3 flex-wrap py-2">
            <div class="flex items-center gap-2">
                <i data-lucide="sparkles" width="16" height="16" class="text-primary shrink-0"></i>
                <span class="text-sm font-medium">
                    Sauvegardez vos analyses &amp; exportez en PDF —
                    <a href="{{ path('app_register') }}" class="font-semibold text-primary no-underline">Créer un compte gratuit</a>
                    <span class="text-muted-foreground mx-1">·</span>
                    <a href="{{ path('app_login') }}" class="text-muted-foreground no-underline">Se connecter</a>
                </span>
            </div>
            <button
                type="button"
                class="shrink-0 p-1 rounded opacity-60 hover:opacity-100 transition-opacity"
                style="font-size: 0.65rem;"
                data-action="guest-banner#dismiss"
                aria-label="Fermer cette bannière"
            >
                <i data-lucide="x" width="16" height="16"></i>
            </button>
        </div>
    </div>
</div>
{% endif %}
