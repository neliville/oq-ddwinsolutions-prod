<div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-end max-w-5xl mx-auto w-full">
    <twig:Button as="a" href="{{ cancelUrl }}" variant="outline" class="min-h-11 w-full sm:w-auto order-2 sm:order-1 sm:mr-auto no-underline">
        <twig:ux:icon name="lucide:arrow-left" class="size-4 mr-1.5" aria-hidden="true" />
        Retour
    </twig:Button>
    <button
        type="submit"
        form="{{ formId }}"
        class="min-h-11 min-w-[12rem] w-full sm:w-auto order-1 sm:order-2 inline-flex items-center justify-center gap-1.5 rounded-lg border border-transparent bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-md transition-opacity hover:opacity-95 focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 motion-cta"
    >
        <twig:ux:icon name="lucide:circle-check-big" class="size-4" aria-hidden="true" />
        Créer l'audit
    </button>
</div>
