{# Bouton d’accordéon (sous-menu) avec aide contextuelle. #}
{% set _help_id = help_id|default(null) %}
{% if _help_id %}
{% set _help_entry = help(_help_id) %}
<twig:HoverCard openDelay="160" closeDelay="120" placement="right" :interactive="true" class="block w-full max-w-full">
    <button type="button"
            class="sidebar-item sidebar-collapse-trigger{{ is_active ? ' active' : '' }}"
            data-sidebar-target="{{ target|e('html_attr') }}"
            data-sidebar-item-label="{{ label|e('html_attr') }}"
            aria-expanded="{{ expanded ? 'true' : 'false' }}"
            aria-controls="{{ controls|e('html_attr') }}"
            data-slot="hover-card-trigger"
    >
        <i data-lucide="{{ icon|e('html_attr') }}" width="16" height="16" class="sidebar-item-icon" aria-hidden="true"></i>
        <span class="sidebar-item-label">{{ label }}</span>
        <i data-lucide="chevron-down" width="14" height="14" class="sidebar-chevron" aria-hidden="true"></i>
    </button>
    <twig:HoverCard:Content>
        {% include 'components/ContextualHelp/_panel_sidebar.html.twig' with { entry: _help_entry } only %}
    </twig:HoverCard:Content>
</twig:HoverCard>
{% else %}
<twig:HoverCard openDelay="160" closeDelay="120" placement="right" :interactive="true" class="block w-full max-w-full">
    <button type="button"
            class="sidebar-item sidebar-collapse-trigger{{ is_active ? ' active' : '' }}"
            data-sidebar-target="{{ target|e('html_attr') }}"
            data-sidebar-item-label="{{ label|e('html_attr') }}"
            aria-expanded="{{ expanded ? 'true' : 'false' }}"
            aria-controls="{{ controls|e('html_attr') }}"
            data-slot="hover-card-trigger"
    >
        <i data-lucide="{{ icon|e('html_attr') }}" width="16" height="16" class="sidebar-item-icon" aria-hidden="true"></i>
        <span class="sidebar-item-label">{{ label }}</span>
        <i data-lucide="chevron-down" width="14" height="14" class="sidebar-chevron" aria-hidden="true"></i>
    </button>
    <twig:HoverCard:Content>
        <span class="block font-semibold leading-tight text-zinc-50">{{ hover_title }}</span>
        <p class="mt-1.5 mb-0 text-[11px] leading-snug font-normal text-zinc-300">{{ hover_text }}</p>
    </twig:HoverCard:Content>
</twig:HoverCard>
{% endif %}
