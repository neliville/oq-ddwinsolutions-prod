{#
  Composant header contextuel pour les pages d'outils.
  Paramètres :
    - tool_icon    : string  — nom icône Lucide (ex: "git-branch")
    - tool_name    : string  — nom affiché de l'outil
    - tool_tagline : string  — description courte (1 ligne)
    - tool_color   : string  — couleur (primary, info, danger, warning, secondary)
    - tool_route   : string  — nom de la route Symfony (pour lien actif dans breadcrumb)
#}
{% set _color = tool_color ?? 'primary' %}
{% set iconColorMap = {
    'primary':   'bg-primary/10 text-primary',
    'info':      'bg-sky-100 text-sky-600',
    'danger':    'bg-red-100 text-red-600',
    'warning':   'bg-amber-100 text-amber-600',
    'secondary': 'bg-slate-100 text-slate-600'
} %}
{% set iconColors = iconColorMap[_color] ?? iconColorMap['primary'] %}

<div class="mb-4 px-3 md:px-0">
    <div class="flex items-center justify-between gap-3 flex-wrap">

        {# Identité de l'outil #}
        <div class="flex items-center gap-3">
            <div class="inline-flex items-center justify-center w-[52px] h-[52px] shrink-0 rounded-xl {{ iconColors }}">
                <i data-lucide="{{ tool_icon ?? 'tool' }}" width="26" height="26"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold mb-0 leading-tight">{{ tool_name ?? 'Outil QSE' }}</h1>
                {% if tool_tagline is defined and tool_tagline %}
                <p class="text-sm text-muted-foreground mb-0">{{ tool_tagline }}</p>
                {% endif %}
            </div>
        </div>

        {# CTA contextuel selon l'état de connexion #}
        <div class="flex items-center gap-2 flex-wrap">
            {% if tool_seo_route is defined and tool_seo_route %}
            <a href="{{ path(tool_seo_route) }}" class="hidden md:inline-flex items-center gap-1.5 text-sm border border-border rounded-md px-3 py-1.5 text-muted-foreground hover:bg-accent hover:text-accent-foreground transition-colors no-underline">
                <i data-lucide="book-open" width="14" height="14"></i>
                En savoir plus
            </a>
            {% endif %}
            {% if not app.user %}
            <a href="{{ path('app_register') }}" class="inline-flex items-center gap-1.5 text-sm bg-primary text-primary-foreground px-3 py-1.5 rounded-md hover:opacity-90 transition-opacity no-underline">
                <i data-lucide="save" width="14" height="14"></i>
                Sauvegarder mes analyses
            </a>
            <a href="{{ path('app_login') }}" class="inline-flex items-center gap-1.5 text-sm border border-border rounded-md px-3 py-1.5 text-muted-foreground hover:bg-accent transition-colors no-underline">
                Se connecter
            </a>
            {% else %}
            <a href="{{ path('app_creations_index') }}" class="inline-flex items-center gap-1.5 text-sm border border-primary/30 text-primary rounded-md px-3 py-1.5 hover:bg-primary/5 transition-colors no-underline">
                <i data-lucide="folder-open" width="14" height="14"></i>
                Mes créations
            </a>
            {% endif %}
        </div>

    </div>

    {# Bannière login pour visiteurs — discrète, non intrusive #}
    {% if not app.user %}
    <div class="mt-3 flex items-center gap-2 px-3 py-2 rounded-xl bg-primary/5 border border-primary/10">
        <i data-lucide="info" width="15" height="15" class="text-primary shrink-0"></i>
        <span class="text-sm text-muted-foreground">
            Créez un <a href="{{ path('app_register') }}" class="font-semibold text-primary no-underline">compte gratuit</a>
            pour sauvegarder, recharger et exporter vos analyses.
        </span>
    </div>
    {% endif %}
</div>
