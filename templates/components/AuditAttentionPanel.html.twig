{# @prop items list<AuditBoardAttentionItem> #}
{%- props items = [] -%}
{% if items is not empty %}
<section
    class="audit-attention-panel mb-8 rounded-xl border border-amber-500/30 bg-gradient-to-br from-amber-500/5 via-card to-card p-4 sm:p-5 shadow-sm ring-1 ring-amber-500/20"
    aria-labelledby="audit-attention-heading"
    data-controller="gsap-reveal"
>
    <div class="flex items-start gap-3 mb-4">
        <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-amber-500/15 text-amber-700 dark:text-amber-400" aria-hidden="true">
            <twig:ux:icon name="lucide:triangle-alert" class="size-5" />
        </span>
        <div>
            <h2 id="audit-attention-heading" class="text-base font-semibold text-foreground m-0">Audits à traiter</h2>
            <p class="text-sm text-muted-foreground m-0 mt-1">Priorisez les dossiers en retard, les NC majeures et les CAPA urgentes.</p>
        </div>
    </div>
    <ul class="space-y-2 m-0 p-0 list-none">
        {% for item in items %}
            <li class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between rounded-lg border border-border/70 bg-background/60 px-3 py-2.5">
                <div class="min-w-0">
                    <p class="m-0 text-sm font-medium text-foreground truncate">{{ item.title }}</p>
                    <p class="m-0 text-xs text-muted-foreground mt-0.5">{{ item.description }}</p>
                </div>
                <twig:Button
                    as="a"
                    href="{{ path(item.ctaRoute, item.ctaParams) }}"
                    variant="outline"
                    size="sm"
                    class="no-underline shrink-0 w-full sm:w-auto"
                >
                    {{ item.ctaLabel }}
                </twig:Button>
            </li>
        {% endfor %}
    </ul>
</section>
{% endif %}
