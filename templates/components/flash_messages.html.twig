{# Composant pour afficher les messages flash de manière accessible #}
{# Stratégie feedback : ce composant est la source unique pour les messages Symfony (flash).
   Ne pas dupliquer le même contenu en « toast » client sans retirer le flash ou sans règle métier explicite.
   Une future couche Toast pourra réutiliser les mêmes variants twig:Alert. #}
{# Usage:
    {% include 'components/flash_messages.html.twig' %}

    Ou avec types spécifiques:
    {% include 'components/flash_messages.html.twig' with { types: ['success', 'error'] } %}
#}
{% set flashTypes = types|default([
    'success', 'error', 'warning', 'info', 'danger',
    'contact_success', 'profile_success', 'reset_password_error',
]) %}

{% for label in flashTypes %}
    {% for message in app.flashes(label) %}
        {% if label == 'contact_success' or label == 'profile_success' %}
            {% set variant = 'success' %}
            {% set iconName = 'check-circle' %}
        {% elseif label == 'reset_password_error' %}
            {% set variant = 'destructive' %}
            {% set iconName = 'alert-circle' %}
        {% elseif label == 'error' or label == 'danger' %}
            {% set variant = 'destructive' %}
            {% set iconName = 'alert-circle' %}
        {% elseif label == 'success' %}
            {% set variant = 'success' %}
            {% set iconName = 'check-circle' %}
        {% elseif label == 'warning' %}
            {% set variant = 'warning' %}
            {% set iconName = 'alert-triangle' %}
        {% else %}
            {% set variant = 'info' %}
            {% set iconName = 'info' %}
        {% endif %}

        <twig:Alert variant="{{ variant }}" class="mb-3 px-4 py-3 shadow-sm" aria-live="polite" aria-atomic="true">
            <i data-lucide="{{ iconName }}"
               width="20"
               height="20"
               class="shrink-0 mt-0.5"
               aria-hidden="true"></i>
            <twig:Alert:Description class="!text-current text-sm self-center">
                {{ message }}
            </twig:Alert:Description>
            <twig:Alert:Action>
                <twig:Button variant="ghost" size="icon" type="button" class="text-current opacity-70 hover:opacity-100" onclick="this.closest('[data-slot=alert]').remove()" aria-label="Fermer le message">
                    <i data-lucide="x" width="16" height="16" aria-hidden="true"></i>
                </twig:Button>
            </twig:Alert:Action>
        </twig:Alert>
    {% endfor %}
{% endfor %}
