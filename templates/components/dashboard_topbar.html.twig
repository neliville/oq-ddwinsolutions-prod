{% set show_sidebar_toggle = show_sidebar_toggle is defined ? show_sidebar_toggle : false %}
<header class="dashboard-topbar shadow-sm" aria-label="En-tête de l’espace connecté">
    <div class="w-full px-4 dashboard-topbar__pad">
        <div class="dashboard-topbar__inner flex items-center justify-between">

            {# ── Gauche : menu mobile (≤1200px) + marque — même breakpoint que la sidebar #}
            <div class="dashboard-topbar__left flex items-center gap-2 sm:gap-3 min-w-0">
                {% if show_sidebar_toggle %}
                    <button type="button"
                            id="sidebarToggleMobile"
                            class="dashboard-mobile-menu-btn navbar-icon-btn shrink-0"
                            aria-controls="app-dashboard-sidebar"
                            aria-expanded="false"
                            aria-label="Afficher la navigation">
                        <i data-lucide="menu" width="22" height="22" aria-hidden="true"></i>
                    </button>
                {% endif %}
                <a class="dashboard-topbar__brand flex items-center min-w-0" href="{{ path('app_dashboard_index') }}">
                    <img src="{{ asset('img/logo.webp') }}" alt="" width="36" height="36" class="mr-2 shrink-0" role="presentation">
                    <span class="font-bold truncate">OUTILS-QUALITÉ</span>
                </a>
            </div>

            {# ── Droite : actions compactes style Mautic ─────────────────── #}
            <div class="dashboard-topbar__actions flex items-center gap-2">

                {# Sidebar toggle #}
                {% if show_sidebar_toggle %}
                    <button class="sidebar-toggle-btn dashboard-desktop-sidebar-toggle" type="button"
                            id="sidebarToggle" aria-label="Afficher la navigation" aria-expanded="true"
                            aria-controls="app-dashboard-sidebar">
                        <i data-lucide="panel-left" width="18" height="18" aria-hidden="true"></i>
                        <span class="sidebar-toggle-label ml-1">Masquer la navigation</span>
                    </button>
                {% else %}
                    <a class="sidebar-toggle-btn" href="{{ path('app_dashboard_index') }}"
                       aria-label="Accéder au tableau de bord">
                        <i data-lucide="layout-dashboard" width="18" height="18"></i>
                        <span class="sidebar-toggle-label ml-1">Tableau de bord</span>
                    </a>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') %}
                    <twig:Button as="a" href="{{ path('app_admin_dashboard_index') }}" variant="outline" size="sm" class="no-underline shrink-0 hidden sm:inline-flex">
                        Administration
                    </twig:Button>
                {% endif %}

                {# Help dropdown #}
                <div class="dropdown" data-controller="profile-dropdown">
                    <button class="navbar-icon-btn" type="button"
                            id="dashboardHelpMenuButton"
                            data-profile-dropdown-target="button"
                            data-action="click->profile-dropdown#toggle"
                            aria-expanded="false" aria-haspopup="true"
                            aria-controls="dashboardHelpMenu"
                            aria-label="Menu Aide et liens utiles">
                        <i data-lucide="circle-help" width="20" height="20" aria-hidden="true"></i>
                    </button>
                    <ul id="dashboardHelpMenu"
                        class="dropdown-menu dropdown-menu-end navbar-help-menu shadow-sm border"
                        data-profile-dropdown-target="menu"
                        role="menu"
                        aria-labelledby="dashboardHelpMenuButton"
                        hidden>
                        <li role="none">
                            <a class="dropdown-item"
                               href="{{ path('app_blog_index') }}" role="menuitem">
                                <i data-lucide="book-open" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                <span>Blog QSE</span>
                            </a>
                        </li>
                        <li role="none">
                            <a class="dropdown-item"
                               href="{{ path('app_outils_index') }}" role="menuitem">
                                <i data-lucide="layers" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                <span>Tous les outils</span>
                            </a>
                        </li>
                        <li role="none"><hr class="dropdown-divider my-1"></li>
                        <li role="none">
                            <a class="dropdown-item"
                               href="{{ path('app_contact_index') }}" role="menuitem">
                                <i data-lucide="mail" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                <span>Nous contacter</span>
                            </a>
                        </li>
                    </ul>
                </div>

                {# Profile dropdown — avatar uniquement #}
                <div class="dropdown relative" data-controller="profile-dropdown">
                    <button class="navbar-icon-btn navbar-avatar-btn p-0" type="button"
                            id="dashboardProfileDropdown"
                            data-profile-dropdown-target="button"
                            data-action="click->profile-dropdown#toggle keydown.enter->profile-dropdown#toggle keydown.space->profile-dropdown#toggle keydown.arrow-down->profile-dropdown#openWithKeyboard keydown.arrow-up->profile-dropdown#openWithKeyboard"
                            aria-expanded="false" aria-haspopup="true"
                            aria-label="Menu utilisateur">
                        <div class="profile-dropdown__avatar bg-primary text-white rounded-full flex items-center justify-center" aria-hidden="true">
                            {{ app.user.email|slice(0, 1)|upper }}
                        </div>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2 profile-dropdown__menu"
                        data-profile-dropdown-target="menu"
                        aria-labelledby="dashboardProfileDropdown"
                        hidden>
                        <li>
                            <div class="px-4 py-3 border-b border-border">
                                <div class="font-semibold truncate" style="max-width:220px;">{{ app.user.email }}</div>
                                <small class="text-muted-foreground">Membre connecté</small>
                            </div>
                        </li>
                        <li>
                            <a class="dropdown-item"
                               href="{{ path('app_profile_index') }}" role="menuitem">
                                <i data-lucide="user" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                <span>Mon profil</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item"
                               href="{{ path('app_preferences_index') }}" role="menuitem">
                                <i data-lucide="settings" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                <span>Préférences</span>
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item"
                               href="{{ path('app_creations_index') }}" role="menuitem">
                                <i data-lucide="file-text" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                <span>Mes créations</span>
                            </a>
                        </li>
                        {% if is_granted('ROLE_ADMIN') %}
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <a class="dropdown-item text-primary"
                               href="{{ path('app_admin_dashboard_index') }}" role="menuitem">
                                <i data-lucide="shield" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                <span>Administration</span>
                            </a>
                        </li>
                        {% endif %}
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <a class="dropdown-item text-destructive"
                               href="{{ path('app_logout') }}" role="menuitem">
                                <i data-lucide="log-out" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                <span>Déconnexion</span>
                            </a>
                        </li>
                    </ul>
                </div>

            </div>
        </div>
    </div>
</header>
