{# @prop status string #}
{# @prop isOverdue bool #}
{# @prop isDueSoon bool #}
{%- props status = 'brouillon', isOverdue = false, isDueSoon = false -%}
{%- set statusMap = {
    brouillon: { class: 'bg-muted text-muted-foreground border-border/60', icon: 'lucide:file-edit', label: 'Brouillon' },
    a_valider: { class: 'bg-amber-500/10 text-amber-800 dark:text-amber-400 border-amber-500/20', icon: 'lucide:clipboard-check', label: 'À valider' },
    validee: { class: 'bg-sky-500/10 text-sky-700 dark:text-sky-400 border-sky-500/20', icon: 'lucide:badge-check', label: 'Validée' },
    en_cours: { class: 'bg-primary/10 text-primary border-primary/20', icon: 'lucide:play-circle', label: 'En cours' },
    en_attente_de_verification: { class: 'bg-violet-500/10 text-violet-700 dark:text-violet-400 border-violet-500/20', icon: 'lucide:shield-check', label: 'Vérif. efficacité' },
    cloturee: { class: 'bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 border-emerald-500/20', icon: 'lucide:check-circle-2', label: 'Clôturée' },
    reouverte: { class: 'bg-orange-500/10 text-orange-700 dark:text-orange-400 border-orange-500/20', icon: 'lucide:rotate-ccw', label: 'Rouverte' },
    annulee: { class: 'bg-zinc-500/10 text-zinc-700 dark:text-zinc-400 border-zinc-500/20', icon: 'lucide:ban', label: 'Annulée' },
} -%}
{%- set cfg = statusMap[status] ?? statusMap.brouillon -%}
<span class="inline-flex flex-wrap items-center gap-1.5">
    <span class="inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs font-medium {{ cfg.class }}">
        <twig:ux:icon name="{{ cfg.icon }}" class="size-3 shrink-0" aria-hidden="true" />
        {{ cfg.label }}
    </span>
    {% if isOverdue %}
        <span class="inline-flex items-center gap-1 rounded-full border border-destructive/30 bg-destructive/10 px-2.5 py-0.5 text-xs font-medium text-destructive">
            <twig:ux:icon name="lucide:alarm-clock" class="size-3 shrink-0" aria-hidden="true" />
            En retard
        </span>
    {% elseif isDueSoon %}
        <span class="inline-flex items-center gap-1 rounded-full border border-amber-500/30 bg-amber-500/10 px-2.5 py-0.5 text-xs font-medium text-amber-800 dark:text-amber-400">
            <twig:ux:icon name="lucide:calendar-clock" class="size-3 shrink-0" aria-hidden="true" />
            Échéance proche
        </span>
    {% endif %}
</span>
