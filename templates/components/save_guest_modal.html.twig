{# Modal pour invités après sauvegarde / utilisation d'un outil : inciter à créer un compte ou capturer l'email #}
{# Inclure avec : {% include 'components/save_guest_modal.html.twig' with { tool: 'ishikawa' } %} (ou 'fivewhy', etc.) #}
<div class="fixed inset-0 z-[1050] flex items-center justify-center p-4"
     id="saveGuestModal"
     tabindex="-1"
     aria-labelledby="saveGuestModalTitle"
     aria-hidden="true"
     aria-modal="true"
     role="dialog"
     style="display: none;"
     data-save-guest-tool="{{ tool|default('') }}"
     {{ stimulus_controller('app-modal', { autoShow: false }) }}
     data-turbo="false">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg" role="document">
        <div class="flex items-center justify-between px-6 py-4 border-b border-border">
            <h2 class="text-base font-semibold text-foreground" id="saveGuestModalTitle">Sauvegarder votre travail définitivement ?</h2>
            <twig:Button variant="ghost" size="icon" type="button" data-action="app-modal#hide" aria-label="Fermer" class="shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </twig:Button>
        </div>
        <div class="px-6 py-4">
            <p class="mb-0">Votre travail est enregistré localement sur cet appareil. Pour le retrouver sur tous vos appareils et ne rien perdre, créez un compte gratuit ou connectez-vous.</p>
            <div class="mt-4 pt-4 border-t border-border">
                <p class="text-sm text-muted-foreground mb-2">Ou laissez votre email pour recevoir un rappel et nos astuces QSE (sans engagement).</p>
                <form id="saveGuestEmailForm" class="flex gap-2 flex-wrap" data-save-guest-form>
                    <input type="email" name="email"
                           class="flex-1 min-w-0 border border-input rounded-md px-3 py-1.5 text-sm bg-background placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
                           placeholder="votre@email.fr" required maxlength="255" aria-label="Votre email">
                    <twig:Button type="submit" variant="outline" class="border-primary text-primary hover:bg-primary/5 shrink-0">Envoyer</twig:Button>
                </form>
                <p id="saveGuestEmailSuccess" class="text-sm text-green-600 mt-2 mb-0 hidden">Merci, nous vous recontacterons.</p>
                <p id="saveGuestEmailError" class="text-sm text-destructive mt-2 mb-0 hidden"></p>
            </div>
        </div>
        <div class="flex flex-wrap gap-2 px-6 py-4 border-t border-border">
            <twig:Button as="a" href="{{ path('app_register') }}" variant="default" class="no-underline px-4 py-2 font-medium">Créer un compte gratuit</twig:Button>
            <twig:Button as="a" href="{{ path('app_login') }}" variant="outline" class="no-underline border-primary text-primary px-4 py-2 font-medium hover:bg-primary/5">Se connecter</twig:Button>
            <twig:Button variant="outline" type="button" data-action="app-modal#hide" class="px-4 py-2 font-medium">Plus tard</twig:Button>
        </div>
    </div>
</div>
<script>
(function() {
    var form = document.getElementById('saveGuestEmailForm');
    if (!form) return;
    var modal = document.getElementById('saveGuestModal');
    var tool = modal && modal.getAttribute('data-save-guest-tool') ? modal.getAttribute('data-save-guest-tool') : '';
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        var emailInput = form.querySelector('input[name="email"]');
        var email = emailInput && emailInput.value ? emailInput.value.trim() : '';
        if (!email) return;
        var successEl = document.getElementById('saveGuestEmailSuccess');
        var errorEl = document.getElementById('saveGuestEmailError');
        if (successEl) successEl.classList.add('hidden');
        if (errorEl) { errorEl.classList.add('hidden'); errorEl.textContent = ''; }
        fetch('{{ path('app_public_lead_create') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ email: email, source: 'tool', tool: tool || 'outil' })
        }).then(function(r) {
            if (r.ok) {
                if (successEl) successEl.classList.remove('hidden');
                if (emailInput) emailInput.value = '';
                form.querySelector('button[type="submit"]').setAttribute('disabled', 'disabled');
            } else {
                if (errorEl) { errorEl.textContent = 'Une erreur est survenue.'; errorEl.classList.remove('hidden'); }
            }
        }).catch(function() {
            if (errorEl) { errorEl.textContent = 'Une erreur est survenue.'; errorEl.classList.remove('hidden'); }
        });
    });
})();
</script>
