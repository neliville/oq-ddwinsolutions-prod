{# Embed Mautic generate.js — id via MAUTIC_FORM_NEWSLETTER_ID (global mautic_newsletter_script_url) #}
{% set is_compact = compact|default(false) %}
<div
    id="mautic-newsletter-container"
    class="newsletter-mautic-embed{% if is_compact %} newsletter-mautic-embed--compact{% endif %}"
    data-newsletter-mautic
    {% if mautic_newsletter_script_url %}data-mautic-newsletter-script-url="{{ mautic_newsletter_script_url|e('html_attr') }}"{% endif %}
    aria-live="polite"
>
    {% if mautic_newsletter_script_url %}
        {# generate.js est injecté par assets/js/components/newsletter-mautic.js (turbo:load) pour éviter les doublons #}
        <div class="newsletter-mautic-embed__viewport"></div>
    {% else %}
        <div class="flex items-start gap-3 rounded-lg border border-yellow-200 bg-yellow-50 text-yellow-800 px-4 py-3 mb-0" role="alert">
            <i class="fas fa-exclamation-triangle mr-2 mt-0.5 shrink-0" aria-hidden="true"></i>
            Le formulaire newsletter n'est pas disponible (configuration Mautic).
        </div>
    {% endif %}
</div>
