{# @prop formId string #}
{# @prop cancelUrl string #}
{# @prop primaryActionValue string|null #}
{# @prop primaryActionLabel string|null #}
{%- props formId = 'capa-edit-form', cancelUrl, primaryActionValue = null, primaryActionLabel = null -%}
{% set desktopClass = 'hidden lg:flex sticky z-30 mb-6 flex-col gap-2 rounded-xl border border-border bg-background/95 p-3 shadow-sm backdrop-blur supports-[backdrop-filter]:bg-background/90 capa-save-action-bar capa-save-action-bar--desktop' %}
{% set mobileClass = 'lg:hidden fixed inset-x-0 bottom-0 z-40 border-t border-border bg-background/95 px-4 pt-3 shadow-[0_-8px_30px_rgba(0,0,0,0.08)] backdrop-blur supports-[backdrop-filter]:bg-background/90 pb-[max(0.75rem,env(safe-area-inset-bottom))] capa-save-action-bar capa-save-action-bar--mobile' %}

<div class="{{ desktopClass }}" style="top: var(--dashboard-sticky-toolbar-top)">
    {% include 'components/CapaSaveActionBar/_buttons.html.twig' with {
        formId: formId,
        cancelUrl: cancelUrl,
        primaryActionValue: primaryActionValue,
        primaryActionLabel: primaryActionLabel,
    } only %}
</div>
<div class="{{ mobileClass }}">
    {% include 'components/CapaSaveActionBar/_buttons.html.twig' with {
        formId: formId,
        cancelUrl: cancelUrl,
        primaryActionValue: primaryActionValue,
        primaryActionLabel: primaryActionLabel,
    } only %}
</div>
