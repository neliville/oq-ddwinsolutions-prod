{# @prop icon string Nom icône Lucide #}
{# @prop title string #}
{# @prop lead string #}
{# @prop expiry string|null Texte expiration (ex. traduction ResetPasswordBundle) #}
{# @prop steps array Liste d'étapes (strings) #}
{# @prop tip string|null HTML conseil #}
{# @prop primaryHref string #}
{# @prop primaryLabel string #}
{# @prop secondaryHref string|null #}
{# @prop secondaryLabel string|null #}
{%- props
    icon = 'mail-check',
    title = '',
    lead = '',
    expiry = null,
    steps = [],
    tip = null,
    primaryHref = '',
    primaryLabel = 'Continuer',
    secondaryHref = null,
    secondaryLabel = null,
-%}
<div class="auth-success-state" data-controller="gsap-reveal">
    <span class="auth-success-state__icon" aria-hidden="true">
        <i data-lucide="{{ icon }}" width="32" height="32"></i>
    </span>

    <h1 class="auth-success-state__title">{{ title }}</h1>

    {% if lead %}
        <p class="auth-success-state__lead">{{ lead }}</p>
    {% endif %}

    {% if expiry %}
        <p class="auth-success-state__expiry">
            <i data-lucide="clock" width="16" height="16" aria-hidden="true"></i>
            {{ expiry }}
        </p>
    {% endif %}

    {% if steps|length > 0 %}
        <ol class="auth-success-state__steps" aria-label="Prochaines étapes">
            {% for step in steps %}
                <li class="auth-success-state__step">
                    <span class="auth-success-state__step-num" aria-hidden="true">{{ loop.index }}</span>
                    <span>{{ step }}</span>
                </li>
            {% endfor %}
        </ol>
    {% endif %}

    {% if tip %}
        <p class="auth-success-state__tip">{{ tip|raw }}</p>
    {% endif %}

    <div class="auth-success-state__actions">
        {% if primaryHref %}
            <twig:Button as="a" href="{{ primaryHref }}" variant="default" class="no-underline w-full sm:w-auto min-h-[44px] gap-2 justify-center">
                <i data-lucide="arrow-left" width="18" height="18" aria-hidden="true"></i>
                {{ primaryLabel }}
            </twig:Button>
        {% endif %}
        {% if secondaryHref and secondaryLabel %}
            <twig:Button as="a" href="{{ secondaryHref }}" variant="outline" class="no-underline w-full sm:w-auto min-h-[44px] gap-2 justify-center">
                <i data-lucide="refresh-cw" width="18" height="18" aria-hidden="true"></i>
                {{ secondaryLabel }}
            </twig:Button>
        {% endif %}
    </div>
</div>
