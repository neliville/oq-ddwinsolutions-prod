{% set preset = presets[variant] ?? presets.login %}
{% set panel_title = title ?? preset.title %}
{% set panel_subtitle = subtitle ?? preset.subtitle %}
{% set panel_eyebrow = eyebrow ?? preset.eyebrow|default(null) %}
{% set panel_benefits = benefits ?? preset.benefits|default([]) %}
{% set panel_stats = stats ?? preset.stats|default([]) %}
{% set panel_trust = trust ?? preset.trust|default([]) %}
{% set panel_timeline = timeline_steps ?? preset.timeline_steps|default([]) %}
{% set panel_highlights = highlights ?? preset.highlights|default([]) %}
{% set panel_meta = meta ?? preset.meta|default(null) %}

<div class="relative auth-feature-panel auth-feature-panel--{{ variant }}">
    {% if panel_eyebrow %}
        <span class="auth-feature-panel__eyebrow">{{ panel_eyebrow }}</span>
    {% endif %}

    <h2 class="auth-info__title">{{ panel_title }}</h2>
    <p class="auth-info__subtitle">{{ panel_subtitle }}</p>

    {% if panel_timeline|length > 0 %}
        <ol class="reset-password-timeline" aria-label="Étapes">
            {% for step in panel_timeline %}
                <li class="reset-password-timeline__item">
                    <span class="reset-password-timeline__marker" aria-hidden="true">{{ loop.index }}</span>
                    <div class="reset-password-timeline__content">
                        <h3 class="reset-password-timeline__heading">{{ step.heading }}</h3>
                        <p class="reset-password-timeline__text">{{ step.text }}</p>
                    </div>
                </li>
            {% endfor %}
        </ol>
    {% elseif panel_benefits|length > 0 %}
        <ul class="auth-benefits">
            {% for benefit in panel_benefits %}
                <li class="auth-benefits__item">
                    <span class="auth-benefits__icon" aria-hidden="true">
                        <i data-lucide="{{ benefit.icon|default('check') }}" width="20" height="20"></i>
                    </span>
                    <div>
                        <h3 class="auth-benefits__heading">{{ benefit.heading }}</h3>
                        <p class="auth-benefits__description">{{ benefit.description|default('')|raw }}</p>
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    {% if panel_stats|length > 0 %}
        <div class="auth-highlights mt-6">
            {% for stat in panel_stats %}
                <div class="auth-highlight">
                    <span class="auth-highlight__value">{{ stat.value|raw }}</span>
                    <span class="auth-highlight__label">{{ stat.label }}</span>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {% if panel_highlights|length > 0 %}
        <div class="auth-highlights mt-6">
            {% for highlight in panel_highlights %}
                <div class="auth-highlight">
                    <span class="auth-highlight__value">{{ highlight.value|raw }}</span>
                    <span class="auth-highlight__label">{{ highlight.label }}</span>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {% if panel_trust|length > 0 %}
        <div class="auth-trust-strip" role="list" aria-label="Garanties">
            {% for badge in panel_trust %}
                <span class="auth-trust-badge" role="listitem">
                    <i data-lucide="{{ badge.icon }}" width="14" height="14" aria-hidden="true"></i>
                    {{ badge.label }}
                </span>
            {% endfor %}
        </div>
    {% endif %}

    {% if panel_meta %}
        <p class="auth-meta mt-6">{{ panel_meta|raw }}</p>
    {% endif %}
</div>
