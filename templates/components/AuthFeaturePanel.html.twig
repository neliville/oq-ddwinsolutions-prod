            { value: '5+', label: 'modules QSE reliés' },
            { value: 'Illimité', label: 'sauvegardes & exports' },
            { value: 'Support', label: 'prioritaire par email' },
        ],
        trust: [
            { icon: 'shield', label: 'Conforme RGPD' },
            { icon: 'map-pin', label: 'Hébergement France' },
            { icon: 'zap', label: 'Prêt en quelques minutes' },
        ],
