        title: 'Ce que vous débloquez',
        subtitle: 'Créez votre compte et accédez à une plateforme QSE pensée pour les équipes terrain et les responsables conformité.',
        benefits: [
            { icon: 'boxes', heading: 'Modules QSE intégrés', description: 'Audits, CAPA, risques, PDCA et outils d’analyse (Ishikawa, 5 Pourquoi, 8D…) en un seul espace.' },
            { icon: 'users', heading: 'Collaboration équipe', description: 'Partagez vos analyses et pilotez vos actions correctives à plusieurs.' },
            { icon: 'timer', heading: 'Gain de temps', description: 'Modèles prêts à l’emploi, exports en un clic, tableaux de bord clairs.' },
            { icon: 'shield-check', heading: 'Confidentialité garantie', description: 'Hébergement français, conformité RGPD, sauvegardes et chiffrement.' },
        ],
