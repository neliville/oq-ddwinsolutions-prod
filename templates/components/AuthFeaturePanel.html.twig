{# @prop variant 'login'|'register'|'reset'|'status' Preset marketing panneau droit #}
{# @prop title string|null Surcharge titre #}
{# @prop subtitle string|null Surcharge sous-titre #}
{# @prop eyebrow string|null Badge au-dessus du titre #}
