<nav class="navbar navbar-expand-lg main-navbar fixed-top" id="mainNav">
    <div class="container">

        {# ── Brand ────────────────────────────────────────────────────────── #}
        <a class="navbar-brand main-navbar__brand d-flex align-items-center text-decoration-none flex-shrink-0"
           href="{{ path('app_home_index') }}">
            <img src="{{ asset('img/logo.webp') }}" alt="OUTILS-QUALITÉ" width="40" height="40"
                 class="me-2 flex-shrink-0" loading="eager" fetchpriority="high">
            <span class="fw-bold main-navbar__brand-text">OUTILS-QUALITÉ</span>
        </a>

        {# ── Mobile : sidebar toggle entre le brand et le hamburger ──────── #}
        {% if app.user %}
        <div class="d-flex d-lg-none align-items-center gap-1 ms-auto me-2">
            {% if show_sidebar_toggle %}
                <button class="navbar-icon-btn" type="button" id="sidebarToggleMobile"
                        aria-label="Afficher la navigation" aria-expanded="true">
                    <i data-lucide="panel-left" width="20" height="20"></i>
                </button>
            {% else %}
                <a class="navbar-icon-btn" href="{{ path('app_dashboard_index') }}"
                   aria-label="Accéder au tableau de bord">
                    <i data-lucide="layout-dashboard" width="20" height="20"></i>
                </a>
            {% endif %}
        </div>
        {% endif %}

        {# ── Hamburger (mobile) ──────────────────────────────────────────── #}
        <button class="navbar-toggler ms-1" type="button"
                data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Afficher le menu">
            <span class="navbar-toggler-icon"></span>
        </button>

        {# ── Collapse : liens de navigation + CTA mobile non connecté ────── #}
        <div class="collapse navbar-collapse" id="navbarNav">
            <div class="navbar-menu flex-grow-1">
                {{ knp_menu_render('app.navbar', {
                    'template': 'menu/navbar.html.twig',
                    'currentClass': 'active',
                    'ancestorClass': 'active',
                    'currentAsLink': true,
                    'allow_safe_labels': true
                }) }}
            </div>

            {% if not app.user %}
            <div class="d-lg-none mt-2">
                <a class="btn btn-primary w-100" href="{{ path('app_login') }}">Connexion</a>
            </div>
            {% endif %}
        </div>

        {# ── Actions droite — desktop (toujours visibles) ─────────────────── #}
        {% if app.user %}
        <div class="navbar-right-actions d-none d-lg-flex align-items-center gap-2 ms-lg-4">

            {# Sidebar toggle #}
            {% if show_sidebar_toggle %}
                <button class="sidebar-toggle-btn" type="button" id="sidebarToggle"
                        aria-label="Afficher la navigation" aria-expanded="true">
                    <i data-lucide="panel-left" width="18" height="18"></i>
                    <span class="sidebar-toggle-label ms-1">Masquer la navigation</span>
                </button>
            {% else %}
                <a class="sidebar-toggle-btn" href="{{ path('app_dashboard_index') }}"
                   aria-label="Accéder au tableau de bord">
                    <i data-lucide="layout-dashboard" width="18" height="18"></i>
                    <span class="sidebar-toggle-label ms-1">Tableau de bord</span>
                </a>
            {% endif %}

            {# Help dropdown #}
            <div class="dropdown" data-controller="profile-dropdown">
                <button class="navbar-icon-btn" type="button"
                        data-profile-dropdown-target="button"
                        data-action="click->profile-dropdown#toggle"
                        aria-expanded="false" aria-haspopup="true"
                        title="Aide" aria-label="Aide">
                    <i data-lucide="circle-help" width="20" height="20"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end navbar-help-menu shadow-sm border"
                    data-profile-dropdown-target="menu"
                    hidden>
                    <li>
                        <a class="dropdown-item d-flex align-items-center justify-content-between"
                           href="{{ path('app_blog_index') }}">
                            <span>Blog QSE</span>
                            <i data-lucide="book-open" width="15" height="15" class="ms-4 text-muted"></i>
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item d-flex align-items-center justify-content-between"
                           href="{{ path('app_outils_index') }}">
                            <span>Tous les outils</span>
                            <i data-lucide="layers" width="15" height="15" class="ms-4 text-muted"></i>
                        </a>
                    </li>
                    <li><hr class="dropdown-divider my-1"></li>
                    <li>
                        <a class="dropdown-item d-flex align-items-center justify-content-between"
                           href="{{ path('app_contact_index') }}">
                            <span>Nous contacter</span>
                            <i data-lucide="mail" width="15" height="15" class="ms-4 text-muted"></i>
                        </a>
                    </li>
                </ul>
            </div>

            {# Profile dropdown — avatar uniquement #}
            <div class="dropdown position-relative" data-controller="profile-dropdown">
                <button class="navbar-icon-btn navbar-avatar-btn p-0" type="button"
                        id="profileDropdown"
                        data-profile-dropdown-target="button"
                        data-action="click->profile-dropdown#toggle keydown.enter->profile-dropdown#toggle keydown.space->profile-dropdown#toggle keydown.arrow-down->profile-dropdown#openWithKeyboard keydown.arrow-up->profile-dropdown#openWithKeyboard"
                        aria-expanded="false" aria-haspopup="true"
                        aria-label="Menu utilisateur">
                    <div class="profile-dropdown__avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center">
                        {{ app.user.email|slice(0, 1)|upper }}
                    </div>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2 profile-dropdown__menu"
                    data-profile-dropdown-target="menu"
                    aria-labelledby="profileDropdown"
                    hidden>
                    <li>
                        <div class="px-4 py-3 border-bottom">
                            <div class="fw-semibold text-truncate" style="max-width:220px;">{{ app.user.email }}</div>
                            <small class="text-muted">Membre connecté</small>
                        </div>
                    </li>
                    <li>
                        <a class="dropdown-item d-flex align-items-center justify-content-between"
                           href="{{ path('app_profile_index') }}" role="menuitem">
                            <span>Mon profil</span>
                            <i data-lucide="user" width="15" height="15" class="ms-4 text-muted"></i>
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item d-flex align-items-center justify-content-between"
                           href="{{ path('app_creations_index') }}" role="menuitem">
                            <span>Mes créations</span>
                            <i data-lucide="file-text" width="15" height="15" class="ms-4 text-muted"></i>
                        </a>
                    </li>
                    {% if is_granted('ROLE_ADMIN') %}
                    <li><hr class="dropdown-divider my-1"></li>
                    <li>
                        <a class="dropdown-item d-flex align-items-center justify-content-between text-primary"
                           href="{{ path('app_admin_dashboard_index') }}" role="menuitem">
                            <span>Administration</span>
                            <i data-lucide="shield" width="15" height="15" class="ms-4"></i>
                        </a>
                    </li>
                    {% endif %}
                    <li><hr class="dropdown-divider my-1"></li>
                    <li>
                        <a class="dropdown-item d-flex align-items-center justify-content-between text-danger"
                           href="{{ path('app_logout') }}" role="menuitem">
                            <span>Déconnexion</span>
                            <i data-lucide="log-out" width="15" height="15" class="ms-4"></i>
                        </a>
                    </li>
                </ul>
            </div>

        </div>
        {% else %}
        <a class="btn btn-primary btn-sm d-none d-lg-inline-flex ms-4"
           href="{{ path('app_login') }}">Connexion</a>
        {% endif %}

    </div>
</nav>
