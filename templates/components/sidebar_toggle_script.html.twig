{# Script partagé : toggle sidebar + overlay (sidebar utilisateur ou admin). #}
<script>
function initSidebar() {
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }

    var RAIL_W = 72;

    function clearRailFlyoutPanel(panel) {
        if (!panel) return;
        panel.style.position = '';
        panel.style.top = '';
        panel.style.left = '';
        panel.style.width = '';
        panel.style.zIndex = '';
        panel.style.maxHeight = '';
        panel.style.overflowY = '';
        panel.classList.remove('sidebar-submenu--rail-flyout');
    }

    function clearAllRailFlyoutPanels() {
        document.querySelectorAll('.sidebar-submenu').forEach(function (panel) {
            clearRailFlyoutPanel(panel);
        });
    }

    function positionRailFlyout(trigger, panel) {
        if (!trigger || !panel) return;
        if (!document.body.classList.contains('sidebar-collapsed') || window.innerWidth <= 1200) {
            clearRailFlyoutPanel(panel);
            return;
        }
        if (!panel.classList.contains('show')) {
            clearRailFlyoutPanel(panel);
            return;
        }
        panel.classList.add('sidebar-submenu--rail-flyout');
        panel.style.position = 'fixed';
        panel.style.left = (RAIL_W + 6) + 'px';
        panel.style.width = 'min(260px, calc(100vw - 88px))';
        panel.style.zIndex = '1031';
        panel.style.maxHeight = 'min(70vh, 420px)';
        panel.style.overflowY = 'auto';
        var rect = trigger.getBoundingClientRect();
        var top = rect.top;
        var estH = Math.min(panel.scrollHeight || 280, 420);
        var maxTop = window.innerHeight - estH - 10;
        if (top > maxTop) top = Math.max(10, maxTop);
        if (top < 10) top = 10;
        panel.style.top = top + 'px';
    }

    function closeOtherRailSubmenus(exceptPanel) {
        document.querySelectorAll('.sidebar-submenu.show').forEach(function (panel) {
            if (panel === exceptPanel) return;
            panel.classList.remove('show');
            clearRailFlyoutPanel(panel);
            var id = panel.id;
            if (!id) return;
            var otherTrigger = document.querySelector('[aria-controls="' + id + '"]');
            if (otherTrigger) {
                otherTrigger.setAttribute('aria-expanded', 'false');
                var ch = otherTrigger.querySelector('.sidebar-chevron');
                if (ch) ch.style.transform = 'rotate(0deg)';
            }
        });
    }

    function syncRailFlyoutsFromDom(sidebar) {
        if (!document.body.classList.contains('sidebar-collapsed') || window.innerWidth <= 1200) return;
        document.querySelectorAll('.sidebar-collapse-trigger[aria-expanded="true"]').forEach(function (tr) {
            var id = tr.getAttribute('aria-controls');
            if (!id) return;
            var panel = document.getElementById(id);
            if (panel && panel.classList.contains('show')) {
                positionRailFlyout(tr, panel);
            }
        });
    }

    function syncRailAccessibleNames() {
        var rail = document.body.classList.contains('sidebar-collapsed') && window.innerWidth > 1200;
        document.querySelectorAll('[data-sidebar-item-label]').forEach(function (el) {
            var name = el.getAttribute('data-sidebar-item-label');
            if (!name) return;
            if (rail) el.setAttribute('aria-label', name);
            else el.removeAttribute('aria-label');
        });
    }

    var collapseTriggers = document.querySelectorAll('.sidebar-collapse-trigger');
    collapseTriggers.forEach(function (trigger) {
        if (trigger.dataset.sidebarListenerAttached === 'true') return;
        trigger.dataset.sidebarListenerAttached = 'true';

        trigger.addEventListener('click', function (event) {
            event.preventDefault();

            var targetSelector = this.dataset.sidebarTarget;
            if (!targetSelector) return;

            var target = document.querySelector(targetSelector);
            if (!target) return;

            var isShown = target.classList.contains('show');

            if (!isShown && window.innerWidth > 1200 && document.body.classList.contains('sidebar-collapsed')) {
                closeOtherRailSubmenus(target);
            }

            target.classList.toggle('show');

            var chevron = this.querySelector('.sidebar-chevron');
            var nowShown = target.classList.contains('show');
            if (chevron) {
                chevron.style.transform = nowShown ? 'rotate(180deg)' : 'rotate(0deg)';
            }

            this.setAttribute('aria-expanded', nowShown ? 'true' : 'false');

            if (!nowShown) {
                clearRailFlyoutPanel(target);
            } else {
                positionRailFlyout(this, target);
                requestAnimationFrame(function () {
                    positionRailFlyout(trigger, target);
                });
            }
        });
    });

    var sidebarPrimaryToggle = document.getElementById('sidebarToggle');
    var sidebarMobileToggle = document.getElementById('sidebarToggleMobile');
    var sidebar = document.querySelector('.admin-sidebar');
    var sidebarOverlay = document.getElementById('sidebarOverlay');
    var mainContent = document.querySelector('[data-sidebar-main-content]');
    var siteFooter = document.querySelector('body > footer');
    var sidebarToggleButtons = [sidebarPrimaryToggle, sidebarMobileToggle].filter(Boolean);

    if (sidebar && sidebarToggleButtons.length) {
        var isDesktop = function () { return window.innerWidth > 1200; };

        var setInertState = function (element, isInert) {
            if (!element) return;

            if (isInert) {
                element.setAttribute('inert', '');
                element.setAttribute('aria-hidden', 'true');
            } else {
                element.removeAttribute('inert');
                element.removeAttribute('aria-hidden');
            }
        };

        var syncMobileDrawerA11y = function () {
            var desktop = isDesktop();
            var mobileOpen = !desktop && sidebar.classList.contains('show');
            var sidebarVisibleForA11y = desktop || mobileOpen;

            document.body.classList.toggle('sidebar-mobile-open', mobileOpen);
            sidebar.setAttribute('aria-hidden', sidebarVisibleForA11y ? 'false' : 'true');
            setInertState(mainContent, mobileOpen);
            setInertState(siteFooter, mobileOpen);
        };

        var hideOverlay = function () {
            if (sidebarOverlay) {
                sidebarOverlay.classList.remove('show');
                sidebarOverlay.style.display = 'none';
                sidebarOverlay.setAttribute('aria-hidden', 'true');
            }
        };

        var showOverlay = function () {
            if (sidebarOverlay) {
                sidebarOverlay.classList.add('show');
                sidebarOverlay.style.display = 'block';
                sidebarOverlay.setAttribute('aria-hidden', 'false');
            }
        };

        var getState = function () {
            var collapsed = document.body.classList.contains('sidebar-collapsed');
            var desktop = isDesktop();
            var open = desktop ? !collapsed : sidebar.classList.contains('show');
            return { collapsed: collapsed, open: open, desktop: desktop };
        };

        var updateToggleVisual = function () {
            var state = getState();
            var collapsed = state.collapsed;
            var open = state.open;
            var desktop = state.desktop;
            var drawerOpenMobile = !desktop && sidebar.classList.contains('show');

            sidebarToggleButtons.forEach(function (button) {
                var labelElement = button.querySelector('.sidebar-toggle-label');
                var iconElement = button.querySelector('i[data-lucide]');
                var labelText = desktop
                    ? (collapsed ? 'Agrandir la navigation' : 'Réduire la navigation')
                    : (drawerOpenMobile ? 'Fermer la navigation' : 'Afficher la navigation');

                var navExpanded = desktop ? !collapsed : drawerOpenMobile;
                button.setAttribute('aria-expanded', navExpanded ? 'true' : 'false');
                button.setAttribute('aria-label', labelText);

                if (labelElement) labelElement.textContent = labelText;

                if (iconElement && typeof lucide !== 'undefined') {
                    var iconName = desktop
                        ? (collapsed ? 'panel-right-open' : 'panel-left')
                        : (drawerOpenMobile ? 'x' : 'menu');
                    iconElement.setAttribute('data-lucide', iconName);
                }
            });

            syncMobileDrawerA11y();
            syncRailAccessibleNames();
            if (typeof lucide !== 'undefined') lucide.createIcons();
        };

        var collapseSidebar = function () {
            document.body.classList.add('sidebar-collapsed');
            sidebar.classList.remove('show');
            clearAllRailFlyoutPanels();
            hideOverlay();
            updateToggleVisual();
            syncRailFlyoutsFromDom(sidebar);
        };

        var expandSidebar = function () {
            document.body.classList.remove('sidebar-collapsed');
            clearAllRailFlyoutPanels();
            document.querySelectorAll('.sidebar-submenu.show').forEach(function (p) {
                clearRailFlyoutPanel(p);
            });
            sidebar.classList.add('show');
            hideOverlay();
            updateToggleVisual();
        };

        var openSidebar = function () {
            document.body.classList.remove('sidebar-collapsed');
            clearAllRailFlyoutPanels();
            sidebar.classList.add('show');
            if (isDesktop()) hideOverlay(); else showOverlay();
            updateToggleVisual();
            if (!isDesktop()) {
                var firstLink = sidebar.querySelector('.sidebar-nav a.sidebar-item[href], .sidebar-nav a[href].cockpit-nav-link');
                if (firstLink && typeof firstLink.focus === 'function') {
                    requestAnimationFrame(function () { firstLink.focus(); });
                }
            }
        };

        var closeSidebar = function () {
            var wasMobileOpen = !isDesktop() && sidebar.classList.contains('show');
            var toggleToFocus = document.getElementById('sidebarToggleMobile') || document.getElementById('sidebarToggle');
            sidebar.classList.remove('show');
            clearAllRailFlyoutPanels();
            hideOverlay();
            updateToggleVisual();
            if (wasMobileOpen && toggleToFocus && document.contains(toggleToFocus)) {
                requestAnimationFrame(function () { toggleToFocus.focus(); });
            }
        };

        if (!document.body.dataset.dashboardSidebarEscapeBound) {
            document.body.dataset.dashboardSidebarEscapeBound = '1';
            document.addEventListener('keydown', function (event) {
                if (event.key !== 'Escape') return;
                if (window.innerWidth > 1200 && document.body.classList.contains('sidebar-collapsed')) {
                    var flyout = document.querySelector('.sidebar-submenu.sidebar-submenu--rail-flyout');
                    if (flyout) {
                        event.preventDefault();
                        document.querySelectorAll('.sidebar-submenu.show').forEach(function (panel) {
                            panel.classList.remove('show');
                            clearRailFlyoutPanel(panel);
                            var pid = panel.id;
                            if (pid) {
                                var trig = document.querySelector('[aria-controls="' + pid + '"]');
                                if (trig) {
                                    trig.setAttribute('aria-expanded', 'false');
                                    var ch = trig.querySelector('.sidebar-chevron');
                                    if (ch) ch.style.transform = 'rotate(0deg)';
                                }
                            }
                        });
                        return;
                    }
                }
                if (window.innerWidth > 1200) return;
                if (!sidebar.classList.contains('show')) return;
                event.preventDefault();
                closeSidebar();
            });
        }

        if (!window.__sidebarRailDocClickBound) {
            window.__sidebarRailDocClickBound = true;
            document.addEventListener('click', function (e) {
                if (window.innerWidth <= 1200 || !document.body.classList.contains('sidebar-collapsed')) return;
                if (sidebar.contains(e.target)) return;
                document.querySelectorAll('.sidebar-submenu.show').forEach(function (panel) {
                    panel.classList.remove('show');
                    clearRailFlyoutPanel(panel);
                    var pid = panel.id;
                    if (pid) {
                        var trig = document.querySelector('[aria-controls="' + pid + '"]');
                        if (trig) {
                            trig.setAttribute('aria-expanded', 'false');
                            var ch = trig.querySelector('.sidebar-chevron');
                            if (ch) ch.style.transform = 'rotate(0deg)';
                        }
                    }
                });
            }, true);
        }

        var navScroll = sidebar.querySelector('.sidebar-nav');
        if (navScroll && !navScroll.dataset.railScrollBound) {
            navScroll.dataset.railScrollBound = '1';
            navScroll.addEventListener('scroll', function () {
                if (!document.body.classList.contains('sidebar-collapsed') || window.innerWidth <= 1200) return;
                document.querySelectorAll('.sidebar-collapse-trigger[aria-expanded="true"]').forEach(function (tr) {
                    var id = tr.getAttribute('aria-controls');
                    var panel = id && document.getElementById(id);
                    if (panel && panel.classList.contains('show')) positionRailFlyout(tr, panel);
                });
            }, { passive: true });
        }

        var bindToggleButton = function (button) {
            if (!button || button.dataset.listenerAttached === 'true') return;
            button.dataset.listenerAttached = 'true';

            button.addEventListener('click', function (event) {
                event.preventDefault();
                event.stopPropagation();

                var state = getState();
                var desktop = state.desktop;
                var collapsed = state.collapsed;

                if (desktop) {
                    if (collapsed) expandSidebar(); else collapseSidebar();
                } else {
                    if (sidebar.classList.contains('show')) closeSidebar(); else openSidebar();
                }
            });
        };

        sidebarToggleButtons.forEach(bindToggleButton);

        if (sidebarOverlay && sidebarOverlay.dataset.listenerAttached !== 'true') {
            sidebarOverlay.dataset.listenerAttached = 'true';
            sidebarOverlay.addEventListener('click', function () { closeSidebar(); });
        }

        if (!sidebar.dataset.linksListenerAttached) {
            sidebar.dataset.linksListenerAttached = 'true';
            var sidebarLinks = sidebar.querySelectorAll('a[href]:not([href^="#"]):not(.sidebar-collapse-trigger)');
            sidebarLinks.forEach(function (link) {
                link.addEventListener('click', function () {
                    if (!isDesktop()) closeSidebar();
                });
            });
        }

        var resizeTimer;
        var handleResize = function () {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(function () {
                if (isDesktop()) {
                    if (document.body.classList.contains('sidebar-collapsed')) {
                        sidebar.classList.remove('show');
                        clearAllRailFlyoutPanels();
                        syncRailFlyoutsFromDom(sidebar);
                    } else {
                        sidebar.classList.add('show');
                        clearAllRailFlyoutPanels();
                    }
                    hideOverlay();
                } else {
                    clearAllRailFlyoutPanels();
                    if (!sidebar.classList.contains('show')) hideOverlay();
                }
                updateToggleVisual();
            }, 200);
        };

        if (window.__sidebarHandleResize) {
            window.removeEventListener('resize', window.__sidebarHandleResize);
        }
        window.__sidebarHandleResize = handleResize;
        window.addEventListener('resize', handleResize);

        if (isDesktop()) {
            if (document.body.classList.contains('sidebar-collapsed')) {
                sidebar.classList.remove('show');
                syncRailFlyoutsFromDom(sidebar);
            } else {
                sidebar.classList.add('show');
            }
            hideOverlay();
        } else {
            sidebar.classList.remove('show');
            hideOverlay();
        }

        updateToggleVisual();
        syncRailFlyoutsFromDom(sidebar);
    }
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebar);
} else {
    initSidebar();
}

if (typeof window.Turbo !== 'undefined') {
    document.addEventListener('turbo:load', initSidebar);
    document.addEventListener('turbo:frame-load', initSidebar);
}
</script>
