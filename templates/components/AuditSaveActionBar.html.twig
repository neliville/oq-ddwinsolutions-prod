{# @var formId string #}
{# @var placement string desktop|mobile #}
{% set isDesktop = placement == 'desktop' %}
{% set wrapClass = isDesktop
    ? 'hidden lg:flex sticky top-2 z-30 mb-4 flex-col gap-2 rounded-xl border border-border bg-background/95 p-3 shadow-sm backdrop-blur supports-[backdrop-filter]:bg-background/90'
    : 'lg:hidden fixed inset-x-0 bottom-0 z-40 border-t border-border bg-background/95 px-4 pt-3 shadow-[0_-8px_30px_rgba(0,0,0,0.08)] backdrop-blur supports-[backdrop-filter]:bg-background/90 pb-[max(0.75rem,env(safe-area-inset-bottom))]'
%}
<div class="{{ wrapClass }}" data-audit-save-bar-target="{{ isDesktop ? 'barDesktop' : 'barMobile' }}">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-xs text-muted-foreground m-0 order-2 sm:order-1" data-audit-save-bar-target="status" aria-live="polite">
            <span data-audit-save-bar-target="statusDirty" class="hidden font-medium text-amber-700 dark:text-amber-300">Modifications non enregistrées</span>
            <span data-audit-save-bar-target="statusIdle" class="text-muted-foreground">Aucune modification en attente d’enregistrement.</span>
        </p>
        <div class="flex flex-wrap items-stretch gap-2 order-1 sm:order-2 sm:justify-end">
            <twig:Button type="button" variant="outline" size="default" class="min-h-11 shrink-0" data-action="audit-save-bar#prevRequirement">
                <twig:ux:icon name="lucide:chevron-up" class="size-4 sm:hidden" aria-hidden="true" />
                <span class="hidden sm:inline">Précédente</span>
            </twig:Button>
            <twig:Button type="button" variant="outline" size="default" class="min-h-11 shrink-0" data-action="audit-save-bar#nextRequirement">
                <twig:ux:icon name="lucide:chevron-down" class="size-4 sm:hidden" aria-hidden="true" />
                <span class="hidden sm:inline">Suivante</span>
            </twig:Button>
            <twig:Button type="button" variant="secondary" class="min-h-11 shrink-0" data-action="audit-save-bar#saveAndContinue">
                Enregistrer et suivante
            </twig:Button>
            <button
                type="submit"
                class="min-h-11 min-w-[10rem] flex-1 sm:flex-none gap-1.5 rounded-lg border border-transparent bg-primary px-3 py-2.5 text-sm font-semibold text-primary-foreground shadow-md transition-opacity hover:opacity-95 focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 inline-flex items-center justify-center shrink-0"
                form="{{ formId }}"
                data-audit-save-bar-target="primarySave"
                data-audit-save-pulse-target="primarySave"
            >
                Enregistrer
            </button>
        </div>
    </div>
    {# Keycaps premium (style Linear/Notion). L’affichage Win/Mac est géré côté CSS via :is() pour rester sans JS. #}
    {% set kbd = 'inline-flex h-5 min-w-5 items-center justify-center rounded-[5px] border border-border/80 bg-muted/60 px-1.5 font-sans text-[10.5px] font-semibold text-foreground/80 shadow-[inset_0_-1px_0_rgba(0,0,0,0.04)] tabular-nums' %}
    <p class="m-0 hidden sm:flex flex-wrap items-center gap-1.5 text-[11px] text-muted-foreground" data-audit-save-bar-target="shortcutHint">
        <span class="inline-flex items-center gap-1 text-muted-foreground/90">
            <twig:ux:icon name="lucide:keyboard" class="size-3.5" aria-hidden="true" />
            <span>Enregistrer</span>
        </span>
        <span class="inline-flex items-center gap-1" aria-label="Raccourci clavier : Ctrl plus Entrée (Windows et Linux), Commande plus Entrée (macOS)">
            <kbd class="{{ kbd }}" data-audit-save-bar-target="shortcutModWin"><span aria-hidden="true">Ctrl</span></kbd>
            <kbd class="{{ kbd }} hidden" data-audit-save-bar-target="shortcutModMac"><span aria-hidden="true">⌘</span></kbd>
            <span class="text-muted-foreground/60" aria-hidden="true">+</span>
            <kbd class="{{ kbd }}"><span aria-hidden="true">Entrée</span></kbd>
        </span>
    </p>
</div>
