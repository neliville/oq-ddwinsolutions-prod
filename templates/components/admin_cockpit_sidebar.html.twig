{% set adminNavSections = admin_navigation_sections() %}

<aside id="app-dashboard-sidebar" class="admin-sidebar admin-cockpit-sidebar" aria-label="Navigation administration">
    <nav class="sidebar-nav" aria-label="Rubriques administration" data-sidebar-scroll-region>
        {% for section in adminNavSections %}
        <div class="sidebar-section">
            <div class="sidebar-section-label">{{ section.label }}</div>
            {% for item in section.items %}
            {% if item.help_id %}
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path(item.route, item.route_parameters|default({})),
                label: item.label,
                icon: item.icon,
                help_id: item.help_id,
                active_if: item.active,
                currentRoute: app.request.get('_route'),
            } %}
            {% else %}
            <a href="{{ path(item.route, item.route_parameters|default({})) }}"
               class="sidebar-item {{ item.active ? 'active' : '' }}"
               {% if item.active %}aria-current="page"{% endif %}
               data-sidebar-item-label="{{ item.label }}">
                <i data-lucide="{{ item.icon }}" width="16" height="16" class="sidebar-item-icon" aria-hidden="true"></i>
                <span class="sidebar-item-label">{{ item.label }}</span>
            </a>
            {% endif %}
            {% endfor %}
        </div>
        {% endfor %}
    </nav>

    <div class="sidebar-footer" aria-label="Actions de session">
        <a href="{{ path('app_logout') }}"
           class="sidebar-item sidebar-item--destructive"
           data-sidebar-item-label="Déconnexion">
            <i data-lucide="log-out" width="16" height="16" class="sidebar-item-icon" aria-hidden="true"></i>
            <span class="sidebar-item-label">Déconnexion</span>
        </a>
    </div>
</aside>

{% include 'components/sidebar_toggle_script.html.twig' %}
