{# @prop row App\Qse\Capa\ViewModel\CapaBoardRow #}
{%- props row -%}
{% set c = row.capa %}
{% set cid = c.id %}
<article
    class="capa-card-row group motion-card rounded-xl border border-border/80 bg-card p-4 sm:p-5 shadow-sm ring-1 ring-border/40 transition-all duration-300 hover:-translate-y-px hover:shadow-lg hover:ring-primary/15"
    aria-label="CAPA {{ c.title|e('html_attr') }}"
>
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:gap-6">
        <div class="min-w-0 flex-1 lg:max-w-[38%] space-y-2">
            <a href="{{ path('app_qse_capa_show', { id: cid }) }}" class="app-inline-link block text-base font-semibold text-foreground">
                {{ c.title }}
            </a>
            <p class="m-0 text-xs text-muted-foreground flex flex-wrap gap-2">
                <twig:Badge variant="outline" class="font-normal">{{ row.typeLabel }}</twig:Badge>
                {% if row.criticalityLabel %}
                    <twig:Badge variant="secondary" class="font-normal">{{ row.criticalityLabel }}</twig:Badge>
                {% endif %}
            </p>
            <dl class="grid grid-cols-1 gap-1 text-xs text-muted-foreground m-0">
                <div class="flex gap-2"><dt class="font-medium shrink-0">Origine</dt><dd class="m-0 truncate">{{ row.originName }}</dd></div>
                {% if c.responsible %}
                    <div class="flex gap-2"><dt class="font-medium shrink-0">Responsable</dt><dd class="m-0 truncate">{{ c.responsible }}</dd></div>
                {% endif %}
                {% if c.dueAt %}
                    <div class="flex gap-2"><dt class="font-medium shrink-0">Échéance</dt><dd class="m-0 tabular-nums">{{ c.dueAt|date('d/m/Y') }}</dd></div>
                {% endif %}
                {% if row.sourceLabel %}
                    <div class="flex gap-2"><dt class="font-medium shrink-0">Source</dt>
                        <dd class="m-0 truncate">
                            {% if row.sourceRoute %}
                                <a href="{{ path(row.sourceRoute, row.sourceRouteParams) }}" class="app-inline-link">{{ row.sourceLabel }}</a>
                            {% else %}
                                {{ row.sourceLabel }}
                            {% endif %}
                        </dd>
                    </div>
                {% endif %}
            </dl>
            <twig:CapaStatusBadge :status="row.status.value" :isOverdue="row.isOverdue" :isDueSoon="row.isDueSoon" />
        </div>

        <div class="flex-1 min-w-0 lg:max-w-[42%]">
            <twig:CapaWorkflowBar :step="row.workflowStep" :total="row.workflowTotal" />
        </div>

        <div class="flex items-center shrink-0 lg:justify-end">
            <twig:Button as="a" href="{{ path('app_qse_capa_show', { id: cid }) }}" variant="default" size="sm" class="no-underline w-full sm:w-auto">
                Ouvrir
            </twig:Button>
        </div>
    </div>
</article>
