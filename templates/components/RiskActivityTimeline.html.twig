{# @prop activity list<App\Qse\Dto\ActivityItem> #}
{%- props activity = [] -%}
<section class="risk-activity-timeline rounded-2xl overflow-hidden border border-border/80 bg-card shadow-sm ring-1 ring-border/40 mb-6" aria-labelledby="risk-activity-heading" data-controller="gsap-reveal">
    <header class="border-b border-border/30 bg-muted/10 px-4 py-3 sm:px-5 sm:py-4">
        <h2 id="risk-activity-heading" class="text-base font-semibold m-0 flex items-center gap-2">
            <twig:ux:icon name="lucide:clock" class="size-5 text-primary shrink-0" aria-hidden="true" />
            Dernières mises à jour
        </h2>
        <p class="text-xs text-muted-foreground m-0 mt-1">Activité récente sur vos fiches risques.</p>
    </header>
    {% if activity|length > 0 %}
        <ol class="relative m-0 p-4 sm:p-5 list-none space-y-0" role="list">
            {% for item in activity %}
                {% set toneRing = {
                    'sky': 'border-sky-500/40 bg-sky-500/10 text-sky-700 dark:text-sky-400',
                    'emerald': 'border-emerald-500/40 bg-emerald-500/10 text-emerald-700 dark:text-emerald-400',
                    'amber': 'border-amber-500/40 bg-amber-500/10 text-amber-700 dark:text-amber-400',
                    'destructive': 'border-rose-500/40 bg-rose-500/10 text-rose-700 dark:text-rose-400',
                }[item.tone] ?? 'border-border bg-muted/30 text-muted-foreground' %}
                <li class="relative flex gap-3 pb-6 last:pb-0 {% if not loop.last %}before:absolute before:left-[1.125rem] before:top-10 before:bottom-0 before:w-px before:bg-border/60{% endif %}">
                    <div class="relative z-[1] flex size-9 shrink-0 items-center justify-center rounded-full border {{ toneRing }}" aria-hidden="true">
                        <twig:ux:icon name="{{ item.icon }}" class="size-4" />
                    </div>
                    <div class="min-w-0 flex-1 pt-0.5">
                        <p class="m-0 text-sm font-medium text-foreground">{{ item.label }}</p>
                        <p class="m-0 mt-0.5 text-sm text-muted-foreground truncate" title="{{ item.description }}">{{ item.description }}</p>
                        <p class="m-0 mt-1 text-xs text-muted-foreground">
                            <time datetime="{{ item.occurredAt|date('c') }}">{{ item.occurredAt|time_ago }}</time>
                        </p>
                        {% if item.routeName %}
                            <twig:Button as="a" href="{{ path(item.routeName, item.routeParams) }}" variant="ghost" size="sm" class="mt-2 h-8 px-2 text-xs no-underline">
                                Voir
                            </twig:Button>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ol>
    {% else %}
        <twig:Empty class="py-8 px-4">
            <twig:Empty:Title>Aucune activité récente</twig:Empty:Title>
            <twig:Empty:Description>Les créations et mises à jour de risques apparaîtront ici.</twig:Empty:Description>
        </twig:Empty>
    {% endif %}
</section>
