{% if app.user %}
<aside class="bg-white border-r border-border fixed top-0 left-0 h-screen w-[280px] z-[1020] pt-[76px] overflow-y-auto shadow-[2px_0_8px_rgba(0,0,0,0.1)]">
    <div class="p-4">
        <!-- Profil utilisateur -->
        <div class="mb-6 pb-4 border-b border-border">
            <div class="flex items-center mb-2">
                <div class="bg-primary text-primary-foreground rounded-full flex items-center justify-center mr-2 shrink-0" style="width: 40px; height: 40px;">
                    <i data-lucide="user" width="20" height="20"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="font-semibold truncate">{{ app.user.email }}</div>
                    <div class="text-sm text-muted-foreground">Connecté</div>
                </div>
            </div>
        </div>

        <!-- Menu de navigation -->
        <nav class="sidebar-nav">
            <ul class="list-none m-0 p-0">
                <li class="mb-2">
                    <a href="{{ path('app_home_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_home_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="home" width="18" height="18" class="mr-2"></i>
                        <span>Accueil</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="{{ path('app_ishikawa_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_ishikawa_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="git-branch" width="18" height="18" class="mr-2"></i>
                        <span>Analyse des causes</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="{{ path('app_fivewhy_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_fivewhy_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="help-circle" width="18" height="18" class="mr-2"></i>
                        <span>Méthode 5 Pourquoi</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="{{ path('app_qqoqccp_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_qqoqccp_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="list-checks" width="18" height="18" class="mr-2"></i>
                        <span>Analyse QQOQCCP</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="{{ path('app_amdec_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_amdec_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="alert-triangle" width="18" height="18" class="mr-2"></i>
                        <span>Analyse AMDEC</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="{{ path('app_pareto_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_pareto_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="bar-chart-2" width="18" height="18" class="mr-2"></i>
                        <span>Diagramme Pareto</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="{{ path('app_eightd_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_eightd_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="layers" width="18" height="18" class="mr-2"></i>
                        <span>Méthode 8D</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="{{ path('app_outils_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_outils_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="tool-case" width="18" height="18" class="mr-2"></i>
                        <span>Outils</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="{{ path('app_creations_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_creations_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="file-text" width="18" height="18" class="mr-2"></i>
                        <span>Mes créations</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="{{ path('app_blog_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_blog_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="book-open" width="18" height="18" class="mr-2"></i>
                        <span>Blog</span>
                    </a>
                </li>
                <li class="mb-2">
                    <a href="{{ path('app_contact_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_contact_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="mail" width="18" height="18" class="mr-2"></i>
                        <span>Contact</span>
                    </a>
                </li>
                {% if is_granted('ROLE_ADMIN') %}
                <li class="mb-2 mt-6 pt-4 border-t border-border">
                    <a href="{{ path('app_admin_dashboard_index') }}" class="flex items-center px-3 py-2 no-underline rounded transition-colors {% if app.request.get('_route') == 'app_admin_dashboard_index' %}bg-primary text-primary-foreground{% else %}text-foreground hover:bg-accent{% endif %}">
                        <i data-lucide="shield" width="18" height="18" class="mr-2"></i>
                        <span>Administration</span>
                    </a>
                </li>
                {% endif %}
                <li class="mb-2 mt-6 pt-4 border-t border-border">
                    <a href="{{ path('app_logout') }}" class="flex items-center px-3 py-2 no-underline rounded text-destructive hover:bg-destructive/10 transition-colors">
                        <i data-lucide="log-out" width="18" height="18" class="mr-2"></i>
                        <span>Déconnexion</span>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</aside>

{% endif %}
