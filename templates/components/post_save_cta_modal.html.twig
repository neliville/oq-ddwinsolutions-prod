<div data-controller="post-save-cta">
    <div class="fixed inset-0 z-[1050] flex items-center justify-center p-4"
         id="postSaveCtaModal"
         tabindex="-1"
         aria-labelledby="postSaveCtaModalLabel"
         aria-hidden="true"
         aria-modal="true"
         role="dialog"
         style="display: none;"
         {{ stimulus_controller('app-modal', { autoShow: false }) }}
         data-turbo="false">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md" role="document">
            <div class="flex justify-end px-4 pt-4">
                <twig:Button variant="ghost" size="icon" type="button" data-action="app-modal#hide" aria-label="Fermer" class="shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </twig:Button>
            </div>
            <div class="text-center px-6 pb-2">
                <div class="inline-flex items-center justify-center bg-green-100 text-green-600 rounded-xl p-3 mb-3">
                    <i data-lucide="check-circle" width="28" height="28"></i>
                </div>
                <h2 class="text-lg font-bold mb-1">Analyse sauvegardée !</h2>
                <p class="text-muted-foreground text-sm mb-0" data-post-save-cta-analysis-name></p>
            </div>
            <div class="flex flex-col gap-2 px-6 pb-6 pt-4">
                <twig:Button as="a" href="{{ path('app_creations_index') }}" variant="default" class="no-underline w-full px-4 py-2 font-medium">
                    <i data-lucide="folder-open" width="15" height="15" class="mr-1" aria-hidden="true"></i>
                    Voir toutes mes analyses
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_ressources_index') }}" variant="outline" class="no-underline w-full px-4 py-2 font-medium">
                    <i data-lucide="package-open" width="15" height="15" class="mr-1" aria-hidden="true"></i>
                    Découvrir les ressources QSE
                </twig:Button>
                <twig:Button variant="link" type="button" data-action="app-modal#hide" class="mt-1 text-sm text-muted-foreground h-auto p-0 py-1">
                    Continuer à éditer
                </twig:Button>
            </div>
        </div>
    </div>
</div>
