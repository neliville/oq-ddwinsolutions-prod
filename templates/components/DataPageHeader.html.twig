{# @prop title string Titre principal de la page #}
{# @prop description string|null Sous-titre optionnel #}
{# @block breadcrumbs Fil d’Ariane ou métadonnées au-dessus du titre #}
{# @block actions Boutons / liens à droite (desktop) ou sous le titre #}
{%- props
    title = '',
    description = null,
-%}
<header
    class="{{ ('mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between ' ~ attributes.render('class'))|tailwind_merge }}"
    {{ attributes }}
>
    <div class="min-w-0 flex-1">
        {%- block breadcrumbs %}{% endblock -%}
        <h1 class="m-0 mb-1 text-2xl font-bold tracking-tight text-foreground">{{ title }}</h1>
        {% if description %}
            <p class="m-0 text-sm text-muted-foreground">{{ description }}</p>
        {% endif %}
    </div>
    <div class="flex w-full shrink-0 flex-col gap-2 sm:w-auto sm:flex-row sm:flex-wrap sm:items-center sm:justify-end">
        {%- block actions %}{% endblock -%}
    </div>
</header>
