{# Modal de confirmation de suppression réutilisable (élément <dialog> natif) #}
{# Usage:
  <div data-controller="dialog delete-confirmation">
    <button
      data-action="click->dialog#open"
      data-dialog-url-value="/api/delete/123"
      data-dialog-message-value="Message personnalisé"
    >
      Supprimer
    </button>
    {% include 'components/delete-confirmation-modal.html.twig' %}
  </div>
#}
<div>
    <dialog data-dialog-target="dialog"
            class="p-0 border-0 rounded-xl shadow-2xl bg-transparent overflow-hidden w-[min(500px,90vw)] backdrop:bg-black/50 backdrop:backdrop-blur-sm">
        <div class="flex flex-col bg-white rounded-xl overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 border-b border-border">
                <h5 class="flex items-center font-semibold text-foreground text-base m-0">
                    <i data-lucide="alert-triangle" width="24" height="24" class="text-yellow-500 mr-2 shrink-0"></i>
                    Confirmation de suppression
                </h5>
                <twig:Button variant="ghost" size="icon" type="button" data-action="dialog#close" aria-label="Fermer" class="shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </twig:Button>
            </div>
            <div class="px-6 py-4">
                <p data-dialog-target="message" class="text-foreground m-0">Êtes-vous sûr de vouloir supprimer cet élément ? Cette action est irréversible.</p>
            </div>
            <div class="flex items-center justify-end gap-2 px-6 py-4 border-t border-border">
                <twig:Button variant="outline" type="button" data-action="dialog#close">Annuler</twig:Button>
                <twig:Button variant="destructive" type="button" data-action="click->delete-confirmation#onConfirmed">
                    <i data-lucide="trash-2" width="18" height="18" class="mr-1" aria-hidden="true"></i>
                    Supprimer
                </twig:Button>
            </div>
        </div>
    </dialog>
</div>
