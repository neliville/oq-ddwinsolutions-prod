{# @prop showCloseButton boolean Whether to display the close button in the top-right corner. Defaults to `true` #}
{# @prop closeOnBackdrop boolean Close when clicking the backdrop. Defaults to `true` #}
{# @prop closeOnEscape boolean Close on Escape. Defaults to `true` #}
{# Classe utilitaire `onboarding-mandatory-dialog` sur le Content : pas de fermeture X / backdrop / Échap (onboarding bloquant). #}
{# @block content The dialog content, typically includes `Dialog:Header` and optionally `Dialog:Footer` #}
{%- props showCloseButton = true, closeOnBackdrop = true, closeOnEscape = true -%}
{%- set _mergedClass = ('text-foreground bg-background fixed top-[50%] left-[50%] z-50 max-w-[calc(100%-2rem)] translate-x-[-50%] translate-y-[-50%] scale-95 gap-4 rounded-lg border p-6 opacity-0 shadow-lg transition-all transition-discrete duration-200 backdrop:transition-discrete backdrop:duration-150 open:grid open:scale-100 open:opacity-100 open:backdrop:bg-black/50 sm:max-w-lg starting:open:scale-95 starting:open:opacity-0 ' ~ attributes.render('class'))|tailwind_merge -%}
{%- if 'onboarding-mandatory-dialog' in _mergedClass -%}
    {%- set showCloseButton = false -%}
    {%- set closeOnBackdrop = false -%}
    {%- set closeOnEscape = false -%}
{%- endif -%}
{%- set dialog_actions = [] -%}
{%- if closeOnEscape -%}
    {%- set dialog_actions = dialog_actions|merge(['keydown.esc->ux-dialog#close:prevent']) -%}
{%- endif -%}
{%- if closeOnBackdrop -%}
    {%- set dialog_actions = dialog_actions|merge(['click->ux-dialog#closeOnClickOutside']) -%}
{%- endif -%}

<dialog
    id="{{ _dialog_id }}"
    class="{{ _mergedClass }}"
    data-ux-dialog-target="dialog"
    {% if dialog_actions|length > 0 %}data-action="{{ dialog_actions|join(' ') }}"{% endif %}
>
    {%- block content %}{% endblock -%}
    {% if showCloseButton %}
        <button type="button" class="ring-offset-background focus:ring-ring absolute top-4 right-4 rounded-xs opacity-70 transition-opacity hover:opacity-100 focus:ring-2 focus:ring-offset-2 focus:outline-hidden disabled:pointer-events-none [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4" data-action="click->ux-dialog#close">
            <twig:ux:icon name="lucide:x" />
            <span class="sr-only">Close</span>
        </button>
    {% endif %}
</dialog>
