{# Panneau aide sidebar (fond zinc) — @param entry App\Help\HelpEntry #}
{% if entry.badge %}
    <span class="mb-1.5 inline-block rounded px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-zinc-400 ring-1 ring-zinc-600">{{ entry.badge }}</span>
{% endif %}
<span class="block font-semibold leading-tight text-zinc-50">{{ entry.title }}</span>
<p class="mt-1.5 mb-0 text-[11px] leading-snug font-normal text-zinc-300">{{ entry.description }}</p>
{% if entry.example %}
    <p class="mt-1.5 mb-0 text-[10px] leading-snug italic text-zinc-400">{{ entry.example }}</p>
{% endif %}
{% if entry.learnMoreUrl %}
    <a href="{{ entry.learnMoreUrl }}" class="mt-2 inline-flex text-[11px] font-medium text-zinc-200 underline underline-offset-2 hover:text-white">
        En savoir plus
    </a>
{% endif %}
