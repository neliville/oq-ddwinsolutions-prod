{% if app.user %}
{% set currentRoute = app.request.get('_route') %}

{# Sidebar utilisateur (cockpit QSE / outils) — ne pas confondre avec /admin (voir admin_cockpit_sidebar). #}
<aside id="app-dashboard-sidebar" class="admin-sidebar" data-controller="sidebar-interaction">

    <nav class="sidebar-nav" aria-label="Navigation espace connecté">

        <div class="sidebar-section">
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_dashboard_index'),
                route_prefix: 'app_dashboard',
                icon: 'layout-dashboard',
                label: 'Tableau de bord',
                help_id: 'help.nav.dashboard',
            } %}
        </div>

        <div class="sidebar-section">
            <div class="sidebar-section-label">Mes Outils</div>
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_ishikawa_index'),
                route_prefix: 'app_ishikawa',
                icon: 'git-branch',
                label: 'Analyse des causes',
                help_id: 'help.nav.tool.ishikawa',
            } %}
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_fivewhy_index'),
                route_prefix: 'app_fivewhy',
                icon: 'help-circle',
                label: 'Méthode 5 Pourquoi',
                help_id: 'help.nav.tool.five_why',
            } %}
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_qqoqccp_index'),
                route_prefix: 'app_qqoqccp',
                icon: 'list-checks',
                label: 'Analyse QQOQCCP',
                help_id: 'help.nav.tool.qqoqccp',
            } %}
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_amdec_index'),
                route_prefix: 'app_amdec',
                icon: 'alert-triangle',
                label: 'Analyse AMDEC',
                help_id: 'help.nav.tool.amdec',
            } %}
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_pareto_index'),
                route_prefix: 'app_pareto',
                icon: 'bar-chart-2',
                label: 'Diagramme Pareto',
                help_id: 'help.nav.tool.pareto',
            } %}
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_eightd_index'),
                route_prefix: 'app_eightd',
                icon: 'layers',
                label: 'Méthode 8D',
                help_id: 'help.nav.tool.eightd',
            } %}
        </div>

        <div class="sidebar-section">
            <div class="sidebar-section-label">Pilotage QSE</div>
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_qse_pdca_index'),
                route_prefix: 'app_qse_pdca',
                icon: 'layout-grid',
                label: 'Cockpit PDCA',
                help_id: 'help.nav.pdca',
            } %}
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_qse_audit_index'),
                route_prefix: 'app_qse_audit',
                icon: 'clipboard-check',
                label: 'Audits ISO',
                help_id: 'help.nav.audit',
            } %}
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_qse_capa_index'),
                route_prefix: 'app_qse_capa',
                icon: 'target',
                label: 'CAPA',
                help_id: 'help.nav.capa',
            } %}
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_qse_risk_index'),
                route_prefix: 'app_qse_risk',
                icon: 'shield-alert',
                label: 'Risques',
                help_id: 'help.nav.risk',
            } %}
        </div>

        <div class="sidebar-section">
            <div class="sidebar-section-label">Mes Contenus</div>
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_creations_index'),
                route_prefix: 'app_creations',
                icon: 'file-text',
                label: 'Mes créations',
                help_id: 'help.nav.creations',
            } %}
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_blog_index'),
                route_prefix: 'app_blog',
                icon: 'book-open',
                label: 'Blog',
                help_id: 'help.nav.blog',
            } %}
        </div>

        <div class="sidebar-section">
            <div class="sidebar-section-label">Mon compte</div>
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_profile_index'),
                route_prefix: 'app_profile',
                icon: 'user',
                label: 'Mon profil',
                help_id: 'help.nav.profile',
            } %}
            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_preferences_index'),
                route_prefix: 'app_preferences',
                icon: 'settings',
                label: 'Préférences',
                help_id: 'help.nav.preferences',
            } %}
        </div>

        {% if is_granted('ROLE_ADMIN') %}
        <div class="sidebar-section">
            <div class="sidebar-section-label">Administration</div>

            {% include 'components/admin_sidebar_nav_link.html.twig' with {
                href: path('app_admin_dashboard_index'),
                route_prefix: 'app_admin_dashboard',
                icon: 'shield',
                label: 'Tableau de bord',
                help_id: 'help.nav.admin.dashboard',
            } %}

            {% set isAdminUsersRoute = currentRoute starts with 'app_admin_users' %}
            {% include 'components/admin_sidebar_nav_button.html.twig' with {
                is_active: isAdminUsersRoute,
                target: '#adminUsersMenu',
                expanded: isAdminUsersRoute,
                controls: 'adminUsersMenu',
                icon: 'users',
                label: 'Utilisateurs',
                help_id: 'help.nav.admin.users',
            } %}
            <div class="collapse sidebar-submenu {{ isAdminUsersRoute ? 'show' : '' }}" id="adminUsersMenu">
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_users_index'),
                    route_prefix: 'app_admin_users',
                    label: 'Liste des utilisateurs',
                    help_id: 'help.nav.admin.users.list',
                } %}
            </div>

            {% set isAdminPostsRoute = currentRoute starts with 'app_admin_blog' or currentRoute starts with 'app_admin_categories' or currentRoute starts with 'app_admin_tags' %}
            {% include 'components/admin_sidebar_nav_button.html.twig' with {
                is_active: isAdminPostsRoute,
                target: '#adminPostsMenu',
                expanded: isAdminPostsRoute,
                controls: 'adminPostsMenu',
                icon: 'file-text',
                label: 'Articles Blog',
                help_id: 'help.nav.admin.blog',
            } %}
            <div class="collapse sidebar-submenu {{ isAdminPostsRoute ? 'show' : '' }}" id="adminPostsMenu">
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_blog_index'),
                    route_prefix: 'app_admin_blog',
                    label: 'Liste des articles',
                    help_id: 'help.nav.admin.blog.list',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_blog_new'),
                    route_prefix: 'app_admin_blog_new',
                    label: 'Nouvel article',
                    help_id: 'help.nav.admin.blog.new',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_categories_index'),
                    route_prefix: 'app_admin_categories',
                    label: 'Catégories',
                    help_id: 'help.nav.admin.categories',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_tags_index'),
                    route_prefix: 'app_admin_tags',
                    label: 'Tags',
                    help_id: 'help.nav.admin.tags',
                } %}
            </div>

            {% set isAdminMessagesRoute = currentRoute starts with 'app_admin_contact' or currentRoute starts with 'app_admin_newsletter' or currentRoute starts with 'app_admin_leads' %}
            {% include 'components/admin_sidebar_nav_button.html.twig' with {
                is_active: isAdminMessagesRoute,
                target: '#adminMessagesMenu',
                expanded: isAdminMessagesRoute,
                controls: 'adminMessagesMenu',
                icon: 'mail',
                label: 'Messages',
                help_id: 'help.nav.admin.messages',
            } %}
            <div class="collapse sidebar-submenu {{ isAdminMessagesRoute ? 'show' : '' }}" id="adminMessagesMenu">
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_contact_index'),
                    route_prefix: 'app_admin_contact',
                    label: 'Messages de contact',
                    help_id: 'help.nav.admin.contact',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_newsletter_index'),
                    route_prefix: 'app_admin_newsletter',
                    label: 'Newsletter',
                    help_id: 'help.nav.admin.newsletter',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_leads_index'),
                    route_prefix: 'app_admin_leads',
                    label: 'Leads',
                    help_id: 'help.nav.admin.leads',
                } %}
            </div>

            {% set isCmsRoute = currentRoute starts with 'app_admin_cms' %}
            {% set currentCmsSlug = app.request.attributes.get('slug') %}
            {% include 'components/admin_sidebar_nav_button.html.twig' with {
                is_active: isCmsRoute,
                target: '#adminCmsMenu',
                expanded: isCmsRoute,
                controls: 'adminCmsMenu',
                icon: 'file-cog',
                label: 'CMS',
                help_id: 'help.nav.admin.cms',
            } %}
            <div class="collapse sidebar-submenu {{ isCmsRoute ? 'show' : '' }}" id="adminCmsMenu">
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_cms_edit', { slug: 'privacy-policy' }),
                    route_prefix: 'app_admin_cms',
                    active_if: isCmsRoute and currentCmsSlug == 'privacy-policy',
                    label: 'Politique de confidentialité',
                    help_id: 'help.nav.admin.cms.privacy',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_cms_edit', { slug: 'terms-of-use' }),
                    route_prefix: 'app_admin_cms',
                    active_if: isCmsRoute and currentCmsSlug == 'terms-of-use',
                    label: "Conditions d'utilisation",
                    help_id: 'help.nav.admin.cms.terms',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_cms_edit', { slug: 'legal-notice' }),
                    route_prefix: 'app_admin_cms',
                    active_if: isCmsRoute and currentCmsSlug == 'legal-notice',
                    label: 'Mentions légales',
                    help_id: 'help.nav.admin.cms.legal',
                } %}
            </div>

            {% set isStatsRoute = currentRoute starts with 'app_admin_analytics_' or currentRoute starts with 'app_admin_export_analytics' or currentRoute starts with 'app_admin_tool_usage' or currentRoute == 'app_admin_logs_index' %}
            {% include 'components/admin_sidebar_nav_button.html.twig' with {
                is_active: isStatsRoute,
                target: '#adminStatsMenu',
                expanded: isStatsRoute,
                controls: 'adminStatsMenu',
                icon: 'bar-chart',
                label: 'Statistiques',
                help_id: 'help.nav.admin.stats',
            } %}
            <div class="collapse sidebar-submenu {{ isStatsRoute ? 'show' : '' }}" id="adminStatsMenu">
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_analytics_index'),
                    route_prefix: 'app_admin_analytics_index',
                    active_if: currentRoute == 'app_admin_analytics_index',
                    label: 'Synthèse',
                    help_id: 'help.nav.admin.stats.summary',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_analytics_traffic'),
                    route_prefix: 'app_admin_analytics_traffic',
                    active_if: currentRoute == 'app_admin_analytics_traffic',
                    label: 'Trafic & audiences',
                    help_id: 'help.nav.admin.stats.traffic',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_analytics_sharing'),
                    route_prefix: 'app_admin_analytics_sharing',
                    active_if: currentRoute == 'app_admin_analytics_sharing',
                    label: 'Partages Ishikawa',
                    help_id: 'help.nav.admin.stats.sharing',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_export_analytics_index'),
                    route_prefix: 'app_admin_export_analytics',
                    label: 'Exports (fichiers)',
                    help_id: 'help.nav.admin.stats.exports',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_tool_usage_index'),
                    route_prefix: 'app_admin_tool_usage',
                    label: 'Outils & créations',
                    help_id: 'help.nav.admin.stats.tools',
                } %}
                {% include 'components/admin_sidebar_subnav_link.html.twig' with {
                    href: path('app_admin_logs_index'),
                    route_prefix: 'app_admin_logs_index',
                    active_if: currentRoute == 'app_admin_logs_index',
                    label: 'Logs d\'administration',
                    help_id: 'help.nav.admin.stats.logs',
                } %}
            </div>
        </div>
        {% endif %}

    </nav>

    {% if is_granted('ROLE_ADMIN') %}
    <div class="sidebar-footer">
        <div class="sidebar-version">
            <div class="sidebar-version-row">
                <span class="sidebar-version-label">
                    <i data-lucide="git-branch" width="10" height="10" aria-hidden="true"></i>
                    Version
                </span>
                <span class="sidebar-version-badge">{{ app_short_hash() ?: 'dev' }}</span>
            </div>
            {% if app_commit_date() %}
            <div class="sidebar-version-date">
                <i data-lucide="clock" width="10" height="10" aria-hidden="true"></i>
                {{ app_commit_date()|date('d/m/Y à H:i') }}
            </div>
            {% endif %}
            {% if app_commit_message() %}
            <div class="sidebar-version-msg" title="{{ app_commit_message() }}">{{ app_commit_message() }}</div>
            {% endif %}
        </div>
    </div>
    {% endif %}
</aside>

{% include 'components/sidebar_toggle_script.html.twig' %}
{% endif %}
