<div class="fixed inset-0 z-[1050] flex items-center justify-center p-4"
     id="onboardingModal"
     tabindex="-1"
     aria-labelledby="onboardingModalLabel"
     aria-hidden="true"
     aria-modal="true"
     role="dialog"
     style="display: none;"
     {{ stimulus_controller('bootstrap-modal', { autoShow: true }) }}
     data-turbo="false">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg" role="document">

        <div class="p-10 text-center">
            <div class="inline-flex items-center justify-center bg-primary/10 text-primary rounded-xl p-3 mb-4">
                <i data-lucide="rocket" width="30" height="30"></i>
            </div>

            <h1 class="text-xl font-bold mb-2" id="onboardingModalLabel">
                Bienvenue, {{ app.user.firstName ?? app.user.email }} !
            </h1>
            <p class="text-muted-foreground mb-4">
                Votre espace QSE est prêt. En 3 étapes, créez votre première analyse.
            </p>

            <ol class="list-none text-left mb-4 flex flex-col gap-3 p-0">
                <li class="flex items-start gap-3">
                    <span class="inline-flex items-center justify-center rounded-full bg-primary text-primary-foreground text-sm font-bold shrink-0" style="width:28px;height:28px;">1</span>
                    <div>
                        <div class="font-semibold text-sm">Choisissez un outil</div>
                        <div class="text-muted-foreground text-sm">Ishikawa, 5 Pourquoi, AMDEC, Pareto ou 8D</div>
                    </div>
                </li>
                <li class="flex items-start gap-3">
                    <span class="inline-flex items-center justify-center rounded-full bg-primary text-primary-foreground text-sm font-bold shrink-0" style="width:28px;height:28px;">2</span>
                    <div>
                        <div class="font-semibold text-sm">Remplissez votre analyse</div>
                        <div class="text-muted-foreground text-sm">L'outil vous guide pas à pas, tout se sauvegarde automatiquement</div>
                    </div>
                </li>
                <li class="flex items-start gap-3">
                    <span class="inline-flex items-center justify-center rounded-full bg-primary text-primary-foreground text-sm font-bold shrink-0" style="width:28px;height:28px;">3</span>
                    <div>
                        <div class="font-semibold text-sm">Exportez en PDF</div>
                        <div class="text-muted-foreground text-sm">Partagez avec votre équipe ou intégrez-le à vos rapports qualité</div>
                    </div>
                </li>
            </ol>

            <a href="{{ path('app_outils_index') }}"
               class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity w-full mb-2 no-underline"
               data-action="bootstrap-modal#hide">
                <i data-lucide="zap" width="15" height="15" class="mr-1"></i>
                Créer ma première analyse
            </a>
            <button type="button"
                    class="text-sm text-muted-foreground p-0 bg-transparent border-none cursor-pointer hover:text-foreground transition-colors"
                    data-action="bootstrap-modal#hide">
                Explorer le tableau de bord d'abord
            </button>
        </div>

    </div>
</div>
