<header class="dashboard-topbar shadow-sm border-b border-border/60 bg-card" aria-label="En-tête administration">
    <div class="w-full px-4 dashboard-topbar__pad">
        <div class="dashboard-topbar__inner flex items-center justify-between gap-3 flex-wrap">
            <div class="flex items-center gap-2 sm:gap-3 min-w-0">
                <button class="sidebar-toggle-btn dashboard-desktop-sidebar-toggle hidden lg:inline-flex shrink-0" type="button"
                        id="sidebarToggle" aria-label="Afficher la navigation" aria-expanded="true"
                        aria-controls="app-dashboard-sidebar">
                    <i data-lucide="panel-left" width="18" height="18" aria-hidden="true"></i>
                    <span class="sidebar-toggle-label ml-1">Masquer la navigation</span>
                </button>
                <button type="button"
                        id="sidebarToggleMobile"
                        class="dashboard-mobile-menu-btn navbar-icon-btn shrink-0 lg:hidden"
                        aria-controls="app-dashboard-sidebar"
                        aria-expanded="false"
                        aria-label="Afficher la navigation">
                    <i data-lucide="menu" width="22" height="22" aria-hidden="true"></i>
                </button>
                <a class="dashboard-topbar__brand flex items-center min-w-0 no-underline text-foreground" href="{{ path('app_admin_dashboard_index') }}">
                    <img src="{{ asset('img/logo.webp') }}" alt="" width="36" height="36" class="mr-2 shrink-0" role="presentation">
                    <span class="font-bold truncate">Administration</span>
                </a>
                <span class="hidden sm:inline text-xs text-muted-foreground truncate">OUTILS-QUALITÉ</span>
            </div>
            {% if is_granted('ROLE_ADMIN') %}
            <div class="flex items-center gap-2 shrink-0">
                <twig:Button as="a" href="{{ path('app_dashboard_index') }}" variant="outline" size="sm" class="no-underline">
                    Vue utilisateur
                </twig:Button>
            </div>
            {% endif %}
        </div>
    </div>
</header>
