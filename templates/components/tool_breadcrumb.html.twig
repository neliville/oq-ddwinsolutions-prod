{# Fil d'Ariane pour les pages d'outils. Variables : tool_name (string), optionnel : tool_route #}
<nav aria-label="Fil d'Ariane" class="mb-3 md:mb-4">
    <ol class="flex flex-wrap items-center gap-1 text-sm text-muted-foreground list-none p-0 m-0">
        <li class="flex items-center gap-1">
            <a href="{{ path('app_home_index') }}" class="hover:text-foreground transition-colors no-underline">Accueil</a>
        </li>
        <li class="flex items-center gap-1">
            <i data-lucide="chevron-right" width="14" height="14" class="shrink-0" aria-hidden="true"></i>
            <a href="{{ path('app_outils_index') }}" class="hover:text-foreground transition-colors no-underline">Outils</a>
        </li>
        <li class="flex items-center gap-1 text-foreground font-medium" aria-current="page">
            <i data-lucide="chevron-right" width="14" height="14" class="shrink-0" aria-hidden="true"></i>
            {{ tool_name|default('Outil') }}
        </li>
    </ol>
</nav>
