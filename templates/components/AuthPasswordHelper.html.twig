{# @prop showCompromised bool Affiche la règle « non compromis » (reset password) #}
{%- props showCompromised = false -%}
<div class="auth-password-strength" data-password-strength-target="helper">
    <div class="auth-password-strength__track" aria-hidden="true">
        <div class="auth-password-strength__bar" data-password-strength-target="bar"></div>
    </div>
    <div class="auth-password-strength__meta">
        <span class="font-medium text-foreground text-sm">Votre mot de passe doit contenir :</span>
        <span class="auth-password-strength__label" data-password-strength-target="label" aria-live="polite"></span>
    </div>
    <ul class="auth-password-rules" role="list">
        <li class="auth-password-rule" data-password-strength-target="rule" data-rule="length" role="listitem" aria-checked="false">
            Au moins 8 caractères
        </li>
        <li class="auth-password-rule" data-password-strength-target="rule" data-rule="lower" role="listitem" aria-checked="false">
            Une lettre minuscule
        </li>
        <li class="auth-password-rule" data-password-strength-target="rule" data-rule="upper" role="listitem" aria-checked="false">
            Une lettre majuscule
        </li>
        <li class="auth-password-rule" data-password-strength-target="rule" data-rule="digit" role="listitem" aria-checked="false">
            Un chiffre
        </li>
        {% if showCompromised %}
            <li class="auth-password-rule auth-password-rule--info" role="listitem">
                Un mot de passe non compromis (vérification automatique)
            </li>
        {% endif %}
    </ul>
</div>
