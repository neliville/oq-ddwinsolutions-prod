{% if app.user %}
{% set currentRoute = app.request.get('_route') %}

<aside class="admin-sidebar" aria-label="Navigation principale">

    {# Brand #}
    <div class="sidebar-brand">
        <img src="{{ asset('img/logo.webp') }}" alt="OUTILS-QUALITÉ" width="28" height="28">
        <span class="sidebar-brand-name">Dashboard</span>
    </div>

    {# Navigation #}
    <nav class="sidebar-nav">

        {# Tableau de bord #}
        <div class="sidebar-section">
            <a href="{{ path('app_dashboard_index') }}"
               class="sidebar-item {{ currentRoute starts with 'app_dashboard' ? 'active' : '' }}"
               {% if currentRoute starts with 'app_dashboard' %}aria-current="page"{% endif %}>
                <i data-lucide="layout-dashboard" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Tableau de bord</span>
            </a>
        </div>

        {# Mes Outils #}
        <div class="sidebar-section">
            <div class="sidebar-section-label">Mes Outils</div>
            <a href="{{ path('app_ishikawa_index') }}"
               class="sidebar-item {{ currentRoute starts with 'app_ishikawa' ? 'active' : '' }}"
               {% if currentRoute starts with 'app_ishikawa' %}aria-current="page"{% endif %}>
                <i data-lucide="git-branch" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Analyse des causes</span>
            </a>
            <a href="{{ path('app_fivewhy_index') }}"
               class="sidebar-item {{ currentRoute starts with 'app_fivewhy' ? 'active' : '' }}"
               {% if currentRoute starts with 'app_fivewhy' %}aria-current="page"{% endif %}>
                <i data-lucide="help-circle" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Méthode 5 Pourquoi</span>
            </a>
            <a href="{{ path('app_qqoqccp_index') }}"
               class="sidebar-item {{ currentRoute starts with 'app_qqoqccp' ? 'active' : '' }}"
               {% if currentRoute starts with 'app_qqoqccp' %}aria-current="page"{% endif %}>
                <i data-lucide="list-checks" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Analyse QQOQCCP</span>
            </a>
            <a href="{{ path('app_amdec_index') }}"
               class="sidebar-item {{ currentRoute starts with 'app_amdec' ? 'active' : '' }}"
               {% if currentRoute starts with 'app_amdec' %}aria-current="page"{% endif %}>
                <i data-lucide="alert-triangle" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Analyse AMDEC</span>
            </a>
            <a href="{{ path('app_pareto_index') }}"
               class="sidebar-item {{ currentRoute starts with 'app_pareto' ? 'active' : '' }}"
               {% if currentRoute starts with 'app_pareto' %}aria-current="page"{% endif %}>
                <i data-lucide="bar-chart-2" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Diagramme Pareto</span>
            </a>
            <a href="{{ path('app_eightd_index') }}"
               class="sidebar-item {{ currentRoute starts with 'app_eightd' ? 'active' : '' }}"
               {% if currentRoute starts with 'app_eightd' %}aria-current="page"{% endif %}>
                <i data-lucide="layers" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Méthode 8D</span>
            </a>
        </div>

        {# Mes Contenus #}
        <div class="sidebar-section">
            <div class="sidebar-section-label">Mes Contenus</div>
            <a href="{{ path('app_creations_index') }}"
               class="sidebar-item {{ currentRoute starts with 'app_creations' ? 'active' : '' }}"
               {% if currentRoute starts with 'app_creations' %}aria-current="page"{% endif %}>
                <i data-lucide="file-text" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Mes créations</span>
            </a>
            <a href="{{ path('app_blog_index') }}"
               class="sidebar-item {{ currentRoute starts with 'app_blog' ? 'active' : '' }}"
               {% if currentRoute starts with 'app_blog' %}aria-current="page"{% endif %}>
                <i data-lucide="book-open" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Blog</span>
            </a>
        </div>

        {# Administration (admins seulement) #}
        {% if is_granted('ROLE_ADMIN') %}
        <div class="sidebar-section">
            <div class="sidebar-section-label">Administration</div>

            <a href="{{ path('app_admin_dashboard_index') }}"
               class="sidebar-item {{ currentRoute starts with 'app_admin_dashboard' ? 'active' : '' }}"
               {% if currentRoute starts with 'app_admin_dashboard' %}aria-current="page"{% endif %}>
                <i data-lucide="shield" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Tableau de bord</span>
            </a>

            {# Utilisateurs #}
            {% set isAdminUsersRoute = currentRoute starts with 'app_admin_users' %}
            <button type="button"
                    class="sidebar-item sidebar-collapse-trigger {{ isAdminUsersRoute ? 'active' : '' }}"
                    data-sidebar-target="#adminUsersMenu"
                    aria-expanded="{{ isAdminUsersRoute ? 'true' : 'false' }}"
                    aria-controls="adminUsersMenu">
                <i data-lucide="users" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Utilisateurs</span>
                <i data-lucide="chevron-down" width="14" height="14" class="sidebar-chevron"></i>
            </button>
            <div class="collapse sidebar-submenu {{ isAdminUsersRoute ? 'show' : '' }}" id="adminUsersMenu">
                <a href="{{ path('app_admin_users_index') }}"
                   class="sidebar-subitem {{ currentRoute starts with 'app_admin_users' ? 'active' : '' }}">
                    Liste des utilisateurs
                </a>
            </div>

            {# Articles Blog #}
            {% set isAdminPostsRoute = currentRoute starts with 'app_admin_blog' or currentRoute starts with 'app_admin_categories' or currentRoute starts with 'app_admin_tags' %}
            <button type="button"
                    class="sidebar-item sidebar-collapse-trigger {{ isAdminPostsRoute ? 'active' : '' }}"
                    data-sidebar-target="#adminPostsMenu"
                    aria-expanded="{{ isAdminPostsRoute ? 'true' : 'false' }}"
                    aria-controls="adminPostsMenu">
                <i data-lucide="file-text" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Articles Blog</span>
                <i data-lucide="chevron-down" width="14" height="14" class="sidebar-chevron"></i>
            </button>
            <div class="collapse sidebar-submenu {{ isAdminPostsRoute ? 'show' : '' }}" id="adminPostsMenu">
                <a href="{{ path('app_admin_blog_index') }}"
                   class="sidebar-subitem {{ currentRoute starts with 'app_admin_blog' ? 'active' : '' }}">
                    Liste des articles
                </a>
                <a href="{{ path('app_admin_blog_new') }}"
                   class="sidebar-subitem {{ currentRoute == 'app_admin_blog_new' ? 'active' : '' }}">
                    Nouvel article
                </a>
                <a href="{{ path('app_admin_categories_index') }}"
                   class="sidebar-subitem {{ currentRoute starts with 'app_admin_categories' ? 'active' : '' }}">
                    Catégories
                </a>
                <a href="{{ path('app_admin_tags_index') }}"
                   class="sidebar-subitem {{ currentRoute starts with 'app_admin_tags' ? 'active' : '' }}">
                    Tags
                </a>
            </div>

            {# Messages #}
            {% set isAdminMessagesRoute = currentRoute starts with 'app_admin_contact' or currentRoute starts with 'app_admin_newsletter' or currentRoute starts with 'app_admin_leads' %}
            <button type="button"
                    class="sidebar-item sidebar-collapse-trigger {{ isAdminMessagesRoute ? 'active' : '' }}"
                    data-sidebar-target="#adminMessagesMenu"
                    aria-expanded="{{ isAdminMessagesRoute ? 'true' : 'false' }}"
                    aria-controls="adminMessagesMenu">
                <i data-lucide="mail" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Messages</span>
                <i data-lucide="chevron-down" width="14" height="14" class="sidebar-chevron"></i>
            </button>
            <div class="collapse sidebar-submenu {{ isAdminMessagesRoute ? 'show' : '' }}" id="adminMessagesMenu">
                <a href="{{ path('app_admin_contact_index') }}"
                   class="sidebar-subitem {{ currentRoute starts with 'app_admin_contact' ? 'active' : '' }}">
                    Messages de contact
                </a>
                <a href="{{ path('app_admin_newsletter_index') }}"
                   class="sidebar-subitem {{ currentRoute starts with 'app_admin_newsletter' ? 'active' : '' }}">
                    Newsletter
                </a>
                <a href="{{ path('app_admin_leads_index') }}"
                   class="sidebar-subitem {{ currentRoute starts with 'app_admin_leads' ? 'active' : '' }}">
                    Leads
                </a>
            </div>

            {# CMS #}
            {% set isCmsRoute = currentRoute starts with 'app_admin_cms' %}
            {% set currentCmsSlug = app.request.attributes.get('slug') %}
            <button type="button"
                    class="sidebar-item sidebar-collapse-trigger {{ isCmsRoute ? 'active' : '' }}"
                    data-sidebar-target="#adminCmsMenu"
                    aria-expanded="{{ isCmsRoute ? 'true' : 'false' }}"
                    aria-controls="adminCmsMenu">
                <i data-lucide="file-cog" width="16" height="16" class="sidebar-item-icon"></i>
                <span>CMS</span>
                <i data-lucide="chevron-down" width="14" height="14" class="sidebar-chevron"></i>
            </button>
            <div class="collapse sidebar-submenu {{ isCmsRoute ? 'show' : '' }}" id="adminCmsMenu">
                <a href="{{ path('app_admin_cms_edit', { slug: 'privacy-policy' }) }}"
                   class="sidebar-subitem {{ isCmsRoute and currentCmsSlug == 'privacy-policy' ? 'active' : '' }}">
                    Politique de confidentialité
                </a>
                <a href="{{ path('app_admin_cms_edit', { slug: 'terms-of-use' }) }}"
                   class="sidebar-subitem {{ isCmsRoute and currentCmsSlug == 'terms-of-use' ? 'active' : '' }}">
                    Conditions d'utilisation
                </a>
                <a href="{{ path('app_admin_cms_edit', { slug: 'legal-notice' }) }}"
                   class="sidebar-subitem {{ isCmsRoute and currentCmsSlug == 'legal-notice' ? 'active' : '' }}">
                    Mentions légales
                </a>
            </div>

            {# Statistiques #}
            {% set isStatsRoute = currentRoute starts with 'app_admin_analytics_' or currentRoute starts with 'app_admin_export_analytics' or currentRoute starts with 'app_admin_tool_usage' or currentRoute == 'app_admin_logs_index' %}
            <button type="button"
                    class="sidebar-item sidebar-collapse-trigger {{ isStatsRoute ? 'active' : '' }}"
                    data-sidebar-target="#adminStatsMenu"
                    aria-expanded="{{ isStatsRoute ? 'true' : 'false' }}"
                    aria-controls="adminStatsMenu">
                <i data-lucide="bar-chart" width="16" height="16" class="sidebar-item-icon"></i>
                <span>Statistiques</span>
                <i data-lucide="chevron-down" width="14" height="14" class="sidebar-chevron"></i>
            </button>
            <div class="collapse sidebar-submenu {{ isStatsRoute ? 'show' : '' }}" id="adminStatsMenu">
                <a href="{{ path('app_admin_analytics_index') }}"
                   class="sidebar-subitem {{ currentRoute == 'app_admin_analytics_index' ? 'active' : '' }}">
                    Synthèse
                </a>
                <a href="{{ path('app_admin_analytics_traffic') }}"
                   class="sidebar-subitem {{ currentRoute == 'app_admin_analytics_traffic' ? 'active' : '' }}">
                    Trafic &amp; audiences
                </a>
                <a href="{{ path('app_admin_analytics_sharing') }}"
                   class="sidebar-subitem {{ currentRoute == 'app_admin_analytics_sharing' ? 'active' : '' }}">
                    Partages Ishikawa
                </a>
                <a href="{{ path('app_admin_export_analytics_index') }}"
                   class="sidebar-subitem {{ currentRoute starts with 'app_admin_export_analytics' ? 'active' : '' }}">
                    Exports (fichiers)
                </a>
                <a href="{{ path('app_admin_tool_usage_index') }}"
                   class="sidebar-subitem {{ currentRoute starts with 'app_admin_tool_usage' ? 'active' : '' }}">
                    Outils &amp; créations
                </a>
                <a href="{{ path('app_admin_logs_index') }}"
                   class="sidebar-subitem {{ currentRoute == 'app_admin_logs_index' ? 'active' : '' }}">
                    Logs d'administration
                </a>
            </div>
        </div>
        {% endif %}

    </nav>

    {# Footer #}
    <div class="sidebar-footer">

        {% if is_granted('ROLE_ADMIN') %}
        <div class="sidebar-version">
            <div class="sidebar-version-row">
                <span class="sidebar-version-label">
                    <i data-lucide="git-branch" width="10" height="10"></i>
                    Version
                </span>
                <span class="sidebar-version-badge">{{ app_short_hash() ?: 'dev' }}</span>
            </div>
            {% if app_commit_date() %}
            <div class="sidebar-version-date">
                <i data-lucide="clock" width="10" height="10"></i>
                {{ app_commit_date()|date('d/m/Y à H:i') }}
            </div>
            {% endif %}
            {% if app_commit_message() %}
            <div class="sidebar-version-msg" title="{{ app_commit_message() }}">{{ app_commit_message() }}</div>
            {% endif %}
        </div>
        {% endif %}

        <div class="sidebar-user">
            <div class="sidebar-user-avatar" aria-hidden="true">{{ app.user.email|slice(0, 1)|upper }}</div>
            <div class="sidebar-user-info">
                <span class="sidebar-user-email">{{ app.user.email }}</span>
            </div>
            <div class="sidebar-user-actions">
                <a href="{{ path('app_profile_index') }}"
                   class="sidebar-icon-btn"
                   title="Mon profil"
                   aria-label="Mon profil">
                    <i data-lucide="settings" width="15" height="15"></i>
                </a>
                <a href="{{ path('app_logout') }}"
                   class="sidebar-icon-btn sidebar-icon-btn--danger"
                   title="Déconnexion"
                   aria-label="Se déconnecter">
                    <i data-lucide="log-out" width="15" height="15"></i>
                </a>
            </div>
        </div>

    </div>
</aside>

<script>
function initSidebar() {
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }

    const collapseTriggers = document.querySelectorAll('.sidebar-collapse-trigger');
    collapseTriggers.forEach((trigger) => {
        if (trigger.dataset.sidebarListenerAttached === 'true') return;
        trigger.dataset.sidebarListenerAttached = 'true';

        trigger.addEventListener('click', function (event) {
            event.preventDefault();

            const targetSelector = this.dataset.sidebarTarget;
            if (!targetSelector) return;

            const target = document.querySelector(targetSelector);
            if (!target) return;

            const isShown = target.classList.contains('show');
            target.classList.toggle('show');

            const chevron = this.querySelector('.sidebar-chevron');
            if (chevron) {
                chevron.style.transform = isShown ? 'rotate(0deg)' : 'rotate(180deg)';
            }

            this.setAttribute('aria-expanded', (!isShown).toString());
        });
    });

    const sidebarPrimaryToggle = document.getElementById('sidebarToggle');
    const sidebarMobileToggle = document.getElementById('sidebarToggleMobile');
    const sidebar = document.querySelector('.admin-sidebar');
    const sidebarOverlay = document.getElementById('sidebarOverlay');
    const sidebarToggleButtons = [sidebarPrimaryToggle, sidebarMobileToggle].filter(Boolean);

    if (sidebar && sidebarToggleButtons.length) {
        const isDesktop = () => window.innerWidth > 1200;

        const hideOverlay = () => {
            if (sidebarOverlay) {
                sidebarOverlay.classList.remove('show');
                sidebarOverlay.style.display = 'none';
            }
        };

        const showOverlay = () => {
            if (sidebarOverlay) {
                sidebarOverlay.classList.add('show');
                sidebarOverlay.style.display = 'block';
            }
        };

        const getState = () => {
            const collapsed = document.body.classList.contains('sidebar-collapsed');
            const open = sidebar.classList.contains('show') && !collapsed;
            const desktop = isDesktop();
            return { collapsed, open, desktop };
        };

        const updateToggleVisual = () => {
            const { collapsed, open, desktop } = getState();

            sidebarToggleButtons.forEach((button) => {
                const labelElement = button.querySelector('.sidebar-toggle-label');
                const iconElement = button.querySelector('i[data-lucide]');
                const labelText = desktop
                    ? (collapsed ? 'Afficher la navigation' : 'Masquer la navigation')
                    : (open ? 'Fermer la navigation' : 'Afficher la navigation');

                button.setAttribute('aria-expanded', open ? 'true' : 'false');
                button.setAttribute('aria-label', labelText);

                if (labelElement) labelElement.textContent = labelText;

                if (iconElement && typeof lucide !== 'undefined') {
                    const iconName = desktop
                        ? (collapsed ? 'panel-right-open' : 'panel-left')
                        : (open ? 'x' : 'menu');
                    iconElement.setAttribute('data-lucide', iconName);
                }
            });

            if (typeof lucide !== 'undefined') lucide.createIcons();
        };

        const collapseSidebar = () => {
            document.body.classList.add('sidebar-collapsed');
            sidebar.classList.remove('show');
            hideOverlay();
            updateToggleVisual();
        };

        const expandSidebar = () => {
            document.body.classList.remove('sidebar-collapsed');
            sidebar.classList.add('show');
            hideOverlay();
            updateToggleVisual();
        };

        const openSidebar = () => {
            document.body.classList.remove('sidebar-collapsed');
            sidebar.classList.add('show');
            if (isDesktop()) hideOverlay(); else showOverlay();
            updateToggleVisual();
        };

        const closeSidebar = () => {
            sidebar.classList.remove('show');
            hideOverlay();
            updateToggleVisual();
        };

        const bindToggleButton = (button) => {
            if (!button || button.dataset.listenerAttached === 'true') return;
            button.dataset.listenerAttached = 'true';

            button.addEventListener('click', function (event) {
                event.preventDefault();
                event.stopPropagation();

                const { desktop, collapsed, open } = getState();

                if (desktop) {
                    if (collapsed) expandSidebar(); else collapseSidebar();
                } else {
                    if (open) closeSidebar(); else openSidebar();
                }
            });
        };

        sidebarToggleButtons.forEach(bindToggleButton);

        if (sidebarOverlay && sidebarOverlay.dataset.listenerAttached !== 'true') {
            sidebarOverlay.dataset.listenerAttached = 'true';
            sidebarOverlay.addEventListener('click', () => closeSidebar());
        }

        if (!sidebar.dataset.linksListenerAttached) {
            sidebar.dataset.linksListenerAttached = 'true';
            const sidebarLinks = sidebar.querySelectorAll('a[href]:not([href^="#"]):not(.sidebar-collapse-trigger)');
            sidebarLinks.forEach((link) => {
                link.addEventListener('click', () => {
                    if (!isDesktop()) closeSidebar();
                });
            });
        }

        let resizeTimer;
        const handleResize = () => {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(() => {
                if (isDesktop()) {
                    if (document.body.classList.contains('sidebar-collapsed')) {
                        sidebar.classList.remove('show');
                    } else {
                        sidebar.classList.add('show');
                    }
                    hideOverlay();
                } else {
                    if (!sidebar.classList.contains('show')) hideOverlay();
                }
                updateToggleVisual();
            }, 200);
        };

        if (window.__sidebarHandleResize) {
            window.removeEventListener('resize', window.__sidebarHandleResize);
        }
        window.__sidebarHandleResize = handleResize;
        window.addEventListener('resize', handleResize);

        if (isDesktop()) {
            if (document.body.classList.contains('sidebar-collapsed')) {
                sidebar.classList.remove('show');
            } else {
                sidebar.classList.add('show');
            }
            hideOverlay();
        } else {
            sidebar.classList.remove('show');
            hideOverlay();
        }

        updateToggleVisual();
    }
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebar);
} else {
    initSidebar();
}

if (typeof window.Turbo !== 'undefined') {
    document.addEventListener('turbo:load', initSidebar);
    document.addEventListener('turbo:frame-load', initSidebar);
}
</script>
{% endif %}
