{# Modal pour afficher la liste des analyses Ishikawa sauvegardées #}
<div {{ attributes.defaults({
    class: 'fixed inset-0 z-[1050] flex items-center justify-center p-4 bg-zinc-900/55 text-foreground',
    tabindex: '-1',
    'aria-hidden': 'true',
    'aria-modal': 'true',
    'role': 'dialog',
    'aria-labelledby': id ? (id ~ '-title') : 'ishikawaLoadModalTitle',
    'aria-describedby': id ? (id ~ '-desc') : 'ishikawaLoadModalDesc',
    id: id ? id : 'ishikawaLoadModal',
    style: 'display: none;'
}) }}
    {{ stimulus_controller('app-modal', { autoShow: false }) }}
    data-turbo="false"
>
    <div class="bg-card text-card-foreground rounded-xl shadow-2xl w-full max-w-lg flex flex-col max-h-[85vh] border border-border ring-1 ring-black/5" role="document">
        <p id="{{ id ? (id ~ '-desc') : 'ishikawaLoadModalDesc' }}" class="sr-only">Liste de vos diagrammes Ishikawa enregistrés. Choisissez une analyse pour l’ouvrir, ou supprimez-en une avec le bouton correspondant.</p>
        <div class="flex items-center justify-between px-6 py-4 border-b border-border shrink-0">
            <h2 class="flex items-center font-semibold text-lg text-foreground m-0" id="{{ id ? (id ~ '-title') : 'ishikawaLoadModalTitle' }}">
                <i data-lucide="folder-open" width="24" height="24" class="mr-2 shrink-0 text-primary" aria-hidden="true"></i>
                Mes analyses Ishikawa
            </h2>
            <twig:Button variant="ghost" size="icon" type="button" data-action="app-modal#hide" aria-label="Fermer le dialogue" class="shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </twig:Button>
        </div>
        <div class="px-6 py-4 overflow-y-auto flex-1 min-h-[8rem]">
            <ul class="m-0 flex list-none flex-col gap-3 p-0" id="ishikawaAnalysesList">
                {# Le contenu sera injecté dynamiquement par JavaScript #}
                <li class="flex justify-center py-6">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary" role="status">
                        <span class="sr-only">Chargement...</span>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</div>
