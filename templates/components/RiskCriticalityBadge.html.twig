{# @prop level string #}
{# @prop label string #}
{%- props level = 'low', label = 'Faible' -%}
{% set classes = {
    low: 'border-sky-500/40 bg-sky-500/10 text-sky-800 dark:text-sky-300',
    medium: 'border-amber-500/40 bg-amber-500/10 text-amber-800 dark:text-amber-300',
    critical: 'border-rose-500/40 bg-rose-500/10 text-rose-800 dark:text-rose-300',
    controlled: 'border-emerald-500/40 bg-emerald-500/10 text-emerald-800 dark:text-emerald-300',
}[level] ?? 'border-border bg-muted/40 text-muted-foreground' %}
<span class="inline-flex items-center rounded-md border px-2 py-0.5 text-xs font-medium {{ classes }}">
    {{ label }}
</span>
