{# Micro-CTA lead pour les pages d'outils + embed newsletter Mautic #}
<section class="tool-lead-cta rounded-xl p-6 md:p-10 mb-6 md:mb-10" aria-labelledby="tool-lead-cta-heading">
    <div class="tool-lead-cta__row">
        <div class="tool-lead-cta__icon" aria-hidden="true">
            <i class="fas fa-envelope-open-text" aria-hidden="true"></i>
        </div>
        <div class="tool-lead-cta__content">
            <h2 id="tool-lead-cta-heading" class="tool-lead-cta__title">Recevez nos ressources QSE</h2>
            <p class="tool-lead-cta__text">Guide complet, bonnes pratiques et astuces d'experts par email — gratuitement.</p>
            <a href="{{ path('app_home_index') }}#newsletter" class="inline-flex items-center gap-1 bg-primary text-primary-foreground px-3 py-1.5 text-sm rounded-md hover:opacity-90 transition-opacity no-underline">
                <i class="fas fa-envelope mr-2" aria-hidden="true"></i>Recevoir le guide par email
            </a>
        </div>
    </div>
    <div class="tool-lead-cta__coming-soon">
        {% include 'components/coming_soon_download.html.twig' %}
    </div>
    <div class="tool-lead-cta__newsletter">
        <p class="text-sm mb-2">Ou inscrivez-vous directement :</p>
        {% include 'components/newsletter-form.html.twig' with { compact: true } %}
    </div>
</section>
