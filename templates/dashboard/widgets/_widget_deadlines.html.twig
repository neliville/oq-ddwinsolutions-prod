<twig:Card class="border-border/80 shadow-sm" aria-labelledby="dash-b1">
    <twig:Card:Content class="p-4 sm:p-5">
        <h3 id="dash-b1" class="text-base font-bold mb-3 flex items-center gap-2">
            <i data-lucide="alarm-clock" width="18" height="18" class="text-destructive shrink-0" aria-hidden="true"></i>
            1. Urgence &amp; délais
        </h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-2 list-none m-0 p-0 text-sm">
            <li><a href="{{ path('app_qse_capa_index') }}" class="flex justify-between gap-2 rounded-md border border-border/70 px-3 py-2.5 no-underline text-foreground hover:bg-muted/60 min-h-[44px] items-center"><span class="text-muted-foreground">CAPA en retard</span><twig:Badge variant="secondary" class="tabular-nums font-semibold">{{ cockpit.overdueOpenCapas }}</twig:Badge></a></li>
            <li><a href="{{ path('app_qse_audit_index') }}" class="flex justify-between gap-2 rounded-md border border-border/70 px-3 py-2.5 no-underline text-foreground hover:bg-muted/60 min-h-[44px] items-center"><span class="text-muted-foreground">Plans d’audit en retard</span><twig:Badge variant="secondary" class="tabular-nums font-semibold">{{ cockpit.overdueAuditPlans }}</twig:Badge></a></li>
            <li><a href="{{ path('app_qse_capa_index') }}" class="flex justify-between gap-2 rounded-md border border-border/70 px-3 py-2.5 no-underline text-foreground hover:bg-muted/60 min-h-[44px] items-center"><span class="text-muted-foreground">CAPA échéance 7&nbsp;j</span><twig:Badge variant="secondary" class="tabular-nums font-semibold">{{ cockpit.dueCapaNext7Days }}</twig:Badge></a></li>
            <li><a href="{{ path('app_qse_audit_index') }}" class="flex justify-between gap-2 rounded-md border border-border/70 px-3 py-2.5 no-underline text-foreground hover:bg-muted/60 min-h-[44px] items-center"><span class="text-muted-foreground">Écarts audit (notes 1–2)</span><twig:Badge variant="secondary" class="tabular-nums font-semibold">{{ cockpit.openNonConformEvaluations }}</twig:Badge></a></li>
            <li><a href="{{ path('app_qse_risk_index') }}" class="flex justify-between gap-2 rounded-md border border-border/70 px-3 py-2.5 no-underline text-foreground hover:bg-muted/60 min-h-[44px] items-center"><span class="text-muted-foreground">Risques critiques sans CAPA</span><twig:Badge variant="secondary" class="tabular-nums font-semibold">{{ cockpit.criticalRisksWithoutCapa }}</twig:Badge></a></li>
            <li><a href="{{ path('app_qse_capa_index') }}" class="flex justify-between gap-2 rounded-md border border-border/70 px-3 py-2.5 no-underline text-foreground hover:bg-muted/60 min-h-[44px] items-center"><span class="text-muted-foreground">CAPA en attente de vérification</span><twig:Badge variant="secondary" class="tabular-nums font-semibold">{{ cockpit.capasAwaitingVerification }}</twig:Badge></a></li>
            <li><a href="{{ path('app_qse_audit_index') }}" class="flex justify-between gap-2 rounded-md border border-border/70 px-3 py-2.5 no-underline text-foreground hover:bg-muted/60 min-h-[44px] items-center"><span class="text-muted-foreground">Audits brouillon &gt; 14&nbsp;j</span><twig:Badge variant="secondary" class="tabular-nums font-semibold">{{ cockpit.staleAuditDrafts }}</twig:Badge></a></li>
        </ul>
    </twig:Card:Content>
</twig:Card>
