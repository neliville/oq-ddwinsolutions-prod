{# Graphiques cockpit utilisateur (ApexCharts) — données : user_dashboard_charts #}
{% if user_dashboard_charts.charts is defined and user_dashboard_charts.charts|length > 0 %}
<section class="rounded-xl border border-border/80 bg-card shadow-sm mb-6 sm:mb-8 overflow-hidden" aria-labelledby="dashboard-charts-heading">
    <div class="border-b border-border/60 bg-muted/20 px-4 py-3 sm:px-5 sm:py-4">
        <h2 id="dashboard-charts-heading" class="text-base font-semibold m-0 flex items-center gap-2">
            <i data-lucide="line-chart" width="18" height="18" class="text-primary shrink-0" aria-hidden="true"></i>
            Pilotage visuel
        </h2>
        <p class="text-xs text-muted-foreground m-0 mt-1">Conformité audits, CAPA ouvertes et points d’attention synthétiques.</p>
    </div>
    <div
        class="p-4 sm:p-5 grid gap-4 sm:gap-6 lg:grid-cols-3"
        data-controller="chart"
        data-chart-kind-value="user-dashboard"
        data-chart-config-value="{{ user_dashboard_charts|json_encode|e('html_attr') }}"
    >
        {% for c in user_dashboard_charts.charts %}
            <div class="rounded-lg border border-border/60 bg-background/80 p-3 min-h-[14rem] flex flex-col">
                <p class="text-[10px] font-semibold uppercase tracking-wide text-muted-foreground m-0 mb-2">
                    {% if c.ref == 'conformity' %}Conformité{% elseif c.ref == 'capa_status' %}CAPA{% else %}Attention{% endif %}
                </p>
                <div class="flex-1 min-h-[12rem] w-full" data-chart-wrap>
                    <canvas data-user-dashboard-chart-ref="{{ c.ref }}" class="block h-full w-full max-h-56" role="img" aria-label="Graphique {{ c.ref }}"></canvas>
                </div>
            </div>
        {% endfor %}
    </div>
</section>
{% endif %}
