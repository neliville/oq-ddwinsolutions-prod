{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Tableau de bord | OUTILS-QUALITÉ{% endblock %}

{% block meta_description %}
<meta name="description" content="Tableau de bord utilisateur - Accédez à vos outils qualité - OUTILS-QUALITÉ">
{% endblock %}

{% block content %}
<div class="container-fluid p-4 p-lg-5 dashboard-page">

    {# ── Header ─────────────────────────────────────────────────────────────── #}
    <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-5">
        <div>
            <h1 class="h3 fw-bold mb-1">Tableau de bord</h1>
            <p class="text-muted mb-0">Bienvenue, <span class="fw-medium">{{ app.user.email }}</span></p>
        </div>
        <a href="{{ path('app_ishikawa_index') }}" class="btn btn-primary">
            <i data-lucide="plus" width="18" height="18" class="me-2"></i>
            Nouvelle analyse
        </a>
    </div>

    {# ── Stats ──────────────────────────────────────────────────────────────── #}
    <div class="row g-3 g-xl-4 mb-5">

        <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="50">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="stat-icon bg-primary bg-opacity-10 text-primary rounded-3 p-2">
                            <i data-lucide="file-text" width="20" height="20"></i>
                        </div>
                        <span class="text-muted small fw-medium">Total</span>
                    </div>
                    <div class="h2 fw-bold mb-0">{{ totalRecords }}</div>
                    <div class="text-muted small mt-1">créations</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="100">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-success bg-opacity-10 text-success rounded-3 p-2">
                                <i data-lucide="git-branch" width="20" height="20"></i>
                            </div>
                            <span class="text-muted small fw-medium">Ishikawa</span>
                        </div>
                        <a href="{{ path('app_ishikawa_index') }}" class="text-muted" aria-label="Ouvrir Ishikawa">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="h2 fw-bold mb-0">{{ ishikawaRecords }}</div>
                    <div class="text-muted small mt-1">diagrammes</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="150">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-info bg-opacity-10 text-info rounded-3 p-2">
                                <i data-lucide="help-circle" width="20" height="20"></i>
                            </div>
                            <span class="text-muted small fw-medium">5 Pourquoi</span>
                        </div>
                        <a href="{{ path('app_fivewhy_index') }}" class="text-muted" aria-label="Ouvrir 5 Pourquoi">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="h2 fw-bold mb-0">{{ fiveWhyRecords }}</div>
                    <div class="text-muted small mt-1">analyses</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="200">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-secondary bg-opacity-10 text-secondary rounded-3 p-2">
                                <i data-lucide="list-checks" width="20" height="20"></i>
                            </div>
                            <span class="text-muted small fw-medium">QQOQCCP</span>
                        </div>
                        <a href="{{ path('app_qqoqccp_index') }}" class="text-muted" aria-label="Ouvrir QQOQCCP">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="h2 fw-bold mb-0">{{ qqoqccpRecords }}</div>
                    <div class="text-muted small mt-1">analyses</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="250">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-danger bg-opacity-10 text-danger rounded-3 p-2">
                                <i data-lucide="alert-triangle" width="20" height="20"></i>
                            </div>
                            <span class="text-muted small fw-medium">AMDEC</span>
                        </div>
                        <a href="{{ path('app_amdec_index') }}" class="text-muted" aria-label="Ouvrir AMDEC">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="h2 fw-bold mb-0">{{ amdecRecords }}</div>
                    <div class="text-muted small mt-1">analyses</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="300">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-info bg-opacity-10 text-info rounded-3 p-2">
                                <i data-lucide="bar-chart-2" width="20" height="20"></i>
                            </div>
                            <span class="text-muted small fw-medium">Pareto</span>
                        </div>
                        <a href="{{ path('app_pareto_index') }}" class="text-muted" aria-label="Ouvrir Pareto">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="h2 fw-bold mb-0">{{ paretoRecords }}</div>
                    <div class="text-muted small mt-1">analyses</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="350">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-warning bg-opacity-10 text-warning rounded-3 p-2">
                                <i data-lucide="layers" width="20" height="20"></i>
                            </div>
                            <span class="text-muted small fw-medium">Méthode 8D</span>
                        </div>
                        <a href="{{ path('app_eightd_index') }}" class="text-muted" aria-label="Ouvrir 8D">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="h2 fw-bold mb-0">{{ eightDRecords }}</div>
                    <div class="text-muted small mt-1">rapports</div>
                </div>
            </div>
        </div>

    </div>

    {# ── Corps principal ─────────────────────────────────────────────────────── #}
    <div class="row g-4 g-xl-5">

        {# Colonne gauche #}
        <div class="col-lg-8">

            {# Mes outils disponibles #}
            <div class="card border-0 shadow-sm mb-4" data-aos="fade-up">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Mes outils disponibles</h5>
                        <a href="{{ path('app_outils_index') }}" class="btn btn-sm btn-outline-primary">
                            Voir tous
                        </a>
                    </div>
                    <div class="row g-3">

                        <div class="col-md-6">
                            <div class="card border h-100 dashboard-tool-card">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-3 gap-3">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 flex-shrink-0">
                                            <i data-lucide="git-branch" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Diagramme Ishikawa</h6>
                                            <small class="text-muted">Analyse des causes (5M)</small>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-3">Identifiez les causes racines d'un problème avec le diagramme en arête de poisson.</p>
                                    <a href="{{ path('app_ishikawa_index') }}" class="btn btn-primary btn-sm dashboard-tool-link d-inline-flex align-items-center">
                                        <i data-lucide="play" width="14" height="14" class="me-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border h-100 dashboard-tool-card">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-3 gap-3">
                                        <div class="bg-info bg-opacity-10 text-info rounded-3 p-2 flex-shrink-0">
                                            <i data-lucide="help-circle" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Méthode 5 Pourquoi</h6>
                                            <small class="text-muted">Cause racine en profondeur</small>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-3">Posez successivement "Pourquoi ?" pour remonter jusqu'à la cause fondamentale.</p>
                                    <a href="{{ path('app_fivewhy_index') }}" class="btn btn-info btn-sm dashboard-tool-link d-inline-flex align-items-center">
                                        <i data-lucide="play" width="14" height="14" class="me-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border h-100 dashboard-tool-card">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-3 gap-3">
                                        <div class="bg-secondary bg-opacity-10 text-secondary rounded-3 p-2 flex-shrink-0">
                                            <i data-lucide="list-checks" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Analyse QQOQCCP</h6>
                                            <small class="text-muted">Questionnement complet 5W2H</small>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-3">Structurez votre diagnostic en répondant aux 7 questions fondamentales.</p>
                                    <a href="{{ path('app_qqoqccp_index') }}" class="btn btn-outline-secondary btn-sm dashboard-tool-link d-inline-flex align-items-center">
                                        <i data-lucide="play" width="14" height="14" class="me-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border h-100 dashboard-tool-card">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-3 gap-3">
                                        <div class="bg-danger bg-opacity-10 text-danger rounded-3 p-2 flex-shrink-0">
                                            <i data-lucide="alert-triangle" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Analyse AMDEC</h6>
                                            <small class="text-muted">Priorisation des risques (NPR)</small>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-3">Calcul automatique de criticité, recommandations de priorisation des actions.</p>
                                    <a href="{{ path('app_amdec_index') }}" class="btn btn-outline-danger btn-sm dashboard-tool-link d-inline-flex align-items-center">
                                        <i data-lucide="play" width="14" height="14" class="me-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border h-100 dashboard-tool-card">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-3 gap-3">
                                        <div class="bg-info bg-opacity-10 text-info rounded-3 p-2 flex-shrink-0">
                                            <i data-lucide="bar-chart-2" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Diagramme Pareto</h6>
                                            <small class="text-muted">Analyse 80 / 20</small>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-3">Visualisez les causes majeures, pourcentages cumulés et priorisez vos actions.</p>
                                    <a href="{{ path('app_pareto_index') }}" class="btn btn-outline-info btn-sm dashboard-tool-link d-inline-flex align-items-center">
                                        <i data-lucide="play" width="14" height="14" class="me-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border h-100 dashboard-tool-card">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-3 gap-3">
                                        <div class="bg-warning bg-opacity-10 text-warning rounded-3 p-2 flex-shrink-0">
                                            <i data-lucide="layers" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Méthode 8D</h6>
                                            <small class="text-muted">Résolution structurée</small>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-3">8 disciplines : containment, causes racines, capitalisation, indicateurs.</p>
                                    <a href="{{ path('app_eightd_index') }}" class="btn btn-outline-warning btn-sm dashboard-tool-link d-inline-flex align-items-center">
                                        <i data-lucide="play" width="14" height="14" class="me-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            {# Dernières créations #}
            {% if recentRecords|length > 0 %}
            <div class="card border-0 shadow-sm" data-aos="fade-up" data-aos-delay="100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Mes dernières créations</h5>
                        <a href="{{ path('app_creations_index') }}" class="btn btn-sm btn-outline-primary">Voir toutes</a>
                    </div>
                    <div class="list-group list-group-flush">
                        {% for item in recentRecords %}
                        {% set record = item.record %}
                        {% set type = item.type %}
                        {% set icon = { 'ishikawa': 'git-branch', 'fivewhy': 'help-circle', 'qqoqccp': 'list-checks', 'amdec': 'alert-triangle', 'pareto': 'bar-chart-2', 'eightd': 'layers' }[type] ?? 'file-text' %}
                        {% set color = { 'ishikawa': 'primary', 'fivewhy': 'info', 'qqoqccp': 'secondary', 'amdec': 'danger', 'pareto': 'info', 'eightd': 'warning' }[type] ?? 'primary' %}
                        {% set loadPath = {
                            'ishikawa': path('app_ishikawa_index') ~ '?load=' ~ record.id,
                            'fivewhy':  path('app_fivewhy_index')  ~ '?load=' ~ record.id,
                            'qqoqccp':  path('app_qqoqccp_index')  ~ '?load=' ~ record.id,
                            'amdec':    path('app_amdec_index')    ~ '?load=' ~ record.id,
                            'pareto':   path('app_pareto_index')   ~ '?load=' ~ record.id,
                            'eightd':   path('app_eightd_index')   ~ '?load=' ~ record.id
                        }[type] ?? path('app_creations_index') %}
                        <div class="list-group-item border-0 px-0 py-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-{{ color }} bg-opacity-10 text-{{ color }} rounded-3 p-2 flex-shrink-0">
                                    <i data-lucide="{{ icon }}" width="18" height="18"></i>
                                </div>
                                <div class="flex-grow-1 min-w-0">
                                    <h6 class="fw-semibold mb-1 text-truncate">{{ record.title }}</h6>
                                    <small class="text-muted">
                                        <i data-lucide="calendar" width="12" height="12" class="me-1"></i>
                                        {{ record.createdAt|date('d/m/Y à H:i') }}
                                    </small>
                                </div>
                                <a href="{{ loadPath }}" class="btn btn-sm btn-outline-primary flex-shrink-0">
                                    <i data-lucide="folder-open" width="14" height="14" class="me-1"></i>
                                    Charger
                                </a>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% else %}
            <div class="card border-0 shadow-sm" data-aos="fade-up" data-aos-delay="100">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <div class="d-inline-flex bg-primary bg-opacity-10 text-primary rounded-circle p-4">
                            <i data-lucide="file-plus" width="36" height="36"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold mb-2">Aucune création pour l'instant</h5>
                    <p class="text-muted mb-4">Commencez par créer votre première analyse avec l'un de vos outils.</p>
                    <div class="d-flex flex-wrap gap-2 justify-content-center">
                        <a href="{{ path('app_ishikawa_index') }}" class="btn btn-primary">
                            <i data-lucide="git-branch" width="16" height="16" class="me-2"></i>
                            Ishikawa
                        </a>
                        <a href="{{ path('app_fivewhy_index') }}" class="btn btn-outline-info">
                            <i data-lucide="help-circle" width="16" height="16" class="me-2"></i>
                            5 Pourquoi
                        </a>
                        <a href="{{ path('app_qqoqccp_index') }}" class="btn btn-outline-secondary">
                            <i data-lucide="list-checks" width="16" height="16" class="me-2"></i>
                            QQOQCCP
                        </a>
                        <a href="{{ path('app_amdec_index') }}" class="btn btn-outline-danger">
                            <i data-lucide="alert-triangle" width="16" height="16" class="me-2"></i>
                            AMDEC
                        </a>
                    </div>
                </div>
            </div>
            {% endif %}

        </div>

        {# Colonne droite #}
        <div class="col-lg-4">

            {# Compte utilisateur #}
            <div class="card border-0 shadow-sm mb-4" data-aos="fade-up" data-aos-delay="150">
                <div class="card-body">
                    <h5 class="fw-semibold mb-4 d-flex align-items-center gap-2">
                        <i data-lucide="user-circle" width="20" height="20" class="text-primary"></i>
                        Mon compte
                    </h5>
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold flex-shrink-0" style="width: 48px; height: 48px;">
                            {{ app.user.email|slice(0, 1)|upper }}
                        </div>
                        <div class="min-w-0">
                            <div class="fw-semibold text-truncate">{{ app.user.email }}</div>
                            <small class="text-muted">Membre depuis {{ app.user.createdAt|date('F Y') }}</small>
                        </div>
                    </div>
                    <div class="d-flex flex-column gap-2">
                        <a href="{{ path('app_creations_index') }}" class="btn btn-sm btn-outline-primary w-100">
                            <i data-lucide="file-text" width="14" height="14" class="me-2"></i>
                            Mes créations
                        </a>
                        <a href="{{ path('app_profile_index') }}" class="btn btn-sm btn-outline-secondary w-100">
                            <i data-lucide="settings" width="14" height="14" class="me-2"></i>
                            Mon profil
                        </a>
                        {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_admin_dashboard_index') }}" class="btn btn-sm btn-outline-warning w-100">
                            <i data-lucide="shield" width="14" height="14" class="me-2"></i>
                            Administration
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Ressources QSE #}
            <div class="card border-0 shadow-sm dashboard-resources-card" data-aos="fade-up" data-aos-delay="250">
                <div class="card-body">
                    <h5 class="fw-semibold mb-1 d-flex align-items-center gap-2">
                        <i data-lucide="book-open" width="20" height="20" class="text-primary"></i>
                        Ressources QSE
                    </h5>
                    <p class="text-muted small mb-4">Guides et modèles prêts à l'emploi pour vos analyses qualité.</p>

                    <div class="d-flex flex-column gap-2">
                        <a href="{{ path('app_ressources_index') }}" class="dashboard-resource-link d-flex align-items-center gap-3 p-3 rounded-3 text-decoration-none">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-2 p-2 flex-shrink-0">
                                <i data-lucide="package-open" width="16" height="16"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="fw-semibold small text-dark">Ressources & modèles QSE</div>
                                <div class="text-muted" style="font-size: 0.75rem;">Modèle 5M, guides, checklists…</div>
                            </div>
                            <i data-lucide="chevron-right" width="14" height="14" class="text-muted ms-auto flex-shrink-0"></i>
                        </a>

                        <a href="{{ path('app_blog_index') }}" class="dashboard-resource-link d-flex align-items-center gap-3 p-3 rounded-3 text-decoration-none">
                            <div class="bg-success bg-opacity-10 text-success rounded-2 p-2 flex-shrink-0">
                                <i data-lucide="newspaper" width="16" height="16"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="fw-semibold small text-dark">Articles & guides QSE</div>
                                <div class="text-muted" style="font-size: 0.75rem;">Bonnes pratiques et méthodologies</div>
                            </div>
                            <i data-lucide="chevron-right" width="14" height="14" class="text-muted ms-auto flex-shrink-0"></i>
                        </a>

                        <a href="https://ddwinsolutions.fr/#contact" target="_blank" rel="noopener" class="dashboard-resource-link d-flex align-items-center gap-3 p-3 rounded-3 text-decoration-none">
                            <div class="bg-warning bg-opacity-10 text-warning rounded-2 p-2 flex-shrink-0">
                                <i data-lucide="headphones" width="16" height="16"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="fw-semibold small text-dark">Accompagnement QSE</div>
                                <div class="text-muted" style="font-size: 0.75rem;">Conseil personnalisé DDWin Solutions</div>
                            </div>
                            <i data-lucide="external-link" width="14" height="14" class="text-muted ms-auto flex-shrink-0"></i>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

{% if showOnboarding %}
    {% include 'components/onboarding_modal.html.twig' %}
{% endif %}
{% endblock %}

{% block stylesheets %}
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
{% endblock %}
