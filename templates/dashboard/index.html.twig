{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Tableau de bord | OUTILS-QUALITÉ{% endblock %}

{% block meta_description %}Tableau de bord utilisateur — accédez à vos outils qualité — OUTILS-QUALITÉ{% endblock %}

{% block content %}
<div class="w-full dashboard-page">

    {# ── Header ─────────────────────────────────────────────────────────────── #}
    <div class="flex items-start justify-between gap-3 flex-wrap mb-12">
        <div>
            <h1 class="text-2xl font-bold mb-1">Tableau de bord</h1>
            <p class="text-muted-foreground mb-0">Bienvenue, <span class="font-medium">{{ app.user.email }}</span></p>
        </div>
        <a href="{{ path('app_ishikawa_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">
            <i data-lucide="plus" width="18" height="18" class="mr-2"></i>
            Nouvelle analyse
        </a>
    </div>

    {# ── Stats ──────────────────────────────────────────────────────────────── #}
    <div class="grid grid-cols-12 gap-4 xl:gap-6 mb-12">

        <div class="col-span-6 md:col-span-4 lg:col-span-3" data-aos="fade-up" data-aos-delay="50">
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="p-6">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="stat-icon bg-primary/10 text-primary rounded-xl p-2">
                            <i data-lucide="file-text" width="20" height="20"></i>
                        </div>
                        <span class="text-muted-foreground text-sm font-medium">Total</span>
                    </div>
                    <div class="text-2xl font-bold mb-0">{{ totalRecords }}</div>
                    <div class="text-muted-foreground text-sm mt-1">créations</div>
                </div>
            </div>
        </div>

        <div class="col-span-6 md:col-span-4 lg:col-span-3" data-aos="fade-up" data-aos-delay="100">
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-3">
                            <div class="stat-icon bg-green-100 text-green-600 rounded-xl p-2">
                                <i data-lucide="git-branch" width="20" height="20"></i>
                            </div>
                            <span class="text-muted-foreground text-sm font-medium">Ishikawa</span>
                        </div>
                        <a href="{{ path('app_ishikawa_index') }}" class="text-muted-foreground" aria-label="Ouvrir Ishikawa">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="text-2xl font-bold mb-0">{{ ishikawaRecords }}</div>
                    <div class="text-muted-foreground text-sm mt-1">diagrammes</div>
                </div>
            </div>
        </div>

        <div class="col-span-6 md:col-span-4 lg:col-span-3" data-aos="fade-up" data-aos-delay="150">
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-3">
                            <div class="stat-icon bg-sky-100 text-sky-600 rounded-xl p-2">
                                <i data-lucide="help-circle" width="20" height="20"></i>
                            </div>
                            <span class="text-muted-foreground text-sm font-medium">5 Pourquoi</span>
                        </div>
                        <a href="{{ path('app_fivewhy_index') }}" class="text-muted-foreground" aria-label="Ouvrir 5 Pourquoi">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="text-2xl font-bold mb-0">{{ fiveWhyRecords }}</div>
                    <div class="text-muted-foreground text-sm mt-1">analyses</div>
                </div>
            </div>
        </div>

        <div class="col-span-6 md:col-span-4 lg:col-span-3" data-aos="fade-up" data-aos-delay="200">
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-3">
                            <div class="stat-icon bg-secondary text-secondary-foreground rounded-xl p-2">
                                <i data-lucide="list-checks" width="20" height="20"></i>
                            </div>
                            <span class="text-muted-foreground text-sm font-medium">QQOQCCP</span>
                        </div>
                        <a href="{{ path('app_qqoqccp_index') }}" class="text-muted-foreground" aria-label="Ouvrir QQOQCCP">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="text-2xl font-bold mb-0">{{ qqoqccpRecords }}</div>
                    <div class="text-muted-foreground text-sm mt-1">analyses</div>
                </div>
            </div>
        </div>

        <div class="col-span-6 md:col-span-4 lg:col-span-3" data-aos="fade-up" data-aos-delay="250">
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-3">
                            <div class="stat-icon bg-red-100 text-destructive rounded-xl p-2">
                                <i data-lucide="alert-triangle" width="20" height="20"></i>
                            </div>
                            <span class="text-muted-foreground text-sm font-medium">AMDEC</span>
                        </div>
                        <a href="{{ path('app_amdec_index') }}" class="text-muted-foreground" aria-label="Ouvrir AMDEC">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="text-2xl font-bold mb-0">{{ amdecRecords }}</div>
                    <div class="text-muted-foreground text-sm mt-1">analyses</div>
                </div>
            </div>
        </div>

        <div class="col-span-6 md:col-span-4 lg:col-span-3" data-aos="fade-up" data-aos-delay="300">
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-3">
                            <div class="stat-icon bg-sky-100 text-sky-600 rounded-xl p-2">
                                <i data-lucide="bar-chart-2" width="20" height="20"></i>
                            </div>
                            <span class="text-muted-foreground text-sm font-medium">Pareto</span>
                        </div>
                        <a href="{{ path('app_pareto_index') }}" class="text-muted-foreground" aria-label="Ouvrir Pareto">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="text-2xl font-bold mb-0">{{ paretoRecords }}</div>
                    <div class="text-muted-foreground text-sm mt-1">analyses</div>
                </div>
            </div>
        </div>

        <div class="col-span-6 md:col-span-4 lg:col-span-3" data-aos="fade-up" data-aos-delay="350">
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-3">
                            <div class="stat-icon bg-amber-100 text-amber-600 rounded-xl p-2">
                                <i data-lucide="layers" width="20" height="20"></i>
                            </div>
                            <span class="text-muted-foreground text-sm font-medium">Méthode 8D</span>
                        </div>
                        <a href="{{ path('app_eightd_index') }}" class="text-muted-foreground" aria-label="Ouvrir 8D">
                            <i data-lucide="arrow-right" width="16" height="16"></i>
                        </a>
                    </div>
                    <div class="text-2xl font-bold mb-0">{{ eightDRecords }}</div>
                    <div class="text-muted-foreground text-sm mt-1">rapports</div>
                </div>
            </div>
        </div>

    </div>

    {# ── Corps principal ─────────────────────────────────────────────────────── #}
    <div class="grid grid-cols-12 gap-6">

        {# Colonne gauche #}
        <div class="col-span-12 lg:col-span-8">

            {# Mes outils disponibles #}
            <div class="rounded-lg bg-card shadow-sm mb-6" data-aos="fade-up">
                <div class="p-6">
                    <div class="flex justify-between items-center mb-6">
                        <h5 class="font-bold mb-0">Mes outils disponibles</h5>
                        <a href="{{ path('app_outils_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline">
                            Voir tous
                        </a>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                        <div>
                            <div class="rounded-lg bg-card border h-full dashboard-tool-card">
                                <div class="p-3">
                                    <div class="flex items-center mb-3 gap-3">
                                        <div class="bg-primary/10 text-primary rounded-xl p-2 shrink-0">
                                            <i data-lucide="git-branch" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="font-bold mb-0">Diagramme Ishikawa</h6>
                                            <small class="text-muted-foreground">Analyse des causes (5M)</small>
                                        </div>
                                    </div>
                                    <p class="text-muted-foreground text-sm mb-3">Identifiez les causes racines d'un problème avec le diagramme en arête de poisson.</p>
                                    <a href="{{ path('app_ishikawa_index') }}" class="inline-flex items-center justify-center gap-1.5 bg-primary text-primary-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity no-underline dashboard-tool-link">
                                        <i data-lucide="play" width="14" height="14" class="mr-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div>
                            <div class="rounded-lg bg-card border h-full dashboard-tool-card">
                                <div class="p-3">
                                    <div class="flex items-center mb-3 gap-3">
                                        <div class="bg-sky-100 text-sky-600 rounded-xl p-2 shrink-0">
                                            <i data-lucide="help-circle" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="font-bold mb-0">Méthode 5 Pourquoi</h6>
                                            <small class="text-muted-foreground">Cause racine en profondeur</small>
                                        </div>
                                    </div>
                                    <p class="text-muted-foreground text-sm mb-3">Posez successivement "Pourquoi ?" pour remonter jusqu'à la cause fondamentale.</p>
                                    <a href="{{ path('app_fivewhy_index') }}" class="inline-flex items-center justify-center gap-1.5 bg-primary text-primary-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity no-underline dashboard-tool-link">
                                        <i data-lucide="play" width="14" height="14" class="mr-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div>
                            <div class="rounded-lg bg-card border h-full dashboard-tool-card">
                                <div class="p-3">
                                    <div class="flex items-center mb-3 gap-3">
                                        <div class="bg-secondary text-secondary-foreground rounded-xl p-2 shrink-0">
                                            <i data-lucide="list-checks" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="font-bold mb-0">Analyse QQOQCCP</h6>
                                            <small class="text-muted-foreground">Questionnement complet 5W2H</small>
                                        </div>
                                    </div>
                                    <p class="text-muted-foreground text-sm mb-3">Structurez votre diagnostic en répondant aux 7 questions fondamentales.</p>
                                    <a href="{{ path('app_qqoqccp_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors no-underline dashboard-tool-link">
                                        <i data-lucide="play" width="14" height="14" class="mr-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div>
                            <div class="rounded-lg bg-card border h-full dashboard-tool-card">
                                <div class="p-3">
                                    <div class="flex items-center mb-3 gap-3">
                                        <div class="bg-red-100 text-destructive rounded-xl p-2 shrink-0">
                                            <i data-lucide="alert-triangle" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="font-bold mb-0">Analyse AMDEC</h6>
                                            <small class="text-muted-foreground">Priorisation des risques (NPR)</small>
                                        </div>
                                    </div>
                                    <p class="text-muted-foreground text-sm mb-3">Calcul automatique de criticité, recommandations de priorisation des actions.</p>
                                    <a href="{{ path('app_amdec_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors no-underline dashboard-tool-link">
                                        <i data-lucide="play" width="14" height="14" class="mr-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div>
                            <div class="rounded-lg bg-card border h-full dashboard-tool-card">
                                <div class="p-3">
                                    <div class="flex items-center mb-3 gap-3">
                                        <div class="bg-sky-100 text-sky-600 rounded-xl p-2 shrink-0">
                                            <i data-lucide="bar-chart-2" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="font-bold mb-0">Diagramme Pareto</h6>
                                            <small class="text-muted-foreground">Analyse 80 / 20</small>
                                        </div>
                                    </div>
                                    <p class="text-muted-foreground text-sm mb-3">Visualisez les causes majeures, pourcentages cumulés et priorisez vos actions.</p>
                                    <a href="{{ path('app_pareto_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline dashboard-tool-link">
                                        <i data-lucide="play" width="14" height="14" class="mr-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div>
                            <div class="rounded-lg bg-card border h-full dashboard-tool-card">
                                <div class="p-3">
                                    <div class="flex items-center mb-3 gap-3">
                                        <div class="bg-amber-100 text-amber-600 rounded-xl p-2 shrink-0">
                                            <i data-lucide="layers" width="22" height="22"></i>
                                        </div>
                                        <div>
                                            <h6 class="font-bold mb-0">Méthode 8D</h6>
                                            <small class="text-muted-foreground">Résolution structurée</small>
                                        </div>
                                    </div>
                                    <p class="text-muted-foreground text-sm mb-3">8 disciplines : containment, causes racines, capitalisation, indicateurs.</p>
                                    <a href="{{ path('app_eightd_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors no-underline dashboard-tool-link">
                                        <i data-lucide="play" width="14" height="14" class="mr-1"></i>
                                        Utiliser l'outil
                                    </a>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            {# Dernières créations #}
            {% if recentRecords|length > 0 %}
            <div class="rounded-lg bg-card shadow-sm" data-aos="fade-up" data-aos-delay="100">
                <div class="p-6">
                    <div class="flex justify-between items-center mb-6">
                        <h5 class="font-bold mb-0">Mes dernières créations</h5>
                        <a href="{{ path('app_creations_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline">Voir toutes</a>
                    </div>
                    <div class="flex flex-col">
                        {% for item in recentRecords %}
                        {% set record = item.record %}
                        {% set type = item.type %}
                        {% set icon = { 'ishikawa': 'git-branch', 'fivewhy': 'help-circle', 'qqoqccp': 'list-checks', 'amdec': 'alert-triangle', 'pareto': 'bar-chart-2', 'eightd': 'layers' }[type] ?? 'file-text' %}
                        {% set color = { 'ishikawa': 'primary', 'fivewhy': 'info', 'qqoqccp': 'secondary', 'amdec': 'danger', 'pareto': 'info', 'eightd': 'warning' }[type] ?? 'primary' %}
                        {% set loadPath = {
                            'ishikawa': path('app_ishikawa_index') ~ '?load=' ~ record.id,
                            'fivewhy':  path('app_fivewhy_index')  ~ '?load=' ~ record.id,
                            'qqoqccp':  path('app_qqoqccp_index')  ~ '?load=' ~ record.id,
                            'amdec':    path('app_amdec_index')    ~ '?load=' ~ record.id,
                            'pareto':   path('app_pareto_index')   ~ '?load=' ~ record.id,
                            'eightd':   path('app_eightd_index')   ~ '?load=' ~ record.id
                        }[type] ?? path('app_creations_index') %}
                        <div class="py-3 border-b border-border last:border-0">
                            <div class="flex items-center gap-3">
                                <div class="bg-{{ color }} bg-opacity-10 text-{{ color }} rounded-xl p-2 shrink-0">
                                    <i data-lucide="{{ icon }}" width="18" height="18"></i>
                                </div>
                                <div class="grow min-w-0">
                                    <h6 class="font-semibold mb-1 truncate">{{ record.title }}</h6>
                                    <small class="text-muted-foreground">
                                        <i data-lucide="calendar" width="12" height="12" class="mr-1"></i>
                                        {{ record.createdAt|date('d/m/Y à H:i') }}
                                    </small>
                                </div>
                                <a href="{{ loadPath }}" class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline shrink-0">
                                    <i data-lucide="folder-open" width="14" height="14" class="mr-1"></i>
                                    Charger
                                </a>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% else %}
            <div class="rounded-lg bg-card shadow-sm" data-aos="fade-up" data-aos-delay="100">
                <div class="p-6 text-center py-12">
                    <div class="mb-6">
                        <div class="inline-flex bg-primary/10 text-primary rounded-full p-4">
                            <i data-lucide="file-plus" width="36" height="36"></i>
                        </div>
                    </div>
                    <h5 class="font-bold mb-2">Aucune création pour l'instant</h5>
                    <p class="text-muted-foreground mb-6">Commencez par créer votre première analyse avec l'un de vos outils.</p>
                    <div class="flex flex-wrap gap-2 justify-center">
                        <a href="{{ path('app_ishikawa_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">
                            <i data-lucide="git-branch" width="16" height="16" class="mr-2"></i>
                            Ishikawa
                        </a>
                        <a href="{{ path('app_fivewhy_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline">
                            <i data-lucide="help-circle" width="16" height="16" class="mr-2"></i>
                            5 Pourquoi
                        </a>
                        <a href="{{ path('app_qqoqccp_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors no-underline">
                            <i data-lucide="list-checks" width="16" height="16" class="mr-2"></i>
                            QQOQCCP
                        </a>
                        <a href="{{ path('app_amdec_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors no-underline">
                            <i data-lucide="alert-triangle" width="16" height="16" class="mr-2"></i>
                            AMDEC
                        </a>
                    </div>
                </div>
            </div>
            {% endif %}

        </div>

        {# Colonne droite #}
        <div class="col-span-12 lg:col-span-4">

            {# Compte utilisateur #}
            <div class="rounded-lg bg-card shadow-sm mb-6" data-aos="fade-up" data-aos-delay="150">
                <div class="p-6">
                    <h5 class="font-semibold mb-6 flex items-center gap-2">
                        <i data-lucide="user-circle" width="20" height="20" class="text-primary"></i>
                        Mon compte
                    </h5>
                    <div class="flex items-center gap-3 mb-6">
                        <div class="bg-primary text-white rounded-full flex items-center justify-center font-bold shrink-0" style="width: 48px; height: 48px;">
                            {{ app.user.email|slice(0, 1)|upper }}
                        </div>
                        <div class="min-w-0">
                            <div class="font-semibold truncate">{{ app.user.email }}</div>
                            <small class="text-muted-foreground">Membre depuis {{ app.user.createdAt|date('F Y') }}</small>
                        </div>
                    </div>
                    <div class="flex flex-col gap-2">
                        <a href="{{ path('app_creations_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline w-full">
                            <i data-lucide="file-text" width="14" height="14" class="mr-2"></i>
                            Mes créations
                        </a>
                        <a href="{{ path('app_profile_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors no-underline w-full">
                            <i data-lucide="settings" width="14" height="14" class="mr-2"></i>
                            Mon profil
                        </a>
                        {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_admin_dashboard_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors no-underline w-full">
                            <i data-lucide="shield" width="14" height="14" class="mr-2"></i>
                            Administration
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Ressources QSE #}
            <div class="rounded-lg bg-card shadow-sm dashboard-resources-card" data-aos="fade-up" data-aos-delay="250">
                <div class="p-6">
                    <h5 class="font-semibold mb-1 flex items-center gap-2">
                        <i data-lucide="book-open" width="20" height="20" class="text-primary"></i>
                        Ressources QSE
                    </h5>
                    <p class="text-muted-foreground text-sm mb-6">Guides et modèles prêts à l'emploi pour vos analyses qualité.</p>

                    <div class="flex flex-col gap-2">
                        <a href="{{ path('app_ressources_index') }}" class="dashboard-resource-link flex items-center gap-3 p-3 rounded-xl no-underline">
                            <div class="bg-primary/10 text-primary rounded-md p-2 shrink-0">
                                <i data-lucide="package-open" width="16" height="16"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="font-semibold text-sm text-foreground">Ressources & modèles QSE</div>
                                <div class="text-muted-foreground" style="font-size: 0.75rem;">Modèle 5M, guides, checklists…</div>
                            </div>
