{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Tableau de bord | OUTILS-QUALITÉ{% endblock %}

{% block meta_description %}Tableau de bord utilisateur — accédez à vos outils qualité — OUTILS-QUALITÉ{% endblock %}

{% block content %}
<div
    class="w-full dashboard-page"
    data-controller="dashboard-personalize"
    data-dashboard-personalize-patch-url-value="{{ path('app_api_preferences_dashboard_layout_update') }}"
    data-dashboard-personalize-csrf-token-value="{{ csrf_token('dashboard_layout') }}"
>
    <div id="app-collaboration-csrf" data-csrf="{{ csrf_token('collaboration') }}" class="sr-only" aria-hidden="true"></div>

    {# ── Header ─────────────────────────────────────────────────────────────── #}
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-3 flex-wrap mb-6 sm:mb-10 lg:mb-12">
        <div class="min-w-0">
            <h1 class="text-xl sm:text-2xl font-bold mb-1">Tableau de bord</h1>
            <p class="text-muted-foreground mb-0 text-sm sm:text-base">Bienvenue, <span class="font-medium break-words">{{ dashboard_welcome_name }}</span></p>
            <p class="text-xs text-muted-foreground mt-1 mb-0">Pilotage : <span class="font-medium text-foreground">{{ piloting_focus_label }}</span> — axe QHSE : <span class="font-medium text-foreground">{{ qhse_priority_label }}</span> — <a href="{{ path('app_preferences_index', { tab: 'qhse' }) }}" class="app-inline-link">Ajuster dans les préférences</a> — <a href="{{ path('app_preferences_index', { tab: 'dashboard' }) }}" class="app-inline-link">Blocs du tableau de bord</a></p>
        </div>
        <div class="flex flex-col sm:flex-row flex-wrap gap-2 w-full sm:w-auto sm:justify-end">
            {% include 'collaboration/_invite_dialog.html.twig' with {
                dialog_id: 'collab_invite_dashboard',
                source: 'dashboard',
                trigger_label: 'Inviter un collaborateur',
                trigger_variant: 'outline',
            } %}
            <twig:Button
                type="button"
                variant="outline"
                class="w-full sm:w-auto min-h-[48px] sm:min-h-8 gap-2"
                data-dashboard-personalize-target="editToggle"
                data-action="dashboard-personalize#startEdit"
            >
                <i data-lucide="layout-grid" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                Personnaliser
            </twig:Button>
            <twig:Button as="a" href="{{ path('app_ishikawa_index') }}" variant="default" class="no-underline w-full sm:w-auto min-h-[48px] sm:min-h-8 gap-2">
                <i data-lucide="plus" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                Nouvelle analyse
            </twig:Button>
        </div>
    </div>

    {% if collaboration_suggestion is defined and collaboration_suggestion %}
        <twig:Alert variant="info" class="mb-6" id="collab-suggestion-banner" data-suggestion-key="{{ collaboration_suggestion.suggestion_key }}">
            <twig:Alert:Title>{{ collaboration_suggestion.title }}</twig:Alert:Title>
            <twig:Alert:Description class="text-sm">{{ collaboration_suggestion.body }}</twig:Alert:Description>
            <div data-slot="alert-action" class="absolute top-2 right-2 flex flex-wrap gap-1">
                <twig:Button as="a" href="{{ collaboration_suggestion.cta_href }}" variant="secondary" size="sm" class="no-underline">{{ collaboration_suggestion.cta_label }}</twig:Button>
                <twig:Button type="button" variant="ghost" size="sm" class="collab-suggestion-dismiss">Masquer</twig:Button>
            </div>
        </twig:Alert>
        <script>
        (function () {
          const b = document.getElementById('collab-suggestion-banner');
          if (!b || b.dataset.bound) return;
          b.dataset.bound = '1';
          const key = b.getAttribute('data-suggestion-key');
          const csrf = {{ csrf_token('collaboration')|json_encode|raw }};
          b.querySelector('.collab-suggestion-dismiss')?.addEventListener('click', async function () {
            await fetch('{{ path('app_api_collaboration_suggestion_dismiss') }}', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
              body: JSON.stringify({ suggestionKey: key, csrf_token: csrf }),
            });
            b.remove();
          });
        })();
        </script>
    {% endif %}

    {% include 'dashboard/_activation_onboarding_banner.html.twig' %}

    <twig:Card class="border-border/80 shadow-sm mb-6">
        <twig:Card:Content class="p-4 sm:p-5">
            <h2 class="text-base font-semibold m-0 mb-2 flex items-center gap-2">
                <i data-lucide="users" width="18" height="18" class="text-primary shrink-0" aria-hidden="true"></i>
                Collaboration
            </h2>
            <p class="text-xs text-muted-foreground m-0 mb-3">Invitations et partages actifs (audit / CAPA).</p>
            <ul class="grid grid-cols-1 sm:grid-cols-3 gap-2 list-none m-0 p-0 text-sm">
                <li class="rounded-md border border-border/70 px-3 py-2 flex justify-between gap-2"><span class="text-muted-foreground">Invitations en attente</span><twig:Badge variant="secondary" class="tabular-nums">{{ collaboration_summary.invitationsPending }}</twig:Badge></li>
                <li class="rounded-md border border-border/70 px-3 py-2 flex justify-between gap-2"><span class="text-muted-foreground">Invitations acceptées</span><twig:Badge variant="secondary" class="tabular-nums">{{ collaboration_summary.invitationsAccepted }}</twig:Badge></li>
                <li class="rounded-md border border-border/70 px-3 py-2 flex justify-between gap-2"><span class="text-muted-foreground">Liens partagés actifs</span><twig:Badge variant="secondary" class="tabular-nums">{{ collaboration_summary.activeShares }}</twig:Badge></li>
            </ul>
        </twig:Card:Content>
    </twig:Card>

    {% if user_preferences.primaryStandard.value == 'undefined' %}
        <div class="mb-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950" role="status">
            <strong class="font-semibold">Référentiel à préciser.</strong>
            Indiquez votre référentiel principal dans les
            <a href="{{ path('app_preferences_index', { tab: 'qhse' }) }}" class="app-inline-link font-medium">préférences QHSE</a>
            pour des indicateurs plus ciblés.
        </div>
    {% endif %}

    {# ── Cockpit manager : 6 blocs « attention aujourd’hui » ───────────────── #}
    {% set pf = user_preferences.pilotingFocus.value %}
    {% set hl_capa = pf == 'capa' or activation_highlight == 'capa' %}
    {% set hl_audit = pf in ['audit', 'certification_prep'] or activation_highlight == 'audit' %}
    {% set hl_risk = pf == 'risk' or activation_highlight == 'risk' %}
    {% set hl_ishikawa = activation_highlight == 'ishikawa' %}
    {% include 'dashboard/_cockpit_personalize.html.twig' %}

    {# ── Corps principal ─────────────────────────────────────────────────────── #}
    <div class="grid grid-cols-12 gap-4 sm:gap-6">

        {# Colonne gauche #}
        <div class="col-span-12 lg:col-span-8" data-controller="gsap-stagger" data-gsap-stagger-child-selector-value=":scope > section, :scope > div.rounded-lg, :scope > div.dashboard-recent-creations">

            {# Mes outils disponibles #}
            <section class="rounded-lg bg-card shadow-sm mb-6 border border-border/50" aria-labelledby="dashboard-tools-heading">
                <div class="p-4 sm:p-6">
                    <div class="flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center mb-5 sm:mb-6">
                        <h2 id="dashboard-tools-heading" class="text-lg sm:text-xl font-bold mb-0 text-foreground tracking-tight">Mes outils disponibles</h2>
                        <a href="{{ path('app_outils_index') }}"
                           class="dashboard-tools-see-all inline-flex items-center justify-center gap-2 border-2 border-primary text-primary px-4 py-3 text-base font-semibold rounded-lg hover:bg-primary/10 active:bg-primary/15 transition-colors no-underline w-full sm:w-auto min-h-[48px] sm:min-h-[44px] sm:py-2 sm:text-sm shrink-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                           aria-label="Voir tous les outils qualité sur la page dédiée">
                            <span>Voir tous les outils</span>
                            <i data-lucide="arrow-right" width="18" height="18" class="shrink-0 sm:w-4 sm:h-4" aria-hidden="true"></i>
                        </a>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-4">

                        <div>
                            <article class="rounded-xl bg-card border border-border h-full dashboard-tool-card motion-card flex flex-col">
                                <div class="p-4 sm:p-5 flex flex-col flex-1">
                                    <div class="flex items-start mb-3 gap-3">
                                        <div class="bg-primary/10 text-primary rounded-xl p-2.5 shrink-0" aria-hidden="true">
                                            <i data-lucide="git-branch" width="22" height="22"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <h3 class="font-bold mb-1 text-lg text-foreground leading-tight">Diagramme Ishikawa</h3>
                                            <p class="text-muted-foreground text-sm mb-0 leading-snug">Analyse des causes (5M)</p>
                                        </div>
                                    </div>
                                    <p class="text-foreground/90 text-base leading-relaxed mb-4 flex-1">Identifiez les causes racines d'un problème avec le diagramme en arête de poisson.</p>
                                    <a href="{{ path('app_ishikawa_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-3 text-base sm:text-sm font-semibold rounded-lg hover:opacity-90 transition-opacity no-underline dashboard-tool-link min-h-[48px] sm:min-h-[44px] mt-auto focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
                                        <i data-lucide="play" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                        Utiliser l’outil
                                    </a>
                                </div>
                            </article>
                        </div>

                        <div>
                            <article class="rounded-xl bg-card border border-border h-full dashboard-tool-card motion-card flex flex-col">
                                <div class="p-4 sm:p-5 flex flex-col flex-1">
                                    <div class="flex items-start mb-3 gap-3">
                                        <div class="bg-sky-100 text-sky-600 rounded-xl p-2.5 shrink-0" aria-hidden="true">
                                            <i data-lucide="help-circle" width="22" height="22"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <h3 class="font-bold mb-1 text-lg text-foreground leading-tight">Méthode 5 Pourquoi</h3>
                                            <p class="text-muted-foreground text-sm mb-0 leading-snug">Cause racine en profondeur</p>
                                        </div>
                                    </div>
                                    <p class="text-foreground/90 text-base leading-relaxed mb-4 flex-1">Posez successivement « Pourquoi&nbsp;? » pour remonter jusqu'à la cause fondamentale.</p>
                                    <a href="{{ path('app_fivewhy_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-3 text-base sm:text-sm font-semibold rounded-lg hover:opacity-90 transition-opacity no-underline dashboard-tool-link min-h-[48px] sm:min-h-[44px] mt-auto focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
                                        <i data-lucide="play" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                        Utiliser l’outil
                                    </a>
                                </div>
                            </article>
                        </div>

                        <div>
                            <article class="rounded-xl bg-card border border-border h-full dashboard-tool-card motion-card flex flex-col">
                                <div class="p-4 sm:p-5 flex flex-col flex-1">
                                    <div class="flex items-start mb-3 gap-3">
                                        <div class="bg-secondary text-secondary-foreground rounded-xl p-2.5 shrink-0" aria-hidden="true">
                                            <i data-lucide="list-checks" width="22" height="22"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <h3 class="font-bold mb-1 text-lg text-foreground leading-tight">Analyse QQOQCCP</h3>
                                            <p class="text-muted-foreground text-sm mb-0 leading-snug">Questionnement complet 5W2H</p>
                                        </div>
                                    </div>
                                    <p class="text-foreground/90 text-base leading-relaxed mb-4 flex-1">Structurez votre diagnostic en répondant aux 7 questions fondamentales.</p>
                                    <a href="{{ path('app_qqoqccp_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-3 text-base sm:text-sm font-semibold rounded-lg hover:opacity-90 transition-opacity no-underline dashboard-tool-link min-h-[48px] sm:min-h-[44px] mt-auto focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
                                        <i data-lucide="play" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                        Utiliser l’outil
                                    </a>
                                </div>
                            </article>
                        </div>

                        <div>
                            <article class="rounded-xl bg-card border border-border h-full dashboard-tool-card motion-card flex flex-col">
                                <div class="p-4 sm:p-5 flex flex-col flex-1">
                                    <div class="flex items-start mb-3 gap-3">
                                        <div class="bg-red-100 text-destructive rounded-xl p-2.5 shrink-0" aria-hidden="true">
                                            <i data-lucide="alert-triangle" width="22" height="22"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <h3 class="font-bold mb-1 text-lg text-foreground leading-tight">Analyse AMDEC</h3>
                                            <p class="text-muted-foreground text-sm mb-0 leading-snug">Priorisation des risques (NPR)</p>
                                        </div>
                                    </div>
                                    <p class="text-foreground/90 text-base leading-relaxed mb-4 flex-1">Calcul automatique de criticité, recommandations de priorisation des actions.</p>
                                    <a href="{{ path('app_amdec_index') }}" class="inline-flex items-center justify-center gap-2 bg-destructive text-destructive-foreground px-4 py-3 text-base sm:text-sm font-semibold rounded-lg hover:opacity-90 transition-opacity no-underline dashboard-tool-link min-h-[48px] sm:min-h-[44px] mt-auto focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-destructive">
                                        <i data-lucide="play" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                        Utiliser l’outil
                                    </a>
                                </div>
                            </article>
                        </div>

                        <div>
                            <article class="rounded-xl bg-card border border-border h-full dashboard-tool-card motion-card flex flex-col">
                                <div class="p-4 sm:p-5 flex flex-col flex-1">
                                    <div class="flex items-start mb-3 gap-3">
                                        <div class="bg-sky-100 text-sky-600 rounded-xl p-2.5 shrink-0" aria-hidden="true">
                                            <i data-lucide="bar-chart-2" width="22" height="22"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <h3 class="font-bold mb-1 text-lg text-foreground leading-tight">Diagramme Pareto</h3>
                                            <p class="text-muted-foreground text-sm mb-0 leading-snug">Analyse 80 / 20</p>
                                        </div>
                                    </div>
                                    <p class="text-foreground/90 text-base leading-relaxed mb-4 flex-1">Visualisez les causes majeures, pourcentages cumulés et priorisez vos actions.</p>
                                    <a href="{{ path('app_pareto_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-3 text-base sm:text-sm font-semibold rounded-lg hover:opacity-90 transition-opacity no-underline dashboard-tool-link min-h-[48px] sm:min-h-[44px] mt-auto focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
                                        <i data-lucide="play" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                        Utiliser l’outil
                                    </a>
                                </div>
                            </article>
                        </div>

                        <div>
                            <article class="rounded-xl bg-card border border-border h-full dashboard-tool-card motion-card flex flex-col">
                                <div class="p-4 sm:p-5 flex flex-col flex-1">
                                    <div class="flex items-start mb-3 gap-3">
                                        <div class="bg-amber-100 text-amber-600 rounded-xl p-2.5 shrink-0" aria-hidden="true">
                                            <i data-lucide="layers" width="22" height="22"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <h3 class="font-bold mb-1 text-lg text-foreground leading-tight">Méthode 8D</h3>
                                            <p class="text-muted-foreground text-sm mb-0 leading-snug">Résolution structurée</p>
                                        </div>
                                    </div>
                                    <p class="text-foreground/90 text-base leading-relaxed mb-4 flex-1">8 disciplines&nbsp;: containment, causes racines, capitalisation, indicateurs.</p>
                                    <a href="{{ path('app_eightd_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-3 text-base sm:text-sm font-semibold rounded-lg hover:opacity-90 transition-opacity no-underline dashboard-tool-link min-h-[48px] sm:min-h-[44px] mt-auto focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
                                        <i data-lucide="play" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
                                        Utiliser l’outil
                                    </a>
                                </div>
                            </article>
                        </div>

                    </div>
                </div>
            </section>

            {# Dernières créations #}
            {% if recentRecords|length > 0 %}
            <div class="dashboard-recent-creations rounded-xl bg-card border border-border shadow-sm">
                <div class="p-6 sm:p-7">
                    <div class="dashboard-recent-creations__header flex flex-col gap-3 sm:flex-row sm:justify-between sm:items-center mb-5">
                        <h2 class="dashboard-recent-creations__title font-bold mb-0 text-lg tracking-tight text-foreground">Mes dernières créations</h2>
                        <a href="{{ path('app_creations_index') }}" class="dashboard-recent-creations__all inline-flex items-center justify-center gap-2 self-stretch sm:self-auto px-4 py-3 sm:py-2 min-h-[48px] sm:min-h-0 text-base sm:text-sm font-semibold rounded-lg border-2 border-primary text-primary hover:bg-primary/10 active:bg-primary/15 no-underline transition-colors w-full sm:w-auto focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary" aria-label="Voir toutes mes créations enregistrées">
                            <span>Voir toutes</span>
                            <i data-lucide="arrow-right" width="18" height="18" class="shrink-0 sm:w-4 sm:h-4" aria-hidden="true"></i>
                        </a>
                    </div>
                    <ul class="dashboard-recent-list list-none m-0 p-0 flex flex-col gap-2">
                        {% for item in recentRecords %}
                        {% set record = item.record %}
                        {% set type = item.type %}
                        {% set icon = { 'ishikawa': 'git-branch', 'fivewhy': 'help-circle', 'qqoqccp': 'list-checks', 'amdec': 'alert-triangle', 'pareto': 'bar-chart-2', 'eightd': 'layers' }[type] ?? 'file-text' %}
                        {% set loadPath = {
                            'ishikawa': path('app_ishikawa_index') ~ '?load=' ~ record.id,
                            'fivewhy':  path('app_fivewhy_index')  ~ '?load=' ~ record.id,
                            'qqoqccp':  path('app_qqoqccp_index')  ~ '?load=' ~ record.id,
                            'amdec':    path('app_amdec_index')    ~ '?load=' ~ record.id,
                            'pareto':   path('app_pareto_index')   ~ '?load=' ~ record.id,
                            'eightd':   path('app_eightd_index')   ~ '?load=' ~ record.id
                        }[type] ?? path('app_creations_index') %}
                        <li class="m-0 p-0">
                            <article class="dashboard-recent-row group">
                                <div class="dashboard-recent-row__main">
                                    <div class="dashboard-recent-icon dashboard-recent-icon--{{ type|e('html_attr') }}" aria-hidden="true">
                                        <i data-lucide="{{ icon }}" width="20" height="20" aria-hidden="true"></i>
                                    </div>
                                    <div class="dashboard-recent-row__text min-w-0">
                                        <h3 class="dashboard-recent-row__title font-semibold mb-0.5 truncate text-base text-foreground">{{ record.title }}</h3>
                                        <p class="dashboard-recent-row__meta mb-0 text-sm text-muted-foreground inline-flex items-center gap-1.5">
                                            <i data-lucide="calendar" width="14" height="14" class="shrink-0 opacity-80" aria-hidden="true"></i>
                                            <span>{{ record.createdAt|date('d/m/Y à H:i') }}</span>
                                        </p>
                                    </div>
                                </div>
                                <a href="{{ loadPath }}" class="dashboard-recent-load inline-flex items-center justify-center gap-1.5 shrink-0 no-underline">
                                    <i data-lucide="folder-open" width="16" height="16" aria-hidden="true"></i>
                                    <span>Charger</span>
                                </a>
                            </article>
                        </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
            {% else %}
            <div class="rounded-lg bg-card shadow-sm">
                <div class="p-6 text-center py-12">
                    <div class="mb-6" aria-hidden="true">
                        <div class="inline-flex bg-primary/10 text-primary rounded-full p-4">
                            <i data-lucide="file-plus" width="36" height="36" aria-hidden="true"></i>
                        </div>
                    </div>
                    <p class="text-lg font-bold mb-2 text-foreground" role="status">Aucune création pour l'instant</p>
                    <p class="text-muted-foreground mb-6">Commencez par créer votre première analyse avec l'un de vos outils.</p>
                    <div class="flex flex-wrap gap-2 justify-center">
                        <a href="{{ path('app_ishikawa_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2.5 rounded-md text-sm font-medium hover:opacity-90 transition-opacity no-underline min-h-[44px]">
                            <i data-lucide="git-branch" width="16" height="16" class="mr-2 shrink-0" aria-hidden="true"></i>
                            Ishikawa
                        </a>
                        <a href="{{ path('app_fivewhy_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-2.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline min-h-[44px]">
                            <i data-lucide="help-circle" width="16" height="16" class="mr-2 shrink-0" aria-hidden="true"></i>
                            5 Pourquoi
                        </a>
                        <a href="{{ path('app_qqoqccp_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-2.5 text-sm rounded-md hover:bg-accent transition-colors no-underline min-h-[44px]">
                            <i data-lucide="list-checks" width="16" height="16" class="mr-2 shrink-0" aria-hidden="true"></i>
                            QQOQCCP
                        </a>
                        <a href="{{ path('app_amdec_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-2.5 text-sm rounded-md hover:bg-destructive/5 transition-colors no-underline min-h-[44px]">
                            <i data-lucide="alert-triangle" width="16" height="16" class="mr-2 shrink-0" aria-hidden="true"></i>
                            AMDEC
                        </a>
                    </div>
                </div>
            </div>
            {% endif %}

        </div>

        {# Colonne droite #}
        <div class="col-span-12 lg:col-span-4">

            {# Compte utilisateur #}
            <div class="rounded-lg bg-card shadow-sm mb-6">
                <div class="p-6">
                    <h2 class="text-lg font-semibold mb-6 flex items-center gap-2 text-foreground">
                        <i data-lucide="user-circle" width="20" height="20" class="text-primary shrink-0" aria-hidden="true"></i>
                        Mon compte
                    </h2>
                    <div class="flex items-center gap-3 mb-6">
                        <div class="bg-primary text-white rounded-full flex items-center justify-center font-bold shrink-0" style="width: 48px; height: 48px;" aria-hidden="true">
