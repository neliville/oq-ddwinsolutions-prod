{% extends 'base.html.twig' %}

{% block title %}Bienvenue sur Outils-Qualité — Votre compte est créé !{% endblock %}
{% block meta_description %}Votre compte Outils-Qualité a été créé avec succès. Connectez-vous pour accéder à votre cockpit QSE.{% endblock %}
{% block seo_robots %}noindex, follow{% endblock %}

{% block body %}
{% embed 'auth/_layout.html.twig' with { auth_page_modifier: ' auth-page--register', brand_icon: 'party-popper' } %}
    {% block brand_baseline %}
        Votre compte est prêt. Connectez-vous pour accéder à votre cockpit QSE et à tous vos modules.
    {% endblock %}

    {% block auth_card_modifier %} auth-card--status{% endblock %}

    {% block form_panel %}
        <twig:AuthSuccessState
            icon="party-popper"
            title="Bienvenue sur Outils-Qualité !"
            lead="Votre compte est prêt. Un email de bienvenue vous a été envoyé — pensez à vérifier vos indésirables si vous ne le voyez pas."
            :steps="[
                'Connectez-vous avec l’email et le mot de passe choisis à l’inscription.',
                'Explorez votre cockpit QSE : audits, CAPA, risques et outils d’analyse.',
                'Exportez vos livrables en PDF, Word ou Excel, prêts pour vos revues.',
            ]"
            primaryHref="{{ path('app_login') }}"
            primaryLabel="Se connecter et commencer"
        />

        <div class="mt-10 w-full">
            <p class="text-center text-muted-foreground text-sm font-semibold uppercase mb-4 tracking-wide">Ce qui vous attend</p>
            <div class="grid grid-cols-2 gap-3">
                <div class="flex items-center gap-2 p-3 rounded-xl bg-secondary border border-border/60">
                    <div class="bg-primary/10 text-primary rounded-md p-2 shrink-0">
                        <i data-lucide="git-branch" width="16" height="16" aria-hidden="true"></i>
                    </div>
                    <span class="text-sm font-semibold text-foreground">Ishikawa 5M</span>
                </div>
                <div class="flex items-center gap-2 p-3 rounded-xl bg-secondary border border-border/60">
                    <div class="bg-sky-100 text-sky-600 rounded-md p-2 shrink-0">
                        <i data-lucide="help-circle" width="16" height="16" aria-hidden="true"></i>
                    </div>
                    <span class="text-sm font-semibold text-foreground">5 Pourquoi</span>
                </div>
                <div class="flex items-center gap-2 p-3 rounded-xl bg-secondary border border-border/60">
                    <div class="bg-red-100 text-destructive rounded-md p-2 shrink-0">
                        <i data-lucide="alert-triangle" width="16" height="16" aria-hidden="true"></i>
                    </div>
                    <span class="text-sm font-semibold text-foreground">AMDEC</span>
                </div>
                <div class="flex items-center gap-2 p-3 rounded-xl bg-secondary border border-border/60">
                    <div class="bg-amber-100 text-amber-600 rounded-md p-2 shrink-0">
                        <i data-lucide="layers" width="16" height="16" aria-hidden="true"></i>
                    </div>
                    <span class="text-sm font-semibold text-foreground">Méthode 8D</span>
                </div>
            </div>
        </div>
    {% endblock %}

    {% block info_panel %}
        <twig:AuthFeaturePanel variant="register" />
    {% endblock %}
{% endembed %}
{% endblock %}
