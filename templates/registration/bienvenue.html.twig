{% extends 'base.html.twig' %}

{% block title %}Bienvenue sur Outils-Qualité — Votre compte est créé !{% endblock %}
{% block meta_description %}Votre compte Outils-Qualité a été créé avec succès. Connectez-vous pour accéder à vos outils QSE gratuits.{% endblock %}

{% block content %}
<main class="bienvenue-page" style="margin-top: 76px;">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">

                {# Flashes #}
                {% for message in app.flashes('success') %}
                <div class="alert alert-success d-flex align-items-center gap-2 mb-4" role="alert">
                    <i data-lucide="check-circle" width="18" height="18" class="flex-shrink-0"></i>
                    {{ message }}
                </div>
                {% endfor %}

                {# Card principale #}
                <div class="card border-0 shadow-sm text-center" data-aos="fade-up">
                    <div class="card-body p-5">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-3 p-3 mb-4">
                            <i data-lucide="party-popper" width="32" height="32"></i>
                        </div>

                        <h1 class="h3 fw-bold mb-2">Bienvenue sur Outils-Qualité !</h1>
                        <p class="text-muted mb-4">
                            Votre compte est prêt. Un email de bienvenue vous a été envoyé —
                            pensez à vérifier vos <strong>indésirables</strong> si vous ne le voyez pas.
                        </p>

                        <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg w-100 mb-3">
                            <i data-lucide="log-in" width="18" height="18" class="me-2"></i>
                            Se connecter et commencer
                        </a>

                        <p class="text-muted small mb-0">
                            Accès immédiat à tous vos outils QSE gratuits.
                        </p>
                    </div>
                </div>

                {# Aperçu des outils #}
                <div class="mt-5" data-aos="fade-up" data-aos-delay="100">
                    <p class="text-center text-muted small fw-semibold text-uppercase mb-3" style="letter-spacing: 0.06em;">Ce qui vous attend</p>
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-2 p-3 rounded-3 bg-light">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-2 p-2 flex-shrink-0">
                                    <i data-lucide="git-branch" width="16" height="16"></i>
                                </div>
                                <span class="small fw-semibold text-dark">Ishikawa 5M</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-2 p-3 rounded-3 bg-light">
                                <div class="bg-info bg-opacity-10 text-info rounded-2 p-2 flex-shrink-0">
                                    <i data-lucide="help-circle" width="16" height="16"></i>
                                </div>
                                <span class="small fw-semibold text-dark">5 Pourquoi</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-2 p-3 rounded-3 bg-light">
                                <div class="bg-danger bg-opacity-10 text-danger rounded-2 p-2 flex-shrink-0">
                                    <i data-lucide="alert-triangle" width="16" height="16"></i>
                                </div>
                                <span class="small fw-semibold text-dark">AMDEC</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-2 p-3 rounded-3 bg-light">
                                <div class="bg-warning bg-opacity-10 text-warning rounded-2 p-2 flex-shrink-0">
                                    <i data-lucide="layers" width="16" height="16"></i>
                                </div>
                                <span class="small fw-semibold text-dark">Méthode 8D</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>
{% endblock %}
