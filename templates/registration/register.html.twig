{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/bundles/auth.css') }}">
{% endblock %}

{% block title %}Inscription - OUTILS-QUALITÉ{% endblock %}
{% block meta_description %}Créez votre compte gratuit pour accéder au cockpit QSE : audits, CAPA, risques et outils d'analyse.{% endblock %}
{% block meta_keywords %}inscription, créer un compte, cockpit QSE, outils qualité{% endblock %}
{% block og_title %}Inscription | OUTILS-QUALITÉ{% endblock %}
{% block og_description %}Créez votre compte pour accéder au cockpit QSE et sauvegarder vos analyses en illimité.{% endblock %}
{% block seo_robots %}noindex, follow{% endblock %}

{% set input_class = 'flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50' %}

{% block body %}
{% embed 'auth/_layout.html.twig' with { auth_page_modifier: ' auth-page--register', brand_icon: 'user-plus' } %}
    {% block brand_baseline %}
        Rejoignez Outils-Qualité et accédez à votre cockpit QSE : audits, CAPA, risques et exports audit-ready.
    {% endblock %}

    {% block mobile_trust %}
        <div class="auth-page__mobile-trust lg:hidden">
            <div class="auth-trust-strip" role="list" aria-label="Garanties">
                <span class="auth-trust-badge" role="listitem"><i data-lucide="shield" width="14" height="14" aria-hidden="true"></i> RGPD</span>
                <span class="auth-trust-badge" role="listitem"><i data-lucide="map-pin" width="14" height="14" aria-hidden="true"></i> France</span>
                <span class="auth-trust-badge" role="listitem"><i data-lucide="zap" width="14" height="14" aria-hidden="true"></i> Accès rapide</span>
            </div>
        </div>
    {% endblock %}

    {% block form_panel %}
        <header>
            <h1 class="auth-card__title">Créer mon compte</h1>
            <p class="auth-card__subtitle">
                En moins d’une minute, accédez à votre cockpit QSE et sauvegardez vos analyses en illimité.
            </p>
        </header>

        {{ form_start(registrationForm, {
            attr: {
                class: 'auth-form space-y-4',
                novalidate: 'novalidate',
            }
        }) }}

            <div class="space-y-2">
                {{ form_label(registrationForm.email, 'Adresse email', {'label_attr': {'class': 'text-sm font-medium leading-none text-foreground'}}) }}
                {{ form_widget(registrationForm.email, {
                    attr: {
                        class: input_class ~ (form_errors(registrationForm.email) ? ' border-destructive' : ''),
                        placeholder: 'votre.email@exemple.com',
                        autocomplete: 'email',
                    }
                }) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            <div class="space-y-2">
                {{ form_label(registrationForm.plainPassword.first, 'Mot de passe', {'label_attr': {'class': 'text-sm font-medium leading-none text-foreground'}}) }}
                {% include 'auth/_password_field.html.twig' with {
                    field: registrationForm.plainPassword.first,
                    strength: true,
                    show_compromised: false,
                } %}
                {{ form_errors(registrationForm.plainPassword.first) }}
            </div>

            <div class="space-y-2">
                {{ form_label(registrationForm.plainPassword.second, 'Confirmer le mot de passe', {'label_attr': {'class': 'text-sm font-medium leading-none text-foreground'}}) }}
                {% include 'auth/_password_field.html.twig' with {
                    field: registrationForm.plainPassword.second,
                    strength: false,
                } %}
                {{ form_errors(registrationForm.plainPassword.second) }}
            </div>

            <p class="auth-terms text-sm text-muted-foreground">
                En créant un compte, vous acceptez nos
                <a href="/mentions-legales" class="text-primary font-semibold no-underline hover:underline">mentions légales</a>
                et notre <a href="/politique-de-confidentialite" class="text-primary font-semibold no-underline hover:underline">politique de confidentialité</a>.
            </p>

            <twig:Button type="submit" variant="default" class="w-full min-h-[44px] gap-2">
                <i data-lucide="user-plus" width="18" height="18" aria-hidden="true"></i>
                Créer mon compte
            </twig:Button>

        {{ form_end(registrationForm) }}

        <div class="auth-card__footer">
            Déjà inscrit ?
            <a href="{{ path('app_login') }}">Se connecter</a>
        </div>
    {% endblock %}

    {% block info_panel %}
        <twig:AuthFeaturePanel variant="register" />
    {% endblock %}
{% endembed %}
{% endblock %}
