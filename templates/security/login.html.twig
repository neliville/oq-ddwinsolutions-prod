{% extends 'base.html.twig' %}

{% block title %}Connexion - OUTILS-QUALITÉ{% endblock %}

{% block meta_description %}Connectez-vous à votre compte pour accéder à vos outils qualité et sauvegarder vos analyses.{% endblock %}

{% block meta_keywords %}connexion, compte utilisateur, outils qualité, sauvegarde analyses{% endblock %}

{% block og_title %}Connexion | OUTILS-QUALITÉ{% endblock %}

{% block og_description %}Connectez-vous à votre compte pour accéder à vos outils qualité et sauvegarder vos analyses.{% endblock %}

{% block seo_robots %}noindex, follow{% endblock %}

{% block body %}
<div class="auth-page auth-page--login">
    <div class="auth-page__container container">
        <div class="auth-page__brand">
            <div class="auth-brand">
                <span class="auth-brand__icon">
                    <i class="fas fa-chart-line"></i>
                </span>
                <span class="auth-brand__name">OUTILS-QUALITÉ</span>
            </div>
            <p class="auth-page__baseline">
                Votre espace sécurisé pour piloter vos analyses qualité, suivre vos projets et retrouver toutes vos créations.
            </p>
        </div>

        <div class="auth-card">
            <div class="lg:col-span-5 lg:order-1">
                <section class="auth-card__panel auth-card__panel--form">
                    <header>
                        <h1 class="auth-card__title">Connexion</h1>
                        <p class="auth-card__subtitle">
                            Accédez instantanément à votre tableau de bord, vos historiques et vos exports personnalisés.
                        </p>
                    </header>

                    {% if app.user %}
                        <div class="auth-alert flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 text-green-800 px-4 py-3 mb-3" role="alert">
                            <i class="fas fa-check-circle mt-1"></i>
                            <div>
                                <strong>Vous êtes déjà connecté</strong> en tant que {{ app.user.userIdentifier }}.
                                <div class="mt-1">
                                    <a href="{{ path('app_logout') }}" class="font-semibold text-green-600 no-underline">Se déconnecter</a>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        {% if error %}
                            <div class="auth-alert flex items-start gap-3 rounded-lg border border-red-200 bg-red-50 text-red-800 px-4 py-3 mb-3" role="alert">
                                <i class="fas fa-exclamation-triangle mt-1 shrink-0"></i>
                                <div class="grow">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                                <button onclick="this.closest('[role=alert]').remove()" class="shrink-0 p-1 rounded opacity-60 hover:opacity-100 transition-opacity" aria-label="Fermer le message"><i data-lucide="x" width="16" height="16"></i></button>
                            </div>
                        {% endif %}

                        <form method="post" data-turbo="false" class="auth-form">
                            <div>
                                <label for="username" class="form-label">Adresse email</label>
                                <input
                                    type="email"
                                    value="{{ last_username }}"
                                    name="_username"
                                    id="username"
                                    class="form-control"
                                    autocomplete="email"
                                    required
                                    autofocus
                                    placeholder="votre.email@exemple.com"
                                >
                            </div>

                            <div>
                                <label for="password" class="form-label">Mot de passe</label>
                                <input
                                    type="password"
                                    name="_password"
                                    id="password"
                                    class="form-control"
                                    autocomplete="current-password"
                                    required
                                    placeholder="••••••••"
                                >
                            </div>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <div class="auth-form__actions">
                                <div class="flex items-center gap-2">
                                    <input class="w-4 h-4 rounded border-border text-primary focus:ring-primary" type="checkbox" name="_remember_me" id="_remember_me">
                                    <label class="text-sm text-foreground" for="_remember_me">
                                        Se souvenir de moi
                                    </label>
                                </div>
                                <a href="{{ path('app_forgot_password_request') }}" class="auth-form__link">
                                    <i class="fas fa-key"></i>
                                    Mot de passe oublié ?
                                </a>
                            </div>

                            <button class="auth-form__submit" type="submit">
                                <i class="fas fa-sign-in-alt"></i>
                                Se connecter
                            </button>
                        </form>

                        <div class="auth-card__footer">
                            Pas encore de compte ?
                            <a href="{{ path('app_register') }}">Créer un compte</a>
                        </div>
                    {% endif %}
                </section>
            </div>

            <div class="lg:col-span-7 lg:order-2">
                <section class="auth-card__panel auth-card__panel--info">
                    <div class="relative">
                        <h2 class="auth-info__title">Pourquoi se connecter ?</h2>
                        <p class="auth-info__subtitle">
                            Centralisez vos outils qualité, restez synchronisé avec votre équipe et partagez vos analyses en toute sécurité.
                        </p>

                        <ul class="auth-benefits">
                            <li class="auth-benefits__item">
                                <span class="auth-benefits__icon">💾</span>
                                <div>
                                    <h3 class="auth-benefits__heading">Sauvegarde automatique</h3>
                                    <p class="auth-benefits__description">Retrouvez vos diagrammes Ishikawa, 5 Pourquoi, Pareto ou 8D à tout moment.</p>
                                </div>
                            </li>
                            <li class="auth-benefits__item">
                                <span class="auth-benefits__icon">📊</span>
                                <div>
                                    <h3 class="auth-benefits__heading">Tableau de bord unifié</h3>
                                    <p class="auth-benefits__description">Un aperçu clair de vos projets en cours, des exports réalisés et des partages actifs.</p>
                                </div>
                            </li>
                            <li class="auth-benefits__item">
                                <span class="auth-benefits__icon">📤</span>
                                <div>
                                    <h3 class="auth-benefits__heading">Exports professionnels</h3>
                                    <p class="auth-benefits__description">PDF, PNG ou JSON : distribuez vos analyses avec la charte graphique OUTILS-QUALITÉ.</p>
                                </div>
                            </li>
                            <li class="auth-benefits__item">
                                <span class="auth-benefits__icon">🔒</span>
                                <div>
                                    <h3 class="auth-benefits__heading">Sécurité & conformité</h3>
                                    <p class="auth-benefits__description">Infrastructure conforme RGPD, hébergée en France, données chiffrées et sauvegardées.</p>
                                </div>
                            </li>
                        </ul>

                        <div class="auth-highlights mt-6">
                            <div class="auth-highlight">
                                <span class="auth-highlight__value">+15&nbsp;000</span>
                                <span class="auth-highlight__label">analyses générées</span>
                            </div>
                            <div class="auth-highlight">
                                <span class="auth-highlight__value">98&nbsp;%</span>
                                <span class="auth-highlight__label">d’utilisateurs satisfaits</span>
                            </div>
                            <div class="auth-highlight">
                                <span class="auth-highlight__value">24h/24</span>
                                <span class="auth-highlight__label">accès à vos exports</span>
                            </div>
                        </div>

                        <p class="auth-meta mt-6">
                            <i class="fas fa-shield-alt mr-2"></i>Conforme RGPD – Vos données restent strictement confidentielles.
                        </p>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>
{% endblock %}
