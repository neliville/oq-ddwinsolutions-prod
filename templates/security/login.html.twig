{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/bundles/auth.css') }}">
{% endblock %}

{% block title %}Connexion - OUTILS-QUALITÉ{% endblock %}
{% block meta_description %}Connectez-vous à votre cockpit QSE : audits, CAPA, risques et exports audit-ready.{% endblock %}
{% block meta_keywords %}connexion, cockpit QSE, outils qualité, sauvegarde analyses{% endblock %}
{% block og_title %}Connexion | OUTILS-QUALITÉ{% endblock %}
{% block og_description %}Connectez-vous à votre cockpit QSE pour piloter audits, CAPA, risques et exports.{% endblock %}
{% block seo_robots %}noindex, follow{% endblock %}

{% block body %}
{% embed 'auth/_layout.html.twig' with { auth_page_modifier: ' auth-page--login' } %}
    {% block brand_baseline %}
        Accédez à votre cockpit QSE : analyses sauvegardées, audits, CAPA et risques dans un espace sécurisé.
    {% endblock %}

    {% block mobile_trust %}
        <div class="auth-page__mobile-trust lg:hidden" aria-hidden="false">
            <div class="auth-trust-strip" role="list" aria-label="Garanties">
                <span class="auth-trust-badge" role="listitem"><i data-lucide="shield" width="14" height="14" aria-hidden="true"></i> RGPD</span>
                <span class="auth-trust-badge" role="listitem"><i data-lucide="map-pin" width="14" height="14" aria-hidden="true"></i> France</span>
                <span class="auth-trust-badge" role="listitem"><i data-lucide="lock" width="14" height="14" aria-hidden="true"></i> TLS</span>
            </div>
        </div>
    {% endblock %}

    {% block form_panel %}
        <header>
            <h1 class="auth-card__title">Connexion</h1>
            <p class="auth-card__subtitle">
                Accédez à votre tableau de bord, vos audits ISO, CAPA, risques et exports personnalisés.
            </p>
        </header>

        {% if app.user %}
            <twig:Alert variant="success" class="mb-3 px-4 py-3 shadow-sm" role="alert">
                <twig:Alert:Description class="!text-current text-sm self-center">
                    <strong>Vous êtes déjà connecté</strong> en tant que {{ app.user.userIdentifier }}.
                    <div class="mt-2">
                        <twig:Button as="a" href="{{ path('app_logout') }}" variant="outline" size="sm" class="no-underline">Se déconnecter</twig:Button>
                    </div>
                </twig:Alert:Description>
            </twig:Alert>
        {% else %}
            {% if error %}
                <twig:Alert variant="destructive" class="mb-3 px-4 py-3 shadow-sm" role="alert">
                    <twig:Alert:Description class="!text-current text-sm self-center grow">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </twig:Alert:Description>
                    <twig:Alert:Action>
                        <twig:Button variant="ghost" size="icon" type="button" class="text-current opacity-70 hover:opacity-100" onclick="this.closest('[data-slot=alert]').remove()" aria-label="Fermer le message">
                            <i data-lucide="x" width="16" height="16"></i>
                        </twig:Button>
                    </twig:Alert:Action>
                </twig:Alert>
            {% endif %}

            <form method="post" data-turbo="false" class="auth-form space-y-4">
                <div class="space-y-2">
                    <twig:Label for="username">Adresse email</twig:Label>
                    <twig:Input
                        type="email"
                        value="{{ last_username }}"
                        name="_username"
                        id="username"
                        autocomplete="email"
                        required
                        autofocus
                        placeholder="votre.email@exemple.com"
                    />
                </div>

                <div class="space-y-2">
                    <twig:Label for="password">Mot de passe</twig:Label>
                    <div class="auth-password-field" data-controller="password-toggle">
                        <div class="auth-password-field__inner">
                            <twig:Input
                                type="password"
                                name="_password"
                                id="password"
                                autocomplete="current-password"
                                required
                                placeholder="••••••••"
                                class="pr-10"
                                data-password-toggle-target="input"
                            />
                            <button
                                type="button"
                                class="auth-password-field__toggle"
                                data-action="password-toggle#toggle"
                                data-password-toggle-target="toggle"
                                aria-pressed="false"
                                aria-label="Afficher le mot de passe"
                            >
                                <i data-lucide="eye" width="18" height="18" data-password-toggle-target="iconShow" aria-hidden="true"></i>
                                <i data-lucide="eye-off" width="18" height="18" class="hidden" data-password-toggle-target="iconHide" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="auth-form__actions flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex items-center gap-2">
                        <twig:Checkbox name="_remember_me" id="_remember_me" />
                        <twig:Label for="_remember_me" class="text-sm font-normal cursor-pointer">Se souvenir de moi</twig:Label>
                    </div>
                    <twig:Button as="a" href="{{ path('app_forgot_password_request') }}" variant="link" class="no-underline h-auto p-0 text-sm justify-start sm:justify-end">
                        Mot de passe oublié ?
                    </twig:Button>
                </div>

                <twig:Button type="submit" variant="default" class="w-full min-h-[44px]">
                    Se connecter
                </twig:Button>
                <p class="auth-card__footer auth-card__footer--inline !mt-4 mb-0">
                    Pas encore de compte ?
                    <a href="{{ path('app_register') }}">Créer mon compte</a>
                </p>
            </form>
        {% endif %}
    {% endblock %}

    {% block info_panel %}
        <twig:AuthFeaturePanel variant="login" />
    {% endblock %}
{% endembed %}
{% endblock %}
