{% extends 'emails/base_transactional.html.twig' %}

{% block email_html_title %}Bienvenue sur {{ app_name }} !{% endblock %}

{% block email_body %}
<p style="margin:0 0 20px 0;font-size:18px;font-weight:bold;color:#1a3a5c;">Bonjour,</p>
<p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;color:#374151;">Nous sommes ravis de vous accueillir sur <strong style="color:#111827;">{{ app_name }}</strong>.</p>
<p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;color:#374151;">Votre compte a été créé avec succès. Vous pouvez désormais :</p>
<table width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-bottom:22px;" role="presentation">
<tr><td style="padding:6px 0;font-size:14px;color:#111827;">&#10003; Accéder à tous nos outils d’analyse qualité (Ishikawa, 5 Pourquoi, QQOQCCP, etc.)</td></tr>
<tr><td style="padding:6px 0;font-size:14px;color:#111827;">&#10003; Sauvegarder vos analyses dans votre espace personnel</td></tr>
<tr><td style="padding:6px 0;font-size:14px;color:#111827;">&#10003; Suivre votre pilotage QHSE depuis le tableau de bord</td></tr>
</table>
<p style="margin:0 0 8px 0;font-size:15px;font-weight:bold;color:#1a3a5c;">Accéder à votre compte</p>
{% include 'emails/_email_cta.html.twig' with { cta_href: login_url, cta_label: 'Accéder à mon compte' } %}
<p style="margin:16px 0 0 0;font-size:14px;line-height:1.65;color:#374151;">Une question ? Répondez à cet email ou écrivez-nous à <a href="mailto:{{ app_email|default('contact@outils-qualite.com') }}" style="color:#2563eb;text-decoration:underline;">{{ app_email|default('contact@outils-qualite.com') }}</a>.</p>
<div style="margin:22px 0 0 0;padding:14px 16px;border:1px solid #e5e7eb;border-radius:8px;background:#f8fafc;font-size:12px;line-height:1.6;color:#475569;text-align:left;">
<strong style="color:#1a3a5c;">Conformité RGPD.</strong> Cet email confirme la création de votre compte ({{ user.email }}). Vous disposez d'un droit d'accès, de rectification et de suppression des données vous concernant. Pour les exercer : <a href="mailto:{{ app_email|default('contact@outils-qualite.com') }}" style="color:#2563eb;text-decoration:underline;">{{ app_email|default('contact@outils-qualite.com') }}</a> — <a href="{{ app_url }}/politique-de-confidentialite" style="color:#2563eb;text-decoration:underline;">Politique de confidentialité</a>.
</div>
{% endblock %}

{% block email_footer %}
{{ parent() }}
{% endblock %}
