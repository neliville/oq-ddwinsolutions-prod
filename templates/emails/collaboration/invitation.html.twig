{% extends 'emails/base_transactional.html.twig' %}

{% block email_html_title %}Invitation — {{ app_name }}{% endblock %}

{% block email_body %}
<p style="margin:0 0 20px 0;font-size:18px;font-weight:bold;color:#1a3a5c;">Bonjour{% if invitation.firstName %} {{ invitation.firstName }}{% endif %},</p>
<p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;color:#374151;"><strong style="color:#111827;">{{ invitation.owner.email }}</strong> vous invite à consulter ou contribuer à son pilotage QHSE sur <strong>{{ app_name }}</strong>.</p>
<p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;color:#374151;">Rôle proposé : <strong style="color:#1a3a5c;">{{ invitation.role.label() }}</strong></p>
{% include 'emails/_email_cta.html.twig' with { cta_href: accept_url, cta_label: 'Accepter l’invitation' } %}
<p style="margin:14px 0 0 0;font-size:13px;line-height:1.6;color:#64748b;">Si le bouton ne s’affiche pas correctement, copiez ce lien dans votre navigateur :<br><a href="{{ accept_url }}" style="color:#2563eb;word-break:break-all;">{{ accept_url }}</a></p>
{% endblock %}

{% block email_footer %}
<span style="color:#64748b;">Message lié à une invitation sur {{ app_name }}.</span><br><br>
{{ parent() }}
{% endblock %}
