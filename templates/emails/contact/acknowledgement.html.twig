{% extends 'emails/base_transactional.html.twig' %}

{% block email_html_title %}Message reçu — {{ app_name }}{% endblock %}

{% block email_body %}
<p style="margin:0 0 20px 0;font-size:18px;font-weight:bold;color:#1a3a5c;">Bonjour {{ contact.name ?: 'cher utilisateur' }},</p>
<p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;color:#374151;">Merci de nous avoir contactés via le site <strong>{{ app_name }}</strong>. Nous avons bien reçu votre message et nous vous répondrons dans les plus brefs délais.</p>
<table width="100%" border="0" cellspacing="0" cellpadding="0" style="margin:20px 0;border:1px solid #e5e7eb;border-radius:8px;background:#f8fafc;" role="presentation">
<tr>
<td style="padding:18px 20px;font-size:14px;color:#334155;line-height:1.55;">
<div style="margin-bottom:12px;"><strong style="color:#111827;">Objet :</strong><br>{{ contact.subject ?: '—' }}</div>
<div style="margin-bottom:12px;"><strong style="color:#111827;">Nom :</strong><br>{{ contact.name ?: '—' }}</div>
<div style="margin-bottom:12px;"><strong style="color:#111827;">Email :</strong><br>{{ contact.email }}</div>
<div><strong style="color:#111827;">Message :</strong><br><div style="margin-top:8px;white-space:pre-wrap;">{{ contact.message }}</div></div>
</td>
</tr>
</table>
<p style="margin:0;font-size:14px;line-height:1.65;color:#475569;">Pour compléter votre demande, vous pouvez répondre à cet email ou utiliser notre formulaire : <a href="{{ app_url }}/contact/" style="color:#2563eb;text-decoration:underline;">{{ app_url }}/contact/</a></p>
{% endblock %}

{% block email_footer %}
<span style="color:#64748b;">Accusé de réception automatique. Urgences : <a href="mailto:{{ app_email|default('contact@outils-qualite.com') }}" style="color:#64748b;">{{ app_email|default('contact@outils-qualite.com') }}</a>.</span><br><br>
{{ parent() }}
{% endblock %}
