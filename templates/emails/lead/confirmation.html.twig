{% extends 'emails/base_transactional.html.twig' %}

{% block email_html_title %}Merci — {{ app_name }}{% endblock %}

{% block email_body %}
<p style="margin:0 0 20px 0;font-size:18px;font-weight:bold;color:#1a3a5c;">Bonjour{% if lead.name %} {{ lead.name }}{% endif %},</p>
<p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;color:#374151;">Merci d’avoir utilisé notre outil sur <strong>{{ app_name|default('OUTILS-QUALITÉ') }}</strong>.</p>
<p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;color:#374151;">Nous espérons qu’il vous a été utile. Découvrez aussi les autres outils d’analyse qualité sur la plateforme.</p>
{% include 'emails/_email_cta.html.twig' with { cta_href: app_url, cta_label: 'Accéder au site' } %}
{% endblock %}

{% block email_footer %}
<span style="color:#64748b;">Cet email a été envoyé à {{ lead.email }} suite à l’utilisation d’un outil sur {{ app_name }}.</span><br><br>
{{ parent() }}
{% endblock %}
