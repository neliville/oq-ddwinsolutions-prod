{% extends 'emails/base_transactional.html.twig' %}

{% block email_html_title %}Lead qualifié — {{ app_name }}{% endblock %}

{% block email_body %}
<p style="margin:0 0 16px 0;font-size:18px;font-weight:bold;color:#1a3a5c;">Nouveau lead qualifié (score &gt; 50)</p>
<table width="100%" border="0" cellspacing="0" cellpadding="0" style="border-collapse:collapse;font-size:14px;color:#374151;" role="presentation">
<tr style="border-bottom:1px solid #e5e7eb;"><td style="padding:10px 12px;background:#f1f5f9;font-weight:bold;color:#111827;width:32%;">Email</td><td style="padding:10px 12px;">{{ lead.email ?? '—' }}</td></tr>
<tr style="border-bottom:1px solid #e5e7eb;"><td style="padding:10px 12px;background:#f1f5f9;font-weight:bold;color:#111827;">Nom</td><td style="padding:10px 12px;">{{ lead.name ?? '—' }}</td></tr>
<tr style="border-bottom:1px solid #e5e7eb;"><td style="padding:10px 12px;background:#f1f5f9;font-weight:bold;color:#111827;">Source</td><td style="padding:10px 12px;">{{ lead.source ?? '—' }}</td></tr>
<tr style="border-bottom:1px solid #e5e7eb;"><td style="padding:10px 12px;background:#f1f5f9;font-weight:bold;color:#111827;">Outil</td><td style="padding:10px 12px;">{{ lead.tool ?? '—' }}</td></tr>
<tr style="border-bottom:1px solid #e5e7eb;"><td style="padding:10px 12px;background:#f1f5f9;font-weight:bold;color:#111827;">Score</td><td style="padding:10px 12px;">{{ lead.score ?? '—' }}</td></tr>
<tr style="border-bottom:1px solid #e5e7eb;"><td style="padding:10px 12px;background:#f1f5f9;font-weight:bold;color:#111827;">Type</td><td style="padding:10px 12px;">{{ lead.type ?? '—' }}</td></tr>
<tr><td style="padding:10px 12px;background:#f1f5f9;font-weight:bold;color:#111827;">Date</td><td style="padding:10px 12px;">{{ lead.createdAt ? lead.createdAt|date('d/m/Y H:i') : '—' }}</td></tr>
</table>
{% include 'emails/_email_cta.html.twig' with { cta_href: app_url ~ '/dashboard', cta_label: 'Ouvrir le tableau de bord' } %}
{% endblock %}

{% block email_footer %}
<span style="color:#64748b;">Notification automatique interne — {{ app_name }}.</span><br><br>
{{ parent() }}
{% endblock %}
