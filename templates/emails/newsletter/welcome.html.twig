{% extends 'emails/base_transactional.html.twig' %}

{% block email_html_title %}Newsletter — {{ app_name }}{% endblock %}

{% block email_body %}
<p style="margin:0 0 20px 0;font-size:18px;font-weight:bold;color:#1a3a5c;">Bonjour,</p>
<p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;color:#374151;">Merci de vous être abonné à la newsletter de <strong style="color:#111827;">{{ app_name|default('OUTILS-QUALITÉ') }}</strong>.</p>
<p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;color:#374151;">Vous recevrez nos actualités, nouveautés d’outils qualité, articles et conseils pour vos démarches QSE.</p>
<p style="margin:0 0 8px 0;font-size:15px;font-weight:bold;color:#1a3a5c;">Découvrir les outils</p>
{% include 'emails/_email_cta.html.twig' with { cta_href: app_url ~ '/outils', cta_label: 'Voir les outils gratuits' } %}
<p style="margin:16px 0 0 0;font-size:13px;line-height:1.65;color:#64748b;">Pour toute question sur votre inscription : <a href="mailto:contact@outils-qualite.com" style="color:#2563eb;text-decoration:underline;">contact@outils-qualite.com</a></p>
{% endblock %}

{% block email_footer %}
<span style="color:#64748b;">Vous recevez cet email suite à votre inscription à la newsletter ({{ subscriber.email }}). <a href="{{ app_url }}/politique-de-confidentialite" style="color:#64748b;">Politique de confidentialité</a>.</span><br><br>
{{ parent() }}
{% endblock %}
