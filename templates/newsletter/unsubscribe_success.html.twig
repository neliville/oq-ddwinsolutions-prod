{% extends 'base.html.twig' %}

{% block title %}Désabonnement confirmé | OUTILS-QUALITÉ{% endblock %}

{% block meta_description %}Vous avez été désabonné de notre newsletter avec succès.{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 my-12">
    <div class="flex justify-center">
        <div class="w-full lg:max-w-2xl">
            <div class="rounded-lg bg-card shadow-sm">
                <div class="p-6 md:p-12 text-center">
                    <div class="mb-6">
                        <i class="fas fa-check-circle text-green-600" style="font-size: 4rem;"></i>
                    </div>

                    <h1 class="text-2xl font-bold mb-6">Merci pour votre retour !</h1>

                    <div class="flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 text-green-800 px-4 py-3 mb-6" role="alert">
                        <i class="fas fa-info-circle mr-2 shrink-0 mt-0.5"></i>
                        <div>L'adresse <strong>{{ email }}</strong> a été désabonnée avec succès.</div>
                    </div>

                    <p class="text-muted-foreground mb-6">
                        Votre avis nous aide à améliorer nos contenus et nos services.
                    </p>

                    <a href="{{ path('app_home_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">
                        <i class="fas fa-home"></i>
                        Retour à l'accueil
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
