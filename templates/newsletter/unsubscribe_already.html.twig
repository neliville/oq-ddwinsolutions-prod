{% extends 'base.html.twig' %}

{% block title %}Déjà désabonné | OUTILS-QUALITÉ{% endblock %}

{% block meta_description %}Vous êtes déjà désabonné de notre newsletter.{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 my-12">
    <div class="flex justify-center">
        <div class="w-full lg:max-w-2xl">
            <div class="rounded-lg bg-card shadow-sm">
                <div class="p-6 md:p-10 text-center">
                    <div class="mb-4">
                        <i class="fas fa-info-circle text-sky-500" style="font-size: 4rem;"></i>
                    </div>

                    <h1 class="text-2xl font-bold mb-4">Vous êtes déjà désabonné</h1>

                    <div class="flex items-start gap-3 rounded-lg border border-sky-200 bg-sky-50 text-sky-800 px-4 py-3 mb-4" role="alert">
                        <i class="fas fa-info-circle mr-2 shrink-0 mt-0.5"></i>
                        <div>L'adresse <strong>{{ email }}</strong> est déjà désabonnée de notre newsletter.</div>
                    </div>

                    <p class="text-muted-foreground mb-4">
                        Vous ne recevrez plus d'emails de notre part.
                    </p>

                    <a href="{{ path('app_home_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">
                        <i class="fas fa-home mr-2"></i>
                        Retour à l'accueil
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

