{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Préférences | OUTILS-QUALITÉ{% endblock %}

{% block meta_description %}Personnalisez votre espace QHSE — OUTILS-QUALITÉ{% endblock %}

{% block content %}
<div class="preferences-page">
    <header class="preferences-page__header">
        <h1 class="preferences-page__title">Préférences</h1>
        <p class="preferences-page__subtitle">Gérez votre compte, le pilotage QHSE, les notifications et l’affichage du tableau de bord.</p>
    </header>

    <div class="preferences-page__layout">
        {% include 'preferences/_nav.html.twig' %}

        <div class="preferences-panel">
            <div class="preferences-panel__inner">
                {% if active_tab == 'profile' %}
                    {% include 'preferences/tabs/_profile.html.twig' %}
                {% elseif active_tab == 'qhse' %}
                    {% include 'preferences/tabs/_qhse.html.twig' %}
                {% elseif active_tab == 'notifications' %}
                    {% include 'preferences/tabs/_notifications.html.twig' %}
                {% elseif active_tab == 'exports' %}
                    {% include 'preferences/tabs/_exports.html.twig' %}
                {% elseif active_tab == 'dashboard' %}
                    {% include 'preferences/tabs/_dashboard.html.twig' %}
                {% elseif active_tab == 'security' %}
                    {% include 'preferences/tabs/_security.html.twig' %}
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/export-branding.js') }}"></script>
    <script>
    (function () {
        function invalidateExportBrandingCacheIfNeeded() {
            if (window.OqExportBranding && typeof window.OqExportBranding.invalidateCache === 'function') {
                window.OqExportBranding.invalidateCache();
            }
        }
        function resetPasswordDialogUi(root) {
            if (!root) return;
            var formStep = root.querySelector('[data-step="form"]');
            var okStep = root.querySelector('[data-step="success"]');
            var feedback = root.querySelector('[data-reset-feedback]');
            if (formStep) formStep.classList.remove('hidden');
            if (okStep) okStep.classList.add('hidden');
            if (feedback) {
                feedback.classList.add('hidden');
                feedback.textContent = '';
            }
        }
        function bindPreferencesPasswordReset() {
            var root = document.querySelector('[data-preferences-password-reset-root]');
            if (!root || root.getAttribute('data-bound') === '1') return;
            root.setAttribute('data-bound', '1');
            var sendBtn = root.querySelector('[data-send-password-reset]');
            var csrf = document.getElementById('preferences-password-reset-csrf');
            var feedback = root.querySelector('[data-reset-feedback]');
            var stepForm = root.querySelector('[data-step="form"]');
            var stepSuccess = root.querySelector('[data-step="success"]');
            var successMsg = root.querySelector('[data-success-message]');
            if (!sendBtn || !csrf || !stepForm || !stepSuccess || !successMsg) return;
            document.querySelectorAll('[data-preferences-reset-opener]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    window.setTimeout(function () { resetPasswordDialogUi(root); }, 0);
                });
            });
            sendBtn.addEventListener('click', function () {
                if (feedback) {
                    feedback.classList.add('hidden');
                    feedback.textContent = '';
                }
                sendBtn.disabled = true;
                var fd = new FormData();
                fd.append('_token', csrf.value);
                var url = sendBtn.getAttribute('data-reset-url') || '';
                fetch(url, {
                    method: 'POST',
                    body: fd,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                })
                    .then(function (res) { return res.json().then(function (data) { return { res: res, data: data }; }); })
                    .catch(function () { return { res: { ok: false, status: 0 }, data: {} }; })
                    .then(function (_ref) {
                        var res = _ref.res;
                        var data = _ref.data;
                        if (res.ok && data.ok) {
                            successMsg.textContent = data.message || '';
                            stepForm.classList.add('hidden');
                            stepSuccess.classList.remove('hidden');
                        } else {
                            if (feedback) {
                                feedback.textContent = (data && data.message) ? data.message : 'Une erreur est survenue.';
                                feedback.classList.remove('hidden');
                            }
                        }
                    })
                    .finally(function () {
                        sendBtn.disabled = false;
                    });
            });
        }
        function scrollActivePrefNavIntoView() {
            var nav = document.querySelector('.pref-nav');
            if (!window.matchMedia('(min-width: 768px) and (max-width: 1023px)').matches) return;
            var active = nav.querySelector('.pref-nav__item.is-active, .pref-nav__item[aria-current="page"]');
            if (!active || nav.scrollWidth <= nav.clientWidth) return;
            active.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'auto' });
        }
        document.addEventListener('DOMContentLoaded', function () {
            bindPreferencesPasswordReset();
            scrollActivePrefNavIntoView();
            {% if active_tab == 'exports' %}
            {% for message in app.flashes('success') %}
            invalidateExportBrandingCacheIfNeeded();
            {% endfor %}
            {% endif %}
        });
        document.addEventListener('turbo:load', function () {
            bindPreferencesPasswordReset();
            scrollActivePrefNavIntoView();
            {% if active_tab == 'exports' %}
            {% for message in app.flashes('success') %}
            invalidateExportBrandingCacheIfNeeded();
            {% endfor %}
            {% endif %}
        });
    })();
    </script>
{% endblock %}
