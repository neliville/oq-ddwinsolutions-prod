{% include 'preferences/_panel_header.html.twig' with {
    title: 'Exports',
    description: 'Personnalisez les libellés affichés sur vos documents PDF exportés.',
} only %}

{{ form_start(export_form, { attr: { class: 'pref-form' } }) }}
    <div class="pref-form-grid pref-form-grid--two">
        <div class="pref-field-group">
            {% include 'components/form/field_with_contextual_help.html.twig' with { field: export_form.exportDisplayName, help_id: 'help.pref.export.display_name' } %}
        </div>
        <div class="pref-field-group">
            {% include 'components/form/field_with_contextual_help.html.twig' with { field: export_form.exportJobTitle, help_id: 'help.pref.export.job_title' } %}
        </div>
        <div class="pref-field-group">
            {% include 'components/form/field_with_contextual_help.html.twig' with { field: export_form.exportCompanyName, help_id: 'help.pref.export.company' } %}
        </div>
        <div class="pref-field-group pref-form-grid__full">
            {% include 'components/form/field_with_contextual_help.html.twig' with { field: export_form.exportPdfFooter, help_id: 'help.pref.export.pdf_footer' } %}
        </div>
    </div>
    <p class="pref-form-hint pref-form-hint--spaced">Les outils peuvent récupérer ces libellés via l’API (connecté). Le logo personnalisé pourra être ajouté ultérieurement.</p>
    {% include 'preferences/_form_footer.html.twig' %}
{{ form_end(export_form) }}
