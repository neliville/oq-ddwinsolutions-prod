{% extends 'layout/admin_base.html.twig' %}

{% block title %}Exigences d’audit (admin){% endblock %}

{% block content %}
<div class="w-full max-w-5xl mx-auto px-4 py-6">
    <h1 class="text-2xl font-bold mb-2">Exigences d’audit</h1>
    <p class="text-sm text-muted-foreground mb-4">
        <a href="{{ path('app_admin_dashboard_index') }}" class="app-inline-link">← Administration</a>
        · <a href="{{ path('app_admin_qse_audit_standards_index') }}" class="app-inline-link">Référentiels</a>
        · <a href="{{ path('app_admin_qse_req_import_index') }}" class="app-inline-link">Import (aperçu)</a>
    </p>
    <form method="get" class="mb-6 flex flex-wrap gap-2 items-end">
        <div>
            <label class="block text-xs text-muted-foreground mb-1" for="standard">Référentiel</label>
            <select id="standard" name="standard" class="rounded-md border border-input bg-background px-3 py-2 text-sm" onchange="this.form.submit()">
                <option value="">— Choisir —</option>
                {% for s in standards %}
                    <option value="{{ s.id }}" {% if selectedStandard and selectedStandard.id == s.id %}selected{% endif %}>{{ s.name }}</option>
                {% endfor %}
            </select>
        </div>
    </form>
    {% if selectedStandard %}
        <p class="text-sm mb-4">Norme : <strong>{{ selectedStandard.name }}</strong></p>
        <div class="overflow-x-auto rounded-lg border border-border">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-border bg-muted/40">
                        <th class="text-left p-2">Ordre</th>
                        <th class="text-left p-2">Chapitre</th>
                        <th class="text-left p-2">Article</th>
                        <th class="text-left p-2">Exigence</th>
                        <th class="text-left p-2">Actif</th>
                        <th class="text-right p-2">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for r in requirements %}
                    <tr class="border-b border-border">
                        <td class="p-2">{{ r.displayOrder }}</td>
                        <td class="p-2">{{ r.chapter }}</td>
                        <td class="p-2">{{ r.isoArticle }}</td>
                        <td class="p-2 max-w-md truncate" title="{{ r.requirementText }}">{{ r.requirementText }}</td>
                        <td class="p-2">{% if r.active %}oui{% else %}non{% endif %}</td>
                        <td class="p-2 text-right space-x-2">
                            <a href="{{ path('app_admin_qse_audit_requirements_edit', { id: r.id }) }}" class="app-inline-link">Éditer</a>
                            <form method="post" action="{{ path('app_admin_qse_audit_requirements_reorder', { id: r.id }) }}" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_qse_audit_requirement_reorder') }}">
                                <input type="hidden" name="direction" value="up">
                                <button type="submit" class="text-xs text-muted-foreground hover:underline">↑</button>
                            </form>
                            <form method="post" action="{{ path('app_admin_qse_audit_requirements_reorder', { id: r.id }) }}" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_qse_audit_requirement_reorder') }}">
                                <input type="hidden" name="direction" value="down">
                                <button type="submit" class="text-xs text-muted-foreground hover:underline">↓</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="p-4 text-muted-foreground">Aucune exigence pour ce référentiel.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <p class="text-muted-foreground text-sm">Sélectionnez un référentiel pour lister les exigences.</p>
    {% endif %}
</div>
{% endblock %}
