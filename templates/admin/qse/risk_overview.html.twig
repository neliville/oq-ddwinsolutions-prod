{% extends 'layout/admin_base.html.twig' %}

{% block title %}Matrice des risques — Administration{% endblock %}

{% block content %}
<div class="w-full max-w-[100rem] mx-auto space-y-6">
    <div class="flex flex-col gap-1">
        <h1 class="text-2xl font-bold tracking-tight text-foreground m-0">Risques (vue globale)</h1>
        <p class="text-muted-foreground text-sm m-0">Synthèse agrégée — identifier les sujets à traiter en priorité.</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Content class="p-5 sm:p-6">
                <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-1">Entrées non clôturées</p>
                <p class="text-2xl font-bold tabular-nums text-foreground m-0">{{ openNonClosed }}</p>
            </twig:Card:Content>
        </twig:Card>
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Content class="p-5 sm:p-6">
                <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-1">Critiques / score élevé</p>
                <p class="text-2xl font-bold tabular-nums text-foreground m-0">{{ criticalOrHighScore }}</p>
                <p class="text-xs text-muted-foreground mb-0 mt-1">Statut critique ou score ≥ 12</p>
            </twig:Card:Content>
        </twig:Card>
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Content class="p-5 sm:p-6 flex items-center justify-center">
                <twig:Button as="a" href="{{ path('app_admin_dashboard_index') }}" variant="outline" size="sm" class="no-underline">
                    Retour dashboard
                </twig:Button>
            </twig:Card:Content>
        </twig:Card>
    </div>

    <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
        <twig:Card:Header class="pb-2">
            <twig:Card:Title class="text-base">Risques ouverts (extrait)</twig:Card:Title>
        </twig:Card:Header>
        <twig:Card:Content class="p-0 sm:p-0 overflow-x-auto">
            {% if recentOpen is empty %}
                <p class="text-sm text-muted-foreground p-6 mb-0">Aucun risque ouvert.</p>
            {% else %}
                <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                    <thead class="border-b border-border bg-muted/40">
                        <tr>
                            <th class="text-left font-medium px-4 py-3">Risque identifié</th>
                            <th class="text-left font-medium px-4 py-3">Compte</th>
                            <th class="text-left font-medium px-4 py-3">Statut</th>
                            <th class="text-right font-medium px-4 py-3">Score</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for risk in recentOpen %}
                        <tr class="border-b border-border/60">
                            <td class="px-4 py-2">{{ risk.identifiedRisk }}</td>
                            <td class="px-4 py-2">{{ risk.owner.email }}</td>
                            <td class="px-4 py-2"><code class="text-xs">{{ risk.status.value }}</code></td>
                            <td class="px-4 py-2 text-right">{{ risk.criticalityScore ?? '—' }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </twig:Card:Content>
    </twig:Card>
</div>
{% endblock %}
