{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Message de contact | Administration{% endblock %}

{% block content %}
<div class="w-full">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <a href="{{ path('app_admin_contact_index') }}" class="inline-flex items-center justify-center gap-2 border border-border text-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:bg-accent transition-colors no-underline mb-2">
                <i data-lucide="arrow-left" width="16" height="16" class="mr-1"></i>
                Retour à la liste
            </a>
            <h1 class="text-2xl font-bold mb-1">Message de contact</h1>
            <p class="text-muted-foreground mb-0">Détails du message reçu</p>
        </div>
        <div>
            {% if not message.read %}
            <span class="inline-flex items-center rounded-full bg-yellow-100 text-yellow-700 px-2.5 py-0.5 text-xs font-semibold mr-2">Non lu</span>
            {% else %}
            <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-semibold mr-2">Lu</span>
            {% endif %}
            {% if message.replied %}
            <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold">Répondu</span>
            {% endif %}
        </div>
    </div>

    <div class="grid grid-cols-12 gap-6">
        <!-- Message principal -->
        <div class="lg:col-span-8 col-span-12">
            <div class="rounded-lg bg-card shadow-sm">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <div class="flex justify-between items-center">
                        <h5 class="mb-0">
                            <i data-lucide="mail" width="20" height="20" class="mr-2"></i>
                            {{ message.subject|default('Sans sujet') }}
                        </h5>
                        <small class="text-muted-foreground">{{ message.createdAt|date('d/m/Y à H:i') }}</small>
                    </div>
                </div>
                <div class="p-6">
                    <!-- Informations expéditeur -->
                    <div class="mb-6 pb-6 border-b border-border">
                        <h6 class="text-muted-foreground uppercase text-sm mb-4">Expéditeur</h6>
                        <div class="flex items-center">
                            <div class="bg-primary/10 text-primary rounded-full flex items-center justify-center mr-4" style="width: 48px; height: 48px;">
                                <i data-lucide="user" width="24" height="24"></i>
                            </div>
                            <div>
                                <strong>{{ message.name }}</strong>
                                <br>
                                <a href="mailto:{{ message.email }}" class="text-decoration-none">
                                    <i data-lucide="mail" width="14" height="14" class="mr-1"></i>
                                    {{ message.email }}
                                </a>
                                {% if message.user %}
                                <br>
                                <small class="text-muted-foreground">
                                    <i data-lucide="user-check" width="14" height="14" class="mr-1"></i>
                                    Utilisateur enregistré
                                </small>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <!-- Contenu du message -->
                    <div class="mb-6">
                        <h6 class="text-muted-foreground uppercase text-sm mb-4">Message</h6>
                        <div class="bg-muted rounded p-4">
                            <p class="mb-0">{{ message.message|nl2br }}</p>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="flex gap-2">
                        {% if not message.read %}
                        <form method="post" action="{{ path('app_admin_contact_mark_read', {id: message.id}) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('mark_read_' ~ message.id) }}">
                            <button type="submit" class="inline-flex items-center justify-center gap-2 bg-green-600 text-white px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">
                                <i data-lucide="check" width="16" height="16" class="mr-1"></i>
                                Marquer comme lu
                            </button>
                        </form>
                        {% else %}
                        <form method="post" action="{{ path('app_admin_contact_mark_unread', {id: message.id}) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('mark_unread_' ~ message.id) }}">
                            <button type="submit" class="inline-flex items-center justify-center gap-2 border border-amber-600 text-amber-600 px-4 py-2 rounded-md font-medium hover:bg-amber-600/5 transition-colors">
                                <i data-lucide="mail" width="16" height="16" class="mr-1"></i>
                                Marquer comme non lu
                            </button>
                        </form>
                        {% endif %}

                        <a href="mailto:{{ message.email }}?subject=Re: {{ message.subject|default('Votre message') }}"
                           class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">
                            <i data-lucide="reply" width="16" height="16" class="mr-1"></i>
                            Répondre par email
                        </a>

                        <form method="post" action="{{ path('app_admin_contact_delete', {id: message.id}) }}"
                              class="inline ml-auto"
                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce message ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ message.id) }}">
                            <button type="submit" class="inline-flex items-center justify-center gap-2 border border-destructive text-destructive px-4 py-2 rounded-md font-medium hover:bg-destructive/5 transition-colors">
                                <i data-lucide="trash-2" width="16" height="16" class="mr-1"></i>
                                Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Informations et réponse -->
        <div class="lg:col-span-4 col-span-12">
            <!-- Informations -->
            <div class="rounded-lg bg-card shadow-sm mb-6">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h6 class="mb-0">Informations</h6>
                </div>
                <div class="p-6">
                    <div class="mb-4">
                        <small class="text-muted-foreground block">Date de réception</small>
                        <strong>{{ message.createdAt|date('d/m/Y à H:i') }}</strong>
                    </div>
                    <div class="mb-4">
                        <small class="text-muted-foreground block">Statut</small>
                        <div>
                            {% if not message.read %}
                            <span class="inline-flex items-center rounded-full bg-yellow-100 text-yellow-700 px-2.5 py-0.5 text-xs font-semibold">Non lu</span>
                            {% else %}
                            <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-semibold">Lu</span>
                            {% endif %}
                            {% if message.replied %}
                            <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold ml-1">Répondu</span>
                            {% else %}
                            <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold ml-1">Non répondu</span>
                            {% endif %}
                        </div>
                    </div>
                    {% if message.user %}
                    <div>
                        <small class="text-muted-foreground block">Utilisateur</small>
                        <strong>{{ message.user.email }}</strong>
                    </div>
                    {% endif %}
                </div>
            </div>

            <!-- Formulaire de réponse -->
            <div class="rounded-lg bg-card shadow-sm">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h6 class="mb-0">Répondre</h6>
                </div>
                <div class="p-6">
                    <form method="post" action="{{ path('app_admin_contact_reply', {id: message.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('reply_' ~ message.id) }}">

                        <div class="mb-4">
                            <label for="reply_message" class="form-label">Votre réponse</label>
                            <textarea class="form-control" id="reply_message" name="reply_message" rows="5" required placeholder="Tapez votre réponse ici..."></textarea>
                            <small class="text-muted-foreground">Cette réponse sera envoyée par email à {{ message.email }}</small>
                        </div>

                        <button type="submit" class="w-full inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">
                            <i data-lucide="send" width="16" height="16" class="mr-1"></i>
                            Envoyer la réponse
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
