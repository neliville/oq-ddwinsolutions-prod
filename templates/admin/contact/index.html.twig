{% extends 'layout/admin_base.html.twig' %}

{% block title %}Messages de contact | Administration{% endblock %}

{% block content %}
<div class="w-full">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold mb-1">Messages de contact</h1>
            <p class="text-muted-foreground mb-0">Gérer les messages reçus via le formulaire de contact</p>
        </div>
        <div>
            {% if unreadCount > 0 %}
            <span class="inline-flex items-center rounded-full bg-red-100 text-destructive px-2.5 py-0.5 text-xs font-semibold mr-2">
                <i data-lucide="mail" width="14" height="14" class="mr-1"></i>
                {{ unreadCount }} non lu{{ unreadCount > 1 ? 's' : '' }}
            </span>
            {% endif %}
        </div>
    </div>

    <!-- Filtres -->
    <div class="rounded-lg bg-card shadow-sm mb-6">
        <div class="p-6">
            <div class="flex flex-wrap gap-1" role="group" aria-label="Filtres">
                <a href="{{ path('app_admin_contact_index', {filter: 'all'}) }}"
                   class="{{ currentFilter == 'all' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Tous ({{ total }})
                </a>
                <a href="{{ path('app_admin_contact_index', {filter: 'unread'}) }}"
                   class="{{ currentFilter == 'unread' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Non lus ({{ unreadCount }})
                </a>
                <a href="{{ path('app_admin_contact_index', {filter: 'read'}) }}"
                   class="{{ currentFilter == 'read' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Lus ({{ readCount }})
                </a>
                <a href="{{ path('app_admin_contact_index', {filter: 'replied'}) }}"
                   class="{{ currentFilter == 'replied' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Répondus ({{ repliedCount }})
                </a>
                <a href="{{ path('app_admin_contact_index', {filter: 'unreplied'}) }}"
                   class="{{ currentFilter == 'unreplied' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Non répondus ({{ unrepliedCount }})
                </a>
            </div>
        </div>
    </div>

    <!-- Messages -->
    {% if messages|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-contact', list_caption: 'Messages de contact' } %}
        {% block list_table %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                    <caption class="sr-only">Liste des messages de contact</caption>
                    <thead class="table-light">
                        <tr>
                            <th scope="col" style="width: 50px;">
                                <input type="checkbox" class="form-check-input" id="selectAll" aria-label="Sélectionner tous les messages">
                            </th>
                            <th scope="col">De</th>
                            <th scope="col">Sujet</th>
                            <th scope="col">Message</th>
                            <th scope="col">Date</th>
                            <th scope="col">Statut</th>
                            <th scope="col" style="width: 120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for message in messages %}
                        <tr class="{% if not message.read %}table-warning{% endif %}">
                            <td>
                                <input type="checkbox" class="form-check-input message-checkbox" value="{{ message.id }}" aria-label="Sélectionner message {{ message.id }}">
                            </td>
                            <td>
                                <div class="flex items-center">
                                    <div class="bg-primary/10 text-primary rounded-full flex items-center justify-center mr-2" style="width: 32px; height: 32px;">
                                        <i data-lucide="user" width="16" height="16"></i>
                                    </div>
                                    <div>
                                        <strong>{{ message.name }}</strong>
                                        <br>
                                        <small class="text-muted-foreground">{{ message.email }}</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <strong>{{ message.subject|default('Sans sujet') }}</strong>
                            </td>
                            <td>
                                <p class="mb-0 truncate" style="max-width: 300px;" title="{{ message.message }}">
                                    {{ message.message|slice(0, 100) }}{% if message.message|length > 100 %}...{% endif %}
                                </p>
                            </td>
                            <td>
                                <small>{{ message.createdAt|date('d/m/Y H:i') }}</small>
                            </td>
                            <td>
                                {% if not message.read %}
                                <span class="inline-flex items-center rounded-full bg-yellow-100 text-yellow-700 px-2.5 py-0.5 text-xs font-semibold">Non lu</span>
                                {% else %}
                                <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-semibold">Lu</span>
                                {% endif %}
                                {% if message.replied %}
                                <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold ml-1">Répondu</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="flex gap-1" role="group">
                                    <a href="{{ path('app_admin_contact_show', {id: message.id}) }}"
                                       class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline" title="Voir">
                                        <i data-lucide="eye" width="14" height="14"></i>
                                    </a>
                                    {% if message.read %}
                                    <form method="post" action="{{ path('app_admin_contact_mark_unread', {id: message.id}) }}" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('mark_unread_' ~ message.id) }}">
                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-amber-600 text-amber-600 px-3 py-1.5 text-sm rounded-md hover:bg-amber-600/5 transition-colors" title="Marquer non lu">
                                            <i data-lucide="mail" width="14" height="14"></i>
                                        </button>
                                    </form>
                                    {% else %}
                                    <form method="post" action="{{ path('app_admin_contact_mark_read', {id: message.id}) }}" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('mark_read_' ~ message.id) }}">
                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-green-600 text-green-600 px-3 py-1.5 text-sm rounded-md hover:bg-green-600/5 transition-colors" title="Marquer lu">
                                            <i data-lucide="check" width="14" height="14"></i>
                                        </button>
                                    </form>
                                    {% endif %}
                                    <form method="post" action="{{ path('app_admin_contact_delete', {id: message.id}) }}"
                                          class="inline"
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce message ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ message.id) }}">
                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors" title="Supprimer">
                                            <i data-lucide="trash-2" width="14" height="14"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
        {% block list_cards %}
            <div class="flex items-center gap-2 mb-4 pb-2 border-b border-border">
                <input type="checkbox" class="form-check-input" id="selectAllCards" aria-label="Tout sélectionner (vue cartes)">
                <label for="selectAllCards" class="text-sm text-muted-foreground mb-0">Sélectionner tout</label>
            </div>
            <div class="grid gap-3 contact-message-list">
                {% for message in messages %}
                <div>
                    <article class="rounded-lg bg-card shadow-sm admin-list-item-card h-full {% if not message.read %}border-l-4 border-amber-500{% endif %}">
                        <div class="p-6">
                            <div class="flex gap-2 mb-2">
                                <input type="checkbox" class="form-check-input message-checkbox shrink-0 mt-1" value="{{ message.id }}" aria-label="Sélectionner {{ message.email }}">
                                <div class="min-w-0 flex-1">
                                    <div class="flex justify-between items-start gap-2 flex-wrap">
                                        <div>
                                            <h2 class="text-base font-semibold mb-1">{{ message.name }}</h2>
                                            <a href="mailto:{{ message.email }}" class="text-sm text-muted-foreground break-all">{{ message.email }}</a>
                                        </div>
                                        <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">{{ message.createdAt|date('d/m/Y H:i') }}</span>
                                    </div>
                                </div>
                            </div>
                            <p class="text-muted-foreground mb-2 text-sm font-medium">{{ message.subject|default('Sans sujet') }}</p>
                            <p class="mb-4 text-sm">{{ message.message|slice(0, 220) }}{% if message.message|length > 220 %}…{% endif %}</p>
                            <div class="flex flex-wrap gap-2 mb-4">
                                {% if not message.read %}
                                <span class="inline-flex items-center rounded-full bg-yellow-100 text-yellow-700 px-2.5 py-0.5 text-xs font-semibold">Non lu</span>
                                {% else %}
                                <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-semibold">Lu</span>
                                {% endif %}
                                {% if message.replied %}
                                <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold">Répondu</span>
                                {% endif %}
                            </div>
                            <div class="flex flex-wrap gap-2">
                                <a href="{{ path('app_admin_contact_show', {id: message.id}) }}" class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline"><i data-lucide="eye" width="14" height="14" class="mr-1"></i>Ouvrir</a>
                                {% if message.read %}
                                <form method="post" action="{{ path('app_admin_contact_mark_unread', {id: message.id}) }}" class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('mark_unread_' ~ message.id) }}">
                                    <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-amber-600 text-amber-600 px-3 py-1.5 text-sm rounded-md hover:bg-amber-600/5 transition-colors"><i data-lucide="mail" width="14" height="14" class="mr-1"></i>Non lu</button>
                                </form>
                                {% else %}
                                <form method="post" action="{{ path('app_admin_contact_mark_read', {id: message.id}) }}" class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('mark_read_' ~ message.id) }}">
                                    <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-green-600 text-green-600 px-3 py-1.5 text-sm rounded-md hover:bg-green-600/5 transition-colors"><i data-lucide="check" width="14" height="14" class="mr-1"></i>Lu</button>
                                </form>
                                {% endif %}
                                <form method="post" action="{{ path('app_admin_contact_delete', {id: message.id}) }}" class="inline" onsubmit="return confirm('Supprimer ce message ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ message.id) }}">
                                    <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors"><i data-lucide="trash-2" width="14" height="14" class="mr-1"></i>Supprimer</button>
                                </form>
                            </div>
                        </div>
                    </article>
                </div>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}
            {% if totalPages > 1 %}
            <div class="card-footer bg-white border-t border-border rounded-b">
                <nav aria-label="Pagination">
                    <ul class="pagination pagination-sm mb-0 justify-center flex-wrap">
                        {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_contact_index', {filter: currentFilter, page: currentPage - 1}) }}">
                                <i data-lucide="chevron-left" width="14" height="14"></i>
                            </a>
                        </li>
                        {% endif %}

                        {% for i in 1..totalPages %}
                        {% if i == currentPage %}
                        <li class="page-item active">
                            <span class="page-link">{{ i }}</span>
                        </li>
                        {% elseif i <= 3 or i >= totalPages - 2 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_contact_index', {filter: currentFilter, page: i}) }}">{{ i }}</a>
                        </li>
                        {% elseif i == 4 or i == totalPages - 3 %}
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                        {% endif %}
                        {% endfor %}

                        {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_contact_index', {filter: currentFilter, page: currentPage + 1}) }}">
                                <i data-lucide="chevron-right" width="14" height="14"></i>
                            </a>
                        </li>
                        {% endif %}
                    </ul>
                </nav>
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
    {% else %}
    <div class="rounded-lg bg-card shadow-sm">
        <div class="p-6 text-center py-12">
            <i data-lucide="inbox" width="48" height="48" class="text-muted-foreground mb-4"></i>
            <p class="text-muted-foreground mb-0">Aucun message{{ currentFilter != 'all' ? ' (' ~ currentFilter ~ ')' : '' }}</p>
        </div>
    </div>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}

function syncMessageCheckboxes(checked) {
    document.querySelectorAll('.message-checkbox').forEach(function(cb) {
        cb.checked = checked;
    });
}

document.getElementById('selectAll')?.addEventListener('change', function(e) {
    syncMessageCheckboxes(e.target.checked);
    const c = document.getElementById('selectAllCards');
    if (c) c.checked = e.target.checked;
});

document.getElementById('selectAllCards')?.addEventListener('change', function(e) {
    syncMessageCheckboxes(e.target.checked);
    const t = document.getElementById('selectAll');
    if (t) t.checked = e.target.checked;
});
</script>
{% endblock %}
