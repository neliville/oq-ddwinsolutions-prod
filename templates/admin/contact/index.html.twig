{% extends 'layout/admin_base.html.twig' %}

{% block title %}Messages de contact | Administration{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-[100rem] space-y-6">
    <twig:DataPageHeader title="Messages de contact" description="Gérer les messages reçus via le formulaire de contact">
        <twig:block name="actions">
            {% if unreadCount > 0 %}
                <twig:Badge variant="destructive" class="gap-1.5 px-3 py-1.5">
                    <twig:ux:icon name="lucide:mail" class="size-3.5 shrink-0" aria-hidden="true" />
                    {{ unreadCount }} non lu{{ unreadCount > 1 ? 's' : '' }}
                </twig:Badge>
            {% endif %}
        </twig:block>
    </twig:DataPageHeader>

    <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
        <twig:Card:Content class="p-4 sm:p-5">
            <div class="flex flex-wrap gap-2" role="group" aria-label="Filtres">
                <twig:Button as="a" href="{{ path('app_admin_contact_index', {filter: 'all'}) }}" variant="{{ currentFilter == 'all' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Tous ({{ total }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_contact_index', {filter: 'unread'}) }}" variant="{{ currentFilter == 'unread' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Non lus ({{ unreadCount }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_contact_index', {filter: 'read'}) }}" variant="{{ currentFilter == 'read' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Lus ({{ readCount }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_contact_index', {filter: 'replied'}) }}" variant="{{ currentFilter == 'replied' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Répondus ({{ repliedCount }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_contact_index', {filter: 'unreplied'}) }}" variant="{{ currentFilter == 'unreplied' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Non répondus ({{ unrepliedCount }})
                </twig:Button>
            </div>
        </twig:Card:Content>
    </twig:Card>

    {% if messages|length > 0 %}
        {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-contact', list_caption: 'Messages de contact' } %}
            {% block list_table %}
                <twig:Table class="[&_tbody_tr:hover]:bg-accent/60">
                    <twig:Table:Caption class="sr-only">Liste des messages de contact</twig:Table:Caption>
                    <twig:Table:Header>
                        <twig:Table:Row class="border-b border-border bg-muted/40 hover:bg-muted/40">
                            <twig:Table:Head scope="col" class="w-12 pr-0">
                                <input type="checkbox" id="selectAll" class="size-4 rounded border-input accent-primary" aria-label="Sélectionner tous les messages">
                            </twig:Table:Head>
                            <twig:Table:Head scope="col" class="min-w-[14rem] font-medium">De</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Sujet</twig:Table:Head>
                            <twig:Table:Head scope="col" class="min-w-[8rem] font-medium">Message</twig:Table:Head>
                            <twig:Table:Head scope="col" class="whitespace-nowrap font-medium">Date</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Statut</twig:Table:Head>
                            <twig:Table:Head scope="col" class="w-[1%] text-end font-medium whitespace-nowrap">Actions</twig:Table:Head>
                        </twig:Table:Row>
                    </twig:Table:Header>
                    <twig:Table:Body>
                        {% for message in messages %}
                            <twig:Table:Row class="border-b border-border/60 {{ not message.read ? 'bg-amber-500/[0.07]' : '' }}">
                                <twig:Table:Cell class="pr-0">
                                    <input type="checkbox" class="message-checkbox size-4 rounded border-input accent-primary" value="{{ message.id }}" aria-label="Sélectionner message {{ message.id }}">
                                </twig:Table:Cell>
                                <twig:Table:Cell>
                                    <div class="flex min-w-0 items-center gap-2">
                                        <div class="flex size-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                                            <i data-lucide="user" width="16" height="16" aria-hidden="true"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <div class="font-semibold text-foreground">{{ message.name }}</div>
                                            <div class="truncate text-xs text-muted-foreground">{{ message.email }}</div>
                                        </div>
                                    </div>
                                </twig:Table:Cell>
                                <twig:Table:Cell class="max-w-[14rem] font-medium">{{ message.subject|default('Sans sujet') }}</twig:Table:Cell>
                                <twig:Table:Cell>
                                    <p class="mb-0 max-w-[18rem] truncate text-sm text-muted-foreground" title="{{ message.message }}">
                                        {{ message.message|slice(0, 100) }}{% if message.message|length > 100 %}…{% endif %}
                                    </p>
                                </twig:Table:Cell>
                                <twig:Table:Cell class="whitespace-nowrap text-xs tabular-nums text-muted-foreground">{{ message.createdAt|date('d/m/Y H:i') }}</twig:Table:Cell>
                                <twig:Table:Cell>
                                    <div class="flex flex-wrap gap-1">
                                        {% if not message.read %}
                                            <twig:Badge variant="outline" class="border-amber-500/40 bg-amber-500/10 text-amber-950 dark:text-amber-50">Non lu</twig:Badge>
                                        {% else %}
                                            <twig:Badge variant="outline" class="border-emerald-500/40 bg-emerald-500/10 text-emerald-900 dark:text-emerald-200">Lu</twig:Badge>
                                        {% endif %}
                                        {% if message.replied %}
                                            <twig:Badge variant="secondary">Répondu</twig:Badge>
                                        {% endif %}
                                    </div>
                                </twig:Table:Cell>
                                <twig:Table:Cell class="text-end">
                                    <div class="inline-flex flex-nowrap gap-1" role="group">
                                        <twig:Button as="a" href="{{ path('app_admin_contact_show', {id: message.id}) }}" variant="outline" size="icon" class="size-9 no-underline shrink-0" title="Voir">
                                            <twig:ux:icon name="lucide:eye" class="size-4" aria-hidden="true" />
                                            <span class="sr-only">Voir</span>
                                        </twig:Button>
                                        {% if message.read %}
                                            <form method="post" action="{{ path('app_admin_contact_mark_unread', {id: message.id}) }}" class="inline-flex">
                                                <input type="hidden" name="_token" value="{{ csrf_token('mark_unread_' ~ message.id) }}">
                                                <twig:Button type="submit" variant="outline" size="icon" class="size-9 shrink-0 text-amber-700 hover:bg-amber-500/10 dark:text-amber-400" title="Marquer non lu">
                                                    <twig:ux:icon name="lucide:mail" class="size-4" aria-hidden="true" />
                                                    <span class="sr-only">Marquer non lu</span>
                                                </twig:Button>
                                            </form>
                                        {% else %}
                                            <form method="post" action="{{ path('app_admin_contact_mark_read', {id: message.id}) }}" class="inline-flex">
                                                <input type="hidden" name="_token" value="{{ csrf_token('mark_read_' ~ message.id) }}">
                                                <twig:Button type="submit" variant="outline" size="icon" class="size-9 shrink-0 text-emerald-700 hover:bg-emerald-500/10 dark:text-emerald-400" title="Marquer lu">
                                                    <twig:ux:icon name="lucide:check" class="size-4" aria-hidden="true" />
                                                    <span class="sr-only">Marquer lu</span>
                                                </twig:Button>
                                            </form>
                                        {% endif %}
                                        <form method="post" action="{{ path('app_admin_contact_delete', {id: message.id}) }}" class="inline-flex" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce message ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ message.id) }}">
                                            <twig:Button type="submit" variant="outline" size="icon" class="size-9 shrink-0 text-destructive hover:bg-destructive/10" title="Supprimer">
                                                <twig:ux:icon name="lucide:trash-2" class="size-4" aria-hidden="true" />
                                                <span class="sr-only">Supprimer</span>
                                            </twig:Button>
                                        </form>
                                    </div>
                                </twig:Table:Cell>
                            </twig:Table:Row>
                        {% endfor %}
                    </twig:Table:Body>
                </twig:Table>
            {% endblock %}
            {% block list_cards %}
                <div class="mb-4 flex items-center gap-2 border-b border-border pb-2">
                    <input type="checkbox" id="selectAllCards" class="size-4 rounded border-input accent-primary" aria-label="Tout sélectionner (vue cartes)">
                    <label for="selectAllCards" class="mb-0 cursor-pointer select-none text-sm text-muted-foreground">Sélectionner tout</label>
                </div>
                <div class="contact-message-list grid gap-3">
                    {% for message in messages %}
                        <div>
                            <twig:Card class="admin-list-item-card h-full border-border/80 shadow-sm ring-1 ring-border/40 {{ not message.read ? 'border-l-4 border-l-amber-500' : '' }}">
                                <twig:Card:Content class="p-5 sm:p-6">
                                    <div class="mb-2 flex gap-2">
                                        <input type="checkbox" class="message-checkbox mt-1 size-4 shrink-0 rounded border-input accent-primary" value="{{ message.id }}" aria-label="Sélectionner {{ message.email }}">
                                        <div class="min-w-0 flex-1">
                                            <div class="flex flex-wrap items-start justify-between gap-2">
                                                <div>
                                                    <h2 class="mb-1 text-base font-semibold">{{ message.name }}</h2>
                                                    <a href="mailto:{{ message.email }}" class="break-all text-sm text-muted-foreground hover:underline">{{ message.email }}</a>
                                                </div>
                                                <twig:Badge variant="outline" class="shrink-0 tabular-nums font-normal">{{ message.createdAt|date('d/m/Y H:i') }}</twig:Badge>
                                            </div>
                                        </div>
                                    </div>
                                    <p class="mb-2 text-sm font-medium text-muted-foreground">{{ message.subject|default('Sans sujet') }}</p>
                                    <p class="mb-4 text-sm">{{ message.message|slice(0, 220) }}{% if message.message|length > 220 %}…{% endif %}</p>
                                    <div class="mb-4 flex flex-wrap gap-2">
                                        {% if not message.read %}
                                            <twig:Badge variant="outline" class="border-amber-500/40 bg-amber-500/10 text-amber-950 dark:text-amber-50">Non lu</twig:Badge>
                                        {% else %}
                                            <twig:Badge variant="outline" class="border-emerald-500/40 bg-emerald-500/10 text-emerald-900 dark:text-emerald-200">Lu</twig:Badge>
                                        {% endif %}
                                        {% if message.replied %}
                                            <twig:Badge variant="secondary">Répondu</twig:Badge>
                                        {% endif %}
                                    </div>
                                    <div class="flex flex-wrap gap-2">
                                        <twig:Button as="a" href="{{ path('app_admin_contact_show', {id: message.id}) }}" variant="outline" size="sm" class="no-underline gap-2">
                                            <twig:ux:icon name="lucide:eye" class="size-4 shrink-0" aria-hidden="true" /> Ouvrir
                                        </twig:Button>
                                        {% if message.read %}
                                            <form method="post" action="{{ path('app_admin_contact_mark_unread', {id: message.id}) }}" class="inline-flex">
                                                <input type="hidden" name="_token" value="{{ csrf_token('mark_unread_' ~ message.id) }}">
                                                <twig:Button type="submit" variant="outline" size="sm" class="gap-2 text-amber-700 hover:bg-amber-500/10 dark:text-amber-400">
                                                    <twig:ux:icon name="lucide:mail" class="size-4 shrink-0" aria-hidden="true" /> Non lu
                                                </twig:Button>
                                            </form>
                                        {% else %}
                                            <form method="post" action="{{ path('app_admin_contact_mark_read', {id: message.id}) }}" class="inline-flex">
                                                <input type="hidden" name="_token" value="{{ csrf_token('mark_read_' ~ message.id) }}">
                                                <twig:Button type="submit" variant="outline" size="sm" class="gap-2 text-emerald-700 hover:bg-emerald-500/10 dark:text-emerald-400">
                                                    <twig:ux:icon name="lucide:check" class="size-4 shrink-0" aria-hidden="true" /> Lu
                                                </twig:Button>
                                            </form>
                                        {% endif %}
                                        <form method="post" action="{{ path('app_admin_contact_delete', {id: message.id}) }}" class="inline-flex" onsubmit="return confirm('Supprimer ce message ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ message.id) }}">
                                            <twig:Button type="submit" variant="outline" size="sm" class="gap-2 text-destructive hover:bg-destructive/10">
                                                <twig:ux:icon name="lucide:trash-2" class="size-4 shrink-0" aria-hidden="true" /> Supprimer
                                            </twig:Button>
                                        </form>
                                    </div>
                                </twig:Card:Content>
                            </twig:Card>
                        </div>
                    {% endfor %}
                </div>
            {% endblock %}
            {% block list_footer %}
                {% include 'components/admin/list_pagination.html.twig' with {
                    routeName: 'app_admin_contact_index',
                    routeParams: { filter: currentFilter },
                    currentPage: currentPage,
                    totalPages: totalPages,
                } %}
            {% endblock %}
        {% endembed %}
    {% else %}
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Content class="flex flex-col items-center justify-center gap-3 py-14 text-center">
                <twig:ux:icon name="lucide:inbox" class="size-12 text-muted-foreground" aria-hidden="true" />
                <p class="m-0 text-sm text-muted-foreground">Aucun message{{ currentFilter != 'all' ? ' (' ~ currentFilter ~ ')' : '' }}</p>
            </twig:Card:Content>
        </twig:Card>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}

function syncMessageCheckboxes(checked) {
    document.querySelectorAll('.message-checkbox').forEach(function(cb) {
        cb.checked = checked;
    });
}

document.getElementById('selectAll')?.addEventListener('change', function(e) {
    syncMessageCheckboxes(e.target.checked);
    const c = document.getElementById('selectAllCards');
    if (c) c.checked = e.target.checked;
});

document.getElementById('selectAllCards')?.addEventListener('change', function(e) {
    syncMessageCheckboxes(e.target.checked);
    const t = document.getElementById('selectAll');
    if (t) t.checked = e.target.checked;
});
</script>
{% endblock %}
