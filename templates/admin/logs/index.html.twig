{% extends 'layout/admin_base.html.twig' %}

{% block title %}Logs d'administration | Administration{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-[100rem] space-y-6">
    <twig:DataPageHeader title="Logs d’administration" description="Historique des actions d’administration">
        <twig:block name="actions">
            <twig:Button as="a" href="{{ path('app_admin_logs_export', app.request.query.all) }}" variant="outline" size="sm" class="no-underline w-full sm:w-auto">
                <twig:ux:icon name="lucide:download" class="size-4 shrink-0" aria-hidden="true" />
                Exporter (CSV)
            </twig:Button>
        </twig:block>
    </twig:DataPageHeader>

    <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
        <twig:Card:Content class="p-4 sm:p-6">
            <form method="get" action="{{ path('app_admin_logs_index') }}" class="grid grid-cols-12 gap-4">
                <div class="col-span-12 md:col-span-2 space-y-1.5">
                    <label for="action" class="text-sm font-medium text-foreground">Action</label>
                    <twig:Select name="action" id="action">
                        <option value="">Toutes</option>
                        {% for actionItem in actions %}
                            <option value="{{ actionItem }}" {{ currentAction == actionItem ? 'selected' : '' }}>{{ actionItem }}</option>
                        {% endfor %}
                    </twig:Select>
                </div>
                <div class="col-span-12 md:col-span-2 space-y-1.5">
                    <label for="entityType" class="text-sm font-medium text-foreground">Entité</label>
                    <twig:Select name="entityType" id="entityType">
                        <option value="">Toutes</option>
                        {% for entityTypeItem in entityTypes %}
                            <option value="{{ entityTypeItem }}" {{ currentEntityType == entityTypeItem ? 'selected' : '' }}>
                                {{ entityTypeItem|split('\\')|last }}
                            </option>
                        {% endfor %}
                    </twig:Select>
                </div>
                <div class="col-span-12 md:col-span-3 space-y-1.5">
                    <label for="user" class="text-sm font-medium text-foreground">Utilisateur</label>
                    <twig:Select name="user" id="user">
                        <option value="">Tous</option>
                        {% for userItem in users %}
                            <option value="{{ userItem.id }}" {{ currentUserId == userItem.id ? 'selected' : '' }}>{{ userItem.email }}</option>
                        {% endfor %}
                    </twig:Select>
                </div>
                <div class="col-span-12 md:col-span-2 space-y-1.5">
                    <label for="period" class="text-sm font-medium text-foreground">Période</label>
                    <twig:Select name="period" id="period">
                        <option value="today" {{ currentPeriod == 'today' ? 'selected' : '' }}>Aujourd'hui</option>
                        <option value="week" {{ currentPeriod == 'week' ? 'selected' : '' }}>7 jours</option>
                        <option value="month" {{ currentPeriod == 'month' ? 'selected' : '' }}>30 jours</option>
                        <option value="year" {{ currentPeriod == 'year' ? 'selected' : '' }}>1 an</option>
                    </twig:Select>
                </div>
                <div class="col-span-12 md:col-span-3 flex flex-wrap items-end gap-2">
                    <twig:Button type="submit" variant="default" size="sm" class="gap-2">
                        <twig:ux:icon name="lucide:filter" class="size-3.5 shrink-0" aria-hidden="true" />
                        Filtrer
                    </twig:Button>
                    <twig:Button as="a" href="{{ path('app_admin_logs_index') }}" variant="outline" size="sm" class="no-underline gap-2">
                        <twig:ux:icon name="lucide:x" class="size-3.5 shrink-0" aria-hidden="true" />
                        Réinitialiser
                    </twig:Button>
                </div>
            </form>
        </twig:Card:Content>
    </twig:Card>

    {% if logs|length > 0 %}
        {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-logs', list_caption: 'Journal d’audit' } %}
            {% block list_table %}
                <twig:Table class="[&_tbody_tr:hover]:bg-accent/60">
                    <twig:Table:Caption class="sr-only">Journal d’audit des actions d’administration</twig:Table:Caption>
                    <twig:Table:Header>
                        <twig:Table:Row class="border-b border-border bg-muted/40 hover:bg-muted/40">
                            <twig:Table:Head scope="col" class="whitespace-nowrap font-medium">Date</twig:Table:Head>
                            <twig:Table:Head scope="col" class="min-w-[12rem] font-medium">Utilisateur</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Action</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Entité</twig:Table:Head>
                            <twig:Table:Head scope="col" class="min-w-[10rem] font-medium">Description</twig:Table:Head>
                            <twig:Table:Head scope="col" class="whitespace-nowrap font-medium">IP</twig:Table:Head>
                        </twig:Table:Row>
                    </twig:Table:Header>
                    <twig:Table:Body>
                        {% for log in logs %}
                            <twig:Table:Row class="border-b border-border/60">
                                <twig:Table:Cell class="whitespace-nowrap align-top text-xs text-muted-foreground tabular-nums">
                                    {{ log.createdAt|date('d/m/Y H:i:s') }}
                                </twig:Table:Cell>
                                <twig:Table:Cell class="align-top">
                                    <div class="flex min-w-0 items-center gap-2">
                                        <div class="flex size-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                                            <i data-lucide="user" width="16" height="16" aria-hidden="true"></i>
                                        </div>
                                        <span class="truncate font-medium text-foreground">{{ log.user.email }}</span>
                                    </div>
                                </twig:Table:Cell>
                                <twig:Table:Cell class="align-top">
                                    {% if log.action == 'CREATE' %}
                                        <twig:Badge variant="outline" class="border-emerald-500/40 bg-emerald-500/10 text-emerald-800 dark:text-emerald-200">{{ log.action }}</twig:Badge>
                                    {% elseif log.action == 'UPDATE' %}
                                        <twig:Badge variant="default">{{ log.action }}</twig:Badge>
                                    {% elseif log.action == 'DELETE' %}
                                        <twig:Badge variant="destructive">{{ log.action }}</twig:Badge>
                                    {% else %}
                                        <twig:Badge variant="secondary">{{ log.action }}</twig:Badge>
                                    {% endif %}
                                </twig:Table:Cell>
                                <twig:Table:Cell class="align-top text-sm">
                                    {% if log.entityType %}
                                        <code class="rounded bg-muted px-1.5 py-0.5 text-xs">{{ log.entityType|split('\\')|last }}</code>
                                        {% if log.entityId %}
                                            <span class="mt-1 block text-xs text-muted-foreground">ID&nbsp;: {{ log.entityId }}</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted-foreground">—</span>
                                    {% endif %}
                                </twig:Table:Cell>
                                <twig:Table:Cell class="max-w-md align-top text-sm text-muted-foreground">
                                    {{ log.description|default('—') }}
                                </twig:Table:Cell>
                                <twig:Table:Cell class="align-top text-xs text-muted-foreground tabular-nums">
                                    {{ log.ipAddress|default('—') }}
                                </twig:Table:Cell>
                            </twig:Table:Row>
                        {% endfor %}
                    </twig:Table:Body>
                </twig:Table>
            {% endblock %}
            {% block list_cards %}
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
                    {% for log in logs %}
                        <twig:Card class="admin-list-item-card h-full border-border/80 shadow-sm ring-1 ring-border/40">
                            <twig:Card:Content class="flex flex-col gap-2 p-5 sm:p-6">
                                <div class="flex items-start justify-between gap-2">
                                    <span class="text-xs text-muted-foreground tabular-nums">{{ log.createdAt|date('d/m/Y H:i:s') }}</span>
                                    {% if log.action == 'CREATE' %}
                                        <twig:Badge variant="outline" class="border-emerald-500/40 bg-emerald-500/10 shrink-0 text-emerald-800 dark:text-emerald-200">{{ log.action }}</twig:Badge>
                                    {% elseif log.action == 'UPDATE' %}
                                        <twig:Badge variant="default" class="shrink-0">{{ log.action }}</twig:Badge>
                                    {% elseif log.action == 'DELETE' %}
                                        <twig:Badge variant="destructive" class="shrink-0">{{ log.action }}</twig:Badge>
                                    {% else %}
                                        <twig:Badge variant="secondary" class="shrink-0">{{ log.action }}</twig:Badge>
                                    {% endif %}
                                </div>
                                <p class="mb-0 break-all text-sm font-semibold text-foreground">{{ log.user.email }}</p>
                                {% if log.entityType %}
                                    <p class="mb-0 text-sm">
                                        <code class="text-xs">{{ log.entityType|split('\\')|last }}</code>{% if log.entityId %} <span class="text-muted-foreground">#{{ log.entityId }}</span>{% endif %}
                                    </p>
                                {% endif %}
                                <p class="mb-0 flex-1 text-sm text-muted-foreground">{{ log.description|default('—')|slice(0, 200) }}{% if log.description|length > 200 %}…{% endif %}</p>
                                <p class="mb-0 mt-auto border-t border-border pt-2 text-xs text-muted-foreground">IP : {{ log.ipAddress|default('—') }}</p>
                            </twig:Card:Content>
                        </twig:Card>
                    {% endfor %}
                </div>
            {% endblock %}
            {% block list_footer %}
                {% include 'components/admin/list_pagination.html.twig' with {
                    routeName: 'app_admin_logs_index',
                    routeParams: {
                        action: currentAction,
                        entityType: currentEntityType,
                        user: currentUserId,
                        period: currentPeriod,
                    },
                    currentPage: currentPage,
                    totalPages: totalPages,
                } %}
            {% endblock %}
        {% endembed %}
    {% else %}
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Content class="flex flex-col items-center justify-center gap-3 py-14 text-center">
                <twig:ux:icon name="lucide:file-text" class="size-12 text-muted-foreground" aria-hidden="true" />
                <p class="m-0 text-sm text-muted-foreground">
                    Aucun log{{ currentAction or currentEntityType or currentUserId ? ' (avec les filtres appliqués)' : '' }}
                </p>
            </twig:Card:Content>
        </twig:Card>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
