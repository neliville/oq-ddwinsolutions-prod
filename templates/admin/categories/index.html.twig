{% extends 'layout/admin_base.html.twig' %}

{% block title %}Gestion des catégories | Administration{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-[100rem] space-y-6">
    <twig:DataPageHeader title="Gestion des catégories" description="Gérer les catégories de blog">
        <twig:block name="actions">
            <twig:Button as="a" href="{{ path('app_admin_categories_new') }}" variant="default" class="no-underline w-full gap-2 sm:w-auto">
                <twig:ux:icon name="lucide:plus" class="size-4 shrink-0" aria-hidden="true" />
                Nouvelle catégorie
            </twig:Button>
        </twig:block>
    </twig:DataPageHeader>

    {% if categories|length > 0 %}
        {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-categories', list_caption: 'Catégories' } %}
            {% block list_table %}
                <twig:Table class="[&_tbody_tr:hover]:bg-accent/60">
                    <twig:Table:Caption class="sr-only">Catégories du blog</twig:Table:Caption>
                    <twig:Table:Header>
                        <twig:Table:Row class="border-b border-border bg-muted/40 hover:bg-muted/40">
                            <twig:Table:Head scope="col" class="w-14 font-medium whitespace-nowrap">Ordre</twig:Table:Head>
                            <twig:Table:Head scope="col" class="min-w-[10rem] font-medium">Nom</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Slug</twig:Table:Head>
                            <twig:Table:Head scope="col" class="min-w-[8rem] font-medium">Description</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Couleur</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Icône</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Articles</twig:Table:Head>
                            <twig:Table:Head scope="col" class="w-[1%] text-end font-medium whitespace-nowrap">Actions</twig:Table:Head>
                        </twig:Table:Row>
                    </twig:Table:Header>
                    <twig:Table:Body>
                        {% for category in categories %}
                            <twig:Table:Row class="border-b border-border/60">
                                <twig:Table:Cell class="tabular-nums font-semibold">{{ category.order }}</twig:Table:Cell>
                                <twig:Table:Cell>
                                    <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold text-white shadow-sm" style="background-color: {{ category.color }};">
                                        <i data-lucide="{{ category.icon }}" width="14" height="14" aria-hidden="true"></i>
                                        {{ category.name }}
                                    </span>
                                </twig:Table:Cell>
                                <twig:Table:Cell><code class="rounded bg-muted px-1.5 py-0.5 text-xs">{{ category.slug }}</code></twig:Table:Cell>
                                <twig:Table:Cell class="max-w-[14rem] text-sm text-muted-foreground">{{ category.description|default('—')|slice(0, 50) }}{% if category.description|length > 50 %}…{% endif %}</twig:Table:Cell>
                                <twig:Table:Cell>
                                    <div class="flex items-center gap-2">
                                        <div class="size-6 shrink-0 rounded border border-border" style="background-color: {{ category.color }};"></div>
                                        <span class="text-xs text-muted-foreground font-mono">{{ category.color }}</span>
                                    </div>
                                </twig:Table:Cell>
                                <twig:Table:Cell class="text-sm">
                                    <i data-lucide="{{ category.icon }}" width="20" height="20" aria-hidden="true"></i>
                                    <span class="ml-1 text-muted-foreground">{{ category.icon }}</span>
                                </twig:Table:Cell>
                                <twig:Table:Cell>
                                    <twig:Badge variant="secondary" class="tabular-nums">{{ category.blogPosts|length }} article{{ category.blogPosts|length > 1 ? 's' : '' }}</twig:Badge>
                                </twig:Table:Cell>
                                <twig:Table:Cell class="text-end">
                                    <div class="inline-flex flex-nowrap gap-1" role="group">
                                        <twig:Button as="a" href="{{ path('app_admin_categories_edit', {id: category.id}) }}" variant="outline" size="icon" class="size-9 shrink-0 no-underline" title="Modifier">
                                            <twig:ux:icon name="lucide:pencil" class="size-4" aria-hidden="true" /><span class="sr-only">Modifier</span>
                                        </twig:Button>
                                        {% if category.blogPosts|length == 0 %}
                                            <form method="post" action="{{ path('app_admin_categories_delete', {id: category.id}) }}" class="inline-flex" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette catégorie ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_category_' ~ category.id) }}">
                                                <twig:Button type="submit" variant="outline" size="icon" class="size-9 shrink-0 text-destructive hover:bg-destructive/10" title="Supprimer">
                                                    <twig:ux:icon name="lucide:trash-2" class="size-4" aria-hidden="true" /><span class="sr-only">Supprimer</span>
                                                </twig:Button>
                                            </form>
                                        {% else %}
                                            <twig:Button type="button" variant="outline" size="icon" disabled class="pointer-events-none size-9 shrink-0 opacity-50" title="Catégorie utilisée">
                                                <twig:ux:icon name="lucide:lock" class="size-4" aria-hidden="true" /><span class="sr-only">Verrouillé</span>
                                            </twig:Button>
                                        {% endif %}
                                    </div>
                                </twig:Table:Cell>
                            </twig:Table:Row>
                        {% endfor %}
                    </twig:Table:Body>
                </twig:Table>
            {% endblock %}
            {% block list_cards %}
                <div class="grid gap-3" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
                    {% for category in categories %}
                        <twig:Card class="admin-list-item-card h-full border-border/80 shadow-sm ring-1 ring-border/40">
                            <twig:Card:Content class="flex flex-col gap-2 p-5 sm:p-6">
                                <div class="mb-2 flex items-center gap-2">
                                    <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold text-white shadow-sm" style="background-color: {{ category.color }};">
                                        <i data-lucide="{{ category.icon }}" width="16" height="16" aria-hidden="true"></i>{{ category.name }}
                                    </span>
                                    <twig:Badge variant="outline" class="ml-auto tabular-nums">#{{ category.order }}</twig:Badge>
                                </div>
                                <code class="mb-2 block text-sm">{{ category.slug }}</code>
                                <p class="mb-2 flex-1 text-sm text-muted-foreground">{{ category.description|default('—')|slice(0, 120) }}{% if category.description|length > 120 %}…{% endif %}</p>
                                <div class="mb-2 flex items-center gap-2">
                                    <div class="size-7 shrink-0 rounded border border-border" style="background-color: {{ category.color }};"></div>
                                    <small class="text-muted-foreground font-mono">{{ category.color }}</small>
                                    <twig:Badge variant="secondary" class="ml-auto shrink-0 tabular-nums">{{ category.blogPosts|length }} art.</twig:Badge>
                                </div>
                                <div class="mt-auto flex flex-wrap gap-2 border-t border-border pt-4">
                                    <twig:Button as="a" href="{{ path('app_admin_categories_edit', {id: category.id}) }}" variant="outline" size="sm" class="no-underline gap-2">
                                        <twig:ux:icon name="lucide:pencil" class="size-4 shrink-0" aria-hidden="true" /> Modifier
                                    </twig:Button>
                                    {% if category.blogPosts|length == 0 %}
                                        <form method="post" action="{{ path('app_admin_categories_delete', {id: category.id}) }}" class="inline-flex" onsubmit="return confirm('Supprimer cette catégorie ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_category_' ~ category.id) }}">
                                            <twig:Button type="submit" variant="outline" size="sm" class="gap-2 text-destructive hover:bg-destructive/10">
                                                <twig:ux:icon name="lucide:trash-2" class="size-4 shrink-0" aria-hidden="true" /> Supprimer
                                            </twig:Button>
                                        </form>
                                    {% else %}
                                        <twig:Button type="button" variant="outline" size="sm" disabled class="pointer-events-none opacity-50 gap-2">
                                            <twig:ux:icon name="lucide:lock" class="size-4 shrink-0" aria-hidden="true" /> Utilisée
                                        </twig:Button>
                                    {% endif %}
                                </div>
                            </twig:Card:Content>
                        </twig:Card>
                    {% endfor %}
                </div>
            {% endblock %}
            {% block list_footer %}{% endblock %}
        {% endembed %}
    {% else %}
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Content class="flex flex-col items-center justify-center gap-4 py-14 text-center">
                <twig:ux:icon name="lucide:folder" class="size-12 text-muted-foreground" aria-hidden="true" />
                <p class="m-0 text-sm text-muted-foreground">Aucune catégorie</p>
                <twig:Button as="a" href="{{ path('app_admin_categories_new') }}" variant="default" class="no-underline gap-2">
                    <twig:ux:icon name="lucide:plus" class="size-4 shrink-0" aria-hidden="true" /> Créer la première catégorie
                </twig:Button>
            </twig:Card:Content>
        </twig:Card>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
