{# Template partiel pour le tableau des logs avec filtres et tri indépendants #}
<turbo-frame id="navigation-logs-frame">
    <div class="mt-6">
        <div class="rounded-lg bg-card shadow-sm">
            <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg" data-controller="filters-panel notifications">
                <div class="flex flex-col md:flex-row justify-between md:items-center gap-3">
                    <div class="flex-1">
                        <h5 class="mb-1">Logs de navigation des utilisateurs</h5>
                        <div class="flex flex-wrap items-center gap-2">
                            <small class="text-muted-foreground">Total : {{ totalLogs|number_format(0, ',', ' ') }} visite(s)</small>
                            {# Badge de période active #}
                            {% if request.query.get('date_from') and request.query.get('date_to') %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 text-primary px-2.5 py-0.5 text-xs font-semibold">
                                <i data-lucide="calendar" width="12" height="12"></i>
                                <span>{{ request.query.get('date_from')|date('d/m/Y') }} → {{ request.query.get('date_to')|date('d/m/Y') }}</span>
                            </span>
                            {% endif %}
                            {# Badges pour autres filtres actifs #}
                            {% if request.query.get('user_type') %}
                            <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold">
                                {% if request.query.get('user_type') == 'authenticated' %}Utilisateurs connectés{% else %}Visiteurs anonymes{% endif %}
                            </span>
                            {% endif %}
                            {% if request.query.get('url') %}
                            <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">
                                URL filtrée
                            </span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex gap-2 flex-wrap items-center">
                        {# Date Range Picker #}
                        <div data-controller="date-range"
                             data-date-range-turbo-frame-value="navigation-logs-frame"
                             data-date-range-date-from-value="{{ request.query.get('date_from') }}"
                             data-date-range-date-to-value="{{ request.query.get('date_to') }}"
                             class="flex items-center gap-2">
                            <label for="date_range" class="form-label text-sm mb-0 hidden md:block">Période :</label>
                            <div class="flex" style="width: 300px;">
                                <span class="inline-flex items-center px-3 border border-r-0 border-border rounded-l-md bg-white">
                                    <i data-lucide="calendar" width="16" height="16"></i>
                                </span>
                                <input type="text"
                                       id="date_range"
                                       data-date-range-target="input"
                                       class="flex-1 min-w-0 border border-border rounded-r-md px-3 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-primary"
                                       placeholder="Sélectionner une période"
                                       readonly
                                       value="{% if request.query.get('date_from') and request.query.get('date_to') %}{{ request.query.get('date_from')|date('d/m/Y') }} → {{ request.query.get('date_to')|date('d/m/Y') }}{% endif %}"
                                       style="background: white; cursor: pointer;">
                            </div>
                        </div>
                        <button class="inline-flex items-center justify-center gap-2 border border-border text-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:bg-accent transition-colors"
                                type="button"
                                data-filters-panel-target="toggle"
                                data-action="click->filters-panel#toggle"
                                aria-expanded="false"
                                aria-controls="logsFilters"
                                data-bs-toggle="collapse"
                                data-bs-target="#logsFilters">
                            <i data-lucide="filter" width="16" height="16" class="mr-1"></i>Filtres
                        </button>
                    </div>
                </div>
            </div>

            {# Section des filtres (collapsible) #}
            <div class="collapse"
                 id="logsFilters"
                 data-filters-panel-target="panel">
                <div class="p-6 bg-muted/30 border-b border-border">
                    <form method="get"
                          action="{{ path('app_admin_analytics_logs') }}"
                          data-turbo-frame="navigation-logs-frame"
                          class="grid grid-cols-12 gap-4"
                          id="logsFiltersForm">
                        {# Inputs cachés pour les dates (utilisés par le datepicker) #}
                        <input type="hidden" id="date_from" name="date_from" value="{{ request.query.get('date_from') }}">
                        <input type="hidden" id="date_to" name="date_to" value="{{ request.query.get('date_to') }}">

                        {# Affichage des filtres actifs #}
                        {% set hasActiveFilters = request.query.get('date_from') or request.query.get('user_type') or request.query.get('url') or request.query.get('user_email') or request.query.get('country') or request.query.get('device') or request.query.get('ip') %}
                        {% if hasActiveFilters %}
                        <div class="col-span-12">
                            <div class="flex items-start gap-2 rounded-lg border border-sky-200 bg-sky-50 text-sky-800 px-3 py-2 text-sm mb-0">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2 flex-wrap">
                                        <i data-lucide="info" width="16" height="16"></i>
                                        <small><strong>Filtres actifs :</strong></small>
                                        {% if request.query.get('date_from') and request.query.get('date_to') %}
                                        <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2.5 py-0.5 text-xs font-semibold">
                                            <i data-lucide="calendar" width="12" height="12" class="mr-1"></i>
                                            {{ request.query.get('date_from')|date('d/m/Y') }} → {{ request.query.get('date_to')|date('d/m/Y') }}
                                        </span>
                                        {% endif %}
                                        {% if request.query.get('user_type') %}
                                        <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold">
                                            {% if request.query.get('user_type') == 'authenticated' %}Utilisateurs connectés{% else %}Visiteurs anonymes{% endif %}
                                        </span>
                                        {% endif %}
                                        {% if request.query.get('url') %}
                                        <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">
                                            URL: {{ request.query.get('url')|slice(0, 30) }}{% if request.query.get('url')|length > 30 %}...{% endif %}
                                        </span>
                                        {% endif %}
                                        {% if request.query.get('user_email') %}
                                        <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">
                                            Email: {{ request.query.get('user_email')|slice(0, 20) }}{% if request.query.get('user_email')|length > 20 %}...{% endif %}
                                        </span>
                                        {% endif %}
                                        {% if request.query.get('country') %}
                                        <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">
                                            Pays: {{ request.query.get('country') }}
                                        </span>
                                        {% endif %}
                                        {% if request.query.get('device') %}
                                        <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">
                                            Appareil: {{ request.query.get('device') }}
                                        </span>
                                        {% endif %}
                                        {% if request.query.get('ip') %}
                                        <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">
                                            IP: {{ request.query.get('ip') }}
                                        </span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                        {% endif %}
                        <div class="col-span-12 md:col-span-2">
                            <label for="user_type" class="form-label text-sm">Type utilisateur</label>
                            <select class="form-select form-select-sm" id="user_type" name="user_type">
                                <option value="">Tous</option>
                                <option value="authenticated" {{ request.query.get('user_type') == 'authenticated' ? 'selected' : '' }}>Connectés</option>
                                <option value="anonymous" {{ request.query.get('user_type') == 'anonymous' ? 'selected' : '' }}>Anonymes</option>
                            </select>
                        </div>
                        <div class="col-span-12 md:col-span-2">
                            <label for="sort" class="form-label text-sm">Trier par</label>
                            <select class="form-select form-select-sm" id="sort" name="sort">
                                <option value="visitedAt" {{ sortBy == 'visitedAt' ? 'selected' : '' }}>Date</option>
                                <option value="url" {{ sortBy == 'url' ? 'selected' : '' }}>URL</option>
                                <option value="user" {{ sortBy == 'user' ? 'selected' : '' }}>Utilisateur</option>
                                <option value="country" {{ sortBy == 'country' ? 'selected' : '' }}>Pays</option>
                                <option value="device" {{ sortBy == 'device' ? 'selected' : '' }}>Appareil</option>
                                <option value="ipAddress" {{ sortBy == 'ipAddress' ? 'selected' : '' }}>IP</option>
                            </select>
                        </div>
                        <div class="col-span-12 md:col-span-2">
                            <label for="order" class="form-label text-sm">Ordre</label>
                            <select class="form-select form-select-sm" id="order" name="order">
                                <option value="desc" {{ sortOrder == 'desc' ? 'selected' : '' }}>Décroissant</option>
                                <option value="asc" {{ sortOrder == 'asc' ? 'selected' : '' }}>Croissant</option>
                            </select>
                        </div>
                        <div class="col-span-12 md:col-span-3">
                            <label for="url" class="form-label text-sm">URL (recherche)</label>
                            <input type="text" class="form-control form-control-sm" id="url" name="url" value="{{ request.query.get('url') }}" placeholder="Rechercher une URL...">
                        </div>
                        <div class="col-span-12 md:col-span-3">
                            <label for="user_email" class="form-label text-sm">Email utilisateur</label>
                            <input type="text" class="form-control form-control-sm" id="user_email" name="user_email" value="{{ request.query.get('user_email') }}" placeholder="Email...">
                        </div>
                        <div class="col-span-12 md:col-span-2">
                            <label for="country" class="form-label text-sm">Pays</label>
                            <input type="text" class="form-control form-control-sm" id="country" name="country" value="{{ request.query.get('country') }}" placeholder="Pays...">
                        </div>
                        <div class="col-span-12 md:col-span-2">
                            <label for="device" class="form-label text-sm">Appareil</label>
                            <input type="text" class="form-control form-control-sm" id="device" name="device" value="{{ request.query.get('device') }}" placeholder="Appareil...">
                        </div>
                        <div class="col-span-12 md:col-span-2">
                            <label for="ip" class="form-label text-sm">IP</label>
                            <input type="text" class="form-control form-control-sm" id="ip" name="ip" value="{{ request.query.get('ip') }}" placeholder="IP...">
                        </div>
                        <div class="col-span-12 md:col-span-2">
                            <label for="limit" class="form-label text-sm">Par page</label>
                            <select class="form-select form-select-sm" id="limit" name="limit">
                                <option value="10" {{ limit == 10 ? 'selected' : '' }}>10</option>
                                <option value="25" {{ limit == 25 ? 'selected' : '' }}>25</option>
                                <option value="50" {{ limit == 50 ? 'selected' : '' }}>50</option>
                                <option value="100" {{ limit == 100 ? 'selected' : '' }}>100</option>
                            </select>
                        </div>
                        <div class="col-span-12 flex gap-2">
                            <button type="submit"
                                    class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity"
                                    data-action="click->notifications#displayNotification"
                                    data-notifications-message-value="Filtres appliqués avec succès"
                                    data-notifications-type-value="success">
                                <i data-lucide="search" width="16" height="16" class="mr-1"></i>Appliquer
                            </button>
                            <a href="{{ path('app_admin_analytics_logs') }}"
                               class="inline-flex items-center justify-center gap-2 border border-border text-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:bg-accent transition-colors no-underline"
                               data-turbo-frame="navigation-logs-frame"
                               data-action="click->notifications#displayNotification"
                               data-notifications-message-value="Filtres réinitialisés"
                               data-notifications-type-value="info">
                                <i data-lucide="x" width="16" height="16" class="mr-1"></i>Réinitialiser
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                    <thead class="bg-muted/50">
                        <tr>
                            <th class="px-4 py-3 text-left font-medium" style="width: 180px;">
                                <a href="{{ path('app_admin_analytics_logs', request.query.all|merge({sort: 'visitedAt', order: sortBy == 'visitedAt' and sortOrder == 'desc' ? 'asc' : 'desc'})) }}"
                                   data-turbo-frame="navigation-logs-frame"
                                   class="no-underline text-foreground">
                                    Date & Heure
                                    {% if sortBy == 'visitedAt' %}
                                        <i data-lucide="{{ sortOrder == 'asc' ? 'arrow-up' : 'arrow-down' }}" width="14" height="14" class="ml-1"></i>
                                    {% endif %}
                                </a>
                            </th>
                            <th class="px-4 py-3 text-left font-medium" style="width: 200px;">
                                <a href="{{ path('app_admin_analytics_logs', request.query.all|merge({sort: 'user', order: sortBy == 'user' and sortOrder == 'desc' ? 'asc' : 'desc'})) }}"
                                   data-turbo-frame="navigation-logs-frame"
                                   class="no-underline text-foreground">
                                    Utilisateur
                                    {% if sortBy == 'user' %}
                                        <i data-lucide="{{ sortOrder == 'asc' ? 'arrow-up' : 'arrow-down' }}" width="14" height="14" class="ml-1"></i>
                                    {% endif %}
                                </a>
                            </th>
                            <th class="px-4 py-3 text-left font-medium">
                                <a href="{{ path('app_admin_analytics_logs', request.query.all|merge({sort: 'url', order: sortBy == 'url' and sortOrder == 'desc' ? 'asc' : 'desc'})) }}"
                                   data-turbo-frame="navigation-logs-frame"
                                   class="no-underline text-foreground">
                                    Page visitée
                                    {% if sortBy == 'url' %}
                                        <i data-lucide="{{ sortOrder == 'asc' ? 'arrow-up' : 'arrow-down' }}" width="14" height="14" class="ml-1"></i>
                                    {% endif %}
                                </a>
                            </th>
                            <th class="px-4 py-3 text-left font-medium" style="width: 120px;">Référent</th>
                            <th class="px-4 py-3 text-left font-medium" style="width: 100px;">
                                <a href="{{ path('app_admin_analytics_logs', request.query.all|merge({sort: 'country', order: sortBy == 'country' and sortOrder == 'desc' ? 'asc' : 'desc'})) }}"
                                   data-turbo-frame="navigation-logs-frame"
                                   class="no-underline text-foreground">
                                    Pays
                                    {% if sortBy == 'country' %}
                                        <i data-lucide="{{ sortOrder == 'asc' ? 'arrow-up' : 'arrow-down' }}" width="14" height="14" class="ml-1"></i>
                                    {% endif %}
                                </a>
                            </th>
                            <th class="px-4 py-3 text-left font-medium" style="width: 100px;">
                                <a href="{{ path('app_admin_analytics_logs', request.query.all|merge({sort: 'device', order: sortBy == 'device' and sortOrder == 'desc' ? 'asc' : 'desc'})) }}"
                                   data-turbo-frame="navigation-logs-frame"
                                   class="no-underline text-foreground">
                                    Appareil
                                    {% if sortBy == 'device' %}
                                        <i data-lucide="{{ sortOrder == 'asc' ? 'arrow-up' : 'arrow-down' }}" width="14" height="14" class="ml-1"></i>
                                    {% endif %}
                                </a>
                            </th>
                            <th class="px-4 py-3 text-left font-medium" style="width: 100px;">
                                <a href="{{ path('app_admin_analytics_logs', request.query.all|merge({sort: 'ipAddress', order: sortBy == 'ipAddress' and sortOrder == 'desc' ? 'asc' : 'desc'})) }}"
                                   data-turbo-frame="navigation-logs-frame"
                                   class="no-underline text-foreground">
                                    IP
                                    {% if sortBy == 'ipAddress' %}
                                        <i data-lucide="{{ sortOrder == 'asc' ? 'arrow-up' : 'arrow-down' }}" width="14" height="14" class="ml-1"></i>
                                    {% endif %}
                                </a>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in navigationLogs %}
                        <tr>
                            <td class="px-4 py-3">
                                <small class="text-muted-foreground">
                                    {{ log.visitedAt|date('d/m/Y') }}<br>
                                    {{ log.visitedAt|date('H:i:s') }}
                                </small>
                            </td>
                            <td class="px-4 py-3">
                                {% if log.user %}
                                    <div class="flex items-center">
                                        <div class="bg-primary/10 rounded-full flex items-center justify-center mr-2" style="width: 32px; height: 32px;">
                                            <span class="text-primary font-semibold text-sm">{{ log.user.email|slice(0, 1)|upper }}</span>
                                        </div>
                                        <div>
                                            <div class="font-semibold text-sm">{{ log.user.email }}</div>
                                            <small class="text-green-600">Connecté</small>
                                        </div>
                                    </div>
                                {% else %}
                                    <div class="flex items-center">
                                        <div class="bg-secondary/10 rounded-full flex items-center justify-center mr-2" style="width: 32px; height: 32px;">
                                            <i data-lucide="user" width="16" height="16" class="text-muted-foreground"></i>
                                        </div>
                                        <div>
                                            <div class="text-muted-foreground text-sm">Visiteur anonyme</div>
                                            <small class="text-muted-foreground">Session: {{ log.sessionId|slice(0, 8) }}...</small>
                                        </div>
                                    </div>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                <code class="text-primary text-sm">{{ log.url|slice(0, 60) }}{% if log.url|length > 60 %}...{% endif %}</code>
                                {% if log.method %}
                                    <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold ml-1">{{ log.method }}</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                {% if log.referer %}
                                    <small class="text-muted-foreground truncate block" style="max-width: 120px;" title="{{ log.referer }}">
                                        {{ log.referer|slice(0, 30) }}...
                                    </small>
                                {% else %}
                                    <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">Direct</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                {% if log.country %}
                                    <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2.5 py-0.5 text-xs font-semibold">{{ log.country }}</span>
                                    {% if log.city %}
                                        <br><small class="text-muted-foreground">{{ log.city }}</small>
                                    {% endif %}
                                {% else %}
                                    <span class="text-muted-foreground text-sm">-</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                {% if log.device %}
                                    <small class="text-muted-foreground">{{ log.device }}</small>
                                {% else %}
                                    <span class="text-muted-foreground text-sm">-</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3">
                                <small class="text-muted-foreground font-mono">{{ log.ipAddress ?? '-' }}</small>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="7" class="px-4 py-12 text-center text-muted-foreground">
                                <i data-lucide="inbox" width="48" height="48" class="text-muted-foreground mb-2"></i>
                                <div>Aucun log de navigation disponible</div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% if totalPages > 1 %}
            <div class="px-6 py-4 bg-white border-t border-border rounded-b">
                <nav aria-label="Pagination des logs">
                    <ul class="pagination pagination-sm mb-0 justify-center">
                        {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_analytics_logs', request.query.all|merge({page: currentPage - 1})) }}"
                               data-turbo-frame="navigation-logs-frame"
                               aria-label="Page précédente">
                                <span aria-hidden="true">&laquo;</span>
                            </a>
                        </li>
                        {% endif %}

                        {% for pageNum in 1..totalPages %}
                            {% if pageNum == currentPage %}
                            <li class="page-item active">
                                <span class="page-link">{{ pageNum }}</span>
                            </li>
                            {% elseif pageNum <= 3 or pageNum > totalPages - 3 or (pageNum >= currentPage - 1 and pageNum <= currentPage + 1) %}
                            <li class="page-item">
                                <a class="page-link" href="{{ path('app_admin_analytics_logs', request.query.all|merge({page: pageNum})) }}"
                                   data-turbo-frame="navigation-logs-frame">{{ pageNum }}</a>
                            </li>
                            {% elseif pageNum == 4 or pageNum == totalPages - 3 %}
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                            {% endif %}
                        {% endfor %}

                        {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_analytics_logs', request.query.all|merge({page: currentPage + 1})) }}"
                               data-turbo-frame="navigation-logs-frame"
                               aria-label="Page suivante">
                                <span aria-hidden="true">&raquo;</span>
                            </a>
                        </li>
                        {% endif %}
                    </ul>
                </nav>
            </div>
            {% endif %}
        </div>
    </div>
</turbo-frame>
