{% extends 'layout/admin_base.html.twig' %}

{% block title %}Analytics | Administration{% endblock %}

{% block content %}
<div class="w-full">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="p-6 flex flex-col">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <h2 class="text-xl font-bold mb-1">Trafic & audiences</h2>
                        <p class="text-muted-foreground mb-0">Visites, pages vues, géographie et appareils utilisés</p>
                    </div>
                    <div class="bg-primary/10 rounded-full p-3">
                        <i data-lucide="bar-chart-2" width="26" height="26" class="text-primary"></i>
                    </div>
                </div>
                <p class="text-muted-foreground text-sm flex-1">Visualisez les courbes de fréquentation, les pages les plus consultées et les pays d'origine de vos visiteurs.</p>
                <a href="{{ path('app_admin_analytics_traffic') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline self-start mt-4">
                    Explorer le trafic
                </a>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="p-6 flex flex-col">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <h2 class="text-xl font-bold mb-1">Partages & collaborations</h2>
                        <p class="text-muted-foreground mb-0">Liens Ishikawa partagés, activité et destinataires</p>
                    </div>
                    <div class="bg-green-100 rounded-full p-3">
                        <i data-lucide="share-2" width="26" height="26" class="text-green-600"></i>
                    </div>
                </div>
                <p class="text-muted-foreground text-sm flex-1">Suivez l'usage des liens sécurisés, les analyses les plus partagées et les destinataires engagés.</p>
                <a href="{{ path('app_admin_analytics_sharing') }}" class="inline-flex items-center justify-center gap-2 border border-green-600 text-green-600 px-4 py-2 rounded-md font-medium hover:bg-green-600/5 transition-colors no-underline self-start mt-4">
                    Analyse des partages
                </a>
            </div>
        </div>
    </div>
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
