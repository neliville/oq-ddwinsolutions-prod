{% extends 'layout/admin_base.html.twig' %}

{% block title %}Trafic & audiences | Analytics{% endblock %}

{% block content %}
{# Graphiques Chart.js pilotés par Stimulus (`analytics-charts`) — données : `trafficCharts` #}
<div
    class="analytics-traffic-page w-full max-w-[100rem] mx-auto space-y-6"
    data-controller="analytics-charts"
    data-analytics-charts-config-value="{{ trafficCharts|json_encode|e('html_attr') }}"
>
    <twig:DataPageHeader title="Trafic et audiences" description="Analyse du trafic et des audiences sur la période sélectionnée. La courbe reflète les vues enregistrées jour par jour.">
        <twig:block name="actions">
            <div class="flex flex-wrap gap-2" role="group" aria-label="Période d'analyse">
                <twig:Button as="a" href="{{ path('app_admin_analytics_traffic', {period: 'today'}) }}" variant="{{ period == 'today' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Aujourd'hui
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_analytics_traffic', {period: 'week'}) }}" variant="{{ period == 'week' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    7 jours
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_analytics_traffic', {period: 'month'}) }}" variant="{{ period == 'month' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    30 jours
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_analytics_traffic', {period: 'year'}) }}" variant="{{ period == 'year' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    1 an
                </twig:Button>
            </div>
        </twig:block>
    </twig:DataPageHeader>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <twig:KpiStatCard label="Visites totales" value="{{ totalVisits|number_format(0, ',', ' ') }}" tone="default" helper="{{ startDate|date('d/m/Y') }} → {{ endDate|date('d/m/Y') }}">
            <twig:block name="icon"><twig:ux:icon name="lucide:activity" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Vues — jour en cours" value="{{ todayVisits|number_format(0, ',', ' ') }}" tone="emerald" delta="Hier : {{ yesterdayVisits|number_format(0, ',', ' ') }}">
            <twig:block name="icon"><twig:ux:icon name="lucide:trending-up" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Visites utilisateurs connectés" value="{{ authenticatedVisits|number_format(0, ',', ' ') }}" tone="sky" helper="Semaine préc. (7 j.) : {{ authenticatedLastWeek|number_format(0, ',', ' ') }} vues connectées">
            <twig:block name="icon"><twig:ux:icon name="lucide:users" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Visites anonymes" value="{{ anonymousVisits|number_format(0, ',', ' ') }}" tone="amber" helper="Mois préc. (30 j.) : {{ anonymousLastMonth|number_format(0, ',', ' ') }} vues anonymes">
            <twig:block name="icon"><twig:ux:icon name="lucide:user" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
        <twig:Card class="lg:col-span-7 border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Visites quotidiennes</twig:Card:Title>
            </twig:Card:Header>
            <twig:Card:Content>
                <p class="text-xs text-muted-foreground mb-3 m-0">{{ startDate|date('d/m/Y') }} → {{ endDate|date('d/m/Y') }} — série temporelle agrégée par jour.</p>
                <div class="relative h-[220px] w-full min-h-[13rem]" data-chart-wrap>
                    <canvas data-analytics-charts-ref="traffic-daily" class="block h-full w-full" role="img" aria-label="Courbe des visites quotidiennes"></canvas>
                </div>
            </twig:Card:Content>
        </twig:Card>

        <twig:Card class="lg:col-span-5 border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Visites mensuelles</twig:Card:Title>
            </twig:Card:Header>
            <twig:Card:Content>
                <p class="text-xs text-muted-foreground mb-3 m-0">12 derniers mois — tendance globale hors filtre courte période.</p>
                <div class="relative h-[220px] w-full min-h-[13rem]" data-chart-wrap>
                    <canvas data-analytics-charts-ref="traffic-monthly" class="block h-full w-full" role="img" aria-label="Histogramme des visites mensuelles"></canvas>
                </div>
            </twig:Card:Content>
        </twig:Card>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <twig:Card class="overflow-hidden border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="flex flex-row items-center justify-between space-y-0 pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Pages les plus visitées</twig:Card:Title>
                <span class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Top 5</span>
            </twig:Card:Header>
            <twig:Card:Content class="p-0 sm:p-0">
                <div class="overflow-x-auto">
                    <twig:Table class="[&_caption]:sr-only">
                        <twig:Table:Caption>Classement des URLs les plus vues</twig:Table:Caption>
                        <twig:Table:Header>
                            <twig:Table:Row>
                                <twig:Table:Head scope="col" class="min-w-[12rem] whitespace-normal">Page</twig:Table:Head>
                                <twig:Table:Head scope="col" class="w-[1%] whitespace-nowrap text-end">Visites</twig:Table:Head>
                            </twig:Table:Row>
                        </twig:Table:Header>
                        <twig:Table:Body>
                            {% for page in mostVisitedPages %}
                                <twig:Table:Row>
                                    <twig:Table:Cell class="max-w-[min(24rem,70vw)] whitespace-normal">
                                        <code class="break-all text-xs">{{ page.url }}</code>
                                    </twig:Table:Cell>
                                    <twig:Table:Cell class="text-end tabular-nums font-semibold text-foreground">{{ page.visitCount|number_format(0, ',', ' ') }}</twig:Table:Cell>
                                </twig:Table:Row>
                            {% else %}
                                <twig:Table:Row>
                                    <twig:Table:Cell colspan="2" class="py-8 text-center text-sm text-muted-foreground">Aucune donnée disponible</twig:Table:Cell>
                                </twig:Table:Row>
                            {% endfor %}
                        </twig:Table:Body>
                    </twig:Table>
                </div>
            </twig:Card:Content>
        </twig:Card>

        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="flex flex-row items-center justify-between space-y-0 pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Répartition par pays</twig:Card:Title>
                <span class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Top 5</span>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="relative h-[220px] w-full min-h-[13rem]">
                    <canvas data-analytics-charts-ref="traffic-countries" class="block h-full w-full" role="img" aria-label="Répartition des visites par pays"></canvas>
                </div>
            </twig:Card:Content>
        </twig:Card>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
        <twig:Card class="lg:col-span-5 border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Type d'appareils</twig:Card:Title>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="relative mx-auto h-[220px] w-full max-w-sm min-h-[13rem]">
                    <canvas data-analytics-charts-ref="traffic-devices" class="block h-full w-full" role="img" aria-label="Répartition par type d'appareil"></canvas>
                </div>
            </twig:Card:Content>
        </twig:Card>

        <twig:Card class="lg:col-span-7 border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Synthèse rapide</twig:Card:Title>
            </twig:Card:Header>
            <twig:Card:Content>
                {% set totalAudience = authenticatedVisits + anonymousVisits %}
                <ul class="m-0 list-none space-y-0 divide-y divide-border p-0">
                    <li class="flex items-center justify-between gap-3 py-3 first:pt-0">
                        <span class="text-sm text-muted-foreground">Période analysée</span>
                        <strong class="text-sm tabular-nums text-foreground">{{ startDate|date('d/m/Y') }} → {{ endDate|date('d/m/Y') }}</strong>
                    </li>
                    <li class="flex items-center justify-between gap-3 py-3">
                        <span class="text-sm text-muted-foreground">Part visiteurs connectés</span>
                        <strong class="text-sm tabular-nums text-foreground">{{ totalAudience > 0 ? ((authenticatedVisits / totalAudience) * 100)|round(1) : 0 }}%</strong>
                    </li>
                    <li class="flex items-center justify-between gap-3 py-3 last:pb-0">
                        <span class="text-sm text-muted-foreground">Visites moyennes / jour</span>
                        {% set dayCount = visitsDailyChart.data|length > 0 ? visitsDailyChart.data|length : 1 %}
                        {% set sumVisits = visitsDailyChart.data|reduce((carry, item) => carry + item, 0) %}
                        <strong class="text-sm tabular-nums text-foreground">{{ (sumVisits / dayCount)|round(1) }}</strong>
                    </li>
                </ul>
            </twig:Card:Content>
        </twig:Card>
    </div>

    {{ render(path('app_admin_analytics_logs')) }}
</div>
{% endblock %}
