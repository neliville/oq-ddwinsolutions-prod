{% extends 'layout/admin_base.html.twig' %}

{% block title %}Trafic & audiences | Analytics{% endblock %}

{% block content %}
<div class="w-full">
    <div class="flex flex-col lg:flex-row justify-between lg:items-center mb-6 gap-3">
        <div>
            <h1 class="text-2xl font-bold mb-1">Trafic et audiences</h1>
            <p class="text-muted-foreground mb-0">Analyse du trafic sur la période sélectionnée</p>
        </div>
        <div>
            <div class="flex flex-wrap gap-1" role="group" aria-label="Période">
                <a href="{{ path('app_admin_analytics_traffic', {period: 'today'}) }}" class="{{ period == 'today' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">Aujourd'hui</a>
                <a href="{{ path('app_admin_analytics_traffic', {period: 'week'}) }}" class="{{ period == 'week' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">7 jours</a>
                <a href="{{ path('app_admin_analytics_traffic', {period: 'month'}) }}" class="{{ period == 'month' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">30 jours</a>
                <a href="{{ path('app_admin_analytics_traffic', {period: 'year'}) }}" class="{{ period == 'year' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">1 an</a>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-6">
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-start">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Visites totales</h6>
                        <h3 class="font-bold mb-1">{{ totalVisits|number_format(0, ',', ' ') }}</h3>
                        <small class="text-muted-foreground">{{ startDate|date('d/m/Y') }} → {{ endDate|date('d/m/Y') }}</small>
                    </div>
                    <div class="bg-primary/10 rounded-full p-3">
                        <i data-lucide="activity" width="24" height="24" class="text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-start">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Aujourd'hui</h6>
                        <h3 class="font-bold mb-1">{{ todayVisits|number_format(0, ',', ' ') }}</h3>
                        <small class="text-muted-foreground">Hier : {{ yesterdayVisits|number_format(0, ',', ' ') }}</small>
                    </div>
                    <div class="bg-green-100 rounded-full p-3">
                        <i data-lucide="trending-up" width="24" height="24" class="text-green-600"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-start">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Utilisateurs connectés</h6>
                        <h3 class="font-bold mb-1">{{ authenticatedVisits|number_format(0, ',', ' ') }}</h3>
                        <small class="text-muted-foreground">Semaine préc. : {{ authenticatedLastWeek|number_format(0, ',', ' ') }}</small>
                    </div>
                    <div class="bg-sky-100 rounded-full p-3">
                        <i data-lucide="users" width="24" height="24" class="text-sky-600"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-start">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Visiteurs anonymes</h6>
                        <h3 class="font-bold mb-1">{{ anonymousVisits|number_format(0, ',', ' ') }}</h3>
                        <small class="text-muted-foreground">Mois préc. : {{ anonymousLastMonth|number_format(0, ',', ' ') }}</small>
                    </div>
                    <div class="bg-amber-100 rounded-full p-3">
                        <i data-lucide="user" width="24" height="24" class="text-amber-600"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6">
        <div class="lg:col-span-7 col-span-12">
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h5 class="mb-0">Visites quotidiennes</h5>
                    <small class="text-muted-foreground">{{ startDate|date('d/m/Y') }} → {{ endDate|date('d/m/Y') }}</small>
                </div>
                <div class="p-6">
                    <canvas id="trafficDailyChart" height="220" aria-label="Courbe des visites quotidiennes" role="img"></canvas>
                </div>
            </div>
        </div>
        <div class="lg:col-span-5 col-span-12">
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h5 class="mb-0">Visites mensuelles</h5>
                    <small class="text-muted-foreground">12 derniers mois</small>
                </div>
                <div class="p-6">
                    <canvas id="trafficMonthlyChart" height="220" aria-label="Histogramme des visites mensuelles" role="img"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg flex justify-between items-center">
                <h5 class="mb-0">Pages les plus visitées</h5>
                <small class="text-muted-foreground">Top 5</small>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                    <thead class="bg-muted/50">
                        <tr>
                            <th class="px-4 py-3 text-left font-medium">Page</th>
                            <th class="px-4 py-3 text-right font-medium">Visites</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for page in mostVisitedPages %}
                        <tr>
                            <td class="px-4 py-3 truncate" style="max-width: 320px;">
                                <code>{{ page.url }}</code>
                            </td>
                            <td class="px-4 py-3 text-right font-semibold">{{ page.visitCount|number_format(0, ',', ' ') }}</td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="2" class="px-4 py-4 text-center text-muted-foreground">Aucune donnée disponible</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg flex justify-between items-center">
                <h5 class="mb-0">Répartition par pays</h5>
                <small class="text-muted-foreground">Top 5</small>
            </div>
            <div class="p-6">
                <canvas id="trafficCountryChart" height="220" role="img" aria-label="Répartition par pays"></canvas>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-5 col-span-12">
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h5 class="mb-0">Type d'appareils</h5>
                </div>
                <div class="p-6">
                    <canvas id="trafficDeviceChart" height="220" role="img" aria-label="Répartition des appareils"></canvas>
                </div>
            </div>
        </div>
        <div class="lg:col-span-7 col-span-12">
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h5 class="mb-0">Synthèse rapide</h5>
                </div>
                <div class="p-6">
                    <ul class="list-none mb-0 p-0">
                        <li class="flex justify-between items-center py-2 border-b border-border">
                            <span class="text-muted-foreground">Période analysée</span>
                            <strong>{{ startDate|date('d/m/Y') }} → {{ endDate|date('d/m/Y') }}</strong>
                        </li>
                        <li class="flex justify-between items-center py-2 border-b border-border">
                            <span class="text-muted-foreground">Part des visiteurs connectés</span>
                            {% set totalAudience = authenticatedVisits + anonymousVisits %}
                            <strong>{{ totalAudience > 0 ? ((authenticatedVisits / totalAudience) * 100)|round(1) : 0 }}%</strong>
                        </li>
                        <li class="flex justify-between items-center py-2">
                            <span class="text-muted-foreground">Visites moyennes / jour</span>
                            {% set dayCount = visitsDailyChart.data|length > 0 ? visitsDailyChart.data|length : 1 %}
                            {% set sumVisits = visitsDailyChart.data|reduce((carry, item) => carry + item, 0) %}
                            <strong>{{ (sumVisits / dayCount)|round(1) }}</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Tableau des logs de navigation (chargé via Turbo Frame) -->
    {{ render(path('app_admin_analytics_logs')) }}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js" integrity="sha384-1+OxzI1+28HqkKqmXda3IIZeF1P0uohsEiL41Z8nfdXbra+XUl3Bd4Kp9Ezg4L7g" crossorigin="anonymous" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }

    const dailyCtx = document.getElementById('trafficDailyChart');
    const monthlyCtx = document.getElementById('trafficMonthlyChart');
    const deviceCtx = document.getElementById('trafficDeviceChart');
    const countryCtx = document.getElementById('trafficCountryChart');

    const dailyData = {{ visitsDailyChart|json_encode|raw }};
    const monthlyData = {{ visitsMonthlyChart|json_encode|raw }};
    const deviceData = {{ deviceChart|json_encode|raw }};
    const countryData = {{ countryChart|json_encode|raw }};

    if (dailyCtx && dailyData.labels.length) {
        new Chart(dailyCtx, {
            type: 'line',
            data: {
                labels: dailyData.labels,
                datasets: [{
                    label: 'Visites',
                    data: dailyData.data,
                    fill: false,
                    borderColor: '#4f46e5',
                    backgroundColor: 'rgba(79, 70, 229, 0.15)',
                    tension: 0.3,
                    pointRadius: 3,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    }

    if (monthlyCtx && monthlyData.labels.length) {
        new Chart(monthlyCtx, {
            type: 'bar',
            data: {
                labels: monthlyData.labels,
                datasets: [{
                    label: 'Visites',
                    data: monthlyData.data,
                    backgroundColor: 'rgba(14, 165, 233, 0.55)',
                    borderRadius: 6,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    }

    if (deviceCtx && deviceData.labels.length) {
        new Chart(deviceCtx, {
            type: 'doughnut',
            data: {
                labels: deviceData.labels,
                datasets: [{
                    data: deviceData.data,
                    backgroundColor: ['#4f46e5', '#0ea5e9', '#f97316', '#22c55e', '#6366f1'],
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });
    }

    if (countryCtx && countryData.labels.length) {
        new Chart(countryCtx, {
            type: 'polarArea',
            data: {
                labels: countryData.labels,
                datasets: [{
                    data: countryData.data,
                    backgroundColor: ['rgba(59,130,246,0.6)', 'rgba(16,185,129,0.6)', 'rgba(249,115,22,0.6)', 'rgba(168,85,247,0.6)', 'rgba(14,165,233,0.6)'],
                    borderWidth: 1,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });
    }
});
</script>
{% endblock %}
