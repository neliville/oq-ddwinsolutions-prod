{% extends 'layout/admin_base.html.twig' %}

{% block title %}Créations par outil | Administration{% endblock %}

{% block content %}
<div class="w-full max-w-[100rem] mx-auto space-y-6">
    <twig:DataPageHeader title="Utilisation des outils" description="Nombre d'analyses enregistrées par outil (tous utilisateurs) et comparaison avec les exports tracés.">
        <twig:block name="actions">
            <div class="flex flex-wrap gap-2">
                <twig:Button as="a" href="{{ path('app_admin_export_analytics_index') }}" variant="default" size="sm" class="no-underline gap-1.5">
                    <twig:ux:icon name="lucide:download" class="size-4 shrink-0" aria-hidden="true" />
                    Exports
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_analytics_index') }}" variant="outline" size="sm" class="no-underline gap-1.5">
                    <twig:ux:icon name="lucide:bar-chart-2" class="size-4 shrink-0" aria-hidden="true" />
                    Analytics
                </twig:Button>
            </div>
        </twig:block>
    </twig:DataPageHeader>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <twig:KpiStatCard label="Analyses enregistrées" value="{{ totalCreations|number_format(0, ',', ' ') }}" tone="default" helper="Toutes sauvegardes sur les outils">
            <twig:block name="icon"><twig:ux:icon name="lucide:database" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Exports tracés" value="{{ totalExports|number_format(0, ',', ' ') }}" tone="sky" helper="PDF, PNG, JSON… — page Exports">
            <twig:block name="icon"><twig:ux:icon name="lucide:download" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <div class="rounded-lg bg-card shadow-sm mb-0">
            <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                <h5 class="mb-0">Outils les plus utilisés (créations)</h5>
                <small class="text-muted-foreground">Classement par nombre d'analyses sauvegardées</small>
            </div>
            <div>
                {% if creationByTool|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                        <thead class="bg-muted/50">
                            <tr>
                                <th class="px-4 py-3 text-left font-medium" scope="col">Rang</th>
                                <th class="px-4 py-3 text-left font-medium" scope="col">Outil</th>
                                <th class="px-4 py-3 text-right font-medium" scope="col">Créations</th>
                                <th class="px-4 py-3 text-right font-medium" scope="col">Part</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in creationByTool %}
                            <tr>
                                <td class="px-4 py-3 text-muted-foreground text-sm">{{ loop.index }}</td>
                                <td class="px-4 py-3"><strong>{{ row.label }}</strong> <span class="text-muted-foreground text-sm">({{ row.key }})</span></td>
                                <td class="px-4 py-3 text-right font-semibold">{{ row.count|number_format(0, ',', ' ') }}</td>
                                <td class="px-4 py-3 text-right text-muted-foreground">{{ totalCreations > 0 ? (row.count / totalCreations * 100)|round(1) : 0 }} %</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="p-6 text-center py-12 text-muted-foreground">Aucune analyse enregistrée.</div>
                {% endif %}
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm mb-0">
            <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                <h5 class="mb-0">Exports par outil (global)</h5>
                <small class="text-muted-foreground">Volumes d'exports enregistrés par outil</small>
            </div>
            <div>
                {% if exportsByTool|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                        <thead class="bg-muted/50">
                            <tr>
                                <th class="px-4 py-3 text-left font-medium" scope="col">Outil</th>
                                <th class="px-4 py-3 text-right font-medium" scope="col">Exports</th>
                                <th class="px-4 py-3 text-right font-medium" scope="col">Part</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in exportsByTool %}
                            <tr>
                                <td class="px-4 py-3">{{ row.tool }}</td>
                                <td class="px-4 py-3 text-right font-semibold">{{ row.total|number_format(0, ',', ' ') }}</td>
                                <td class="px-4 py-3 text-right text-muted-foreground">{{ totalExports > 0 ? (row.total / totalExports * 100)|round(1) : 0 }} %</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="p-6 text-center py-12 text-muted-foreground">Aucun export tracé.</div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
