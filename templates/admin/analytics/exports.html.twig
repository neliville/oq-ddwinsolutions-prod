{% extends 'layout/admin_base.html.twig' %}

{% block title %}Insights exports | Administration{% endblock %}

{% block content %}
<div class="w-full max-w-[100rem] mx-auto space-y-6">
    <twig:DataPageHeader title="Suivi des exports" description="Formats téléchargés, outils sollicités et activité des utilisateurs.">
        <twig:block name="actions">
            <twig:Button as="a" href="{{ path('app_admin_analytics_index') }}" variant="outline" size="sm" class="no-underline gap-1.5">
                <twig:ux:icon name="lucide:arrow-left" class="size-4 shrink-0" aria-hidden="true" />
                Retour aux analytics
            </twig:Button>
        </twig:block>
    </twig:DataPageHeader>

    {% set totalExports = totalsByFormat|reduce((carry, item) => carry + item.total, 0) %}

    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        <twig:KpiStatCard label="Exports totaux" value="{{ totalExports|default(0)|number_format(0, ',', ' ') }}" tone="default">
            <twig:block name="icon"><twig:ux:icon name="lucide:download" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Formats suivis" value="{{ totalsByFormat|length }}" tone="emerald" helper="PNG, PDF, JSON…">
            <twig:block name="icon"><twig:ux:icon name="lucide:layers" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Utilisateurs (top liste)" value="{{ topUsers|length }}" tone="sky" helper="Jusqu’à 10 contributeurs affichés">
            <twig:block name="icon"><twig:ux:icon name="lucide:users" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-6">
        <div class="rounded-lg bg-card shadow-sm mb-0">
            <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                <h5 class="mb-0">Répartition par format</h5>
            </div>
            <div>
                {% if totalsByFormat|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                        <thead class="bg-muted/50">
                            <tr>
                                <th class="px-4 py-3 text-left font-medium">Format</th>
                                <th class="px-4 py-3 text-right font-medium">Exports</th>
                                <th class="px-4 py-3 text-right font-medium">Part</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for format in totalsByFormat %}
                            <tr>
                                <td class="px-4 py-3"><span class="inline-flex items-center rounded-full bg-primary text-primary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ format.format|upper }}</span></td>
                                <td class="px-4 py-3 text-right font-semibold">{{ format.total|number_format(0, ',', ' ') }}</td>
                                <td class="px-4 py-3 text-right">{{ totalExports > 0 ? (format.total / totalExports * 100)|round(1) : 0 }} %</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                    <div class="p-6 text-center py-12">
                        <i data-lucide="pie-chart" width="48" height="48" class="text-muted-foreground mb-4"></i>
                        <p class="text-muted-foreground mb-0">Aucun export enregistré pour le moment.</p>
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm mb-0">
            <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                <h5 class="mb-0">Répartition par outil</h5>
            </div>
            <div>
                {% if totalsByTool|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                        <thead class="bg-muted/50">
                            <tr>
                                <th class="px-4 py-3 text-left font-medium">Outil</th>
                                <th class="px-4 py-3 text-right font-medium">Exports</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for tool in totalsByTool %}
                            <tr>
                                <td class="px-4 py-3">{{ tool.tool|title }}</td>
                                <td class="px-4 py-3 text-right font-semibold">{{ tool.total|number_format(0, ',', ' ') }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                    <div class="p-6 text-center py-12">
                        <i data-lucide="grid" width="48" height="48" class="text-muted-foreground mb-4"></i>
                        <p class="text-muted-foreground mb-0">Aucun export enregistré pour le moment.</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <div class="rounded-lg bg-card shadow-sm mb-0">
            <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                <h5 class="mb-0">Top utilisateurs</h5>
            </div>
            <div>
                {% if topUsers|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                        <thead class="bg-muted/50">
                            <tr>
                                <th class="px-4 py-3 text-left font-medium">Utilisateur</th>
                                <th class="px-4 py-3 text-right font-medium">Exports</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in topUsers %}
                            <tr>
                                <td class="px-4 py-3">{{ user.email }}</td>
                                <td class="px-4 py-3 text-right font-semibold">{{ user.total|number_format(0, ',', ' ') }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                    <div class="p-6 text-center py-12">
                        <i data-lucide="user-check" width="48" height="48" class="text-muted-foreground mb-4"></i>
                        <p class="text-muted-foreground mb-0">Aucun export identifié par utilisateur.</p>
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm mb-0">
            <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                <h5 class="mb-0">Derniers exports</h5>
            </div>
            <div>
                {% if recentExports|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                        <thead class="bg-muted/50">
                            <tr>
                                <th class="px-4 py-3 text-left font-medium">Date</th>
                                <th class="px-4 py-3 text-left font-medium">Utilisateur</th>
                                <th class="px-4 py-3 text-left font-medium">Outil</th>
                                <th class="px-4 py-3 text-left font-medium">Format</th>
                                <th class="px-4 py-3 text-right font-medium">Source</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for log in recentExports %}
                            <tr>
                                <td class="px-4 py-3">{{ log.createdAt|date('d/m/Y H:i') }}</td>
                                <td class="px-4 py-3">{{ log.user ? log.user.email : 'Anonyme' }}</td>
                                <td class="px-4 py-3">{{ log.tool|title }}</td>
                                <td class="px-4 py-3"><span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ log.format|upper }}</span></td>
                                <td class="px-4 py-3 text-right">
                                    {% if log.sourceUrl %}
                                        <a href="{{ log.sourceUrl }}" target="_blank" rel="noopener" class="no-underline">Voir</a>
                                    {% else %}
                                        <span class="text-muted-foreground">—</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                    <div class="p-6 text-center py-12">
                        <i data-lucide="clock" width="48" height="48" class="text-muted-foreground mb-4"></i>
                        <p class="text-muted-foreground mb-0">Aucun export récent enregistré.</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
