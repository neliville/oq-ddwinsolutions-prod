{% extends 'layout/admin_base.html.twig' %}

{% block title %}Partages Ishikawa | Analytics{% endblock %}

{% block content %}
<div
    class="analytics-sharing-page w-full max-w-[100rem] mx-auto space-y-6"
    data-controller="analytics-charts"
    data-analytics-charts-config-value="{{ sharingCharts|json_encode|e('html_attr') }}"
>
    <twig:DataPageHeader title="Partages et collaboration" description="Liens Ishikawa partagés, visites agrégées et séries sur la période choisie.">
        <twig:block name="actions">
            <div class="flex flex-wrap gap-2" role="group" aria-label="Période d'analyse">
                <twig:Button as="a" href="{{ path('app_admin_analytics_sharing', {period: 'today'}) }}" variant="{{ period == 'today' ? 'default' : 'outline' }}" size="sm" class="no-underline">Aujourd'hui</twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_analytics_sharing', {period: 'week'}) }}" variant="{{ period == 'week' ? 'default' : 'outline' }}" size="sm" class="no-underline">7 jours</twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_analytics_sharing', {period: 'month'}) }}" variant="{{ period == 'month' ? 'default' : 'outline' }}" size="sm" class="no-underline">30 jours</twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_analytics_sharing', {period: 'year'}) }}" variant="{{ period == 'year' ? 'default' : 'outline' }}" size="sm" class="no-underline">1 an</twig:Button>
            </div>
        </twig:block>
    </twig:DataPageHeader>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <twig:KpiStatCard label="Liens partagés (total)" value="{{ shareTotals.totalShares|number_format(0, ',', ' ') }}" tone="default" helper="Depuis le lancement">
            <twig:block name="icon"><twig:ux:icon name="lucide:link" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Liens actifs" value="{{ shareTotals.activeShares|number_format(0, ',', ' ') }}" tone="emerald" helper="Non expirés à date">
            <twig:block name="icon"><twig:ux:icon name="lucide:check-circle-2" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Partages (période)" value="{{ shareTotals.sharesThisPeriod|number_format(0, ',', ' ') }}" tone="sky" helper="{{ startDate|date('d/m/Y') }} → {{ endDate|date('d/m/Y') }}">
            <twig:block name="icon"><twig:ux:icon name="lucide:share-2" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Visites via partage" value="{{ shareTotals.shareVisitsThisPeriod|number_format(0, ',', ' ') }}" tone="amber" helper="Cumul global : {{ shareTotals.totalShareVisits|number_format(0, ',', ' ') }}">
            <twig:block name="icon"><twig:ux:icon name="lucide:line-chart" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Créations de liens</twig:Card:Title>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="relative h-[220px] w-full min-h-[13rem]">
                    <canvas data-analytics-charts-ref="share-creation" class="block h-full w-full" role="img" aria-label="Évolution des créations de liens partagés"></canvas>
                </div>
            </twig:Card:Content>
        </twig:Card>
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Visites issues des partages</twig:Card:Title>
            </twig:Card:Header>
            <twig:Card:Content>
                <div class="relative h-[220px] w-full min-h-[13rem]">
                    <canvas data-analytics-charts-ref="share-visits" class="block h-full w-full" role="img" aria-label="Évolution des visites via lien partagé"></canvas>
                </div>
            </twig:Card:Content>
        </twig:Card>
    </div>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
        <twig:Card class="overflow-hidden border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="flex flex-row items-center justify-between space-y-0 pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Top contributeurs</twig:Card:Title>
                <span class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Top 5</span>
            </twig:Card:Header>
            <twig:Card:Content class="p-0 sm:p-0">
                <div class="overflow-x-auto">
                    <twig:Table>
                        <twig:Table:Header>
                            <twig:Table:Row>
                                <twig:Table:Head scope="col" class="min-w-[12rem]">Utilisateur</twig:Table:Head>
                                <twig:Table:Head scope="col" class="w-[1%] whitespace-nowrap text-end">Partages</twig:Table:Head>
                            </twig:Table:Row>
                        </twig:Table:Header>
                        <twig:Table:Body>
                            {% for sharer in topSharers %}
                                <twig:Table:Row>
                                    <twig:Table:Cell class="whitespace-normal">{{ sharer.email }}</twig:Table:Cell>
                                    <twig:Table:Cell class="text-end tabular-nums font-semibold">{{ sharer.shareCount|number_format(0, ',', ' ') }}</twig:Table:Cell>
                                </twig:Table:Row>
                            {% else %}
                                <twig:Table:Row>
                                    <twig:Table:Cell colspan="2" class="py-8 text-center text-sm text-muted-foreground">Aucun partage enregistré</twig:Table:Cell>
                                </twig:Table:Row>
                            {% endfor %}
                        </twig:Table:Body>
                    </twig:Table>
                </div>
            </twig:Card:Content>
        </twig:Card>

        <twig:Card class="overflow-hidden border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="flex flex-row items-center justify-between space-y-0 pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Analyses les plus consultées</twig:Card:Title>
                <span class="text-xs font-medium uppercase tracking-wide text-muted-foreground">Via partage</span>
            </twig:Card:Header>
            <twig:Card:Content class="p-0 sm:p-0">
                <div class="overflow-x-auto">
                    <twig:Table>
                        <twig:Table:Header>
                            <twig:Table:Row>
                                <twig:Table:Head scope="col" class="min-w-[10rem]">Analyse</twig:Table:Head>
                                <twig:Table:Head scope="col" class="w-[1%] whitespace-nowrap text-end">Visites</twig:Table:Head>
                            </twig:Table:Row>
                        </twig:Table:Header>
                        <twig:Table:Body>
                            {% for analysis in topSharedAnalyses %}
                                <twig:Table:Row>
                                    <twig:Table:Cell class="whitespace-normal">{{ analysis.title }}</twig:Table:Cell>
                                    <twig:Table:Cell class="text-end tabular-nums font-semibold">{{ analysis.visitCount|number_format(0, ',', ' ') }}</twig:Table:Cell>
                                </twig:Table:Row>
                            {% else %}
                                <twig:Table:Row>
                                    <twig:Table:Cell colspan="2" class="py-8 text-center text-sm text-muted-foreground">Aucune donnée</twig:Table:Cell>
                                </twig:Table:Row>
                            {% endfor %}
                        </twig:Table:Body>
                    </twig:Table>
                </div>
            </twig:Card:Content>
        </twig:Card>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <twig:Card class="overflow-hidden border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Partages récents</twig:Card:Title>
            </twig:Card:Header>
            <twig:Card:Content class="p-0 sm:p-0">
                <div class="overflow-x-auto">
                    <twig:Table>
                        <twig:Table:Header>
                            <twig:Table:Row>
                                <twig:Table:Head scope="col">Analyse</twig:Table:Head>
                                <twig:Table:Head scope="col">Créé par</twig:Table:Head>
                                <twig:Table:Head scope="col" class="whitespace-nowrap">Créé le</twig:Table:Head>
                                <twig:Table:Head scope="col" class="whitespace-nowrap">Expire le</twig:Table:Head>
                            </twig:Table:Row>
                        </twig:Table:Header>
                        <twig:Table:Body>
                            {% for share in recentShares %}
                                <twig:Table:Row>
                                    <twig:Table:Cell class="whitespace-normal">{{ share.title }}</twig:Table:Cell>
                                    <twig:Table:Cell class="whitespace-normal">{{ share.owner }}</twig:Table:Cell>
                                    <twig:Table:Cell class="tabular-nums text-xs text-muted-foreground">{{ share.createdAt|date('d/m/Y H:i') }}</twig:Table:Cell>
                                    <twig:Table:Cell class="tabular-nums text-xs text-muted-foreground">{{ share.expiresAt|date('d/m/Y H:i') }}</twig:Table:Cell>
                                </twig:Table:Row>
                            {% else %}
                                <twig:Table:Row>
                                    <twig:Table:Cell colspan="4" class="py-8 text-center text-sm text-muted-foreground">Aucun partage récent</twig:Table:Cell>
                                </twig:Table:Row>
                            {% endfor %}
                        </twig:Table:Body>
                    </twig:Table>
                </div>
            </twig:Card:Content>
        </twig:Card>

        <twig:Card class="overflow-hidden border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Visites récentes</twig:Card:Title>
            </twig:Card:Header>
            <twig:Card:Content class="p-0 sm:p-0">
                <div class="overflow-x-auto">
                    <twig:Table>
                        <twig:Table:Header>
                            <twig:Table:Row>
                                <twig:Table:Head scope="col">Analyse</twig:Table:Head>
                                <twig:Table:Head scope="col">Token</twig:Table:Head>
                                <twig:Table:Head scope="col" class="whitespace-nowrap">Date</twig:Table:Head>
                            </twig:Table:Row>
                        </twig:Table:Header>
                        <twig:Table:Body>
                            {% for visit in recentShareVisits %}
                                <twig:Table:Row>
                                    <twig:Table:Cell class="whitespace-normal">{{ visit.title }}</twig:Table:Cell>
                                    <twig:Table:Cell><code class="text-xs">{{ visit.token }}</code></twig:Table:Cell>
                                    <twig:Table:Cell class="tabular-nums text-xs text-muted-foreground">{{ visit.visitedAt|date('d/m/Y H:i') }}</twig:Table:Cell>
                                </twig:Table:Row>
                            {% else %}
                                <twig:Table:Row>
                                    <twig:Table:Cell colspan="3" class="py-8 text-center text-sm text-muted-foreground">Aucune visite récente</twig:Table:Cell>
                                </twig:Table:Row>
                            {% endfor %}
                        </twig:Table:Body>
                    </twig:Table>
                </div>
            </twig:Card:Content>
        </twig:Card>
    </div>
</div>
{% endblock %}
