{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Gestion de la newsletter | Administration{% endblock %}

{% block content %}
<div class="w-full">
    {% for message in app.flashes('success') %}
        <div class="flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 text-green-800 px-4 py-3 mb-3" role="alert">
            <span class="flex-1 text-sm">{{ message }}</span>
            <button type="button" class="shrink-0 -mr-1 p-1 ml-auto rounded opacity-60 hover:opacity-100 transition-opacity" data-bs-dismiss="alert" aria-label="Fermer"><i data-lucide="x" width="16" height="16"></i></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('danger') %}
        <div class="flex items-start gap-3 rounded-lg border border-red-200 bg-red-50 text-red-800 px-4 py-3 mb-3" role="alert">
            <span class="flex-1 text-sm">{{ message }}</span>
            <button type="button" class="shrink-0 -mr-1 p-1 ml-auto rounded opacity-60 hover:opacity-100 transition-opacity" data-bs-dismiss="alert" aria-label="Fermer"><i data-lucide="x" width="16" height="16"></i></button>
        </div>
    {% endfor %}
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold mb-1">Gestion de la newsletter</h1>
            <p class="text-muted-foreground mb-0">Gérer les abonnés à la newsletter</p>
        </div>
        <div>
            <a href="{{ path('app_admin_newsletter_export', {filter: 'active'}) }}" class="inline-flex items-center justify-center gap-2 border border-primary text-primary px-3 py-1.5 text-sm rounded-md font-medium hover:bg-primary/5 transition-colors no-underline">
                <i data-lucide="download" width="16" height="16" class="mr-1"></i>
                Exporter (CSV)
            </a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Abonnés actifs</h6>
                        <h3 class="font-bold mb-0">{{ activeCount }}</h3>
                    </div>
                    <div class="bg-green-100 rounded-full p-3">
                        <i data-lucide="users" width="24" height="24" class="text-green-600"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Désabonnés</h6>
                        <h3 class="font-bold mb-0">{{ inactiveCount }}</h3>
                    </div>
                    <div class="bg-red-100 rounded-full p-3">
                        <i data-lucide="user-x" width="24" height="24" class="text-destructive"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Total</h6>
                        <h3 class="font-bold mb-0">{{ total }}</h3>
                    </div>
                    <div class="bg-primary/10 rounded-full p-3">
                        <i data-lucide="mail" width="24" height="24" class="text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtres -->
    <div class="rounded-lg bg-card shadow-sm mb-6">
        <div class="p-6">
            <div class="flex flex-wrap gap-1" role="group" aria-label="Filtres">
                <a href="{{ path('app_admin_newsletter_index', {filter: 'all'}) }}"
                   class="{{ currentFilter == 'all' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Tous ({{ total }})
                </a>
                <a href="{{ path('app_admin_newsletter_index', {filter: 'active'}) }}"
                   class="{{ currentFilter == 'active' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Actifs ({{ activeCount }})
                </a>
                <a href="{{ path('app_admin_newsletter_index', {filter: 'inactive'}) }}"
                   class="{{ currentFilter == 'inactive' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Inactifs ({{ inactiveCount }})
                </a>
            </div>
        </div>
    </div>

    <!-- Liste des abonnés -->
    {% if subscribers|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-newsletter', list_caption: 'Abonnés newsletter' } %}
        {% block list_table %}
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px;">
                                <input type="checkbox" class="form-check-input" id="selectAll" aria-label="Tout sélectionner">
                            </th>
                            <th>Email</th>
                            <th>Date d'inscription</th>
                            <th>Date de désabonnement</th>
                            <th>Source</th>
                            <th>Statut</th>
                            <th style="width: 120px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for subscriber in subscribers %}
                        <tr class="{% if not subscriber.active %}table-secondary{% endif %}">
                            <td>
                                <input type="checkbox" class="form-check-input subscriber-checkbox" value="{{ subscriber.id }}" aria-label="Sélectionner {{ subscriber.email }}">
                            </td>
                            <td>
                                <strong>{{ subscriber.email }}</strong>
                            </td>
                            <td>
                                <small>{{ subscriber.subscribedAt|date('d/m/Y H:i') }}</small>
                            </td>
                            <td>
                                {% if subscriber.unsubscribedAt %}
                                <small class="text-muted-foreground">{{ subscriber.unsubscribedAt|date('d/m/Y H:i') }}</small>
                                {% else %}
                                <span class="text-muted-foreground">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if subscriber.source %}
                                <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold">{{ subscriber.source }}</span>
                                {% else %}
                                <span class="text-muted-foreground">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if subscriber.active %}
                                <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-semibold">Actif</span>
                                {% else %}
                                <span class="inline-flex items-center rounded-full bg-red-100 text-destructive px-2.5 py-0.5 text-xs font-semibold">Inactif</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="flex gap-1" role="group">
                                    {% if subscriber.active %}
                                    <form method="post" action="{{ path('app_admin_newsletter_unsubscribe', {id: subscriber.id}) }}" class="inline" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('unsubscribe_' ~ subscriber.id) }}">
                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-amber-600 text-amber-600 px-3 py-1.5 text-sm rounded-md hover:bg-amber-600/5 transition-colors" title="Désabonner">
                                            <i data-lucide="user-x" width="14" height="14"></i>
                                        </button>
                                    </form>
                                    {% endif %}
                                    <form method="post" action="{{ path('app_admin_newsletter_delete', {id: subscriber.id}) }}"
                                          class="inline"
                                          data-turbo="false"
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet abonné ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ subscriber.id) }}">
                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors" title="Supprimer">
                                            <i data-lucide="trash-2" width="14" height="14"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
        {% block list_cards %}
            <div class="flex items-center gap-2 mb-4 pb-2 border-b border-border">
                <input type="checkbox" class="form-check-input" id="selectAllCards" aria-label="Tout sélectionner (vue cartes)">
                <label for="selectAllCards" class="text-sm text-muted-foreground mb-0">Sélectionner tout</label>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for subscriber in subscribers %}
                <article class="rounded-lg bg-card shadow-sm admin-list-item-card h-full {% if not subscriber.active %}opacity-75{% endif %}">
                    <div class="p-6 flex flex-col">
                        <div class="flex gap-2 mb-2">
                            <input type="checkbox" class="form-check-input subscriber-checkbox shrink-0 mt-1" value="{{ subscriber.id }}" aria-label="Sélectionner {{ subscriber.email }}">
                            <div class="min-w-0 flex-1">
                                <h2 class="text-base font-semibold mb-1 break-all">{{ subscriber.email }}</h2>
                                {% if subscriber.active %}
                                <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-semibold">Actif</span>
                                {% else %}
                                <span class="inline-flex items-center rounded-full bg-red-100 text-destructive px-2.5 py-0.5 text-xs font-semibold">Inactif</span>
                                {% endif %}
                                {% if subscriber.source %}
                                <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold ml-1">{{ subscriber.source }}</span>
                                {% endif %}
                            </div>
                        </div>
                        <dl class="grid grid-cols-2 text-sm gap-1 mb-4">
                            <dt class="text-muted-foreground">Inscription</dt>
                            <dd class="mb-0">{{ subscriber.subscribedAt|date('d/m/Y H:i') }}</dd>
                            <dt class="text-muted-foreground">Désabonnement</dt>
                            <dd class="mb-0">{{ subscriber.unsubscribedAt ? subscriber.unsubscribedAt|date('d/m/Y H:i') : '—' }}</dd>
                        </dl>
                        <div class="flex flex-wrap gap-2 mt-auto pt-2 border-t border-border">
                            {% if subscriber.active %}
                            <form method="post" action="{{ path('app_admin_newsletter_unsubscribe', {id: subscriber.id}) }}" class="inline" data-turbo="false">
                                <input type="hidden" name="_token" value="{{ csrf_token('unsubscribe_' ~ subscriber.id) }}">
                                <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-amber-600 text-amber-600 px-3 py-1.5 text-sm rounded-md hover:bg-amber-600/5 transition-colors"><i data-lucide="user-x" width="14" height="14" class="mr-1"></i>Désabonner</button>
                            </form>
                            {% endif %}
                            <form method="post" action="{{ path('app_admin_newsletter_delete', {id: subscriber.id}) }}" class="inline" data-turbo="false" onsubmit="return confirm('Supprimer cet abonné ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ subscriber.id) }}">
                                <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors"><i data-lucide="trash-2" width="14" height="14" class="mr-1"></i>Supprimer</button>
                            </form>
                        </div>
                    </div>
                </article>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}
            {% if totalPages > 1 %}
            <div class="card-footer bg-white border-t border-border rounded-b">
                <nav aria-label="Pagination">
                    <ul class="pagination pagination-sm mb-0 justify-center flex-wrap">
                        {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_newsletter_index', {filter: currentFilter, page: currentPage - 1}) }}">
                                <i data-lucide="chevron-left" width="14" height="14"></i>
                            </a>
                        </li>
                        {% endif %}

                        {% for i in 1..totalPages %}
                        {% if i == currentPage %}
                        <li class="page-item active">
                            <span class="page-link">{{ i }}</span>
                        </li>
                        {% elseif i <= 3 or i >= totalPages - 2 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_newsletter_index', {filter: currentFilter, page: i}) }}">{{ i }}</a>
                        </li>
                        {% elseif i == 4 or i == totalPages - 3 %}
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                        {% endif %}
                        {% endfor %}

                        {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_newsletter_index', {filter: currentFilter, page: currentPage + 1}) }}">
                                <i data-lucide="chevron-right" width="14" height="14"></i>
                            </a>
                        </li>
                        {% endif %}
                    </ul>
                </nav>
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
    {% else %}
    <div class="rounded-lg bg-card shadow-sm">
        <div class="p-6 text-center py-12">
            <i data-lucide="users" width="48" height="48" class="text-muted-foreground mb-4"></i>
            <p class="text-muted-foreground mb-0">Aucun abonné{{ currentFilter != 'all' ? ' (' ~ currentFilter ~ ')' : '' }}</p>
        </div>
    </div>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}

function syncSubscriberCheckboxes(checked) {
    document.querySelectorAll('.subscriber-checkbox').forEach(function(cb) {
        cb.checked = checked;
    });
}

document.getElementById('selectAll')?.addEventListener('change', function(e) {
    syncSubscriberCheckboxes(e.target.checked);
    const cards = document.getElementById('selectAllCards');
    if (cards) cards.checked = e.target.checked;
});

document.getElementById('selectAllCards')?.addEventListener('change', function(e) {
    syncSubscriberCheckboxes(e.target.checked);
    const table = document.getElementById('selectAll');
    if (table) table.checked = e.target.checked;
});
</script>
{% endblock %}
