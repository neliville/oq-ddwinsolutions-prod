{% extends 'layout/admin_base.html.twig' %}

{% block title %}Gestion de la newsletter | Administration{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-[100rem] space-y-6">
    <twig:DataPageHeader title="Gestion de la newsletter" description="Gérer les abonnés à la newsletter">
        <twig:block name="actions">
            <twig:Button as="a" href="{{ path('app_admin_newsletter_export', {filter: 'active'}) }}" variant="outline" size="sm" class="no-underline w-full sm:w-auto">
                <twig:ux:icon name="lucide:download" class="size-4 shrink-0" aria-hidden="true" />
                Exporter (CSV)
            </twig:Button>
        </twig:block>
    </twig:DataPageHeader>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        <twig:KpiStatCard label="Abonnés actifs" value="{{ activeCount }}" tone="emerald">
            <twig:block name="icon"><twig:ux:icon name="lucide:users" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Désabonnés" value="{{ inactiveCount }}" tone="destructive">
            <twig:block name="icon"><twig:ux:icon name="lucide:user-x" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Total" value="{{ total }}" tone="default">
            <twig:block name="icon"><twig:ux:icon name="lucide:mail" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
    </div>

    <twig:DataToolbar ariaLabel="Filtrer les abonnés">
        <twig:block name="content">
            <div class="flex flex-wrap gap-2" role="group" aria-label="Filtres">
                <twig:Button as="a" href="{{ path('app_admin_newsletter_index', {filter: 'all'}) }}" variant="{{ currentFilter == 'all' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Tous ({{ total }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_newsletter_index', {filter: 'active'}) }}" variant="{{ currentFilter == 'active' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Actifs ({{ activeCount }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_newsletter_index', {filter: 'inactive'}) }}" variant="{{ currentFilter == 'inactive' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Inactifs ({{ inactiveCount }})
                </twig:Button>
            </div>
        </twig:block>
    </twig:DataToolbar>

    {% if subscribers|length > 0 %}
        {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-newsletter', list_caption: 'Abonnés newsletter' } %}
            {% block list_table %}
                <twig:Table class="[&_tbody_tr:hover]:bg-accent/60">
                    <twig:Table:Caption class="sr-only">Abonnés à la newsletter</twig:Table:Caption>
                    <twig:Table:Header>
                        <twig:Table:Row class="border-b border-border bg-muted/40 hover:bg-muted/40">
                            <twig:Table:Head scope="col" class="w-12 pr-0">
                                <input type="checkbox" id="selectAll" class="size-4 rounded border-input accent-primary" aria-label="Tout sélectionner">
                            </twig:Table:Head>
                            <twig:Table:Head scope="col" class="min-w-[12rem] font-medium">Email</twig:Table:Head>
                            <twig:Table:Head scope="col" class="whitespace-nowrap font-medium">Inscription</twig:Table:Head>
                            <twig:Table:Head scope="col" class="whitespace-nowrap font-medium">Désabonnement</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Source</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Statut</twig:Table:Head>
                            <twig:Table:Head scope="col" class="w-[1%] text-end font-medium whitespace-nowrap">Actions</twig:Table:Head>
                        </twig:Table:Row>
                    </twig:Table:Header>
                    <twig:Table:Body>
                        {% for subscriber in subscribers %}
                            <twig:Table:Row class="border-b border-border/60 {{ not subscriber.active ? 'bg-muted/25' : '' }}">
                                <twig:Table:Cell class="pr-0">
                                    <input type="checkbox" class="subscriber-checkbox size-4 rounded border-input accent-primary" value="{{ subscriber.id }}" aria-label="Sélectionner {{ subscriber.email }}">
                                </twig:Table:Cell>
                                <twig:Table:Cell class="font-medium">{{ subscriber.email }}</twig:Table:Cell>
                                <twig:Table:Cell class="whitespace-nowrap text-xs tabular-nums text-muted-foreground">{{ subscriber.subscribedAt|date('d/m/Y H:i') }}</twig:Table:Cell>
                                <twig:Table:Cell class="whitespace-nowrap text-xs tabular-nums text-muted-foreground">
                                    {% if subscriber.unsubscribedAt %}
                                        {{ subscriber.unsubscribedAt|date('d/m/Y H:i') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </twig:Table:Cell>
                                <twig:Table:Cell>
                                    {% if subscriber.source %}
                                        <twig:Badge variant="outline" class="border-sky-500/30 bg-sky-500/10 text-sky-900 dark:border-sky-500/40 dark:text-sky-100">{{ subscriber.source }}</twig:Badge>
                                    {% else %}
                                        <span class="text-muted-foreground">—</span>
                                    {% endif %}
                                </twig:Table:Cell>
                                <twig:Table:Cell>
                                    {% if subscriber.active %}
                                        <twig:Badge variant="outline" class="border-emerald-500/40 bg-emerald-500/10 text-emerald-900 dark:text-emerald-200">Actif</twig:Badge>
                                    {% else %}
                                        <twig:Badge variant="secondary">Inactif</twig:Badge>
                                    {% endif %}
                                </twig:Table:Cell>
                                <twig:Table:Cell class="text-end">
                                    <div class="inline-flex flex-nowrap gap-1" role="group">
                                        {% if subscriber.active %}
                                            <form method="post" action="{{ path('app_admin_newsletter_unsubscribe', {id: subscriber.id}) }}" class="inline-flex" data-turbo="false">
                                                <input type="hidden" name="_token" value="{{ csrf_token('unsubscribe_' ~ subscriber.id) }}">
                                                <twig:Button type="submit" variant="outline" size="icon" class="size-9 text-amber-700 hover:bg-amber-500/10 dark:text-amber-400" title="Désabonner">
                                                    <twig:ux:icon name="lucide:user-x" class="size-4" aria-hidden="true" />
                                                    <span class="sr-only">Désabonner {{ subscriber.email }}</span>
                                                </twig:Button>
                                            </form>
                                        {% endif %}
                                        <form method="post"
                                              action="{{ path('app_admin_newsletter_delete', {id: subscriber.id}) }}"
                                              class="inline-flex"
                                              data-turbo="false"
                                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet abonné ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ subscriber.id) }}">
                                            <twig:Button type="submit" variant="outline" size="icon" class="size-9 text-destructive hover:bg-destructive/10" title="Supprimer">
                                                <twig:ux:icon name="lucide:trash-2" class="size-4" aria-hidden="true" />
                                                <span class="sr-only">Supprimer {{ subscriber.email }}</span>
                                            </twig:Button>
                                        </form>
                                    </div>
                                </twig:Table:Cell>
                            </twig:Table:Row>
                        {% endfor %}
                    </twig:Table:Body>
                </twig:Table>
            {% endblock %}
            {% block list_cards %}
                <div class="mb-4 flex items-center gap-2 border-b border-border pb-2">
                    <input type="checkbox" id="selectAllCards" class="size-4 rounded border-input accent-primary" aria-label="Tout sélectionner (vue cartes)">
                    <label for="selectAllCards" class="mb-0 text-sm text-muted-foreground cursor-pointer select-none">Sélectionner tout</label>
                </div>
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
                    {% for subscriber in subscribers %}
                        <twig:Card class="admin-list-item-card h-full border-border/80 shadow-sm ring-1 ring-border/40 {{ not subscriber.active ? 'opacity-80' : '' }}">
                            <twig:Card:Content class="flex flex-col gap-3 p-5 sm:p-6">
                                <div class="flex gap-2">
                                    <input type="checkbox" class="subscriber-checkbox mt-1 size-4 shrink-0 rounded border-input accent-primary" value="{{ subscriber.id }}" aria-label="Sélectionner {{ subscriber.email }}">
                                    <div class="min-w-0 flex-1">
                                        <h2 class="mb-1 break-all text-base font-semibold">{{ subscriber.email }}</h2>
                                        {% if subscriber.active %}
                                            <twig:Badge variant="outline" class="border-emerald-500/40 bg-emerald-500/10 text-emerald-900 dark:text-emerald-200">Actif</twig:Badge>
                                        {% else %}
                                            <twig:Badge variant="secondary">Inactif</twig:Badge>
                                        {% endif %}
                                        {% if subscriber.source %}
                                            <twig:Badge variant="outline" class="ml-1 border-sky-500/30 bg-sky-500/10">{{ subscriber.source }}</twig:Badge>
                                        {% endif %}
                                    </div>
                                </div>
                                <dl class="m-0 grid grid-cols-2 gap-x-2 gap-y-1 text-sm">
                                    <dt class="text-muted-foreground">Inscription</dt>
                                    <dd class="m-0 text-end tabular-nums">{{ subscriber.subscribedAt|date('d/m/Y H:i') }}</dd>
                                    <dt class="text-muted-foreground">Désabonnement</dt>
                                    <dd class="m-0 text-end tabular-nums">{{ subscriber.unsubscribedAt ? subscriber.unsubscribedAt|date('d/m/Y H:i') : '—' }}</dd>
                                </dl>
                                <div class="mt-auto flex flex-wrap gap-2 border-t border-border pt-2">
                                    {% if subscriber.active %}
                                        <form method="post" action="{{ path('app_admin_newsletter_unsubscribe', {id: subscriber.id}) }}" class="inline-flex" data-turbo="false">
                                            <input type="hidden" name="_token" value="{{ csrf_token('unsubscribe_' ~ subscriber.id) }}">
                                            <twig:Button type="submit" variant="outline" size="sm" class="gap-2 text-amber-700 hover:bg-amber-500/10 dark:text-amber-400">
                                                <twig:ux:icon name="lucide:user-x" class="size-4 shrink-0" aria-hidden="true" /> Désabonner
                                            </twig:Button>
                                        </form>
                                    {% endif %}
                                    <form method="post" action="{{ path('app_admin_newsletter_delete', {id: subscriber.id}) }}" class="inline-flex" data-turbo="false" onsubmit="return confirm('Supprimer cet abonné ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ subscriber.id) }}">
                                        <twig:Button type="submit" variant="outline" size="sm" class="gap-2 text-destructive hover:bg-destructive/10">
                                            <twig:ux:icon name="lucide:trash-2" class="size-4 shrink-0" aria-hidden="true" /> Supprimer
                                        </twig:Button>
                                    </form>
                                </div>
                            </twig:Card:Content>
                        </twig:Card>
                    {% endfor %}
                </div>
            {% endblock %}
            {% block list_footer %}
                {% include 'components/admin/list_pagination.html.twig' with {
                    routeName: 'app_admin_newsletter_index',
                    routeParams: { filter: currentFilter },
                    currentPage: currentPage,
                    totalPages: totalPages,
                } %}
            {% endblock %}
        {% endembed %}
    {% else %}
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Content class="flex flex-col items-center justify-center gap-3 py-14 text-center">
                <twig:ux:icon name="lucide:users" class="size-12 text-muted-foreground" aria-hidden="true" />
                <p class="m-0 text-sm text-muted-foreground">Aucun abonné{{ currentFilter != 'all' ? ' (' ~ currentFilter ~ ')' : '' }}</p>
            </twig:Card:Content>
        </twig:Card>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}

function syncSubscriberCheckboxes(checked) {
    document.querySelectorAll('.subscriber-checkbox').forEach(function(cb) {
        cb.checked = checked;
    });
}

document.getElementById('selectAll')?.addEventListener('change', function(e) {
    syncSubscriberCheckboxes(e.target.checked);
    const cards = document.getElementById('selectAllCards');
    if (cards) cards.checked = e.target.checked;
});

document.getElementById('selectAllCards')?.addEventListener('change', function(e) {
    syncSubscriberCheckboxes(e.target.checked);
    const table = document.getElementById('selectAll');
    if (table) table.checked = e.target.checked;
});
</script>
{% endblock %}
