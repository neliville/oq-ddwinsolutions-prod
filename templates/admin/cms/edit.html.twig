{% extends 'layout/admin_base.html.twig' %}

{% block title %}{{ cmsPage.title }} | CMS{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" integrity="sha512-SfZ5HKe3Xf1FR8Mq74ZVvYIfR0oMw66N53WhzxSp8UOZbKgjMqvkKcznowBmX5DQ9K1YZm0sl5POn7gZpv+Rw==" crossorigin="anonymous" referrerpolicy="no-referrer">
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.js"></script>
<script>
function initCmsEditor() {
    const textarea = document.getElementById('{{ form.content.vars.id }}');
    if (!textarea || textarea.dataset.easymdeInitialized === 'true') {
        return;
    }

    const easyMDE = new EasyMDE({
        element: textarea,
        spellChecker: false,
        forceSync: true,
        minHeight: '320px',
        toolbar: [
            'bold', 'italic', 'heading', '|', 'quote', 'unordered-list', 'ordered-list',
            '|', 'link', 'table', '|', 'preview', 'side-by-side', 'fullscreen', '|', 'guide'
        ],
        status: false,
    });

    textarea.dataset.easymdeInitialized = 'true';
    textarea.easyMDEInstance = easyMDE;
}

const initCmsPage = () => {
    initCmsEditor();
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
};

document.addEventListener('DOMContentLoaded', initCmsPage);
document.addEventListener('turbo:load', initCmsPage);
document.addEventListener('turbo:render', initCmsPage);
</script>
{% endblock %}

{% block content %}
<div class="w-full">
    <div class="flex justify-between items-center mb-6">
        <div>
            <a href="{{ path('app_admin_cms_index') }}" class="inline-flex items-center justify-center gap-2 border border-border text-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:bg-accent transition-colors no-underline mb-2">
                <i data-lucide="arrow-left" width="16" height="16" class="mr-1"></i>
                Retour aux pages CMS
            </a>
            <h1 class="text-2xl font-bold mb-1">{{ cmsPage.title }}</h1>
            <p class="text-muted-foreground mb-0">Dernière mise à jour : {{ cmsPage.updatedAt|date('d/m/Y à H:i') }}</p>
        </div>
    </div>

    <div class="grid grid-cols-12 gap-6">
        <div class="lg:col-span-8 col-span-12">
            <div class="rounded-lg bg-card shadow-sm">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h5 class="mb-0">Contenu en Markdown</h5>
                </div>
                <div class="p-6">
                    {{ form_start(form) }}
                        <div class="mb-4">
                            {{ form_label(form.title) }}
                            {{ form_widget(form.title, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(form.title) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.content) }}
                            {{ form_widget(form.content, { attr: { class: 'form-control', rows: 16 } }) }}
                            {{ form_errors(form.content) }}
                            <small class="text-muted-foreground">Utilisez la syntaxe Markdown. Prévisualisation disponible via EasyMDE.</small>
                        </div>

                        <div class="flex justify-end gap-2">
                            <a href="{{ path('app_admin_cms_index') }}" class="inline-flex items-center justify-center gap-2 border border-border text-foreground px-4 py-2 rounded-md font-medium hover:bg-accent transition-colors no-underline">Annuler</a>
                            <button type="submit" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">
                                <i data-lucide="save" width="16" height="16" class="mr-1"></i>
                                Enregistrer
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="lg:col-span-4 col-span-12">
            <div class="rounded-lg bg-card shadow-sm">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h6 class="mb-0">Informations</h6>
                </div>
                <div class="p-6">
                    <div class="mb-4">
                        <small class="text-muted-foreground block">Slug</small>
                        <code>{{ cmsPage.slug }}</code>
                    </div>
                    <div class="mb-4">
                        <small class="text-muted-foreground block">Créé le</small>
                        <strong>{{ cmsPage.createdAt|date('d/m/Y à H:i') }}</strong>
                    </div>
                    <div>
                        <small class="text-muted-foreground block">Dernière mise à jour</small>
                        <strong>{{ cmsPage.updatedAt|date('d/m/Y à H:i') }}</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
