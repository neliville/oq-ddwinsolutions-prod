{% extends 'layout/admin_base.html.twig' %}

{% block title %}Gestion du contenu | Administration{% endblock %}

{% block content %}
<div class="w-full">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold mb-1">Gestion du contenu légal</h1>
            <p class="text-muted-foreground mb-0">Modifier les pages légales du site (Markdown + EasyMDE).</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for slug, page in pages %}
            <div class="rounded-lg bg-card shadow-sm h-full">
                <div class="p-6 flex flex-col">
                    <h5 class="card-title">{{ page.title }}</h5>
                    <p class="text-muted-foreground text-sm flex-1">
                        Dernière mise à jour disponible dans l'éditeur.
                    </p>
                    <a href="{{ path('app_admin_cms_edit', { slug: slug }) }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity no-underline mt-4 self-start">
                        <i data-lucide="edit" width="16" height="16" class="mr-1"></i>
                        Modifier
                    </a>
                </div>
            </div>
        {% endfor %}
    </div>
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
