{% extends 'layout/admin_base.html.twig' %}

{% block title %}Gestion des tags | Administration{% endblock %}

{% block content %}
<div class="w-full">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold mb-1">Gestion des tags</h1>
            <p class="text-muted-foreground mb-0">Gérer les tags de blog</p>
        </div>
        <div>
            <a href="{{ path('app_admin_tags_new') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">
                <i data-lucide="plus" width="16" height="16" class="mr-1"></i>
                Nouveau tag
            </a>
        </div>
    </div>

    <!-- Liste des tags -->
    {% if tags|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-tags', list_caption: 'Tags' } %}
        {% block list_table %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                    <thead class="table-light">
                        <tr>
                            <th>Nom</th>
                            <th>Slug</th>
                            <th>Articles</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for tag in tags %}
                        <tr>
                            <td>
                                <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">
                                    {{ tag.name }}
                                </span>
                            </td>
                            <td>
                                <code class="small">{{ tag.slug }}</code>
                            </td>
                            <td>
                                <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold">{{ tag.blogPosts|length }} article{{ tag.blogPosts|length > 1 ? 's' : '' }}</span>
                            </td>
                            <td>
                                <div class="flex gap-1" role="group">
                                    <a href="{{ path('app_admin_tags_edit', {id: tag.id}) }}"
                                       class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors no-underline" title="Modifier">
                                        <i data-lucide="edit" width="14" height="14"></i>
                                    </a>
                                    {% if tag.blogPosts|length == 0 %}
                                    <form method="post" action="{{ path('app_admin_tags_delete', {id: tag.id}) }}"
                                          class="inline"
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce tag ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_tag_' ~ tag.id) }}">
                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors" title="Supprimer">
                                            <i data-lucide="trash-2" width="14" height="14"></i>
                                        </button>
                                    </form>
                                    {% else %}
                                    <button type="button" class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md opacity-50 cursor-not-allowed" disabled title="Tag utilisé, impossible de supprimer">
                                        <i data-lucide="lock" width="14" height="14"></i>
                                    </button>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
        {% block list_cards %}
            <div class="grid gap-3" style="grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));">
                {% for tag in tags %}
                <article class="rounded-lg bg-card shadow-sm admin-list-item-card h-full">
                    <div class="p-6 flex flex-col">
                        <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold mb-2 self-start">{{ tag.name }}</span>
                        <code class="text-sm mb-2">{{ tag.slug }}</code>
                        <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold mb-4">{{ tag.blogPosts|length }} article{{ tag.blogPosts|length > 1 ? 's' : '' }}</span>
                        <div class="flex flex-wrap gap-2 mt-auto pt-2 border-t border-border">
                            <a href="{{ path('app_admin_tags_edit', {id: tag.id}) }}" class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors no-underline"><i data-lucide="edit" width="14" height="14" class="mr-1"></i>Modifier</a>
                            {% if tag.blogPosts|length == 0 %}
                            <form method="post" action="{{ path('app_admin_tags_delete', {id: tag.id}) }}" class="inline" onsubmit="return confirm('Supprimer ce tag ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_tag_' ~ tag.id) }}">
                                <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors"><i data-lucide="trash-2" width="14" height="14" class="mr-1"></i>Supprimer</button>
                            </form>
                            {% else %}
                            <button type="button" class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md opacity-50 cursor-not-allowed" disabled><i data-lucide="lock" width="14" height="14" class="mr-1"></i>Utilisé</button>
                            {% endif %}
                        </div>
                    </div>
                </article>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}{% endblock %}
    {% endembed %}
    {% else %}
    <div class="rounded-lg bg-card shadow-sm">
        <div class="p-6 text-center py-12">
            <i data-lucide="tag" width="48" height="48" class="text-muted-foreground mb-4"></i>
            <p class="text-muted-foreground mb-0">Aucun tag</p>
            <a href="{{ path('app_admin_tags_new') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline mt-4">
                <i data-lucide="plus" width="16" height="16" class="mr-1"></i>
                Créer le premier tag
            </a>
        </div>
    </div>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
