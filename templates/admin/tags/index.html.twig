{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Gestion des tags | Administration{% endblock %}

{% block content %}
<div class="container-fluid p-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Gestion des tags</h1>
            <p class="text-muted mb-0">Gérer les tags de blog</p>
        </div>
        <div>
            <a href="{{ path('app_admin_tags_new') }}" class="btn btn-primary">
                <i data-lucide="plus" width="16" height="16" class="me-1"></i>
                Nouveau tag
            </a>
        </div>
    </div>

    <!-- Liste des tags -->
    {% if tags|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-tags', list_caption: 'Tags' } %}
        {% block list_table %}
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nom</th>
                            <th>Slug</th>
                            <th>Articles</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for tag in tags %}
                        <tr>
                            <td>
                                <span class="badge bg-secondary">
                                    {{ tag.name }}
                                </span>
                            </td>
                            <td>
                                <code class="small">{{ tag.slug }}</code>
                            </td>
                            <td>
                                <span class="badge bg-info">{{ tag.blogPosts|length }} article{{ tag.blogPosts|length > 1 ? 's' : '' }}</span>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a href="{{ path('app_admin_tags_edit', {id: tag.id}) }}" 
                                       class="btn btn-outline-secondary" title="Modifier">
                                        <i data-lucide="edit" width="14" height="14"></i>
                                    </a>
                                    {% if tag.blogPosts|length == 0 %}
                                    <form method="post" action="{{ path('app_admin_tags_delete', {id: tag.id}) }}" 
                                          class="d-inline" 
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce tag ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_tag_' ~ tag.id) }}">
                                        <button type="submit" class="btn btn-outline-danger" title="Supprimer">
                                            <i data-lucide="trash-2" width="14" height="14"></i>
                                        </button>
                                    </form>
                                    {% else %}
                                    <button type="button" class="btn btn-outline-secondary" disabled title="Tag utilisé, impossible de supprimer">
                                        <i data-lucide="lock" width="14" height="14"></i>
                                    </button>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
        {% block list_cards %}
            <div class="row g-3">
                {% for tag in tags %}
                <div class="col-12 col-sm-6 col-md-4 col-xl-3">
                    <article class="card border-0 shadow-sm admin-list-item-card h-100">
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-secondary fs-6 mb-2 align-self-start">{{ tag.name }}</span>
                            <code class="small mb-2">{{ tag.slug }}</code>
                            <span class="badge bg-info mb-3">{{ tag.blogPosts|length }} article{{ tag.blogPosts|length > 1 ? 's' : '' }}</span>
                            <div class="d-flex flex-wrap gap-2 mt-auto pt-2 border-top">
                                <a href="{{ path('app_admin_tags_edit', {id: tag.id}) }}" class="btn btn-outline-secondary btn-sm"><i data-lucide="edit" width="14" height="14" class="me-1"></i>Modifier</a>
                                {% if tag.blogPosts|length == 0 %}
                                <form method="post" action="{{ path('app_admin_tags_delete', {id: tag.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce tag ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_tag_' ~ tag.id) }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm"><i data-lucide="trash-2" width="14" height="14" class="me-1"></i>Supprimer</button>
                                </form>
                                {% else %}
                                <button type="button" class="btn btn-outline-secondary btn-sm" disabled><i data-lucide="lock" width="14" height="14" class="me-1"></i>Utilisé</button>
                                {% endif %}
                            </div>
                        </div>
                    </article>
                </div>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}{% endblock %}
    {% endembed %}
    {% else %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i data-lucide="tag" width="48" height="48" class="text-muted mb-3"></i>
            <p class="text-muted mb-0">Aucun tag</p>
            <a href="{{ path('app_admin_tags_new') }}" class="btn btn-primary mt-3">
                <i data-lucide="plus" width="16" height="16" class="me-1"></i>
                Créer le premier tag
            </a>
        </div>
    </div>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}

