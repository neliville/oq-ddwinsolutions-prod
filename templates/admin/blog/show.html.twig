{% extends 'base_with_sidebar.html.twig' %}

{% block title %}{{ post.title }} | Administration{% endblock %}

{% block content %}
<div class="w-full">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <a href="{{ path('app_admin_blog_index') }}" class="inline-flex items-center justify-center gap-2 border border-border text-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:bg-accent transition-colors no-underline mb-2">
                <i data-lucide="arrow-left" width="16" height="16" class="mr-1"></i>
                Retour à la liste
            </a>
            <h1 class="text-2xl font-bold mb-1">{{ post.title }}</h1>
            <p class="text-muted-foreground mb-0">Aperçu de l'article</p>
        </div>
        <div>
            {% if post.publishedAt %}
            <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-semibold mr-2">Publié</span>
            {% else %}
            <span class="inline-flex items-center rounded-full bg-yellow-100 text-yellow-700 px-2.5 py-0.5 text-xs font-semibold mr-2">Brouillon</span>
            {% endif %}
            {% if post.featured %}
            <span class="inline-flex items-center rounded-full bg-primary text-primary-foreground px-2.5 py-0.5 text-xs font-semibold">⭐ Mis en avant</span>
            {% endif %}
        </div>
    </div>

    <div class="grid grid-cols-12 gap-6">
        <!-- Contenu de l'article -->
        <div class="lg:col-span-8 col-span-12">
            <div class="rounded-lg bg-card shadow-sm mb-6">
                <div class="p-6">
                    <!-- Métadonnées -->
                    <div class="mb-6 pb-6 border-b border-border">
                        <div class="flex flex-wrap gap-3 items-center mb-4">
                            {% if post.category %}
                            <span class="badge" style="background-color: {{ post.category.color }}; color: white; font-size: 0.9rem;">
                                <i data-lucide="{{ post.category.icon }}" width="14" height="14" class="mr-1"></i>
                                {{ post.category.name }}
                            </span>
                            {% endif %}
                            {% if post.tags|length > 0 %}
                            {% for tag in post.tags %}
                            <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ tag.name }}</span>
                            {% endfor %}
                            {% endif %}
                            <small class="text-muted-foreground">
                                <i data-lucide="clock" width="14" height="14" class="mr-1"></i>
                                {{ post.readTime }}
                            </small>
                            <small class="text-muted-foreground">
                                <i data-lucide="eye" width="14" height="14" class="mr-1"></i>
                                {{ post.views }} vues
                            </small>
                        </div>
                        <div class="flex flex-wrap gap-3 text-muted-foreground text-sm">
                            <div>
                                <strong>Créé le:</strong> {{ post.createdAt|date('d/m/Y à H:i') }}
                            </div>
                            {% if post.updatedAt %}
                            <div>
                                <strong>Modifié le:</strong> {{ post.updatedAt|date('d/m/Y à H:i') }}
                            </div>
                            {% endif %}
                            {% if post.publishedAt %}
                            <div>
                                <strong>Publié le:</strong> {{ post.publishedAt|date('d/m/Y à H:i') }}
                            </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Extrait -->
                    <div class="mb-6">
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Extrait</h6>
                        <p class="lead">{{ post.excerpt }}</p>
                    </div>

                    {% if post.image %}
                    <div class="mb-6">
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Image à la une</h6>
                        <img src="{{ (post.image starts with 'http') ? post.image : asset(post.image) }}" alt="{{ post.title }}" class="max-w-full h-auto rounded shadow-sm" loading="lazy" width="800" height="450">
                    </div>
                    {% endif %}

                    <!-- Contenu -->
                    <div class="mb-6">
                        <h6 class="text-muted-foreground uppercase text-sm mb-4">Contenu</h6>
                        <div class="bg-muted rounded p-4">
                            {{ post.content|markdown_to_html|raw }}
                        </div>
                    </div>

                    <!-- Slug -->
                    <div class="mb-6">
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Slug (URL)</h6>
                        <code class="bg-muted p-2 rounded block">{{ post.slug }}</code>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="lg:col-span-4 col-span-12">
            <div class="rounded-lg bg-card shadow-sm mb-4">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h6 class="mb-0">Actions</h6>
                </div>
                <div class="p-6">
                    <div class="flex flex-col gap-2">
                        <a href="{{ path('app_admin_blog_edit', {id: post.id}) }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">
                            <i data-lucide="edit" width="16" height="16" class="mr-1"></i>
                            Modifier l'article
                        </a>
                        {% if post.publishedAt %}
                        <form method="post" action="{{ path('app_admin_blog_unpublish', {id: post.id}) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('unpublish_' ~ post.id) }}">
                            <button type="submit" class="w-full inline-flex items-center justify-center gap-2 border border-amber-600 text-amber-600 px-4 py-2 rounded-md font-medium hover:bg-amber-600/5 transition-colors">
                                <i data-lucide="eye-off" width="16" height="16" class="mr-1"></i>
                                Dépublier
                            </button>
                        </form>
                        {% else %}
                        <form method="post" action="{{ path('app_admin_blog_publish', {id: post.id}) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('publish_' ~ post.id) }}">
                            <button type="submit" class="w-full inline-flex items-center justify-center gap-2 border border-green-600 text-green-600 px-4 py-2 rounded-md font-medium hover:bg-green-600/5 transition-colors">
                                <i data-lucide="check" width="16" height="16" class="mr-1"></i>
                                Publier
                            </button>
                        </form>
                        {% endif %}
                        <form method="post" action="{{ path('app_admin_blog_delete', {id: post.id}) }}"
                              class="inline"
                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet article ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ post.id) }}">
                            <button type="submit" class="w-full inline-flex items-center justify-center gap-2 border border-destructive text-destructive px-4 py-2 rounded-md font-medium hover:bg-destructive/5 transition-colors">
                                <i data-lucide="trash-2" width="16" height="16" class="mr-1"></i>
                                Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Statistiques -->
            <div class="rounded-lg bg-card shadow-sm">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h6 class="mb-0">Statistiques</h6>
                </div>
                <div class="p-6">
                    <div class="mb-4">
                        <small class="text-muted-foreground block">Vues</small>
                        <strong>{{ post.views }}</strong>
                    </div>
                    {% if post.publishedAt %}
                    <div class="mb-4">
                        <small class="text-muted-foreground block">Jours depuis publication</small>
                        <strong>{{ date().diff(post.publishedAt).days }} jours</strong>
                    </div>
                    {% endif %}
                    <div>
                        <small class="text-muted-foreground block">Nombre de mots</small>
                        <strong>{{ post.content|split(' ')|length }} mots</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}

