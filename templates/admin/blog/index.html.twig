{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Gestion du blog | Administration{% endblock %}

{% block head %}
    {{ parent() }}
    <meta name="turbo-cache-control" content="no-cache">
{% endblock %}

{% block content %}
<div class="w-full">
    {% for message in app.flashes('success') %}
        <div class="flex items-start gap-3 rounded-lg border border-green-200 bg-green-50 text-green-800 px-4 py-3 mb-3" role="alert">
            <span class="flex-1 text-sm">{{ message }}</span>
            <button type="button" class="shrink-0 -mr-1 p-1 ml-auto rounded opacity-60 hover:opacity-100 transition-opacity" data-bs-dismiss="alert" aria-label="Fermer"><i data-lucide="x" width="16" height="16"></i></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('danger') %}
        <div class="flex items-start gap-3 rounded-lg border border-red-200 bg-red-50 text-red-800 px-4 py-3 mb-3" role="alert">
            <span class="flex-1 text-sm">{{ message }}</span>
            <button type="button" class="shrink-0 -mr-1 p-1 ml-auto rounded opacity-60 hover:opacity-100 transition-opacity" data-bs-dismiss="alert" aria-label="Fermer"><i data-lucide="x" width="16" height="16"></i></button>
        </div>
    {% endfor %}
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="h3 font-bold mb-1">Gestion du blog</h1>
            <p class="text-muted-foreground mb-0">Gérer les articles de blog</p>
        </div>
        <div>
            <a href="{{ path('app_admin_blog_new') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline" data-turbo="false">
                <i data-lucide="plus" width="16" height="16" class="mr-1"></i>
                Nouvel article
            </a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid gap-6 mb-6 md:grid-cols-3">
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Articles publiés</h6>
                        <h3 class="font-bold mb-0">{{ publishedCount }}</h3>
                    </div>
                    <div class="bg-green-100 rounded-full p-3">
                        <i data-lucide="check-circle" width="24" height="24" class="text-green-600"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Brouillons</h6>
                        <h3 class="font-bold mb-0">{{ draftCount }}</h3>
                    </div>
                    <div class="bg-amber-100 rounded-full p-3">
                        <i data-lucide="file-text" width="24" height="24" class="text-amber-600"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Mis en avant</h6>
                        <h3 class="font-bold mb-0">{{ featuredCount }}</h3>
                    </div>
                    <div class="bg-primary/10 rounded-full p-3">
                        <i data-lucide="star" width="24" height="24" class="text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtres -->
    <div class="rounded-lg bg-card shadow-sm mb-6">
        <div class="p-6">
            <div class="flex flex-wrap gap-1" role="group" aria-label="Filtres">
                <a href="{{ path('app_admin_blog_index', {filter: 'all'}) }}"
                   class="{{ currentFilter == 'all' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Tous ({{ total }})
                </a>
                <a href="{{ path('app_admin_blog_index', {filter: 'published'}) }}"
                   class="{{ currentFilter == 'published' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Publiés ({{ publishedCount }})
                </a>
                <a href="{{ path('app_admin_blog_index', {filter: 'draft'}) }}"
                   class="{{ currentFilter == 'draft' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Brouillons ({{ draftCount }})
                </a>
                <a href="{{ path('app_admin_blog_index', {filter: 'featured'}) }}"
                   class="{{ currentFilter == 'featured' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Mis en avant ({{ featuredCount }})
                </a>
            </div>
        </div>
    </div>

    <!-- Liste des articles -->
    {% if posts|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-blog', list_caption: 'Articles' } %}
        {% block list_table %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                    <caption class="sr-only">Liste des articles de blog</caption>
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Titre</th>
                            <th scope="col">Catégorie</th>
                            <th scope="col">Tags</th>
                            <th scope="col">Statut</th>
                            <th scope="col">Vues</th>
                            <th scope="col">Date</th>
                            <th scope="col" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for post in posts %}
                        <tr>
                            <td>
                                <strong>{{ post.title }}</strong>
                                {% if post.featured %}
                                <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2.5 py-0.5 text-xs font-semibold ml-2">⭐</span>
                                {% endif %}
                                <br>
                                <small class="text-muted-foreground">/{{ post.slug }}</small>
                            </td>
                            <td>
                                {% if post.category %}
                                <span class="badge badge-category"
                                      style="background-color: {{ post.category.color }};"
                                      aria-label="Catégorie {{ post.category.name }}">
                                    {{ post.category.name }}
                                </span>
                                {% else %}
                                <span class="text-muted-foreground">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if post.tags|length > 0 %}
                                {% for tag in post.tags|slice(0, 2) %}
                                <span class="badge badge-tag mr-1">{{ tag.name }}</span>
                                {% endfor %}
                                {% if post.tags|length > 2 %}
                                <small class="text-muted-foreground">+{{ post.tags|length - 2 }}</small>
                                {% endif %}
                                {% else %}
                                <span class="text-muted-foreground">-</span>
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge badge-status {{ post.publishedAt ? 'is-published' : 'is-draft' }}">
                                    {{ post.publishedAt ? 'Publié' : 'Brouillon' }}
                                </span>
                            </td>
                            <td>
                                <small>{{ post.views }} vues</small>
                            </td>
                            <td>
                                <small>
                                    {% if post.publishedAt %}
                                    {{ post.publishedAt|date('d/m/Y H:i') }}
                                    {% else %}
                                    {{ post.createdAt|date('d/m/Y H:i') }}
                                    {% endif %}
                                </small>
                            </td>
                            <td>
                                <div class="flex flex-wrap gap-1" role="group" aria-label="Actions pour l'article {{ post.title }}">
                                    <a href="{{ path('app_admin_blog_show', {id: post.id}) }}"
                                       class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline"
                                       aria-label="Voir l'article {{ post.title }}"
                                       title="Voir" data-turbo="false">
                                        <i data-lucide="eye" width="14" height="14" aria-hidden="true"></i>
                                    </a>
                                    <a href="{{ path('app_admin_blog_edit', {id: post.id}) }}"
                                       class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors no-underline"
                                       aria-label="Modifier l'article {{ post.title }}"
                                       title="Modifier" data-turbo="false">
                                        <i data-lucide="edit" width="14" height="14" aria-hidden="true"></i>
                                    </a>
                                    {% if post.publishedAt %}
                                    <form method="post" action="{{ path('app_admin_blog_unpublish', {id: post.id}) }}" class="inline" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('unpublish_' ~ post.id) }}">
                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-amber-600 text-amber-600 px-3 py-1.5 text-sm rounded-md hover:bg-amber-600/5 transition-colors"
                                                aria-label="Dépublier l'article {{ post.title }}"
                                                title="Dépublier">
                                            <i data-lucide="eye-off" width="14" height="14" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                    {% else %}
                                    <form method="post" action="{{ path('app_admin_blog_publish', {id: post.id}) }}" class="inline" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('publish_' ~ post.id) }}">
                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-green-600 text-green-600 px-3 py-1.5 text-sm rounded-md hover:bg-green-600/5 transition-colors"
                                                aria-label="Publier l'article {{ post.title }}"
                                                title="Publier">
                                            <i data-lucide="check" width="14" height="14" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                    {% endif %}
                                    <form method="post" action="{{ path('app_admin_blog_delete', {id: post.id}) }}"
                                          class="inline"
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet article ?');"
                                          data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ post.id) }}">
                                        <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors"
                                                aria-label="Supprimer l'article {{ post.title }}"
                                                title="Supprimer">
                                            <i data-lucide="trash-2" width="14" height="14" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
        {% block list_cards %}
            <div class="grid gap-3" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
                {% for post in posts %}
                <div>
                    <article class="rounded-lg bg-card shadow-sm admin-list-item-card h-full">
                        <div class="p-6 flex flex-col">
                            <h2 class="h6 font-semibold mb-1">{{ post.title }}{% if post.featured %} <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2.5 py-0.5 text-xs font-semibold">⭐</span>{% endif %}</h2>
                            <p class="text-sm text-muted-foreground mb-2">/{{ post.slug }}</p>
                            <div class="flex flex-wrap gap-1 mb-2">
                                <span class="badge badge-status {{ post.publishedAt ? 'is-published' : 'is-draft' }}">{{ post.publishedAt ? 'Publié' : 'Brouillon' }}</span>
                                {% if post.category %}
                                <span class="badge badge-category" style="background-color: {{ post.category.color }};">{{ post.category.name }}</span>
                                {% endif %}
                                <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ post.views }} vues</span>
                            </div>
                            {% if post.tags|length > 0 %}
                            <div class="mb-2">
                                {% for tag in post.tags|slice(0, 4) %}
                                <span class="badge badge-tag mr-1">{{ tag.name }}</span>
                                {% endfor %}
                            </div>
                            {% endif %}
                            <p class="text-sm text-muted-foreground mt-auto mb-3">
                                {% if post.publishedAt %}{{ post.publishedAt|date('d/m/Y H:i') }}{% else %}{{ post.createdAt|date('d/m/Y H:i') }}{% endif %}
                            </p>
                            <div class="flex flex-wrap gap-2 pt-2 border-t">
                                <a href="{{ path('app_admin_blog_show', {id: post.id}) }}" class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline" data-turbo="false"><i data-lucide="eye" width="14" height="14" class="mr-1"></i>Voir</a>
                                <a href="{{ path('app_admin_blog_edit', {id: post.id}) }}" class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors no-underline" data-turbo="false"><i data-lucide="edit" width="14" height="14" class="mr-1"></i>Modifier</a>
                                {% if post.publishedAt %}
                                <form method="post" action="{{ path('app_admin_blog_unpublish', {id: post.id}) }}" class="inline" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('unpublish_' ~ post.id) }}">
                                    <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-amber-600 text-amber-600 px-3 py-1.5 text-sm rounded-md hover:bg-amber-600/5 transition-colors"><i data-lucide="eye-off" width="14" height="14" class="mr-1"></i>Dépublier</button>
                                </form>
                                {% else %}
                                <form method="post" action="{{ path('app_admin_blog_publish', {id: post.id}) }}" class="inline" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('publish_' ~ post.id) }}">
                                    <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-green-600 text-green-600 px-3 py-1.5 text-sm rounded-md hover:bg-green-600/5 transition-colors"><i data-lucide="check" width="14" height="14" class="mr-1"></i>Publier</button>
                                </form>
                                {% endif %}
                                <form method="post" action="{{ path('app_admin_blog_delete', {id: post.id}) }}" class="inline" data-turbo="false" onsubmit="return confirm('Supprimer cet article ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ post.id) }}">
                                    <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors"><i data-lucide="trash-2" width="14" height="14" class="mr-1"></i>Supprimer</button>
                                </form>
                            </div>
                        </div>
                    </article>
                </div>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}
            {% if totalPages > 1 %}
            <div class="card-footer bg-white border-t border-border rounded-b">
                <nav aria-label="Pagination">
                    <ul class="pagination pagination-sm mb-0 justify-center flex-wrap">
                        {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_blog_index', {filter: currentFilter, page: currentPage - 1}) }}">
                                <i data-lucide="chevron-left" width="14" height="14"></i>
                            </a>
                        </li>
                        {% endif %}

                        {% for i in 1..totalPages %}
                        {% if i == currentPage %}
                        <li class="page-item active">
                            <span class="page-link">{{ i }}</span>
                        </li>
                        {% elseif i <= 3 or i >= totalPages - 2 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_blog_index', {filter: currentFilter, page: i}) }}">{{ i }}</a>
                        </li>
                        {% elseif i == 4 or i == totalPages - 3 %}
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                        {% endif %}
                        {% endfor %}

                        {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_blog_index', {filter: currentFilter, page: currentPage + 1}) }}">
                                <i data-lucide="chevron-right" width="14" height="14"></i>
                            </a>
                        </li>
                        {% endif %}
                    </ul>
                </nav>
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
    {% else %}
    <div class="rounded-lg bg-card shadow-sm">
        <div class="p-6 text-center py-12">
            <i data-lucide="file-text" width="48" height="48" class="text-muted-foreground mb-3"></i>
            <p class="text-muted-foreground mb-0">Aucun article{{ currentFilter != 'all' ? ' (' ~ currentFilter ~ ')' : '' }}</p>
            <a href="{{ path('app_admin_blog_new') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline mt-3" data-turbo="false">
                <i data-lucide="plus" width="16" height="16" class="mr-1"></i>
                Créer le premier article
            </a>
        </div>
    </div>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
