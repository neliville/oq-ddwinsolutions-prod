{% extends 'layout/admin_base.html.twig' %}

{% block title %}Gestion du blog | Administration{% endblock %}

{% block head %}
    {{ parent() }}
    <meta name="turbo-cache-control" content="no-cache">
{% endblock %}

{% block content %}
<div class="w-full max-w-[100rem] mx-auto space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-foreground mb-1">Gestion du blog</h1>
            <p class="text-muted-foreground text-sm mb-0">Gérer les articles de blog</p>
        </div>
        <twig:Button as="a" href="{{ path('app_admin_blog_new') }}" variant="default" size="default" class="no-underline shrink-0" data-turbo="false">
            <twig:ux:icon name="lucide:plus" class="size-4 shrink-0" aria-hidden="true" />
            Nouvel article
        </twig:Button>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Content class="p-5 sm:p-6">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-1">Articles publiés</p>
                        <p class="text-2xl font-bold tabular-nums text-foreground m-0">{{ publishedCount }}</p>
                    </div>
                    <div class="flex size-11 shrink-0 items-center justify-center rounded-full bg-emerald-500/10 text-emerald-700 dark:text-emerald-400">
                        <twig:ux:icon name="lucide:circle-check" class="size-6 shrink-0" aria-hidden="true" />
                    </div>
                </div>
            </twig:Card:Content>
        </twig:Card>
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Content class="p-5 sm:p-6">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-1">Brouillons</p>
                        <p class="text-2xl font-bold tabular-nums text-foreground m-0">{{ draftCount }}</p>
                    </div>
                    <div class="flex size-11 shrink-0 items-center justify-center rounded-full bg-amber-500/10 text-amber-700 dark:text-amber-400">
                        <twig:ux:icon name="lucide:file-text" class="size-6 shrink-0" aria-hidden="true" />
                    </div>
                </div>
            </twig:Card:Content>
        </twig:Card>
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Content class="p-5 sm:p-6">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-1">Mis en avant</p>
                        <p class="text-2xl font-bold tabular-nums text-foreground m-0">{{ featuredCount }}</p>
                    </div>
                    <div class="flex size-11 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                        <twig:ux:icon name="lucide:star" class="size-6 shrink-0" aria-hidden="true" />
                    </div>
                </div>
            </twig:Card:Content>
        </twig:Card>
    </div>

    <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
        <twig:Card:Content class="p-4 sm:p-5">
            <div class="flex flex-wrap gap-2" role="group" aria-label="Filtres">
                <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: 'all'}) }}" variant="{{ currentFilter == 'all' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Tous ({{ total }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: 'published'}) }}" variant="{{ currentFilter == 'published' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Publiés ({{ publishedCount }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: 'draft'}) }}" variant="{{ currentFilter == 'draft' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Brouillons ({{ draftCount }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: 'featured'}) }}" variant="{{ currentFilter == 'featured' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Mis en avant ({{ featuredCount }})
                </twig:Button>
            </div>
        </twig:Card:Content>
    </twig:Card>

    {% if posts|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-blog', list_caption: 'Articles' } %}
        {% block list_table %}
            <twig:Table>
                <twig:Table:Caption class="sr-only">Liste des articles de blog</twig:Table:Caption>
                <twig:Table:Header>
                    <twig:Table:Row>
                        <twig:Table:Head class="min-w-[12rem] whitespace-normal">Titre</twig:Table:Head>
                        <twig:Table:Head class="min-w-[8rem] whitespace-normal">Catégorie</twig:Table:Head>
                        <twig:Table:Head class="min-w-[10rem] max-w-[18rem] whitespace-normal">Tags</twig:Table:Head>
                        <twig:Table:Head class="w-[7rem] whitespace-normal">Statut</twig:Table:Head>
                        <twig:Table:Head class="w-[5.5rem] whitespace-normal text-end">Vues</twig:Table:Head>
                        <twig:Table:Head class="w-[9.5rem] whitespace-normal">Date</twig:Table:Head>
                        <twig:Table:Head class="w-[1%] text-end whitespace-nowrap">Actions</twig:Table:Head>
                    </twig:Table:Row>
                </twig:Table:Header>
                <twig:Table:Body>
                    {% for post in posts %}
                    <twig:Table:Row>
                        <twig:Table:Cell class="max-w-[min(28rem,48vw)] whitespace-normal align-top">
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="font-semibold text-foreground">{{ post.title }}</span>
                                {% if post.featured %}
                                    <twig:Badge variant="outline" class="gap-0.5 border-amber-500/40 bg-amber-500/10 text-amber-900 dark:border-amber-500/50 dark:bg-amber-500/15 dark:text-amber-100" title="Mis en avant">
                                        <twig:ux:icon name="lucide:star" class="size-3 shrink-0" aria-hidden="true" />
                                        <span class="sr-only">Mis en avant</span>
                                    </twig:Badge>
                                {% endif %}
                            </div>
                            <p class="mt-1 mb-0 text-xs text-muted-foreground tabular-nums">/{{ post.slug }}</p>
                        </twig:Table:Cell>
                        <twig:Table:Cell class="whitespace-normal align-top">
                            {% if post.category %}
                                <span
                                    class="inline-flex max-w-full items-center rounded-full border-0 px-2.5 py-0.5 text-xs font-semibold text-white shadow-sm"
                                    style="background-color: {{ post.category.color }};"
                                    aria-label="Catégorie {{ post.category.name }}"
                                >
                                    <span class="truncate">{{ post.category.name }}</span>
                                </span>
                            {% else %}
                                <span class="text-muted-foreground">—</span>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell class="whitespace-normal align-top">
                            {% if post.tags|length > 0 %}
                                <div class="flex flex-wrap gap-1">
                                    {% for tag in post.tags|slice(0, 2) %}
                                        <twig:Badge variant="secondary" class="max-w-[10rem] truncate font-normal">{{ tag.name }}</twig:Badge>
                                    {% endfor %}
                                    {% if post.tags|length > 2 %}
                                        <twig:Badge variant="outline" class="tabular-nums">+{{ post.tags|length - 2 }}</twig:Badge>
                                    {% endif %}
                                </div>
                            {% else %}
                                <span class="text-muted-foreground">—</span>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell class="whitespace-normal align-top">
                            {% if post.publishedAt %}
                                <twig:Badge variant="outline" class="border-emerald-500/30 bg-emerald-600/15 text-emerald-900 dark:border-emerald-500/40 dark:bg-emerald-500/20 dark:text-emerald-100">Publié</twig:Badge>
                            {% else %}
                                <twig:Badge variant="outline" class="border-amber-500/40 bg-amber-500/15 text-amber-950 dark:border-amber-500/50 dark:bg-amber-500/25 dark:text-amber-50">Brouillon</twig:Badge>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell class="whitespace-normal text-end align-top tabular-nums text-sm text-muted-foreground">
                            {{ post.views }} vues
                        </twig:Table:Cell>
                        <twig:Table:Cell class="whitespace-normal align-top text-xs text-muted-foreground tabular-nums">
                            {% if post.publishedAt %}
                                {{ post.publishedAt|date('d/m/Y H:i') }}
                            {% else %}
                                {{ post.createdAt|date('d/m/Y H:i') }}
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell class="text-end align-top">
                            <div class="inline-flex flex-nowrap items-center justify-end gap-1" role="group" aria-label="Actions pour {{ post.title|e('html_attr') }}">
                                <twig:Button as="a" href="{{ path('app_admin_blog_show', {id: post.id}) }}" variant="outline" size="icon" class="no-underline size-9 shrink-0" title="Voir" data-turbo="false">
                                    <twig:ux:icon name="lucide:eye" class="size-4" aria-hidden="true" />
                                    <span class="sr-only">Voir {{ post.title }}</span>
                                </twig:Button>
                                <twig:Button as="a" href="{{ path('app_admin_blog_edit', {id: post.id}) }}" variant="outline" size="icon" class="no-underline size-9 shrink-0" title="Modifier" data-turbo="false">
                                    <twig:ux:icon name="lucide:pencil" class="size-4" aria-hidden="true" />
                                    <span class="sr-only">Modifier {{ post.title }}</span>
                                </twig:Button>
                                {% if post.publishedAt %}
                                    <form method="post" action="{{ path('app_admin_blog_unpublish', {id: post.id}) }}" class="inline-flex" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('unpublish_' ~ post.id) }}">
                                        <twig:Button type="submit" variant="outline" size="icon" class="size-9 shrink-0 text-amber-700 hover:bg-amber-500/10 hover:text-amber-800 dark:text-amber-400 dark:hover:bg-amber-500/15" title="Dépublier">
                                            <twig:ux:icon name="lucide:eye-off" class="size-4" aria-hidden="true" />
                                            <span class="sr-only">Dépublier {{ post.title }}</span>
                                        </twig:Button>
                                    </form>
                                {% else %}
                                    <form method="post" action="{{ path('app_admin_blog_publish', {id: post.id}) }}" class="inline-flex" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('publish_' ~ post.id) }}">
                                        <twig:Button type="submit" variant="outline" size="icon" class="size-9 shrink-0 text-emerald-700 hover:bg-emerald-500/10 hover:text-emerald-800 dark:text-emerald-400 dark:hover:bg-emerald-500/15" title="Publier">
                                            <twig:ux:icon name="lucide:circle-check" class="size-4" aria-hidden="true" />
                                            <span class="sr-only">Publier {{ post.title }}</span>
                                        </twig:Button>
                                    </form>
                                {% endif %}
                                <form method="post" action="{{ path('app_admin_blog_delete', {id: post.id}) }}"
                                      class="inline-flex"
                                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet article ?');"
                                      data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ post.id) }}">
                                    <twig:Button type="submit" variant="outline" size="icon" class="size-9 shrink-0 text-destructive hover:bg-destructive/10 hover:text-destructive" title="Supprimer">
                                        <twig:ux:icon name="lucide:trash-2" class="size-4" aria-hidden="true" />
                                        <span class="sr-only">Supprimer {{ post.title }}</span>
                                    </twig:Button>
                                </form>
                            </div>
                        </twig:Table:Cell>
                    </twig:Table:Row>
                    {% endfor %}
                </twig:Table:Body>
            </twig:Table>
        {% endblock %}
        {% block list_cards %}
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
                {% for post in posts %}
                <twig:Card class="admin-list-item-card h-full border-border/80 shadow-sm ring-1 ring-border/40">
                    <twig:Card:Content class="flex flex-col gap-3 p-5 sm:p-6">
                        <div class="min-w-0">
                            <div class="flex flex-wrap items-start gap-2">
                                <h2 class="text-base font-semibold leading-snug text-foreground m-0">{{ post.title }}</h2>
                                {% if post.featured %}
                                    <twig:Badge variant="outline" class="shrink-0 gap-0.5 border-amber-500/40 bg-amber-500/10 text-amber-900 dark:border-amber-500/50 dark:bg-amber-500/15 dark:text-amber-100" title="Mis en avant">
                                        <twig:ux:icon name="lucide:star" class="size-3 shrink-0" aria-hidden="true" />
                                    </twig:Badge>
                                {% endif %}
                            </div>
                            <p class="mt-1 mb-0 text-sm text-muted-foreground">/{{ post.slug }}</p>
                        </div>
                        <div class="flex flex-wrap gap-1.5">
                            {% if post.publishedAt %}
                                <twig:Badge variant="outline" class="border-emerald-500/30 bg-emerald-600/15 text-emerald-900 dark:border-emerald-500/40 dark:bg-emerald-500/20 dark:text-emerald-100">Publié</twig:Badge>
                            {% else %}
                                <twig:Badge variant="outline" class="border-amber-500/40 bg-amber-500/15 text-amber-950 dark:border-amber-500/50 dark:bg-amber-500/25 dark:text-amber-50">Brouillon</twig:Badge>
                            {% endif %}
                            {% if post.category %}
                                <span
                                    class="inline-flex max-w-full items-center rounded-full border-0 px-2.5 py-0.5 text-xs font-semibold text-white shadow-sm"
                                    style="background-color: {{ post.category.color }};"
                                >
                                    <span class="truncate">{{ post.category.name }}</span>
                                </span>
                            {% endif %}
                            <twig:Badge variant="outline" class="tabular-nums font-normal">{{ post.views }} vues</twig:Badge>
                        </div>
                        {% if post.tags|length > 0 %}
                        <div class="flex flex-wrap gap-1">
                            {% for tag in post.tags|slice(0, 4) %}
                                <twig:Badge variant="secondary" class="max-w-full truncate font-normal">{{ tag.name }}</twig:Badge>
                            {% endfor %}
                        </div>
                        {% endif %}
                        <p class="text-sm text-muted-foreground tabular-nums mt-auto mb-0">
                            {% if post.publishedAt %}{{ post.publishedAt|date('d/m/Y H:i') }}{% else %}{{ post.createdAt|date('d/m/Y H:i') }}{% endif %}
                        </p>
                        <div class="mt-auto flex flex-wrap gap-2 border-t border-border pt-4">
                            <twig:Button as="a" href="{{ path('app_admin_blog_show', {id: post.id}) }}" variant="outline" size="sm" class="no-underline" data-turbo="false">
                                <twig:ux:icon name="lucide:eye" class="size-4 shrink-0" aria-hidden="true" />
                                Voir
                            </twig:Button>
                            <twig:Button as="a" href="{{ path('app_admin_blog_edit', {id: post.id}) }}" variant="outline" size="sm" class="no-underline" data-turbo="false">
                                <twig:ux:icon name="lucide:pencil" class="size-4 shrink-0" aria-hidden="true" />
                                Modifier
                            </twig:Button>
                            {% if post.publishedAt %}
                            <form method="post" action="{{ path('app_admin_blog_unpublish', {id: post.id}) }}" class="inline-flex" data-turbo="false">
                                <input type="hidden" name="_token" value="{{ csrf_token('unpublish_' ~ post.id) }}">
                                <twig:Button type="submit" variant="outline" size="sm" class="text-amber-700 hover:bg-amber-500/10 hover:text-amber-800 dark:text-amber-400">
                                    <twig:ux:icon name="lucide:eye-off" class="size-4 shrink-0" aria-hidden="true" />
                                    Dépublier
                                </twig:Button>
                            </form>
                            {% else %}
                            <form method="post" action="{{ path('app_admin_blog_publish', {id: post.id}) }}" class="inline-flex" data-turbo="false">
                                <input type="hidden" name="_token" value="{{ csrf_token('publish_' ~ post.id) }}">
                                <twig:Button type="submit" variant="outline" size="sm" class="text-emerald-700 hover:bg-emerald-500/10 hover:text-emerald-800 dark:text-emerald-400">
                                    <twig:ux:icon name="lucide:circle-check" class="size-4 shrink-0" aria-hidden="true" />
                                    Publier
                                </twig:Button>
                            </form>
                            {% endif %}
                            <form method="post" action="{{ path('app_admin_blog_delete', {id: post.id}) }}" class="inline-flex" data-turbo="false" onsubmit="return confirm('Supprimer cet article ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ post.id) }}">
                                <twig:Button type="submit" variant="outline" size="sm" class="text-destructive hover:bg-destructive/10 hover:text-destructive">
                                    <twig:ux:icon name="lucide:trash-2" class="size-4 shrink-0" aria-hidden="true" />
                                    Supprimer
                                </twig:Button>
                            </form>
                        </div>
                    </twig:Card:Content>
                </twig:Card>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}
            {% if totalPages > 1 %}
            <div class="border-t border-border bg-muted/20 px-4 py-4 sm:px-5">
                <nav class="flex flex-wrap items-center justify-center gap-1" aria-label="Pagination">
                    {% if currentPage > 1 %}
                        <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: currentFilter, page: currentPage - 1}) }}" variant="outline" size="icon" class="no-underline size-9" aria-label="Page précédente">
                            <twig:ux:icon name="lucide:chevron-left" class="size-4" aria-hidden="true" />
                        </twig:Button>
                    {% endif %}

                    {% for i in 1..totalPages %}
                        {% if i == currentPage %}
                            <twig:Button type="button" variant="default" size="sm" class="min-w-9 pointer-events-none" disabled aria-current="page">{{ i }}</twig:Button>
                        {% elseif i <= 3 or i >= totalPages - 2 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                            <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: currentFilter, page: i}) }}" variant="outline" size="sm" class="no-underline min-w-9">{{ i }}</twig:Button>
                        {% elseif i == 4 or i == totalPages - 3 %}
                            <span class="px-2 text-sm text-muted-foreground" aria-hidden="true">…</span>
                        {% endif %}
                    {% endfor %}

                    {% if currentPage < totalPages %}
                        <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: currentFilter, page: currentPage + 1}) }}" variant="outline" size="icon" class="no-underline size-9" aria-label="Page suivante">
                            <twig:ux:icon name="lucide:chevron-right" class="size-4" aria-hidden="true" />
                        </twig:Button>
                    {% endif %}
                </nav>
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
    {% else %}
    <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
        <twig:Card:Content class="flex flex-col items-center justify-center gap-4 py-14 text-center">
            <div class="flex size-14 items-center justify-center rounded-full bg-muted text-muted-foreground">
                <twig:ux:icon name="lucide:file-text" class="size-7 shrink-0" aria-hidden="true" />
            </div>
            <p class="text-sm text-muted-foreground m-0">Aucun article{{ currentFilter != 'all' ? ' (' ~ currentFilter ~ ')' : '' }}</p>
            <twig:Button as="a" href="{{ path('app_admin_blog_new') }}" variant="default" class="no-underline" data-turbo="false">
                <twig:ux:icon name="lucide:plus" class="size-4 shrink-0" aria-hidden="true" />
                Créer le premier article
            </twig:Button>
        </twig:Card:Content>
    </twig:Card>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
