{% extends 'layout/admin_base.html.twig' %}

{% block title %}Gestion du blog | Administration{% endblock %}

{% block head %}
    {{ parent() }}
    <meta name="turbo-cache-control" content="no-cache">
{% endblock %}

{% block content %}
<div class="w-full max-w-[100rem] mx-auto space-y-6">
    <twig:DataPageHeader title="Gestion du blog" description="Gérer les articles de blog">
        <twig:block name="actions">
            <twig:Button as="a" href="{{ path('app_admin_blog_new') }}" variant="default" size="default" class="no-underline w-full sm:w-auto" data-turbo="false">
                <twig:ux:icon name="lucide:plus" class="size-4 shrink-0" aria-hidden="true" />
                Nouvel article
            </twig:Button>
        </twig:block>
    </twig:DataPageHeader>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        <twig:KpiStatCard label="Articles publiés" value="{{ publishedCount }}" tone="emerald">
            <twig:block name="icon"><twig:ux:icon name="lucide:circle-check" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Brouillons" value="{{ draftCount }}" tone="amber">
            <twig:block name="icon"><twig:ux:icon name="lucide:file-text" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Mis en avant" value="{{ featuredCount }}" tone="default">
            <twig:block name="icon"><twig:ux:icon name="lucide:star" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
    </div>

    <twig:DataToolbar ariaLabel="Filtrer les articles du blog">
        <twig:block name="content">
            <div class="flex flex-wrap gap-2" role="group" aria-label="Filtres">
                <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: 'all'}) }}" variant="{{ currentFilter == 'all' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Tous ({{ total }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: 'published'}) }}" variant="{{ currentFilter == 'published' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Publiés ({{ publishedCount }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: 'draft'}) }}" variant="{{ currentFilter == 'draft' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Brouillons ({{ draftCount }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: 'featured'}) }}" variant="{{ currentFilter == 'featured' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Mis en avant ({{ featuredCount }})
                </twig:Button>
            </div>
        </twig:block>
    </twig:DataToolbar>

    {% if posts|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-blog', list_caption: 'Articles' } %}
        {% block list_table %}
            <div data-controller="data-table-columns" data-data-table-columns-storage-key-value="admin-blog-table">
                <details class="group mb-4 rounded-lg border border-border/70 bg-muted/15 open:bg-muted/25">
                    <summary class="flex cursor-pointer list-none items-center gap-2 px-4 py-3 text-sm font-medium text-foreground [&::-webkit-details-marker]:hidden">
                        <twig:ux:icon name="lucide:columns-2" class="size-4 shrink-0 text-muted-foreground" aria-hidden="true" />
                        Colonnes affichées
                    </summary>
                    <div class="flex flex-wrap gap-x-8 gap-y-2 border-t border-border/60 px-4 py-3 text-sm text-foreground" role="group" aria-label="Colonnes du tableau articles">
                        <label class="inline-flex cursor-pointer items-center gap-2 font-normal"><input type="checkbox" checked class="size-4 rounded border-input accent-primary" data-table-col-toggle="category" data-action="change->data-table-columns#toggle" />Catégorie</label>
                        <label class="inline-flex cursor-pointer items-center gap-2 font-normal"><input type="checkbox" checked class="size-4 rounded border-input accent-primary" data-table-col-toggle="tags" data-action="change->data-table-columns#toggle" />Tags</label>
                        <label class="inline-flex cursor-pointer items-center gap-2 font-normal"><input type="checkbox" checked class="size-4 rounded border-input accent-primary" data-table-col-toggle="status" data-action="change->data-table-columns#toggle" />Statut</label>
                        <label class="inline-flex cursor-pointer items-center gap-2 font-normal"><input type="checkbox" checked class="size-4 rounded border-input accent-primary" data-table-col-toggle="views" data-action="change->data-table-columns#toggle" />Vues</label>
                        <label class="inline-flex cursor-pointer items-center gap-2 font-normal"><input type="checkbox" checked class="size-4 rounded border-input accent-primary" data-table-col-toggle="published" data-action="change->data-table-columns#toggle" />Date</label>
                    </div>
                </details>

            <twig:Table>
                <twig:Table:Caption class="sr-only">Liste des articles de blog</twig:Table:Caption>
                <twig:Table:Header>
                    <twig:Table:Row>
                        <twig:Table:Head class="min-w-[12rem] whitespace-normal">Titre</twig:Table:Head>
                        <twig:Table:Head class="min-w-[8rem] whitespace-normal" data-table-col="category">Catégorie</twig:Table:Head>
                        <twig:Table:Head class="min-w-[10rem] max-w-[18rem] whitespace-normal" data-table-col="tags">Tags</twig:Table:Head>
                        <twig:Table:Head class="w-[7rem] whitespace-normal" data-table-col="status">Statut</twig:Table:Head>
                        <twig:Table:Head class="w-[5.5rem] whitespace-normal text-end" data-table-col="views">Vues</twig:Table:Head>
                        <twig:Table:Head class="w-[9.5rem] whitespace-normal" data-table-col="published">Date</twig:Table:Head>
                        <twig:Table:Head class="w-[1%] text-end whitespace-nowrap">Actions</twig:Table:Head>
                    </twig:Table:Row>
                </twig:Table:Header>
                <twig:Table:Body>
                    {% for post in posts %}
                    <twig:Table:Row>
                        <twig:Table:Cell class="max-w-[min(28rem,48vw)] whitespace-normal align-top">
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="font-semibold text-foreground">{{ post.title }}</span>
                                {% if post.featured %}
                                    <twig:Badge variant="outline" class="gap-0.5 border-amber-500/40 bg-amber-500/10 text-amber-900 dark:border-amber-500/50 dark:bg-amber-500/15 dark:text-amber-100" title="Mis en avant">
                                        <twig:ux:icon name="lucide:star" class="size-3 shrink-0" aria-hidden="true" />
                                        <span class="sr-only">Mis en avant</span>
                                    </twig:Badge>
                                {% endif %}
                            </div>
                            <p class="mt-1 mb-0 text-xs text-muted-foreground tabular-nums">/{{ post.slug }}</p>
                        </twig:Table:Cell>
                        <twig:Table:Cell class="whitespace-normal align-top" data-table-col="category">
                            {% if post.category %}
                                <span
                                    class="inline-flex max-w-full items-center rounded-full border-0 px-2.5 py-0.5 text-xs font-semibold text-white shadow-sm"
                                    style="background-color: {{ post.category.color }};"
                                    aria-label="Catégorie {{ post.category.name }}"
                                >
                                    <span class="truncate">{{ post.category.name }}</span>
                                </span>
                            {% else %}
                                <span class="text-muted-foreground">—</span>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell class="whitespace-normal align-top" data-table-col="tags">
                            {% if post.tags|length > 0 %}
                                <div class="flex flex-wrap gap-1">
                                    {% for tag in post.tags|slice(0, 2) %}
                                        <twig:Badge variant="secondary" class="max-w-[10rem] truncate font-normal">{{ tag.name }}</twig:Badge>
                                    {% endfor %}
                                    {% if post.tags|length > 2 %}
                                        <twig:Badge variant="outline" class="tabular-nums">+{{ post.tags|length - 2 }}</twig:Badge>
                                    {% endif %}
                                </div>
                            {% else %}
                                <span class="text-muted-foreground">—</span>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell class="whitespace-normal align-top" data-table-col="status">
                            {% if post.publishedAt %}
                                <twig:Badge variant="outline" class="border-emerald-500/30 bg-emerald-600/15 text-emerald-900 dark:border-emerald-500/40 dark:bg-emerald-500/20 dark:text-emerald-100">Publié</twig:Badge>
                            {% else %}
                                <twig:Badge variant="outline" class="border-amber-500/40 bg-amber-500/15 text-amber-950 dark:border-amber-500/50 dark:bg-amber-500/25 dark:text-amber-50">Brouillon</twig:Badge>
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell class="whitespace-normal text-end align-top tabular-nums text-sm text-muted-foreground" data-table-col="views">
                            {{ post.views }} vues
                        </twig:Table:Cell>
                        <twig:Table:Cell class="whitespace-normal align-top text-xs text-muted-foreground tabular-nums" data-table-col="published">
                            {% if post.publishedAt %}
                                {{ post.publishedAt|date('d/m/Y H:i') }}
                            {% else %}
                                {{ post.createdAt|date('d/m/Y H:i') }}
                            {% endif %}
                        </twig:Table:Cell>
                        <twig:Table:Cell class="text-end align-top">
                            <details class="relative inline-block text-end">
                                <summary class="inline-flex size-9 cursor-pointer list-none items-center justify-center rounded-md border border-input bg-background text-foreground shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden" aria-haspopup="menu" aria-label="Menu actions pour {{ post.title|e('html_attr') }}">
                                    <twig:ux:icon name="lucide:more-horizontal" class="size-4" aria-hidden="true" />
                                    <span class="sr-only">Ouvrir le menu actions</span>
                                </summary>
                                <div class="absolute right-0 z-50 mt-1 w-52 rounded-md border border-border bg-popover p-2 text-start shadow-xl" role="menu">
                                    <div class="flex flex-col gap-1">
                                        <twig:Button as="a" href="{{ path('app_admin_blog_show', {id: post.id}) }}" variant="ghost" size="sm" class="w-full justify-start gap-2 no-underline border border-transparent hover:bg-muted focus-visible:ring-offset-2" data-turbo="false" role="menuitem">
                                            <twig:ux:icon name="lucide:eye" class="size-4 shrink-0" aria-hidden="true" />
                                            Voir
                                        </twig:Button>
                                        <twig:Button as="a" href="{{ path('app_admin_blog_edit', {id: post.id}) }}" variant="ghost" size="sm" class="w-full justify-start gap-2 no-underline border border-transparent hover:bg-muted focus-visible:ring-offset-2" data-turbo="false" role="menuitem">
                                            <twig:ux:icon name="lucide:pencil" class="size-4 shrink-0" aria-hidden="true" />
                                            Modifier
                                        </twig:Button>
                                        {% if post.publishedAt %}
                                            <form method="post" action="{{ path('app_admin_blog_unpublish', {id: post.id}) }}" class="m-0" data-turbo="false" role="none">
                                                <input type="hidden" name="_token" value="{{ csrf_token('unpublish_' ~ post.id) }}">
                                                <twig:Button type="submit" variant="ghost" size="sm" class="w-full justify-start gap-2 text-amber-700 hover:bg-amber-500/10 hover:text-amber-800 dark:text-amber-400 dark:hover:bg-amber-500/15" role="menuitem">
                                                    <twig:ux:icon name="lucide:eye-off" class="size-4 shrink-0" aria-hidden="true" />
                                                    Dépublier
                                                </twig:Button>
                                            </form>
                                        {% else %}
                                            <form method="post" action="{{ path('app_admin_blog_publish', {id: post.id}) }}" class="m-0" data-turbo="false" role="none">
                                                <input type="hidden" name="_token" value="{{ csrf_token('publish_' ~ post.id) }}">
                                                <twig:Button type="submit" variant="ghost" size="sm" class="w-full justify-start gap-2 text-emerald-700 hover:bg-emerald-500/10 hover:text-emerald-800 dark:text-emerald-400 dark:hover:bg-emerald-500/15" role="menuitem">
                                                    <twig:ux:icon name="lucide:circle-check" class="size-4 shrink-0" aria-hidden="true" />
                                                    Publier
                                                </twig:Button>
                                            </form>
                                        {% endif %}
                                        <form method="post" action="{{ path('app_admin_blog_delete', {id: post.id}) }}"
                                              class="m-0"
                                              data-turbo="false"
                                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet article ?');"
                                              role="none">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ post.id) }}">
                                            <twig:Button type="submit" variant="ghost" size="sm" class="w-full justify-start gap-2 text-destructive hover:bg-destructive/10 hover:text-destructive" role="menuitem">
                                                <twig:ux:icon name="lucide:trash-2" class="size-4 shrink-0" aria-hidden="true" />
                                                Supprimer
                                            </twig:Button>
                                        </form>
                                    </div>
                                </div>
                            </details>
                        </twig:Table:Cell>
                    </twig:Table:Row>
                    {% endfor %}
                </twig:Table:Body>
            </twig:Table>
            </div>
        {% endblock %}
        {% block list_cards %}
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
                {% for post in posts %}
                <twig:Card class="admin-list-item-card h-full border-border/80 shadow-sm ring-1 ring-border/40">
                    <twig:Card:Content class="flex flex-col gap-3 p-5 sm:p-6">
                        <div class="min-w-0">
                            <div class="flex flex-wrap items-start gap-2">
                                <h2 class="text-base font-semibold leading-snug text-foreground m-0">{{ post.title }}</h2>
                                {% if post.featured %}
                                    <twig:Badge variant="outline" class="shrink-0 gap-0.5 border-amber-500/40 bg-amber-500/10 text-amber-900 dark:border-amber-500/50 dark:bg-amber-500/15 dark:text-amber-100" title="Mis en avant">
                                        <twig:ux:icon name="lucide:star" class="size-3 shrink-0" aria-hidden="true" />
                                    </twig:Badge>
                                {% endif %}
                            </div>
                            <p class="mt-1 mb-0 text-sm text-muted-foreground">/{{ post.slug }}</p>
                        </div>
                        <div class="flex flex-wrap gap-1.5">
                            {% if post.publishedAt %}
                                <twig:Badge variant="outline" class="border-emerald-500/30 bg-emerald-600/15 text-emerald-900 dark:border-emerald-500/40 dark:bg-emerald-500/20 dark:text-emerald-100">Publié</twig:Badge>
                            {% else %}
                                <twig:Badge variant="outline" class="border-amber-500/40 bg-amber-500/15 text-amber-950 dark:border-amber-500/50 dark:bg-amber-500/25 dark:text-amber-50">Brouillon</twig:Badge>
                            {% endif %}
                            {% if post.category %}
                                <span
                                    class="inline-flex max-w-full items-center rounded-full border-0 px-2.5 py-0.5 text-xs font-semibold text-white shadow-sm"
                                    style="background-color: {{ post.category.color }};"
                                >
                                    <span class="truncate">{{ post.category.name }}</span>
                                </span>
                            {% endif %}
                            <twig:Badge variant="outline" class="tabular-nums font-normal">{{ post.views }} vues</twig:Badge>
                        </div>
                        {% if post.tags|length > 0 %}
                        <div class="flex flex-wrap gap-1">
                            {% for tag in post.tags|slice(0, 4) %}
                                <twig:Badge variant="secondary" class="max-w-full truncate font-normal">{{ tag.name }}</twig:Badge>
                            {% endfor %}
                        </div>
                        {% endif %}
                        <p class="text-sm text-muted-foreground tabular-nums mt-auto mb-0">
                            {% if post.publishedAt %}{{ post.publishedAt|date('d/m/Y H:i') }}{% else %}{{ post.createdAt|date('d/m/Y H:i') }}{% endif %}
                        </p>
                        <div class="mt-auto flex flex-wrap gap-2 border-t border-border pt-4">
                            <twig:Button as="a" href="{{ path('app_admin_blog_show', {id: post.id}) }}" variant="outline" size="sm" class="no-underline" data-turbo="false">
                                <twig:ux:icon name="lucide:eye" class="size-4 shrink-0" aria-hidden="true" />
                                Voir
                            </twig:Button>
                            <twig:Button as="a" href="{{ path('app_admin_blog_edit', {id: post.id}) }}" variant="outline" size="sm" class="no-underline" data-turbo="false">
                                <twig:ux:icon name="lucide:pencil" class="size-4 shrink-0" aria-hidden="true" />
                                Modifier
                            </twig:Button>
                            {% if post.publishedAt %}
                            <form method="post" action="{{ path('app_admin_blog_unpublish', {id: post.id}) }}" class="inline-flex" data-turbo="false">
                                <input type="hidden" name="_token" value="{{ csrf_token('unpublish_' ~ post.id) }}">
                                <twig:Button type="submit" variant="outline" size="sm" class="text-amber-700 hover:bg-amber-500/10 hover:text-amber-800 dark:text-amber-400">
                                    <twig:ux:icon name="lucide:eye-off" class="size-4 shrink-0" aria-hidden="true" />
                                    Dépublier
                                </twig:Button>
                            </form>
                            {% else %}
                            <form method="post" action="{{ path('app_admin_blog_publish', {id: post.id}) }}" class="inline-flex" data-turbo="false">
                                <input type="hidden" name="_token" value="{{ csrf_token('publish_' ~ post.id) }}">
                                <twig:Button type="submit" variant="outline" size="sm" class="text-emerald-700 hover:bg-emerald-500/10 hover:text-emerald-800 dark:text-emerald-400">
                                    <twig:ux:icon name="lucide:circle-check" class="size-4 shrink-0" aria-hidden="true" />
                                    Publier
                                </twig:Button>
                            </form>
                            {% endif %}
                            <form method="post" action="{{ path('app_admin_blog_delete', {id: post.id}) }}" class="inline-flex" data-turbo="false" onsubmit="return confirm('Supprimer cet article ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ post.id) }}">
                                <twig:Button type="submit" variant="outline" size="sm" class="text-destructive hover:bg-destructive/10 hover:text-destructive">
                                    <twig:ux:icon name="lucide:trash-2" class="size-4 shrink-0" aria-hidden="true" />
                                    Supprimer
                                </twig:Button>
                            </form>
                        </div>
                    </twig:Card:Content>
                </twig:Card>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}
            {% if totalPages > 1 %}
            <div class="border-t border-border bg-muted/20 px-4 py-4 sm:px-5">
                <nav class="flex flex-wrap items-center justify-center gap-1" aria-label="Pagination">
                    {% if currentPage > 1 %}
                        <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: currentFilter, page: currentPage - 1}) }}" variant="outline" size="icon" class="no-underline size-9" aria-label="Page précédente">
                            <twig:ux:icon name="lucide:chevron-left" class="size-4" aria-hidden="true" />
                        </twig:Button>
                    {% endif %}

                    {% for i in 1..totalPages %}
                        {% if i == currentPage %}
                            <twig:Button type="button" variant="default" size="sm" class="min-w-9 pointer-events-none" disabled aria-current="page">{{ i }}</twig:Button>
                        {% elseif i <= 3 or i >= totalPages - 2 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                            <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: currentFilter, page: i}) }}" variant="outline" size="sm" class="no-underline min-w-9">{{ i }}</twig:Button>
                        {% elseif i == 4 or i == totalPages - 3 %}
                            <span class="px-2 text-sm text-muted-foreground" aria-hidden="true">…</span>
                        {% endif %}
                    {% endfor %}

                    {% if currentPage < totalPages %}
                        <twig:Button as="a" href="{{ path('app_admin_blog_index', {filter: currentFilter, page: currentPage + 1}) }}" variant="outline" size="icon" class="no-underline size-9" aria-label="Page suivante">
                            <twig:ux:icon name="lucide:chevron-right" class="size-4" aria-hidden="true" />
                        </twig:Button>
                    {% endif %}
                </nav>
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
    {% else %}
    <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
        <twig:Card:Content class="flex flex-col items-center justify-center gap-4 py-14 text-center">
            <div class="flex size-14 items-center justify-center rounded-full bg-muted text-muted-foreground">
                <twig:ux:icon name="lucide:file-text" class="size-7 shrink-0" aria-hidden="true" />
            </div>
            <p class="text-sm text-muted-foreground m-0">Aucun article{{ currentFilter != 'all' ? ' (' ~ currentFilter ~ ')' : '' }}</p>
            <twig:Button as="a" href="{{ path('app_admin_blog_new') }}" variant="default" class="no-underline" data-turbo="false">
                <twig:ux:icon name="lucide:plus" class="size-4 shrink-0" aria-hidden="true" />
                Créer le premier article
            </twig:Button>
        </twig:Card:Content>
    </twig:Card>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
