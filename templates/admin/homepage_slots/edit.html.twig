{% extends 'layout/admin_base.html.twig' %}

{% block title %}Modifier {{ slot.label }} — Homepage{% endblock %}

{% block content %}
<div class="w-full max-w-[56rem] mx-auto space-y-6">
    <div class="flex flex-col gap-1">
        <h1 class="text-2xl font-bold tracking-tight text-foreground m-0">{{ slot.label }}</h1>
        <p class="text-muted-foreground text-sm m-0 font-mono">{{ slot.slotKey }}</p>
    </div>

    <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
        <twig:Card:Content class="p-5 sm:p-6">
            {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
                {{ form_row(form.content) }}
                {{ form_row(form.active) }}
                <div class="flex gap-2 pt-2">
                    <twig:Button type="submit" size="sm">Enregistrer</twig:Button>
                    <twig:Button as="a" href="{{ path('app_admin_homepage_slots_index') }}" variant="outline" size="sm" class="no-underline">Annuler</twig:Button>
                </div>
            {{ form_end(form) }}
        </twig:Card:Content>
    </twig:Card>
</div>
{% endblock %}
