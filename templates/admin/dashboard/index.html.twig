{% extends 'layout/admin_base.html.twig' %}

{% block title %}Tableau de bord Administration | OUTILS-QUALITÉ{% endblock %}

{% block meta_description %}Tableau de bord de l'administration — OUTILS-QUALITÉ{% endblock %}

{% block content %}
<div class="dashboard-page admin-dashboard-page w-full">
    {% set pis = platformIntegrationSummary %}
    <div class="flex flex-col gap-4 sm:flex-row sm:justify-between sm:items-start mb-6">
        <div>
            <h1 class="text-2xl font-bold mb-1">Tableau de bord Administration</h1>
            <p class="text-muted-foreground mb-0">Vue synthétique — les actions détaillées sont accessibles depuis la sidebar ou les liens rapides ci‑dessous.</p>
        </div>
        <div class="flex flex-wrap gap-2 shrink-0">
            <twig:Button as="a" href="{{ path('app_admin_platform_health_index') }}" variant="outline" size="sm" class="no-underline">
                Santé &amp; intégrations
            </twig:Button>
            <twig:Button as="a" href="{{ path('app_admin_tool_usage_index') }}" variant="outline" size="sm" class="no-underline">
                Usage outils
            </twig:Button>
            <twig:Button as="a" href="{{ path('app_admin_export_analytics_index') }}" variant="outline" size="sm" class="no-underline">
                Exports fichiers
            </twig:Button>
        </div>
    </div>

    {% if (pis.mautic_configured and pis.mautic_reachable is same as(false)) or (pis.messenger_failed_count is not null and pis.messenger_failed_count > 0) %}
    <div class="rounded-lg border border-destructive/40 bg-destructive/5 px-4 py-3 mb-6 text-sm">
        <strong class="text-destructive">Alerte plateforme</strong>
        {% if pis.mautic_configured and pis.mautic_reachable is same as(false) %}
            <span class="block mt-1 text-foreground/90">{{ pis.mautic_detail }}</span>
        {% endif %}
        {% if pis.messenger_failed_count is not null and pis.messenger_failed_count > 0 %}
            <span class="block mt-1 text-foreground/90">{{ pis.messenger_failed_detail }}</span>
        {% endif %}
        <twig:Button as="a" href="{{ path('app_admin_platform_health_index') }}" variant="destructive" size="sm" class="no-underline mt-3">
            Diagnostic complet
        </twig:Button>
    </div>
    {% endif %}

    <div class="rounded-lg border border-border bg-muted/30 p-4 sm:p-6 mb-6"
         data-controller="chart gsap-stagger"
         data-chart-kind-value="admin-dashboard"
         data-chart-config-value="{{ adminDashboardCharts|json_encode|e('html_attr') }}"
         data-gsap-stagger-child-selector-value=":scope .admin-kpi-stagger > *"
    >
        <h2 class="text-lg font-semibold mb-2 flex items-center gap-2">
            <i data-lucide="radar" width="20" height="20" aria-hidden="true"></i>
            Pilotage produit (7 derniers jours)
        </h2>
        <p class="text-sm text-muted-foreground mb-4">
            Vues détaillées :
            <a href="{{ path('app_admin_qse_capa_overview') }}" class="text-primary underline-offset-4 hover:underline">CAPA (file globale)</a>
            ·
            <a href="{{ path('app_admin_qse_risk_overview') }}" class="text-primary underline-offset-4 hover:underline">Risques</a>
            ·
            <a href="{{ path('app_admin_tool_usage_index') }}" class="text-primary underline-offset-4 hover:underline">Créations par outil</a>
            ·
            <a href="{{ path('app_admin_export_analytics_index') }}" class="text-primary underline-offset-4 hover:underline">Exports</a>
        </p>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4 mb-6 admin-kpi-stagger">
            <twig:KpiStatCard label="Utilisateurs actifs (TE)" value="{{ trackingUsers7d }}" tone="default" helpId="help.admin.kpi.te_users">
                <twig:block name="icon"><twig:ux:icon name="lucide:radio" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
            </twig:KpiStatCard>
            <twig:KpiStatCard label="Inscriptions" value="{{ registrations7d }}" tone="emerald">
                <twig:block name="icon"><twig:ux:icon name="lucide:user-plus" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
            </twig:KpiStatCard>
            <twig:KpiStatCard label="Exports déclenchés" value="{{ exports7d }}" tone="sky">
                <twig:block name="icon"><twig:ux:icon name="lucide:download" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
            </twig:KpiStatCard>
            <twig:KpiStatCard label="CAPA créées" value="{{ capaEntities7d }}" tone="amber" helpId="help.admin.kpi.capa_entities" :helperVisible="true" helper="Événements TE : {{ capaEvents7d }}">
                <twig:block name="icon"><twig:ux:icon name="lucide:list-checks" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
            </twig:KpiStatCard>
        </div>

        <div class="grid gap-6 lg:grid-cols-2 mb-6">
            <twig:Card class="admin-chart-card border-border/80 shadow-sm ring-1 ring-border/40">
                <twig:Card:Header class="pb-2">
                    <twig:Card:Title class="text-base font-semibold tracking-tight">Inscriptions journalières</twig:Card:Title>
                </twig:Card:Header>
                <twig:Card:Content>
                    <p class="text-xs text-muted-foreground mb-3 m-0">Nouveaux comptes par jour — tendance brute sur 7&nbsp;jours glissants.</p>
                    <div class="h-52 w-full min-h-[13rem]" data-chart-wrap>
                        <canvas data-admin-dashboard-charts-chart-ref="chartRegistrations" class="block h-full max-h-52 w-full" role="img" aria-label="Graphique inscriptions 7 jours"></canvas>
                    </div>
                </twig:Card:Content>
            </twig:Card>
            <twig:Card class="admin-chart-card border-border/80 shadow-sm ring-1 ring-border/40">
                <twig:Card:Header class="pb-2">
                    <twig:Card:Title class="text-base font-semibold tracking-tight">Visites (pages)</twig:Card:Title>
                </twig:Card:Header>
                <twig:Card:Content>
                    <p class="text-xs text-muted-foreground mb-3 m-0">Volume agrégé de vues journalières — corrélé au référent acquisition.</p>
                    <div class="h-52 w-full min-h-[13rem]" data-chart-wrap>
                        <canvas data-admin-dashboard-charts-chart-ref="chartVisits" class="block h-full max-h-52 w-full" role="img" aria-label="Graphique visites 7 jours"></canvas>
                    </div>
                </twig:Card:Content>
            </twig:Card>
        </div>

        <twig:Card class="admin-chart-card mb-6 border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Header class="pb-2">
                <twig:Card:Title class="text-base font-semibold tracking-tight">Entonnoir d’activation (7&nbsp;j)</twig:Card:Title>
            </twig:Card:Header>
            <twig:Card:Content>
                <p class="text-xs text-muted-foreground mb-3 m-0">Comparaison ordres de grandeur : actifs événements → engagement cockpit → exports.</p>
                <div class="h-64 w-full min-h-[16rem]" data-chart-wrap>
                    <canvas data-admin-dashboard-charts-chart-ref="chartEngagement" class="block h-full w-full" role="img" aria-label="Graphique activation 7 jours"></canvas>
                </div>
            </twig:Card:Content>
        </twig:Card>

        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4 mb-6">
            <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
                <twig:Card:Content class="p-4 sm:p-5">
                    <p class="mb-1 text-xs font-medium uppercase tracking-wide text-muted-foreground">Retours connexion</p>
                    <p class="m-0 text-xl font-bold tabular-nums text-foreground">{{ loginReturns7d }}</p>
                </twig:Card:Content>
            </twig:Card>
            <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
                <twig:Card:Content class="p-4 sm:p-5">
                    <p class="mb-1 text-xs font-medium uppercase tracking-wide text-muted-foreground">Ouvertures cockpit</p>
                    <p class="m-0 text-xl font-bold tabular-nums text-foreground">{{ dashboardOpens7d }}</p>
                </twig:Card:Content>
            </twig:Card>
            <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
                <twig:Card:Content class="p-4 sm:p-5">
                    <p class="mb-1 text-xs font-medium uppercase tracking-wide text-muted-foreground">Audits créés</p>
                    <p class="m-0 text-xl font-bold tabular-nums text-foreground">{{ auditEntities7d }}</p>
                    <p class="mb-0 mt-1 text-xs text-muted-foreground">TE&nbsp;: {{ auditEvents7d }}</p>
                </twig:Card:Content>
            </twig:Card>
            <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
                <twig:Card:Content class="p-4 sm:p-5">
                    <p class="mb-1 text-xs font-medium uppercase tracking-wide text-muted-foreground">Risques créés</p>
                    <p class="m-0 text-xl font-bold tabular-nums text-foreground">{{ riskEntities7d }}</p>
                    <p class="mb-0 mt-1 text-xs text-muted-foreground">TE&nbsp;: {{ riskEvents7d }}</p>
                </twig:Card:Content>
            </twig:Card>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
            <div>
                <h3 class="text-sm font-semibold mb-2">Événements par type (TE)</h3>
                {% if trackingByType7d|length > 0 %}
                    <ul class="text-sm space-y-1 list-none p-0 m-0">
                        {% for row in trackingByType7d %}
                            <li class="flex justify-between gap-2 border-b border-border/60 py-1">
                                <code>{{ row.event_type }}</code>
                                <span class="font-medium">{{ row.cnt }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-sm text-muted-foreground mb-0">Aucun événement sur cette période.</p>
                {% endif %}
            </div>
            <div>
                <h3 class="text-sm font-semibold mb-2">Top outils ouverts (TE)</h3>
                {% if topToolsOpened7d|length > 0 %}
                    <ul class="text-sm space-y-1 list-none p-0 m-0">
                        {% for row in topToolsOpened7d %}
                            <li class="flex justify-between gap-2 border-b border-border/60 py-1">
                                <span>{{ row.tool }}</span>
                                <span class="font-medium">{{ row.cnt }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-sm text-muted-foreground mb-0">Pas encore de <code>tool_opened</code> sur 7 jours.</p>
                {% endif %}
            </div>
        </div>
        <div class="mt-4">
            <h3 class="text-sm font-semibold mb-2">Créations enregistrées par outil (tous utilisateurs)</h3>
            {% if globalToolCreations|length > 0 %}
                <div class="flex flex-wrap gap-2">
                    {% for t in globalToolCreations|slice(0, 6) %}
                        <span class="inline-flex items-center rounded-full border border-border px-2.5 py-0.5 text-xs">{{ t.label }} : {{ t.count }}</span>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-sm text-muted-foreground mb-0">Aucune donnée agrégée.</p>
            {% endif %}
        </div>
    </div>

    <div class="rounded-lg border border-border bg-card p-4 sm:p-6 mb-6 shadow-sm ring-1 ring-border/40"
         data-controller="chart"
         data-chart-kind-value="admin-growth"
         data-chart-config-value="{{ adminGrowthChart|json_encode|e('html_attr') }}"
    >
        <h2 class="text-lg font-semibold mb-2 flex items-center gap-2">
            <i data-lucide="trending-up" width="20" height="20" aria-hidden="true"></i>
            Leads &amp; croissance plateforme
        </h2>
        <p class="text-sm text-muted-foreground mb-4 m-0">Volume leads (Mautic), abonnés newsletter actifs, inscriptions sur 7 jours.</p>
        <div class="h-64 w-full min-h-[16rem]" data-chart-wrap>
            <canvas data-admin-growth-chart-ref="main" class="block h-full w-full" role="img" aria-label="Indicateurs acquisition"></canvas>
        </div>
    </div>

    <div class="rounded-lg bg-card shadow-sm border border-border mb-6">
        <div class="px-6 py-4 border-b border-border">
            <h2 class="text-base font-semibold mb-0 flex items-center gap-2">
                <i data-lucide="list-tree" width="18" height="18"></i>
                Derniers événements métier (TrackingEvent)
            </h2>
        </div>
        <div class="p-6 max-w-full overflow-x-auto">
            {% if recentTrackingEvents|length > 0 %}
                <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Utilisateur</th>
                            <th>Outil</th>
                            <th>Source</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for ev in recentTrackingEvents %}
                            <tr>
                                <td>{{ ev.createdAt|date('d/m/Y H:i') }}</td>
                                <td><code>{{ ev.eventType.value }}</code></td>
                                <td>{% if ev.user %}{{ ev.user.email }}{% else %}—{% endif %}</td>
                                <td>{{ ev.tool|default('—') }}</td>
                                <td>{{ ev.source|default('—') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="text-muted-foreground mb-0 text-sm">Aucun événement enregistré pour l’instant.</p>
            {% endif %}
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid gap-6 mb-6" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));">
        <!-- Messages de contact non lus -->
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="p-6">
                <div class="flex justify-between items-start">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Messages non lus</h6>
                        <h3 class="font-bold mb-0">{{ unreadMessagesCount }}</h3>
                        <small class="text-muted-foreground">
                            <i data-lucide="mail" width="14" height="14" class="mr-1"></i>
                            {{ messagesToday }} aujourd'hui
                        </small>
                    </div>
                    <div class="bg-red-100 rounded-full p-3">
                        <i data-lucide="mail" width="24" height="24" class="text-destructive"></i>
                    </div>
                </div>
                <a href="{{ path('app_admin_contact_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors no-underline mt-3 w-full">
                    Voir les messages
                </a>
            </div>
        </div>

        <!-- Abonnés newsletter -->
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="p-6">
                <div class="flex justify-between items-start">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Abonnés actifs</h6>
                        <h3 class="font-bold mb-0">{{ activeSubscribersCount }}</h3>
                        <small class="text-muted-foreground">
                            <i data-lucide="user-plus" width="14" height="14" class="mr-1"></i>
                            {{ newSubscribersToday }} nouveaux aujourd'hui
                        </small>
                    </div>
                    <div class="bg-primary/10 rounded-full p-3">
                        <i data-lucide="users" width="24" height="24" class="text-primary"></i>
                    </div>
                </div>
                <a href="{{ path('app_admin_newsletter_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline mt-3 w-full">
                    Gérer la newsletter
                </a>
            </div>
        </div>

        <!-- Visites aujourd'hui -->
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="p-6">
                <div class="flex justify-between items-start">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Visites aujourd'hui</h6>
                        <h3 class="font-bold mb-0">{{ visitsToday }}</h3>
                        <small class="text-muted-foreground">
                            <i data-lucide="trending-up" width="14" height="14" class="mr-1"></i>
                            {{ visitsLastWeek }} cette semaine
                        </small>
                    </div>
                    <div class="bg-sky-100 rounded-full p-3">
                        <i data-lucide="bar-chart-2" width="24" height="24" class="text-sky-600"></i>
                    </div>
                </div>
                <a href="{{ path('app_admin_analytics_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-sky-600 text-sky-600 px-3 py-1.5 text-sm rounded-md hover:bg-sky-600/5 transition-colors no-underline mt-3 w-full">
                    Voir les analytics
                </a>
            </div>
        </div>

        <!-- Articles publiés -->
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="p-6">
                <div class="flex justify-between items-start">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Articles publiés</h6>
                        <h3 class="font-bold mb-0">{{ blogPostsPublishedCount }}</h3>
                        <small class="text-muted-foreground">
                            <i data-lucide="book-open" width="14" height="14" class="mr-1"></i>
                            Articles au catalogue public
                        </small>
                    </div>
                    <div class="bg-green-100 rounded-full p-3">
                        <i data-lucide="book" width="24" height="24" class="text-green-600"></i>
                    </div>
                </div>
                <a href="{{ path('app_admin_blog_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-green-600 text-green-600 px-3 py-1.5 text-sm rounded-md hover:bg-green-600/5 transition-colors no-underline mt-3 w-full">
                    Gérer les articles
                </a>
            </div>
        </div>

        <!-- Leads (utilisation des outils) -->
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="p-6">
                <div class="flex justify-between items-start">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Leads</h6>
                        <h3 class="font-bold mb-0">{{ leadsTotal }}</h3>
                        <small class="text-muted-foreground">
                            <i data-lucide="user-plus" width="14" height="14" class="mr-1"></i>
                            {{ leadsToday }} aujourd'hui · {{ leadsLastWeek }} cette semaine
                        </small>
                    </div>
                    <div class="bg-amber-100 rounded-full p-3">
                        <i data-lucide="target" width="24" height="24" class="text-amber-600"></i>
                    </div>
                </div>
                <a href="{{ path('app_admin_leads_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-amber-600 text-amber-600 px-3 py-1.5 text-sm rounded-md hover:bg-amber-600/5 transition-colors no-underline mt-3 w-full">
                    Voir les leads
                </a>
            </div>
        </div>
    </div>

    <!-- Graphiques et détails -->
    <div class="grid gap-6 mb-6 md:grid-cols-2">
        <!-- Pages les plus visitées -->
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="px-6 py-4 border-b bg-card">
                <h5 class="mb-0">
                    <i data-lucide="trending-up" width="20" height="20" class="mr-2"></i>
                    Pages les plus visitées
                </h5>
            </div>
            <div class="p-6">
                {% if mostVisitedPages|length > 0 %}
                <div class="max-w-full overflow-x-auto">
                    <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                        <thead>
                            <tr>
                                <th>URL</th>
                                <th class="text-right">Visites</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for page in mostVisitedPages %}
                            <tr>
                                <td>
                                    <code class="text-sm">{{ page['url']|slice(0, 50) }}{% if page['url']|length > 50 %}...{% endif %}</code>
                                </td>
                                <td class="text-right">
                                    <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2.5 py-0.5 text-xs font-semibold">{{ page['visitCount'] }}</span>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="text-center py-6">
                    <i data-lucide="bar-chart-2" width="48" height="48" class="text-muted-foreground mb-2"></i>
                    <p class="text-muted-foreground mb-0">Aucune visite enregistrée</p>
                </div>
                {% endif %}
            </div>
        </div>

        <!-- Articles les plus vus -->
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="px-6 py-4 border-b bg-card">
                <h5 class="mb-0">
                    <i data-lucide="eye" width="20" height="20" class="mr-2"></i>
                    Articles les plus vus
                </h5>
            </div>
            <div class="p-6">
                {% if mostViewedPosts|length > 0 %}
                <div class="max-w-full overflow-x-auto">
                    <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                        <thead>
                            <tr>
                                <th>Titre</th>
                                <th class="text-right">Vues</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for post in mostViewedPosts %}
                            <tr>
                                <td>
                                    <strong>{{ post.title }}</strong>
                                    {% if post.category %}
                                    <br>
                                    <small class="text-muted-foreground">{{ post.category.name }}</small>
                                    {% endif %}
                                </td>
                                <td class="text-right">
                                    <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold">{{ post.views }}</span>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="text-center py-6">
                    <i data-lucide="book-open" width="48" height="48" class="text-muted-foreground mb-2"></i>
                    <p class="text-muted-foreground mb-0">Aucun article publié</p>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="rounded-lg border border-border bg-card p-4 mb-6">
        <h5 class="font-semibold mb-2">QSE — référentiels d’audit</h5>
        <div class="flex flex-wrap gap-3 text-sm">
            <a href="{{ path('app_admin_qse_audit_standards_index') }}" class="app-inline-link">Référentiels</a>
            <a href="{{ path('app_admin_qse_audit_requirements_index') }}" class="app-inline-link">Exigences</a>
            <a href="{{ path('app_admin_qse_req_import_index') }}" class="app-inline-link">Import (prévisualisation)</a>
        </div>
    </div>

    <!-- Statistiques détaillées -->
    <div class="grid gap-6 mb-6 lg:grid-cols-3">
        <!-- Statistiques des messages -->
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="px-6 py-4 border-b bg-card">
                <h5 class="mb-0">
                    <i data-lucide="mail" width="20" height="20" class="mr-2"></i>
                    Messages de contact
                </h5>
            </div>
            <div class="p-6">
                <div class="mb-3">
                    <div class="flex justify-between mb-2">
                        <span class="text-muted-foreground">Aujourd'hui</span>
                        <strong>{{ messagesToday }}</strong>
                    </div>
                    <div class="w-full bg-muted rounded-full overflow-hidden" style="height: 8px;">
                        <div class="bg-destructive h-full rounded-full" role="progressbar" style="width: {{ messagesToday > 0 ? (messagesToday / (messagesLastWeek > 0 ? messagesLastWeek : 1)) * 100 : 0 }}%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="flex justify-between mb-2">
                        <span class="text-muted-foreground">Cette semaine</span>
                        <strong>{{ messagesLastWeek }}</strong>
                    </div>
                    <div class="w-full bg-muted rounded-full overflow-hidden" style="height: 8px;">
                        <div class="bg-yellow-500 h-full rounded-full" role="progressbar" style="width: {{ messagesLastWeek > 0 ? (messagesLastWeek / (messagesLastMonth > 0 ? messagesLastMonth : 1)) * 100 : 0 }}%"></div>
                    </div>
                </div>
                <div class="mb-0">
                    <div class="flex justify-between mb-2">
                        <span class="text-muted-foreground">Ce mois</span>
                        <strong>{{ messagesLastMonth }}</strong>
                    </div>
                    <div class="w-full bg-muted rounded-full overflow-hidden" style="height: 8px;">
                        <div class="bg-green-500 h-full rounded-full" role="progressbar" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistiques newsletter -->
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="px-6 py-4 border-b bg-card">
                <h5 class="mb-0">
                    <i data-lucide="users" width="20" height="20" class="mr-2"></i>
                    Newsletter
                </h5>
            </div>
            <div class="p-6">
                <div class="mb-3">
                    <div class="flex justify-between mb-2">
                        <span class="text-muted-foreground">Nouveaux aujourd'hui</span>
                        <strong>{{ newSubscribersToday }}</strong>
                    </div>
                    <div class="w-full bg-muted rounded-full overflow-hidden" style="height: 8px;">
                        <div class="bg-primary h-full rounded-full" role="progressbar" style="width: {{ newSubscribersToday > 0 ? (newSubscribersToday / (newSubscribersLastWeek > 0 ? newSubscribersLastWeek : 1)) * 100 : 0 }}%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="flex justify-between mb-2">
                        <span class="text-muted-foreground">Cette semaine</span>
                        <strong>{{ newSubscribersLastWeek }}</strong>
                    </div>
                    <div class="w-full bg-muted rounded-full overflow-hidden" style="height: 8px;">
                        <div class="bg-sky-500 h-full rounded-full" role="progressbar" style="width: {{ newSubscribersLastWeek > 0 ? (newSubscribersLastWeek / (newSubscribersLastMonth > 0 ? newSubscribersLastMonth : 1)) * 100 : 0 }}%"></div>
                    </div>
                </div>
                <div class="mb-0">
                    <div class="flex justify-between mb-2">
                        <span class="text-muted-foreground">Ce mois</span>
                        <strong>{{ newSubscribersLastMonth }}</strong>
                    </div>
                    <div class="w-full bg-muted rounded-full overflow-hidden" style="height: 8px;">
                        <div class="bg-green-500 h-full rounded-full" role="progressbar" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistiques des visites -->
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="px-6 py-4 border-b bg-card">
                <h5 class="mb-0">
                    <i data-lucide="activity" width="20" height="20" class="mr-2"></i>
                    Visites
                </h5>
            </div>
            <div class="p-6">
                <div class="mb-3">
                    <div class="flex justify-between mb-2">
                        <span class="text-muted-foreground">Aujourd'hui</span>
                        <strong>{{ visitsToday }}</strong>
                    </div>
                    <div class="w-full bg-muted rounded-full overflow-hidden" style="height: 8px;">
                        <div class="bg-sky-500 h-full rounded-full" role="progressbar" style="width: {{ visitsToday > 0 ? (visitsToday / (visitsLastWeek > 0 ? visitsLastWeek : 1)) * 100 : 0 }}%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="flex justify-between mb-2">
                        <span class="text-muted-foreground">Cette semaine</span>
                        <strong>{{ visitsLastWeek }}</strong>
                    </div>
                    <div class="w-full bg-muted rounded-full overflow-hidden" style="height: 8px;">
                        <div class="bg-primary h-full rounded-full" role="progressbar" style="width: {{ visitsLastWeek > 0 ? (visitsLastWeek / (visitsLastMonth > 0 ? visitsLastMonth : 1)) * 100 : 0 }}%"></div>
                    </div>
                </div>
                <div class="mb-0">
                    <div class="flex justify-between mb-2">
                        <span class="text-muted-foreground">Ce mois</span>
                        <strong>{{ visitsLastMonth }}</strong>
                    </div>
                    <div class="w-full bg-muted rounded-full overflow-hidden" style="height: 8px;">
                        <div class="bg-green-500 h-full rounded-full" role="progressbar" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Activité récente et Derniers leads -->
    <div class="grid gap-6 lg:grid-cols-[2fr_1fr]">
        <div class="rounded-lg bg-card shadow-sm">
            <div class="px-6 py-4 border-b bg-card">
                <h5 class="mb-0">
                    <i data-lucide="clock" width="20" height="20" class="mr-2"></i>
                    Activité récente
                </h5>
            </div>
            <div class="p-6">
                {% if recentActivity|length > 0 %}
                <div class="max-w-full overflow-x-auto">
                    <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Utilisateur</th>
                                <th>Action</th>
                                <th>Entité</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for activity in recentActivity %}
                            <tr>
                                <td>
                                    <small>{{ activity.createdAt|date('d/m/Y H:i') }}</small>
                                </td>
                                <td>
                                    <strong>{{ activity.user.email }}</strong>
                                </td>
                                <td>
                                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold
                                        {% if activity.action == 'CREATE' %}bg-green-100 text-green-700
                                        {% elseif activity.action == 'UPDATE' %}bg-primary/10 text-primary
                                        {% elseif activity.action == 'DELETE' %}bg-red-100 text-destructive
                                        {% else %}bg-secondary text-secondary-foreground
                                        {% endif %}">
                                        {{ activity.action }}
                                    </span>
                                </td>
                                <td>
                                    {% if activity.entityType %}
                                    <code class="text-sm">{{ activity.entityType }}</code>
                                    {% else %}
                                    <span class="text-muted-foreground">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if activity.description %}
                                    {{ activity.description|slice(0, 50) }}{% if activity.description|length > 50 %}...{% endif %}
                                    {% else %}
                                    <span class="text-muted-foreground">-</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="text-center py-6">
                    <i data-lucide="activity" width="48" height="48" class="text-muted-foreground mb-2"></i>
                    <p class="text-muted-foreground mb-0">Aucune activité récente</p>
                </div>
                {% endif %}
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="px-6 py-4 border-b bg-card flex justify-between items-center">
                <h5 class="mb-0">
                    <i data-lucide="target" width="20" height="20" class="mr-2"></i>
                    Derniers leads
                </h5>
                <a href="{{ path('app_admin_leads_index') }}" class="inline-flex items-center justify-center gap-1.5 border border-amber-600 text-amber-600 px-3 py-1.5 text-sm rounded-md hover:bg-amber-600/5 transition-colors no-underline">Voir tout</a>
            </div>
            <div class="p-6">
                {% if recentLeads|length > 0 %}
                <ul class="list-none p-0 mb-0">
                    {% for lead in recentLeads %}
                    <li class="flex justify-between items-center py-2 border-b border-border">
                        <span class="text-sm">{{ lead.email ?? 'Invité' }}</span>
                        <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ lead.tool ?? lead.source ?? '—' }}</span>
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <div class="text-center py-6 text-muted-foreground text-sm">
                    Aucun lead récent
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
