{% extends 'layout/admin_base.html.twig' %}

{% block title %}Leads | Administration{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-[100rem] space-y-6">
    <twig:DataPageHeader title="Leads" description="Prospects issus de l’utilisation des outils et formulaires" />

    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        <twig:KpiStatCard label="Total" value="{{ total }}" tone="default">
            <twig:block name="icon"><twig:ux:icon name="lucide:users" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Source : outil" value="{{ bySource.tool }}" tone="sky">
            <twig:block name="icon"><twig:ux:icon name="lucide:wrench" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Ishikawa / 5 Pourquoi" value="{{ byTool.ishikawa ~ ' / ' ~ byTool.fivewhy }}" tone="amber" helper="Répartition par outil">
            <twig:block name="icon"><twig:ux:icon name="lucide:split" class="size-6 shrink-0" aria-hidden="true" /></twig:block>
        </twig:KpiStatCard>
    </div>

    {% if leads|length > 0 %}
        {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-leads', list_caption: 'Leads' } %}
            {% block list_table %}
                <twig:Table class="[&_tbody_tr:hover]:bg-accent/60">
                    <twig:Table:Caption class="sr-only">Liste des leads</twig:Table:Caption>
                    <twig:Table:Header>
                        <twig:Table:Row class="border-b border-border bg-muted/40 hover:bg-muted/40">
                            <twig:Table:Head scope="col" class="font-medium">Email</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Source</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Outil</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Type</twig:Table:Head>
                            <twig:Table:Head scope="col" class="font-medium">Score</twig:Table:Head>
                            <twig:Table:Head scope="col" class="whitespace-nowrap font-medium">Date</twig:Table:Head>
                        </twig:Table:Row>
                    </twig:Table:Header>
                    <twig:Table:Body>
                        {% for lead in leads %}
                            <twig:Table:Row class="border-b border-border/60">
                                <twig:Table:Cell class="max-w-[min(20rem,50vw)] break-all font-medium">{{ lead.email ?? '—' }}</twig:Table:Cell>
                                <twig:Table:Cell>
                                    <twig:Badge variant="secondary">{{ lead.source ?? '—' }}</twig:Badge>
                                </twig:Table:Cell>
                                <twig:Table:Cell class="text-muted-foreground">{{ lead.tool ?? '—' }}</twig:Table:Cell>
                                <twig:Table:Cell class="text-muted-foreground">{{ lead.type ?? '—' }}</twig:Table:Cell>
                                <twig:Table:Cell class="tabular-nums">{{ lead.score ?? '—' }}</twig:Table:Cell>
                                <twig:Table:Cell class="whitespace-nowrap text-xs text-muted-foreground tabular-nums">
                                    {{ lead.createdAt ? lead.createdAt|date('d/m/Y H:i') : '—' }}
                                </twig:Table:Cell>
                            </twig:Table:Row>
                        {% endfor %}
                    </twig:Table:Body>
                </twig:Table>
            {% endblock %}
            {% block list_cards %}
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
                    {% for lead in leads %}
                        <twig:Card class="admin-list-item-card h-full border-border/80 shadow-sm ring-1 ring-border/40">
                            <twig:Card:Content class="flex flex-col gap-2 p-5 sm:p-6">
                                <h2 class="m-0 break-all text-base font-semibold">{{ lead.email ?? '—' }}</h2>
                                <dl class="m-0 grid grid-cols-2 gap-x-2 gap-y-2 text-sm">
                                    <dt class="text-muted-foreground">Source</dt>
                                    <dd class="m-0 justify-self-end">
                                        <twig:Badge variant="secondary">{{ lead.source ?? '—' }}</twig:Badge>
                                    </dd>
                                    <dt class="text-muted-foreground">Outil</dt>
                                    <dd class="m-0 text-end">{{ lead.tool ?? '—' }}</dd>
                                    <dt class="text-muted-foreground">Type</dt>
                                    <dd class="m-0 text-end">{{ lead.type ?? '—' }}</dd>
                                    <dt class="text-muted-foreground">Score</dt>
                                    <dd class="m-0 text-end tabular-nums">{{ lead.score ?? '—' }}</dd>
                                    <dt class="text-muted-foreground">Date</dt>
                                    <dd class="m-0 text-end text-xs tabular-nums">{{ lead.createdAt ? lead.createdAt|date('d/m/Y H:i') : '—' }}</dd>
                                </dl>
                            </twig:Card:Content>
                        </twig:Card>
                    {% endfor %}
                </div>
            {% endblock %}
            {% block list_footer %}{% endblock %}
        {% endembed %}
    {% else %}
        <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
            <twig:Card:Content class="flex flex-col items-center justify-center gap-3 py-14 text-center text-muted-foreground">
                <twig:ux:icon name="lucide:users" class="size-12 shrink-0 opacity-70" aria-hidden="true" />
                <p class="m-0 text-sm">Aucun lead enregistré</p>
            </twig:Card:Content>
        </twig:Card>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
