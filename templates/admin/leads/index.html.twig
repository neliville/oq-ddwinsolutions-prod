{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Leads | Administration{% endblock %}

{% block content %}
<div class="w-full">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold mb-1">Leads</h1>
            <p class="text-muted-foreground mb-0">Prospects issus de l'utilisation des outils et formulaires</p>
        </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <h6 class="text-muted-foreground uppercase text-sm mb-1">Total</h6>
                <h3 class="font-bold mb-0">{{ total }}</h3>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <h6 class="text-muted-foreground uppercase text-sm mb-1">Source : outil</h6>
                <h3 class="font-bold mb-0">{{ bySource.tool }}</h3>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <h6 class="text-muted-foreground uppercase text-sm mb-1">Par outil (Ishikawa / 5 Pourquoi)</h6>
                <p class="mb-0">{{ byTool.ishikawa }} / {{ byTool.fivewhy }}</p>
            </div>
        </div>
    </div>

    <!-- Liste -->
    {% if leads|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-leads', list_caption: 'Leads' } %}
        {% block list_table %}
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Email</th>
                            <th>Source</th>
                            <th>Outil</th>
                            <th>Type</th>
                            <th>Score</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for lead in leads %}
                        <tr>
                            <td>{{ lead.email ?? '—' }}</td>
                            <td><span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ lead.source ?? '—' }}</span></td>
                            <td>{{ lead.tool ?? '—' }}</td>
                            <td>{{ lead.type ?? '—' }}</td>
                            <td>{{ lead.score ?? '—' }}</td>
                            <td>{{ lead.createdAt ? lead.createdAt|date('d/m/Y H:i') : '—' }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
        {% block list_cards %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for lead in leads %}
                <article class="rounded-lg bg-card shadow-sm admin-list-item-card h-full">
                    <div class="p-6">
                        <h2 class="text-base font-semibold mb-2 break-all">{{ lead.email ?? '—' }}</h2>
                        <dl class="grid grid-cols-2 text-sm gap-1 mb-0">
                            <dt class="text-muted-foreground">Source</dt>
                            <dd class="mb-0"><span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ lead.source ?? '—' }}</span></dd>
                            <dt class="text-muted-foreground">Outil</dt>
                            <dd class="mb-0">{{ lead.tool ?? '—' }}</dd>
                            <dt class="text-muted-foreground">Type</dt>
                            <dd class="mb-0">{{ lead.type ?? '—' }}</dd>
                            <dt class="text-muted-foreground">Score</dt>
                            <dd class="mb-0">{{ lead.score ?? '—' }}</dd>
                            <dt class="text-muted-foreground">Date</dt>
                            <dd class="mb-0">{{ lead.createdAt ? lead.createdAt|date('d/m/Y H:i') : '—' }}</dd>
                        </dl>
                    </div>
                </article>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}{% endblock %}
    {% endembed %}
    {% else %}
    <div class="rounded-lg bg-card shadow-sm">
        <div class="p-6 text-center py-12 text-muted-foreground">
            <i data-lucide="users" width="48" height="48" class="mb-2"></i>
            <p class="mb-0">Aucun lead enregistré</p>
        </div>
    </div>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
