{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Leads | Administration{% endblock %}

{% block content %}
<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Leads</h1>
            <p class="text-muted mb-0">Prospects issus de l'utilisation des outils et formulaires</p>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small mb-1">Total</h6>
                    <h3 class="fw-bold mb-0">{{ total }}</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small mb-1">Source : outil</h6>
                    <h3 class="fw-bold mb-0">{{ bySource.tool }}</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small mb-1">Par outil (Ishikawa / 5 Pourquoi)</h6>
                    <p class="mb-0">{{ byTool.ishikawa }} / {{ byTool.fivewhy }}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste -->
    {% if leads|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-leads', list_caption: 'Leads' } %}
        {% block list_table %}
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Email</th>
                            <th>Source</th>
                            <th>Outil</th>
                            <th>Type</th>
                            <th>Score</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for lead in leads %}
                        <tr>
                            <td>{{ lead.email ?? '—' }}</td>
                            <td><span class="badge bg-secondary">{{ lead.source ?? '—' }}</span></td>
                            <td>{{ lead.tool ?? '—' }}</td>
                            <td>{{ lead.type ?? '—' }}</td>
                            <td>{{ lead.score ?? '—' }}</td>
                            <td>{{ lead.createdAt ? lead.createdAt|date('d/m/Y H:i') : '—' }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
        {% block list_cards %}
            <div class="row g-3">
                {% for lead in leads %}
                <div class="col-12 col-md-6 col-xl-4">
                    <article class="card border-0 shadow-sm admin-list-item-card h-100">
                        <div class="card-body">
                            <h2 class="h6 fw-semibold mb-2 text-break">{{ lead.email ?? '—' }}</h2>
                            <dl class="row small g-1 mb-0">
                                <dt class="col-5 text-muted">Source</dt>
                                <dd class="col-7 mb-0"><span class="badge bg-secondary">{{ lead.source ?? '—' }}</span></dd>
                                <dt class="col-5 text-muted">Outil</dt>
                                <dd class="col-7 mb-0">{{ lead.tool ?? '—' }}</dd>
                                <dt class="col-5 text-muted">Type</dt>
                                <dd class="col-7 mb-0">{{ lead.type ?? '—' }}</dd>
                                <dt class="col-5 text-muted">Score</dt>
                                <dd class="col-7 mb-0">{{ lead.score ?? '—' }}</dd>
                                <dt class="col-5 text-muted">Date</dt>
                                <dd class="col-7 mb-0">{{ lead.createdAt ? lead.createdAt|date('d/m/Y H:i') : '—' }}</dd>
                            </dl>
                        </div>
                    </article>
                </div>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}{% endblock %}
    {% endembed %}
    {% else %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i data-lucide="users" width="48" height="48" class="mb-2"></i>
            <p class="mb-0">Aucun lead enregistré</p>
        </div>
    </div>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
