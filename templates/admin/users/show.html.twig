{% extends 'base_with_sidebar.html.twig' %}

{% block title %}{{ user.email }} | Administration{% endblock %}

{% block content %}
<div class="w-full">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <a href="{{ path('app_admin_users_index') }}" class="inline-flex items-center justify-center gap-2 border border-border text-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:bg-accent transition-colors no-underline mb-2">
                <i data-lucide="arrow-left" width="16" height="16" class="mr-1"></i>
                Retour à la liste
            </a>
            <h1 class="text-2xl font-bold mb-1">Utilisateur : {{ user.email }}</h1>
            <p class="text-muted-foreground mb-0">Détails, activité produit et audit d'administration</p>
        </div>
        <div>
            <a href="{{ path('app_admin_users_edit', {id: user.id}) }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">
                <i data-lucide="edit" width="16" height="16" class="mr-1"></i>
                Modifier
            </a>
        </div>
    </div>

    <!-- Synthèse activité -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="p-6">
                <small class="text-muted-foreground uppercase block">Dernière connexion</small>
                <div class="font-bold mt-1">
                    {% if user.lastLoginAt %}
                        {{ user.lastLoginAt|date('d/m/Y H:i') }}
                    {% else %}
                        <span class="text-muted-foreground">Jamais</span>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="p-6">
                <small class="text-muted-foreground uppercase block">Dernière activité</small>
                <div class="font-bold mt-1">
                    {% if user.lastActivityAt %}
                        {{ user.lastActivityAt|date('d/m/Y H:i') }}
                    {% else %}
                        <span class="text-muted-foreground">—</span>
                    {% endif %}
                </div>
                <small class="text-muted-foreground">Connexion, sauvegarde ou export</small>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="p-6">
                <small class="text-muted-foreground uppercase block">Analyses enregistrées (6 outils)</small>
                <div class="font-bold mt-1">{{ analysisTotalCount }}</div>
                {% if recordTotalCount > 0 %}
                <small class="text-muted-foreground">+ {{ recordTotalCount }} entrée(s) historique « Record »</small>
                {% endif %}
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm h-full">
            <div class="p-6">
                <small class="text-muted-foreground uppercase block">Exports tracés</small>
                <div class="font-bold mt-1">{{ exportTotalCount }}</div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-12 gap-6">
        <!-- Informations utilisateur -->
        <div class="lg:col-span-6 col-span-12">
            <div class="rounded-lg bg-card shadow-sm mb-6">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h5 class="mb-0">Informations</h5>
                </div>
                <div class="p-6">
                    <div class="mb-4">
                        <small class="text-muted-foreground block">Email</small>
                        <strong>{{ user.email }}</strong>
                    </div>
                    <div class="mb-4">
                        <small class="text-muted-foreground block">Rôles</small>
                        <div>
                            {% for role in user.roles %}
                            {% if role == 'ROLE_ADMIN' %}
                            <span class="inline-flex items-center rounded-full bg-red-100 text-destructive px-2.5 py-0.5 text-xs font-semibold mr-1">
                                <i data-lucide="shield" width="12" height="12" class="mr-1"></i>
                                Admin
                            </span>
                            {% elseif role == 'ROLE_USER' %}
                            <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-semibold mr-1">User</span>
                            {% else %}
                            <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold mr-1">{{ role }}</span>
                            {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="mb-4">
                        <small class="text-muted-foreground block">Date de création</small>
                        <strong>{{ user.createdAt|date('d/m/Y à H:i') }}</strong>
                    </div>
                    <div class="mb-0">
                        <small class="text-muted-foreground block">Formule / quota export (mois)</small>
                        <strong>{{ user.plan }}</strong>
                        <span class="text-muted-foreground">—</span>
                        <strong>{{ user.exportCountThisMonth }}</strong>
                        <span class="text-muted-foreground text-sm">export(s) ce mois</span>
                    </div>
                </div>
            </div>

            <div class="rounded-lg bg-card shadow-sm mb-6">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h5 class="mb-0">Créations par outil</h5>
                    <small class="text-muted-foreground">Nombre d'analyses sauvegardées (Ishikawa, 5 Pourquoi, QQOQCCP, AMDEC, Pareto, 8D), tri décroissant</small>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                        <thead class="bg-muted/50">
                            <tr>
                                <th class="px-4 py-3 text-left font-medium">Outil</th>
                                <th class="px-4 py-3 text-right font-medium">Créations</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in toolBreakdown %}
                            <tr>
                                <td class="px-4 py-3"><span class="font-semibold">{{ row.label }}</span> <span class="text-muted-foreground text-sm">({{ row.key }})</span></td>
                                <td class="px-4 py-3 text-right"><span class="inline-flex items-center rounded-full bg-primary text-primary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ row.count }}</span></td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            {% if recordStatsByType|length > 0 %}
            <div class="rounded-lg bg-card shadow-sm mb-6">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h5 class="mb-0">Ancien modèle « Record »</h5>
                    <small class="text-muted-foreground">Comptages legacy si présents en base</small>
                </div>
                <div class="p-6">
                    <ul class="list-none mb-0 p-0">
                        {% for row in recordStatsByType %}
                        <li class="flex justify-between border-b border-border py-1 text-sm">
                            <span class="font-mono">{{ row.type|default('(non défini)') }}</span>
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">{{ row.total }}</span>
                        </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
            {% endif %}

            {% if exportStatsByTool|length > 0 or exportStatsByToolAndFormat|length > 0 %}
            <div class="rounded-lg bg-card shadow-sm">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h5 class="mb-0">Exports tracés</h5>
                    <small class="text-muted-foreground">Par outil puis par format (PDF, PNG, JSON…)</small>
                </div>
                <div class="p-6">
                    {% if exportStatsByTool|length > 0 %}
                    <p class="text-sm text-muted-foreground mb-2">Total par outil</p>
                    <ul class="list-none mb-4 p-0">
                        {% for row in exportStatsByTool %}
                        <li class="flex justify-between border-b border-border py-1 text-sm">
                            <span>{{ row.tool }}</span>
                            <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold">{{ row.total }}</span>
                        </li>
                        {% endfor %}
                    </ul>
                    {% endif %}
                    {% if exportStatsByToolAndFormat|length > 0 %}
                    <p class="text-sm text-muted-foreground mb-2">Détail outil × format</p>
                    <ul class="list-none mb-0 p-0">
                        {% for row in exportStatsByToolAndFormat %}
                        <li class="flex justify-between border-b border-border py-1 text-sm">
                            <span><span class="font-medium">{{ row.tool }}</span> <span class="text-muted-foreground">· {{ row.format|upper }}</span></span>
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">{{ row.total }}</span>
                        </li>
                        {% endfor %}
                    </ul>
                    {% endif %}
                </div>
            </div>
            {% endif %}
        </div>

        <!-- Audit admin -->
        <div class="lg:col-span-6 col-span-12">
            <div class="rounded-lg bg-card shadow-sm mb-6">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg flex justify-between items-center">
                    <h5 class="mb-0">Audit administration</h5>
                    <small class="text-muted-foreground">Actions effectuées par ce compte en tant qu'admin</small>
                </div>
                <div>
                    {% if adminAuditLogs|length > 0 %}
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                            <thead class="bg-muted/50">
                                <tr>
                                    <th class="px-4 py-3 text-left font-medium">Date</th>
                                    <th class="px-4 py-3 text-left font-medium">Action</th>
                                    <th class="px-4 py-3 text-left font-medium">Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for log in adminAuditLogs %}
                                <tr>
                                    <td class="px-4 py-3">
                                        <small>{{ log.createdAt|date('d/m/Y H:i') }}</small>
                                    </td>
                                    <td class="px-4 py-3">
                                        {% if log.action == 'CREATE' %}
                                        <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-semibold">{{ log.action }}</span>
                                        {% elseif log.action == 'UPDATE' %}
                                        <span class="inline-flex items-center rounded-full bg-primary text-primary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ log.action }}</span>
                                        {% elseif log.action == 'DELETE' %}
                                        <span class="inline-flex items-center rounded-full bg-red-100 text-destructive px-2.5 py-0.5 text-xs font-semibold">{{ log.action }}</span>
                                        {% else %}
                                        <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ log.action }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-4 py-3">
                                        <small>{{ log.description|default('-')|slice(0, 80) }}{% if log.description|length > 80 %}…{% endif %}</small>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-8 px-6">
                        <p class="text-muted-foreground text-sm mb-0">Aucune entrée d'audit (normal si l'utilisateur n'est pas admin ou n'a pas effectué d'actions dans le back-office).</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            <div class="rounded-lg bg-card shadow-sm mb-6">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h5 class="mb-0">Analyses récentes (tous outils)</h5>
                </div>
                <div>
                    {% if recentAnalyses|length > 0 %}
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                            <thead class="bg-muted/50">
                                <tr>
                                    <th class="px-4 py-3 text-left font-medium">Date</th>
                                    <th class="px-4 py-3 text-left font-medium">Titre</th>
                                    <th class="px-4 py-3 text-left font-medium">Outil</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for rec in recentAnalyses %}
                                <tr>
                                    <td class="px-4 py-3"><small>{{ rec.createdAt|date('d/m/Y H:i') }}</small></td>
                                    <td class="px-4 py-3"><small>{{ rec.title|slice(0, 48) }}{% if rec.title|length > 48 %}…{% endif %}</small></td>
                                    <td class="px-4 py-3"><span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ rec.typeLabel }}</span></td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-8">
                        <p class="text-muted-foreground text-sm mb-0">Aucune analyse enregistrée sur les outils.</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            <div class="rounded-lg bg-card shadow-sm">
                <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
                    <h5 class="mb-0">Historique des exports</h5>
                    <small class="text-muted-foreground">Derniers exports enregistrés pour ce compte</small>
                </div>
                <div>
                    {% if recentExports|length > 0 %}
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm [&_tbody_tr:hover]:bg-accent">
                            <thead class="bg-muted/50">
                                <tr>
                                    <th class="px-4 py-3 text-left font-medium">Date</th>
                                    <th class="px-4 py-3 text-left font-medium">Outil</th>
                                    <th class="px-4 py-3 text-left font-medium">Format</th>
                                    <th class="px-4 py-3 text-left font-medium">Source</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for ex in recentExports %}
                                <tr>
                                    <td class="px-4 py-3"><small>{{ ex.createdAt|date('d/m/Y H:i') }}</small></td>
                                    <td class="px-4 py-3"><span class="inline-flex items-center rounded-full bg-sky-100 text-sky-700 px-2.5 py-0.5 text-xs font-semibold">{{ ex.tool }}</span></td>
                                    <td class="px-4 py-3"><small class="uppercase">{{ ex.format }}</small></td>
                                    <td class="px-4 py-3 text-sm">
                                        {% if ex.sourceUrl %}
                                            <a href="{{ ex.sourceUrl }}" target="_blank" rel="noopener" class="no-underline truncate inline-block" style="max-width: 140px;">Lien</a>
                                        {% else %}
                                            <span class="text-muted-foreground">—</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-8">
                        <p class="text-muted-foreground text-sm mb-0">Aucun export associé à ce compte.</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    {% if user.id != app.user.id %}
    <div class="rounded-lg bg-card shadow-sm mt-6">
        <div class="px-6 py-4 border-b border-border bg-white rounded-t-lg">
            <h5 class="mb-0 text-destructive">Zone de danger</h5>
        </div>
        <div class="p-6">
            <form method="post" action="{{ path('app_admin_users_delete', {id: user.id}) }}"
                  onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ? Cette action est irréversible.');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                <button type="submit" class="inline-flex items-center justify-center gap-2 bg-destructive text-white px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity">
                    <i data-lucide="trash-2" width="16" height="16" class="mr-1"></i>
                    Supprimer l'utilisateur
                </button>
            </form>
        </div>
    </div>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
