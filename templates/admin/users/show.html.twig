{% extends 'base_with_sidebar.html.twig' %}

{% block title %}{{ user.email }} | Administration{% endblock %}

{% block content %}
<div class="container-fluid p-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="{{ path('app_admin_users_index') }}" class="btn btn-sm btn-outline-secondary mb-2">
                <i data-lucide="arrow-left" width="16" height="16" class="me-1"></i>
                Retour à la liste
            </a>
            <h1 class="h3 fw-bold mb-1">Utilisateur : {{ user.email }}</h1>
            <p class="text-muted mb-0">Détails, activité produit et audit d’administration</p>
        </div>
        <div>
            <a href="{{ path('app_admin_users_edit', {id: user.id}) }}" class="btn btn-primary">
                <i data-lucide="edit" width="16" height="16" class="me-1"></i>
                Modifier
            </a>
        </div>
    </div>

    <!-- Synthèse activité -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted text-uppercase">Dernière connexion</small>
                    <div class="fw-bold mt-1">
                        {% if user.lastLoginAt %}
                            {{ user.lastLoginAt|date('d/m/Y H:i') }}
                        {% else %}
                            <span class="text-muted">Jamais</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted text-uppercase">Dernière activité</small>
                    <div class="fw-bold mt-1">
                        {% if user.lastActivityAt %}
                            {{ user.lastActivityAt|date('d/m/Y H:i') }}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </div>
                    <small class="text-muted">Connexion, sauvegarde ou export</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted text-uppercase">Analyses enregistrées (6 outils)</small>
                    <div class="fw-bold mt-1">{{ analysisTotalCount }}</div>
                    {% if recordTotalCount > 0 %}
                    <small class="text-muted">+ {{ recordTotalCount }} entrée(s) historique « Record »</small>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted text-uppercase">Exports tracés</small>
                    <div class="fw-bold mt-1">{{ exportTotalCount }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Informations utilisateur -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">Informations</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-muted d-block">Email</small>
                        <strong>{{ user.email }}</strong>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Rôles</small>
                        <div>
                            {% for role in user.roles %}
                            {% if role == 'ROLE_ADMIN' %}
                            <span class="badge bg-danger me-1">
                                <i data-lucide="shield" width="12" height="12" class="me-1"></i>
                                Admin
                            </span>
                            {% elseif role == 'ROLE_USER' %}
                            <span class="badge bg-success me-1">User</span>
                            {% else %}
                            <span class="badge bg-secondary me-1">{{ role }}</span>
                            {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Date de création</small>
                        <strong>{{ user.createdAt|date('d/m/Y à H:i') }}</strong>
                    </div>
                    <div class="mb-0">
                        <small class="text-muted d-block">Formule / quota export (mois)</small>
                        <strong>{{ user.plan }}</strong>
                        <span class="text-muted">—</span>
                        <strong>{{ user.exportCountThisMonth }}</strong>
                        <span class="text-muted small">export(s) ce mois</span>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">Créations par outil</h5>
                    <small class="text-muted">Nombre d’analyses sauvegardées (Ishikawa, 5 Pourquoi, QQOQCCP, AMDEC, Pareto, 8D), tri décroissant</small>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Outil</th>
                                    <th class="text-end">Créations</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in toolBreakdown %}
                                <tr>
                                    <td><span class="fw-semibold">{{ row.label }}</span> <span class="text-muted small">({{ row.key }})</span></td>
                                    <td class="text-end"><span class="badge bg-primary">{{ row.count }}</span></td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            {% if recordStatsByType|length > 0 %}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">Ancien modèle « Record »</h5>
                    <small class="text-muted">Comptages legacy si présents en base</small>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        {% for row in recordStatsByType %}
                        <li class="d-flex justify-content-between border-bottom py-1 small">
                            <span class="font-monospace">{{ row.type|default('(non défini)') }}</span>
                            <span class="badge bg-light text-dark">{{ row.total }}</span>
                        </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
            {% endif %}

            {% if exportStatsByTool|length > 0 or exportStatsByToolAndFormat|length > 0 %}
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">Exports tracés</h5>
                    <small class="text-muted">Par outil puis par format (PDF, PNG, JSON…)</small>
                </div>
                <div class="card-body">
                    {% if exportStatsByTool|length > 0 %}
                    <p class="small text-muted mb-2">Total par outil</p>
                    <ul class="list-unstyled mb-3">
                        {% for row in exportStatsByTool %}
                        <li class="d-flex justify-content-between border-bottom py-1 small">
                            <span>{{ row.tool }}</span>
                            <span class="badge bg-info text-dark">{{ row.total }}</span>
                        </li>
                        {% endfor %}
                    </ul>
                    {% endif %}
                    {% if exportStatsByToolAndFormat|length > 0 %}
                    <p class="small text-muted mb-2">Détail outil × format</p>
                    <ul class="list-unstyled mb-0">
                        {% for row in exportStatsByToolAndFormat %}
                        <li class="d-flex justify-content-between border-bottom py-1 small">
                            <span><span class="fw-medium">{{ row.tool }}</span> <span class="text-muted">· {{ row.format|upper }}</span></span>
                            <span class="badge bg-light text-dark">{{ row.total }}</span>
                        </li>
                        {% endfor %}
                    </ul>
                    {% endif %}
                </div>
            </div>
            {% endif %}
        </div>

        <!-- Audit admin -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Audit administration</h5>
                    <small class="text-muted">Actions effectuées par ce compte en tant qu’admin</small>
                </div>
                <div class="card-body p-0">
                    {% if adminAuditLogs|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Action</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for log in adminAuditLogs %}
                                <tr>
                                    <td>
                                        <small>{{ log.createdAt|date('d/m/Y H:i') }}</small>
                                    </td>
                                    <td>
                                        {% if log.action == 'CREATE' %}
                                        <span class="badge bg-success">{{ log.action }}</span>
                                        {% elseif log.action == 'UPDATE' %}
                                        <span class="badge bg-primary">{{ log.action }}</span>
                                        {% elseif log.action == 'DELETE' %}
                                        <span class="badge bg-danger">{{ log.action }}</span>
                                        {% else %}
                                        <span class="badge bg-secondary">{{ log.action }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <small>{{ log.description|default('-')|slice(0, 80) }}{% if log.description|length > 80 %}…{% endif %}</small>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-4 px-3">
                        <p class="text-muted small mb-0">Aucune entrée d’audit (normal si l’utilisateur n’est pas admin ou n’a pas effectué d’actions dans le back-office).</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">Analyses récentes (tous outils)</h5>
                </div>
                <div class="card-body p-0">
                    {% if recentAnalyses|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Titre</th>
                                    <th>Outil</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for rec in recentAnalyses %}
                                <tr>
                                    <td><small>{{ rec.createdAt|date('d/m/Y H:i') }}</small></td>
                                    <td><small>{{ rec.title|slice(0, 48) }}{% if rec.title|length > 48 %}…{% endif %}</small></td>
                                    <td><span class="badge bg-secondary">{{ rec.typeLabel }}</span></td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-4">
                        <p class="text-muted small mb-0">Aucune analyse enregistrée sur les outils.</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0">Historique des exports</h5>
                    <small class="text-muted">Derniers exports enregistrés pour ce compte</small>
                </div>
                <div class="card-body p-0">
                    {% if recentExports|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Outil</th>
                                    <th>Format</th>
                                    <th>Source</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for ex in recentExports %}
                                <tr>
                                    <td><small>{{ ex.createdAt|date('d/m/Y H:i') }}</small></td>
                                    <td><span class="badge bg-info text-dark">{{ ex.tool }}</span></td>
                                    <td><small class="text-uppercase">{{ ex.format }}</small></td>
                                    <td class="small">
                                        {% if ex.sourceUrl %}
                                            <a href="{{ ex.sourceUrl }}" target="_blank" rel="noopener" class="text-decoration-none text-truncate d-inline-block" style="max-width: 140px;">Lien</a>
                                        {% else %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-4">
                        <p class="text-muted small mb-0">Aucun export associé à ce compte.</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    {% if user.id != app.user.id %}
    <div class="card border-0 shadow-sm mt-4">
        <div class="card-header bg-white border-bottom">
            <h5 class="mb-0 text-danger">Zone de danger</h5>
        </div>
        <div class="card-body">
            <form method="post" action="{{ path('app_admin_users_delete', {id: user.id}) }}" 
                  onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ? Cette action est irréversible.');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                <button type="submit" class="btn btn-danger">
                    <i data-lucide="trash-2" width="16" height="16" class="me-1"></i>
                    Supprimer l'utilisateur
                </button>
            </form>
        </div>
    </div>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
