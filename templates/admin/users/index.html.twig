{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Gestion des utilisateurs | Administration{% endblock %}

{% block content %}
<div class="container-fluid p-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Gestion des utilisateurs</h1>
            <p class="text-muted mb-0">Gérer les utilisateurs et leurs rôles</p>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase small mb-2">Total utilisateurs</h6>
                            <h3 class="fw-bold mb-0">{{ allCount }}</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                            <i data-lucide="users" width="24" height="24" class="text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase small mb-2">Administrateurs</h6>
                            <h3 class="fw-bold mb-0">{{ adminCount }}</h3>
                        </div>
                        <div class="bg-danger bg-opacity-10 rounded-circle p-3">
                            <i data-lucide="shield" width="24" height="24" class="text-danger"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase small mb-2">Utilisateurs</h6>
                            <h3 class="fw-bold mb-0">{{ userCount }}</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-circle p-3">
                            <i data-lucide="user" width="24" height="24" class="text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtres -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="btn-group" role="group" aria-label="Filtres">
                <a href="{{ path('app_admin_users_index', {filter: 'all'}) }}" 
                   class="btn btn-sm {{ currentFilter == 'all' ? 'btn-primary' : 'btn-outline-primary' }}">
                    Tous ({{ allCount }})
                </a>
                <a href="{{ path('app_admin_users_index', {filter: 'admin'}) }}" 
                   class="btn btn-sm {{ currentFilter == 'admin' ? 'btn-primary' : 'btn-outline-primary' }}">
                    Administrateurs ({{ adminCount }})
                </a>
                <a href="{{ path('app_admin_users_index', {filter: 'user'}) }}" 
                   class="btn btn-sm {{ currentFilter == 'user' ? 'btn-primary' : 'btn-outline-primary' }}">
                    Utilisateurs ({{ userCount }})
                </a>
            </div>
        </div>
    </div>

    <!-- Liste des utilisateurs -->
    {% if users|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-users', list_caption: 'Comptes utilisateurs' } %}
        {% block list_table %}
            <div data-controller="checkbox-select-all users-bulk-actions"
                 data-action="change->users-bulk-actions#refresh">
                <form id="bulk-users-form"
                      method="post"
                      action="{{ path('app_admin_users_bulk') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('bulk_users') }}">

                <div class="p-3 border-bottom bg-light-subtle d-flex flex-wrap align-items-center justify-content-between gap-2">
                    <div class="small text-muted">
                        <strong data-users-bulk-actions-target="count">0</strong> utilisateur(s) sélectionné(s)
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <select class="form-select form-select-sm"
                                name="action"
                                style="min-width: 240px;"
                                data-users-bulk-actions-target="action"
                                data-action="change->users-bulk-actions#refresh">
                            <option value="">Action groupée…</option>
                            <option value="export_csv">Exporter en CSV</option>
                            <option value="export_json">Exporter en JSON</option>
                            <option value="export_emails_txt">Exporter les emails (.txt)</option>
                            <option value="grant_admin">Ajouter le rôle admin</option>
                            <option value="revoke_admin">Retirer le rôle admin</option>
                        </select>
                        <button type="submit"
                                class="btn btn-sm btn-primary"
                                data-users-bulk-actions-target="submit"
                                disabled>
                            Appliquer
                        </button>
                    </div>
                </div>
                </form>

                <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 48px;">
                                <input type="checkbox"
                                       class="form-check-input"
                                       title="Tout sélectionner"
                                       data-checkbox-select-all-target="checkboxAll"
                                       data-action="change->users-bulk-actions#refresh">
                            </th>
                            <th>Email</th>
                            <th>Rôles</th>
                            <th>Création</th>
                            <th>Dernière connexion</th>
                            <th>Dernière activité</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                        <tr>
                            <td>
                                <input type="checkbox"
                                       class="form-check-input"
                                       name="selected_ids[]"
                                       value="{{ user.id }}"
                                       form="bulk-users-form"
                                       data-checkbox-select-all-target="checkbox"
                                       data-action="change->users-bulk-actions#refresh">
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        {{ user.email|slice(0, 1)|upper }}
                                    </div>
                                    <div>
                                        <strong>{{ user.email }}</strong>
                                    </div>
                                </div>
                            </td>
                            <td>
                                {% for role in user.roles %}
                                {% if role == 'ROLE_ADMIN' %}
                                <span class="badge bg-danger me-1">
                                    <i data-lucide="shield" width="12" height="12" class="me-1"></i>
                                    Admin
                                </span>
                                {% elseif role == 'ROLE_USER' %}
                                <span class="badge bg-success me-1">User</span>
                                {% else %}
                                <span class="badge bg-secondary me-1">{{ role }}</span>
                                {% endif %}
                                {% endfor %}
                            </td>
                            <td>
                                <small>{{ user.createdAt|date('d/m/Y H:i') }}</small>
                            </td>
                            <td>
                                <small class="text-muted">
                                    {% if user.lastLoginAt %}
                                        {{ user.lastLoginAt|date('d/m/Y H:i') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </small>
                            </td>
                            <td>
                                <small class="text-muted">
                                    {% if user.lastActivityAt %}
                                        {{ user.lastActivityAt|date('d/m/Y H:i') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </small>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a href="{{ path('app_admin_users_show', {id: user.id}) }}" 
                                       class="btn btn-outline-primary" title="Voir">
                                        <i data-lucide="eye" width="14" height="14"></i>
                                    </a>
                                    <a href="{{ path('app_admin_users_edit', {id: user.id}) }}" 
                                       class="btn btn-outline-secondary" title="Modifier">
                                        <i data-lucide="edit" width="14" height="14"></i>
                                    </a>
                                    {% if user.id != app.user.id %}
                                    <form method="post" action="{{ path('app_admin_users_delete', {id: user.id}) }}" 
                                          class="d-inline" 
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                        <button type="submit" class="btn btn-outline-danger" title="Supprimer">
                                            <i data-lucide="trash-2" width="14" height="14"></i>
                                        </button>
                                    </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                </div>
            </div>
        {% endblock %}
        {% block list_cards %}
            <div class="row g-3">
                {% for user in users %}
                <div class="col-12 col-md-6 col-xl-4">
                    <article class="card border-0 shadow-sm admin-list-item-card h-100">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px;">
                                    {{ user.email|slice(0, 1)|upper }}
                                </div>
                                <div class="min-w-0 flex-grow-1">
                                    <h2 class="h6 fw-semibold mb-1 text-break">{{ user.email }}</h2>
                                    <div class="d-flex flex-wrap gap-1 mb-2">
                                        {% for role in user.roles %}
                                        {% if role == 'ROLE_ADMIN' %}
                                        <span class="badge bg-danger"><i data-lucide="shield" width="12" height="12" class="me-1"></i>Admin</span>
                                        {% elseif role == 'ROLE_USER' %}
                                        <span class="badge bg-success">User</span>
                                        {% else %}
                                        <span class="badge bg-secondary">{{ role }}</span>
                                        {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                            <dl class="row small mb-0 flex-grow-1 g-1">
                                <dt class="col-5 text-muted">Création</dt>
                                <dd class="col-7 mb-0">{{ user.createdAt|date('d/m/Y H:i') }}</dd>
                                <dt class="col-5 text-muted">Connexion</dt>
                                <dd class="col-7 mb-0">{{ user.lastLoginAt ? user.lastLoginAt|date('d/m/Y H:i') : '—' }}</dd>
                                <dt class="col-5 text-muted">Activité</dt>
                                <dd class="col-7 mb-0">{{ user.lastActivityAt ? user.lastActivityAt|date('d/m/Y H:i') : '—' }}</dd>
                            </dl>
                            <div class="d-flex flex-wrap gap-2 mt-3 pt-2 border-top">
                                <a href="{{ path('app_admin_users_show', {id: user.id}) }}" class="btn btn-outline-primary btn-sm"><i data-lucide="eye" width="14" height="14" class="me-1"></i>Voir</a>
                                <a href="{{ path('app_admin_users_edit', {id: user.id}) }}" class="btn btn-outline-secondary btn-sm"><i data-lucide="edit" width="14" height="14" class="me-1"></i>Modifier</a>
                                {% if user.id != app.user.id %}
                                <form method="post" action="{{ path('app_admin_users_delete', {id: user.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm"><i data-lucide="trash-2" width="14" height="14" class="me-1"></i>Supprimer</button>
                                </form>
                                {% endif %}
                            </div>
                        </div>
                    </article>
                </div>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}
            {% if totalPages > 1 %}
            <div class="card-footer bg-white border-top rounded-bottom">
                <nav aria-label="Pagination">
                    <ul class="pagination pagination-sm mb-0 justify-content-center flex-wrap">
                        {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_users_index', {filter: currentFilter, page: currentPage - 1}) }}">
                                <i data-lucide="chevron-left" width="14" height="14"></i>
                            </a>
                        </li>
                        {% endif %}

                        {% for i in 1..totalPages %}
                        {% if i == currentPage %}
                        <li class="page-item active">
                            <span class="page-link">{{ i }}</span>
                        </li>
                        {% elseif i <= 3 or i >= totalPages - 2 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_users_index', {filter: currentFilter, page: i}) }}">{{ i }}</a>
                        </li>
                        {% elseif i == 4 or i == totalPages - 3 %}
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                        {% endif %}
                        {% endfor %}

                        {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_users_index', {filter: currentFilter, page: currentPage + 1}) }}">
                                <i data-lucide="chevron-right" width="14" height="14"></i>
                            </a>
                        </li>
                        {% endif %}
                    </ul>
                </nav>
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
    {% else %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i data-lucide="users" width="48" height="48" class="text-muted mb-3"></i>
            <p class="text-muted mb-0">Aucun utilisateur{{ currentFilter != 'all' ? ' (' ~ currentFilter ~ ')' : '' }}</p>
        </div>
    </div>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}

