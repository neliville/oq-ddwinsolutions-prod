{% extends 'layout/admin_base.html.twig' %}

{% block title %}Gestion des utilisateurs | Administration{% endblock %}

{% block content %}
<div class="w-full max-w-[100rem] mx-auto space-y-6">
    <twig:DataPageHeader title="Gestion des utilisateurs" description="Gérer les utilisateurs et leurs rôles" />

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        <twig:KpiStatCard label="Total utilisateurs" value="{{ allCount }}" tone="default">
            <twig:block name="icon"><i data-lucide="users" width="22" height="22" aria-hidden="true"></i></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Administrateurs" value="{{ adminCount }}" tone="destructive">
            <twig:block name="icon"><i data-lucide="shield" width="22" height="22" aria-hidden="true"></i></twig:block>
        </twig:KpiStatCard>
        <twig:KpiStatCard label="Utilisateurs" value="{{ userCount }}" tone="emerald">
            <twig:block name="icon"><i data-lucide="user" width="22" height="22" aria-hidden="true"></i></twig:block>
        </twig:KpiStatCard>
    </div>

    <twig:DataToolbar ariaLabel="Filtrer la liste des utilisateurs">
        <twig:block name="content">
            <div class="flex flex-wrap gap-2" role="group" aria-label="Filtres">
                <twig:Button as="a" href="{{ path('app_admin_users_index', {filter: 'all'}) }}" variant="{{ currentFilter == 'all' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Tous ({{ allCount }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_users_index', {filter: 'admin'}) }}" variant="{{ currentFilter == 'admin' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Administrateurs ({{ adminCount }})
                </twig:Button>
                <twig:Button as="a" href="{{ path('app_admin_users_index', {filter: 'user'}) }}" variant="{{ currentFilter == 'user' ? 'default' : 'outline' }}" size="sm" class="no-underline">
                    Utilisateurs ({{ userCount }})
                </twig:Button>
            </div>
        </twig:block>
    </twig:DataToolbar>

    {% if users|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-users', list_caption: 'Comptes utilisateurs' } %}
        {% block list_table %}
            <div data-controller="checkbox-select-all users-bulk-actions data-table-columns"
                 data-data-table-columns-storage-key-value="admin-users-table"
                 data-action="change->users-bulk-actions#refresh">
                <form id="bulk-users-form"
                      method="post"
                      action="{{ path('app_admin_users_bulk') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('bulk_users') }}">

                    <div class="flex flex-wrap items-center justify-between gap-3 border-b border-border bg-muted/30 px-4 py-3 sm:px-5">
                        <p class="text-sm text-muted-foreground m-0">
                            <strong class="text-foreground tabular-nums" data-users-bulk-actions-target="count">0</strong>
                            utilisateur(s) sélectionné(s)
                        </p>
                        <div class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row sm:items-center sm:gap-2">
                            <twig:Select name="action"
                                    class="min-h-10 min-w-0 sm:min-w-[16rem]"
                                    data-users-bulk-actions-target="action"
                                    data-action="change->users-bulk-actions#refresh">
                                <option value="">Action groupée…</option>
                                <option value="export_csv">Exporter en CSV</option>
                                <option value="export_json">Exporter en JSON</option>
                                <option value="export_emails_txt">Exporter les emails (.txt)</option>
                                <option value="grant_admin">Ajouter le rôle admin</option>
                                <option value="revoke_admin">Retirer le rôle admin</option>
                            </twig:Select>
                            <twig:Button type="submit"
                                    variant="default"
                                    size="sm"
                                    class="shrink-0 disabled:opacity-50"
                                    data-users-bulk-actions-target="submit"
                                    disabled>
                                Appliquer
                            </twig:Button>
                        </div>
                    </div>
                </form>

                    <details class="mb-3 rounded-lg border border-border/70 bg-muted/15 open:bg-muted/25">
                        <summary class="flex cursor-pointer list-none items-center gap-2 px-4 py-3 text-sm font-medium text-foreground [&::-webkit-details-marker]:hidden">
                            <twig:ux:icon name="lucide:columns-2" class="size-4 shrink-0 text-muted-foreground" aria-hidden="true" />
                            Colonnes affichées
                        </summary>
                        <div class="flex flex-wrap gap-x-8 gap-y-2 border-t border-border/60 px-4 py-3 text-sm text-foreground" role="group" aria-label="Colonnes du tableau utilisateurs">
                            <label class="inline-flex cursor-pointer items-center gap-2 font-normal"><input type="checkbox" checked class="size-4 rounded border-input accent-primary" data-table-col-toggle="roles" data-action="change->data-table-columns#toggle" />Rôles</label>
                            <label class="inline-flex cursor-pointer items-center gap-2 font-normal"><input type="checkbox" checked class="size-4 rounded border-input accent-primary" data-table-col-toggle="created" data-action="change->data-table-columns#toggle" />Création</label>
                            <label class="inline-flex cursor-pointer items-center gap-2 font-normal"><input type="checkbox" checked class="size-4 rounded border-input accent-primary" data-table-col-toggle="lastLogin" data-action="change->data-table-columns#toggle" />Dernière connexion</label>
                            <label class="inline-flex cursor-pointer items-center gap-2 font-normal"><input type="checkbox" checked class="size-4 rounded border-input accent-primary" data-table-col-toggle="lastActivity" data-action="change->data-table-columns#toggle" />Dernière activité</label>
                        </div>
                    </details>

                <twig:Table>
                    <twig:Table:Header>
                        <twig:Table:Row>
                            <twig:Table:Head class="w-12 pr-0">
                                <input type="checkbox"
                                       class="size-4 rounded border-input accent-primary"
                                       title="Tout sélectionner"
                                       data-checkbox-select-all-target="checkboxAll"
                                       data-action="change->users-bulk-actions#refresh">
                            </twig:Table:Head>
                            <twig:Table:Head class="min-w-[14rem]">Email</twig:Table:Head>
                            <twig:Table:Head class="min-w-[8rem]" data-table-col="roles">Rôles</twig:Table:Head>
                            <twig:Table:Head class="w-[9.5rem] whitespace-normal" data-table-col="created">Création</twig:Table:Head>
                            <twig:Table:Head class="w-[9.5rem] whitespace-normal" data-table-col="lastLogin">Dernière connexion</twig:Table:Head>
                            <twig:Table:Head class="w-[9.5rem] whitespace-normal" data-table-col="lastActivity">Dernière activité</twig:Table:Head>
                            <twig:Table:Head class="w-[1%] text-end whitespace-nowrap">Actions</twig:Table:Head>
                        </twig:Table:Row>
                    </twig:Table:Header>
                    <twig:Table:Body>
                        {% for user in users %}
                        <twig:Table:Row>
                            <twig:Table:Cell class="pr-0">
                                <input type="checkbox"
                                       class="size-4 rounded border-input accent-primary"
                                       name="selected_ids[]"
                                       value="{{ user.id }}"
                                       form="bulk-users-form"
                                       data-checkbox-select-all-target="checkbox"
                                       data-action="change->users-bulk-actions#refresh">
                            </twig:Table:Cell>
                            <twig:Table:Cell class="max-w-[min(22rem,42vw)] whitespace-normal">
                                <div class="flex min-w-0 items-center gap-2">
                                    <div class="flex size-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-semibold text-primary" aria-hidden="true">
                                        {{ user.email|slice(0, 1)|upper }}
                                    </div>
                                    <span class="truncate font-medium text-foreground">{{ user.email }}</span>
                                </div>
                            </twig:Table:Cell>
                            <twig:Table:Cell class="whitespace-normal" data-table-col="roles">
                                <div class="flex flex-wrap gap-1">
                                    {% for role in user.roles %}
                                        {% if role == 'ROLE_ADMIN' %}
                                            <twig:Badge variant="destructive" class="gap-1">
                                                <i data-lucide="shield" width="12" height="12" aria-hidden="true"></i>
                                                Admin
                                            </twig:Badge>
                                        {% elseif role == 'ROLE_USER' %}
                                            <twig:Badge variant="secondary">User</twig:Badge>
                                        {% else %}
                                            <twig:Badge variant="outline">{{ role }}</twig:Badge>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </twig:Table:Cell>
                            <twig:Table:Cell class="whitespace-normal text-xs text-muted-foreground tabular-nums" data-table-col="created">
                                {{ user.createdAt|date('d/m/Y H:i') }}
                            </twig:Table:Cell>
                            <twig:Table:Cell class="whitespace-normal text-xs text-muted-foreground tabular-nums" data-table-col="lastLogin">
                                {% if user.lastLoginAt %}
                                    {{ user.lastLoginAt|date('d/m/Y H:i') }}
                                {% else %}
                                    —
                                {% endif %}
                            </twig:Table:Cell>
                            <twig:Table:Cell class="whitespace-normal text-xs text-muted-foreground tabular-nums" data-table-col="lastActivity">
                                {% if user.lastActivityAt %}
                                    {{ user.lastActivityAt|date('d/m/Y H:i') }}
                                {% else %}
                                    —
                                {% endif %}
                            </twig:Table:Cell>
                            <twig:Table:Cell class="text-end">
                                <details class="relative inline-block text-end">
                                    <summary class="inline-flex size-9 cursor-pointer list-none items-center justify-center rounded-md border border-input bg-background text-foreground shadow-sm hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden" aria-haspopup="menu" aria-label="Menu actions pour {{ user.email|e('html_attr') }}">
                                        <twig:ux:icon name="lucide:more-horizontal" class="size-4" aria-hidden="true" />
                                        <span class="sr-only">Ouvrir le menu actions</span>
                                    </summary>
                                    <div class="absolute right-0 z-50 mt-1 w-48 rounded-md border border-border bg-popover p-2 text-start shadow-xl" role="menu">
                                        <div class="flex flex-col gap-1">
                                            <twig:Button as="a" href="{{ path('app_admin_users_show', {id: user.id}) }}" variant="ghost" size="sm" class="w-full justify-start gap-2 border border-transparent no-underline hover:bg-muted focus-visible:ring-offset-2" role="menuitem">
                                                <twig:ux:icon name="lucide:eye" class="size-4 shrink-0" aria-hidden="true" />
                                                Voir
                                            </twig:Button>
                                            <twig:Button as="a" href="{{ path('app_admin_users_edit', {id: user.id}) }}" variant="ghost" size="sm" class="w-full justify-start gap-2 border border-transparent no-underline hover:bg-muted focus-visible:ring-offset-2" role="menuitem">
                                                <twig:ux:icon name="lucide:pencil" class="size-4 shrink-0" aria-hidden="true" />
                                                Modifier
                                            </twig:Button>
                                            {% if user.id != app.user.id %}
                                                <form method="post" action="{{ path('app_admin_users_delete', {id: user.id}) }}" class="m-0" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');" role="none">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                                    <twig:Button type="submit" variant="ghost" size="sm" class="w-full justify-start gap-2 text-destructive hover:bg-destructive/10 hover:text-destructive" role="menuitem">
                                                        <twig:ux:icon name="lucide:trash-2" class="size-4 shrink-0" aria-hidden="true" />
                                                        Supprimer
                                                    </twig:Button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </div>
                                </details>
                            </twig:Table:Cell>
                        </twig:Table:Row>
                        {% endfor %}
                    </twig:Table:Body>
                </twig:Table>
            </div>
        {% endblock %}
        {% block list_cards %}
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
                {% for user in users %}
                <twig:Card class="admin-list-item-card h-full border-border/80 shadow-sm ring-1 ring-border/40">
                    <twig:Card:Content class="flex flex-col gap-3 p-5 sm:p-6">
                        <div class="flex items-start gap-3">
                            <div class="flex size-10 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-semibold text-primary" aria-hidden="true">
                                {{ user.email|slice(0, 1)|upper }}
                            </div>
                            <div class="min-w-0 flex-1">
                                <h2 class="text-base font-semibold leading-snug break-all text-foreground m-0">{{ user.email }}</h2>
                                <div class="mt-2 flex flex-wrap gap-1">
                                    {% for role in user.roles %}
                                        {% if role == 'ROLE_ADMIN' %}
                                            <twig:Badge variant="destructive" class="gap-1">
                                                <i data-lucide="shield" width="12" height="12" aria-hidden="true"></i>
                                                Admin
                                            </twig:Badge>
                                        {% elseif role == 'ROLE_USER' %}
                                            <twig:Badge variant="secondary">User</twig:Badge>
                                        {% else %}
                                            <twig:Badge variant="outline">{{ role }}</twig:Badge>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                        <dl class="grid grid-cols-2 gap-x-2 gap-y-1 text-sm">
                            <dt class="text-muted-foreground">Création</dt>
                            <dd class="m-0 text-end tabular-nums text-foreground">{{ user.createdAt|date('d/m/Y H:i') }}</dd>
                            <dt class="text-muted-foreground">Connexion</dt>
                            <dd class="m-0 text-end tabular-nums text-foreground">{{ user.lastLoginAt ? user.lastLoginAt|date('d/m/Y H:i') : '—' }}</dd>
                            <dt class="text-muted-foreground">Activité</dt>
                            <dd class="m-0 text-end tabular-nums text-foreground">{{ user.lastActivityAt ? user.lastActivityAt|date('d/m/Y H:i') : '—' }}</dd>
                        </dl>
                        <div class="mt-auto flex flex-wrap gap-2 border-t border-border pt-4">
                            <twig:Button as="a" href="{{ path('app_admin_users_show', {id: user.id}) }}" variant="outline" size="sm" class="no-underline">
                                <twig:ux:icon name="lucide:eye" class="size-4 shrink-0" aria-hidden="true" />
                                Voir
                            </twig:Button>
                            <twig:Button as="a" href="{{ path('app_admin_users_edit', {id: user.id}) }}" variant="outline" size="sm" class="no-underline">
                                <twig:ux:icon name="lucide:pencil" class="size-4 shrink-0" aria-hidden="true" />
                                Modifier
                            </twig:Button>
                            {% if user.id != app.user.id %}
                            <form method="post" action="{{ path('app_admin_users_delete', {id: user.id}) }}" class="inline-flex" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                <twig:Button type="submit" variant="outline" size="sm" class="text-destructive hover:bg-destructive/10 hover:text-destructive">
                                    <twig:ux:icon name="lucide:trash-2" class="size-4 shrink-0" aria-hidden="true" />
                                    Supprimer
                                </twig:Button>
                            </form>
                            {% endif %}
                        </div>
                    </twig:Card:Content>
                </twig:Card>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}
            {% if totalPages > 1 %}
            <div class="border-t border-border bg-muted/20 px-4 py-4 sm:px-5">
                <nav class="flex flex-wrap items-center justify-center gap-1" aria-label="Pagination">
                    {% if currentPage > 1 %}
                        <twig:Button as="a" href="{{ path('app_admin_users_index', {filter: currentFilter, page: currentPage - 1}) }}" variant="outline" size="icon" class="no-underline size-9" aria-label="Page précédente">
                            <twig:ux:icon name="lucide:chevron-left" class="size-4" aria-hidden="true" />
                        </twig:Button>
                    {% endif %}

                    {% for i in 1..totalPages %}
                        {% if i == currentPage %}
                            <twig:Button type="button" variant="default" size="sm" class="min-w-9 pointer-events-none" disabled aria-current="page">{{ i }}</twig:Button>
                        {% elseif i <= 3 or i >= totalPages - 2 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                            <twig:Button as="a" href="{{ path('app_admin_users_index', {filter: currentFilter, page: i}) }}" variant="outline" size="sm" class="no-underline min-w-9">{{ i }}</twig:Button>
                        {% elseif i == 4 or i == totalPages - 3 %}
                            <span class="px-2 text-sm text-muted-foreground" aria-hidden="true">…</span>
                        {% endif %}
                    {% endfor %}

                    {% if currentPage < totalPages %}
                        <twig:Button as="a" href="{{ path('app_admin_users_index', {filter: currentFilter, page: currentPage + 1}) }}" variant="outline" size="icon" class="no-underline size-9" aria-label="Page suivante">
                            <twig:ux:icon name="lucide:chevron-right" class="size-4" aria-hidden="true" />
                        </twig:Button>
                    {% endif %}
                </nav>
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
    {% else %}
    <twig:Card class="border-border/80 shadow-sm ring-1 ring-border/40">
        <twig:Card:Content class="flex flex-col items-center justify-center gap-3 py-14 text-center">
            <div class="flex size-14 items-center justify-center rounded-full bg-muted text-muted-foreground">
                <i data-lucide="users" width="28" height="28" aria-hidden="true"></i>
            </div>
            <p class="text-sm text-muted-foreground m-0">Aucun utilisateur{{ currentFilter != 'all' ? ' (' ~ currentFilter ~ ')' : '' }}</p>
        </twig:Card:Content>
    </twig:Card>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}
