{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Gestion des utilisateurs | Administration{% endblock %}

{% block content %}
<div class="w-full">
    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold mb-1">Gestion des utilisateurs</h1>
            <p class="text-muted-foreground mb-0">Gérer les utilisateurs et leurs rôles</p>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Total utilisateurs</h6>
                        <h3 class="font-bold mb-0">{{ allCount }}</h3>
                    </div>
                    <div class="bg-primary/10 rounded-full p-3">
                        <i data-lucide="users" width="24" height="24" class="text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Administrateurs</h6>
                        <h3 class="font-bold mb-0">{{ adminCount }}</h3>
                    </div>
                    <div class="bg-red-100 rounded-full p-3">
                        <i data-lucide="shield" width="24" height="24" class="text-destructive"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="rounded-lg bg-card shadow-sm">
            <div class="p-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h6 class="text-muted-foreground uppercase text-sm mb-2">Utilisateurs</h6>
                        <h3 class="font-bold mb-0">{{ userCount }}</h3>
                    </div>
                    <div class="bg-green-100 rounded-full p-3">
                        <i data-lucide="user" width="24" height="24" class="text-green-600"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtres -->
    <div class="rounded-lg bg-card shadow-sm mb-6">
        <div class="p-6">
            <div class="flex flex-wrap gap-1" role="group" aria-label="Filtres">
                <a href="{{ path('app_admin_users_index', {filter: 'all'}) }}"
                   class="{{ currentFilter == 'all' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Tous ({{ allCount }})
                </a>
                <a href="{{ path('app_admin_users_index', {filter: 'admin'}) }}"
                   class="{{ currentFilter == 'admin' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Administrateurs ({{ adminCount }})
                </a>
                <a href="{{ path('app_admin_users_index', {filter: 'user'}) }}"
                   class="{{ currentFilter == 'user' ? 'inline-flex items-center px-2.5 py-1 text-sm rounded-md bg-primary text-primary-foreground hover:opacity-90 transition-opacity no-underline' : 'inline-flex items-center px-2.5 py-1 text-sm rounded-md border border-border text-foreground hover:bg-accent transition-colors no-underline' }}">
                    Utilisateurs ({{ userCount }})
                </a>
            </div>
        </div>
    </div>

    <!-- Liste des utilisateurs -->
    {% if users|length > 0 %}
    {% embed 'components/admin/list_view_shell.html.twig' with { storage_key: 'admin-users', list_caption: 'Comptes utilisateurs' } %}
        {% block list_table %}
            <div data-controller="checkbox-select-all users-bulk-actions"
                 data-action="change->users-bulk-actions#refresh">
                <form id="bulk-users-form"
                      method="post"
                      action="{{ path('app_admin_users_bulk') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('bulk_users') }}">

                <div class="p-4 border-b border-border bg-muted/30 flex flex-wrap items-center justify-between gap-2">
                    <div class="text-sm text-muted-foreground">
                        <strong data-users-bulk-actions-target="count">0</strong> utilisateur(s) sélectionné(s)
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                        <select class="form-select form-select-sm"
                                name="action"
                                style="min-width: 240px;"
                                data-users-bulk-actions-target="action"
                                data-action="change->users-bulk-actions#refresh">
                            <option value="">Action groupée…</option>
                            <option value="export_csv">Exporter en CSV</option>
                            <option value="export_json">Exporter en JSON</option>
                            <option value="export_emails_txt">Exporter les emails (.txt)</option>
                            <option value="grant_admin">Ajouter le rôle admin</option>
                            <option value="revoke_admin">Retirer le rôle admin</option>
                        </select>
                        <button type="submit"
                                class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed"
                                data-users-bulk-actions-target="submit"
                                disabled>
                            Appliquer
                        </button>
                    </div>
                </div>
                </form>

                <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 48px;">
                                <input type="checkbox"
                                       class="form-check-input"
                                       title="Tout sélectionner"
                                       data-checkbox-select-all-target="checkboxAll"
                                       data-action="change->users-bulk-actions#refresh">
                            </th>
                            <th>Email</th>
                            <th>Rôles</th>
                            <th>Création</th>
                            <th>Dernière connexion</th>
                            <th>Dernière activité</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                        <tr>
                            <td>
                                <input type="checkbox"
                                       class="form-check-input"
                                       name="selected_ids[]"
                                       value="{{ user.id }}"
                                       form="bulk-users-form"
                                       data-checkbox-select-all-target="checkbox"
                                       data-action="change->users-bulk-actions#refresh">
                            </td>
                            <td>
                                <div class="flex items-center">
                                    <div class="bg-primary/10 text-primary rounded-full flex items-center justify-center mr-2" style="width: 32px; height: 32px;">
                                        {{ user.email|slice(0, 1)|upper }}
                                    </div>
                                    <div>
                                        <strong>{{ user.email }}</strong>
                                    </div>
                                </div>
                            </td>
                            <td>
                                {% for role in user.roles %}
                                {% if role == 'ROLE_ADMIN' %}
                                <span class="inline-flex items-center rounded-full bg-red-100 text-destructive px-2.5 py-0.5 text-xs font-semibold mr-1">
                                    <i data-lucide="shield" width="12" height="12" class="mr-1"></i>
                                    Admin
                                </span>
                                {% elseif role == 'ROLE_USER' %}
                                <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-semibold mr-1">User</span>
                                {% else %}
                                <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold mr-1">{{ role }}</span>
                                {% endif %}
                                {% endfor %}
                            </td>
                            <td>
                                <small>{{ user.createdAt|date('d/m/Y H:i') }}</small>
                            </td>
                            <td>
                                <small class="text-muted-foreground">
                                    {% if user.lastLoginAt %}
                                        {{ user.lastLoginAt|date('d/m/Y H:i') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </small>
                            </td>
                            <td>
                                <small class="text-muted-foreground">
                                    {% if user.lastActivityAt %}
                                        {{ user.lastActivityAt|date('d/m/Y H:i') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </small>
                            </td>
                            <td>
                                <div class="flex gap-1" role="group">
                                    <a href="{{ path('app_admin_users_show', {id: user.id}) }}"
                                       class="inline-flex items-center justify-center gap-2 border border-primary text-primary px-2 py-1 text-sm rounded-md hover:bg-primary/5 transition-colors" title="Voir">
                                        <i data-lucide="eye" width="14" height="14"></i>
                                    </a>
                                    <a href="{{ path('app_admin_users_edit', {id: user.id}) }}"
                                       class="inline-flex items-center justify-center gap-2 border border-border text-foreground px-2 py-1 text-sm rounded-md hover:bg-accent transition-colors" title="Modifier">
                                        <i data-lucide="edit" width="14" height="14"></i>
                                    </a>
                                    {% if user.id != app.user.id %}
                                    <form method="post" action="{{ path('app_admin_users_delete', {id: user.id}) }}"
                                          class="inline"
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                        <button type="submit" class="inline-flex items-center justify-center gap-2 border border-destructive text-destructive px-2 py-1 text-sm rounded-md hover:bg-destructive/5 transition-colors" title="Supprimer">
                                            <i data-lucide="trash-2" width="14" height="14"></i>
                                        </button>
                                    </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                </div>
            </div>
        {% endblock %}
        {% block list_cards %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for user in users %}
                <article class="rounded-lg bg-card shadow-sm admin-list-item-card h-full">
                    <div class="p-6 flex flex-col">
                        <div class="flex items-start gap-2 mb-2">
                            <div class="bg-primary/10 text-primary rounded-full flex items-center justify-center shrink-0" style="width: 40px; height: 40px;">
                                {{ user.email|slice(0, 1)|upper }}
                            </div>
                            <div class="min-w-0 flex-1">
                                <h2 class="text-base font-semibold mb-1 break-all">{{ user.email }}</h2>
                                <div class="flex flex-wrap gap-1 mb-2">
                                    {% for role in user.roles %}
                                    {% if role == 'ROLE_ADMIN' %}
                                    <span class="inline-flex items-center rounded-full bg-red-100 text-destructive px-2.5 py-0.5 text-xs font-semibold"><i data-lucide="shield" width="12" height="12" class="mr-1"></i>Admin</span>
                                    {% elseif role == 'ROLE_USER' %}
                                    <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2.5 py-0.5 text-xs font-semibold">User</span>
                                    {% else %}
                                    <span class="inline-flex items-center rounded-full bg-secondary text-secondary-foreground px-2.5 py-0.5 text-xs font-semibold">{{ role }}</span>
                                    {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                        <dl class="grid grid-cols-2 text-sm gap-1 mb-0 flex-1">
                            <dt class="text-muted-foreground">Création</dt>
                            <dd class="mb-0">{{ user.createdAt|date('d/m/Y H:i') }}</dd>
                            <dt class="text-muted-foreground">Connexion</dt>
                            <dd class="mb-0">{{ user.lastLoginAt ? user.lastLoginAt|date('d/m/Y H:i') : '—' }}</dd>
                            <dt class="text-muted-foreground">Activité</dt>
                            <dd class="mb-0">{{ user.lastActivityAt ? user.lastActivityAt|date('d/m/Y H:i') : '—' }}</dd>
                        </dl>
                        <div class="flex flex-wrap gap-2 mt-4 pt-2 border-t border-border">
                            <a href="{{ path('app_admin_users_show', {id: user.id}) }}" class="inline-flex items-center justify-center gap-1.5 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors"><i data-lucide="eye" width="14" height="14" class="mr-1"></i>Voir</a>
                            <a href="{{ path('app_admin_users_edit', {id: user.id}) }}" class="inline-flex items-center justify-center gap-1.5 border border-border text-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors"><i data-lucide="edit" width="14" height="14" class="mr-1"></i>Modifier</a>
                            {% if user.id != app.user.id %}
                            <form method="post" action="{{ path('app_admin_users_delete', {id: user.id}) }}" class="inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                <button type="submit" class="inline-flex items-center justify-center gap-1.5 border border-destructive text-destructive px-3 py-1.5 text-sm rounded-md hover:bg-destructive/5 transition-colors"><i data-lucide="trash-2" width="14" height="14" class="mr-1"></i>Supprimer</button>
                            </form>
                            {% endif %}
                        </div>
                    </div>
                </article>
                {% endfor %}
            </div>
        {% endblock %}
        {% block list_footer %}
            {% if totalPages > 1 %}
            <div class="card-footer bg-white border-t border-border rounded-b">
                <nav aria-label="Pagination">
                    <ul class="pagination pagination-sm mb-0 justify-center flex-wrap">
                        {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_users_index', {filter: currentFilter, page: currentPage - 1}) }}">
                                <i data-lucide="chevron-left" width="14" height="14"></i>
                            </a>
                        </li>
                        {% endif %}

                        {% for i in 1..totalPages %}
                        {% if i == currentPage %}
                        <li class="page-item active">
                            <span class="page-link">{{ i }}</span>
                        </li>
                        {% elseif i <= 3 or i >= totalPages - 2 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_users_index', {filter: currentFilter, page: i}) }}">{{ i }}</a>
                        </li>
                        {% elseif i == 4 or i == totalPages - 3 %}
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                        {% endif %}
                        {% endfor %}

                        {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_admin_users_index', {filter: currentFilter, page: currentPage + 1}) }}">
                                <i data-lucide="chevron-right" width="14" height="14"></i>
                            </a>
                        </li>
                        {% endif %}
                    </ul>
                </nav>
            </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
    {% else %}
    <div class="rounded-lg bg-card shadow-sm">
        <div class="p-6 text-center py-12">
            <i data-lucide="users" width="48" height="48" class="text-muted-foreground mb-4"></i>
            <p class="text-muted-foreground mb-0">Aucun utilisateur{{ currentFilter != 'all' ? ' (' ~ currentFilter ~ ')' : '' }}</p>
        </div>
    </div>
    {% endif %}
</div>

<script>
if (typeof lucide !== 'undefined') {
    lucide.createIcons();
}
</script>
{% endblock %}

