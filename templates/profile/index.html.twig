{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Mon profil | OUTILS-QUALITÉ{% endblock %}

{% block meta_description %}Gérez votre profil utilisateur — OUTILS-QUALITÉ{% endblock %}

{% block content %}
<div class="profile-page-shell pt-5 mt-4">
    <div class="w-full px-4">
        <!-- Header -->
        <div class="header text-center mb-12" data-aos="fade-up">
            <h1 class="text-4xl font-bold mb-3">Mon profil</h1>
            <p class="text-lg text-muted-foreground">Gérez vos informations personnelles</p>
        </div>

        <div class="flex justify-center">
            <div class="w-full max-w-2xl">
                <!-- Profile Card -->
                <twig:Card class="shadow-lg mb-6 border-border/80" data-aos="fade-up" data-aos-delay="100">
                    <twig:Card:Content class="p-6">
                        <!-- Avatar Section -->
                        <div class="text-center mb-6">
                            <div class="bg-primary text-white rounded-full inline-flex items-center justify-center mb-3" style="width: 100px; height: 100px; font-size: 2.5rem; font-weight: 600;">
                                {{ app.user.email|slice(0, 1)|upper }}
                            </div>
                            <h4 class="font-bold mb-1">{{ app.user.email }}</h4>
                            <p class="text-muted-foreground mb-0">
                                Membre depuis {{ app.user.createdAt|date('F Y') }}
                            </p>
                        </div>

                        <hr class="my-4">

                        <!-- Profile Form -->
                        <h5 class="font-semibold mb-6">
                            <i class="fas fa-edit mr-2 text-primary"></i>
                            Modifier mes informations
                        </h5>

                        {{ form_start(form, {'attr': {'class': 'needs-validation space-y-4', 'novalidate': 'novalidate'}}) }}
                            <div class="space-y-2">
                                {{ form_label(form.email, null, {'label_attr': {'class': 'text-sm font-medium leading-none'}}) }}
                                {{ form_widget(form.email, {'attr': {'class': 'flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2'}}) }}
                                {{ form_errors(form.email) }}
                                <div class="text-sm text-muted-foreground mt-1">
                                    <i class="fas fa-info-circle mr-1"></i>
                                    Cette adresse email sera utilisée pour vous identifier sur la plateforme.
                                </div>
                            </div>

                            <div class="flex flex-col md:flex-row gap-2 justify-end mt-6">
                                <twig:Button as="a" href="{{ path('app_home_index') }}" variant="outline" class="no-underline w-full md:w-auto justify-center">Annuler</twig:Button>
                                <twig:Button type="submit" variant="default" class="w-full md:w-auto justify-center">Enregistrer les modifications</twig:Button>
                            </div>
                        {{ form_end(form) }}
                    </twig:Card:Content>
                </twig:Card>

                <!-- Account Info Card -->
                <twig:Card class="border-border/80 shadow-sm" data-aos="fade-up" data-aos-delay="200">
                    <twig:Card:Content class="p-6">
                        <h5 class="font-semibold mb-3">
                            <i class="fas fa-info-circle mr-2 text-sky-600"></i>
                            Informations du compte
                        </h5>

                        <div class="grid gap-4">
                            <div class="col-span-12">
                                <div class="flex justify-between items-center py-2 border-b">
                                    <span class="text-muted-foreground">Email</span>
                                    <span class="font-semibold">{{ app.user.email }}</span>
                                </div>
                            </div>
                            <div class="col-span-12">
                                <div class="flex justify-between items-center py-2 border-b">
                                    <span class="text-muted-foreground">Date d'inscription</span>
                                    <span class="font-semibold">{{ app.user.createdAt|date('d/m/Y à H:i') }}</span>
                                </div>
                            </div>
                            <div class="col-span-12">
                                <div class="flex justify-between items-center py-2">
                                    <span class="text-muted-foreground">Rôle</span>
                                    <twig:Badge variant="secondary" class="text-xs font-semibold">
                                        {% if is_granted('ROLE_ADMIN') %}
                                            Administrateur
                                        {% else %}
                                            Utilisateur
                                        {% endif %}
                                    </twig:Badge>
                                </div>
                            </div>
                        </div>
                    </twig:Card:Content>
                </twig:Card>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<!-- Font Awesome -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
{% endblock %}
