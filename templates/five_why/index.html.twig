{% extends (app.user ? 'base_with_sidebar.html.twig' : 'base.html.twig') %}

{% block head %}
    {{ parent() }}
    {% include 'components/turbo_newsletter_no_cache_meta.html.twig' %}
{% endblock %}

{% block title %}Méthode 5 Pourquoi en Ligne — Analyse de Cause Racine Gratuite | Outils-Qualité{% endblock %}

{% block meta_description %}Utilisez la méthode des 5 Pourquoi en ligne pour identifier les causes racines de vos problèmes. Outil gratuit avec export PDF conforme ISO 9001.{% endblock %}

{% block meta_keywords %}5 pourquoi, méthode des 5 pourquoi, 5 whys, analyse des causes racines, root cause analysis, Sakichi Toyoda, outil qualité gratuit, amélioration continue, résolution de problèmes{% endblock %}

{% block og_title %}Méthode des 5 Pourquoi - Outil Gratuit | OUTILS-QUALITÉ{% endblock %}

{% block og_description %}Utilisez la méthode des 5 Pourquoi pour identifier les causes racines. Outil gratuit et professionnel avec export PDF.{% endblock %}

{% block schema_type %}{{ parent() }},SoftwareApplication{% endblock %}

{% block schema_data %}
