{% extends 'base.html.twig' %}

{% block title %}{{ meta.title }}{% endblock %}

{% block meta_description %}{{ meta.description }}{% endblock %}

{% block meta_keywords %}{{ meta.keywords|default('legal, conformité, outils qualité') }}{% endblock %}

{% block og_title %}{{ meta.title }} | OUTILS-QUALITÉ{% endblock %}

{% block og_description %}{{ meta.description }}{% endblock %}

{% block body %}
<section class="py-12 bg-gradient-primary text-black" style="margin-top: 76px;" role="banner" aria-labelledby="legal-page-title">
    <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-12 items-center gap-6">
            <div class="lg:col-span-8">
                <h1 id="legal-page-title" class="text-4xl font-bold mb-6">{{ page.title }}</h1>
                <p class="text-lg mb-6">{{ meta.description }}</p>
            </div>
            <div class="lg:col-span-4">
                <figure>
                    {% include 'components/media/responsive_picture.html.twig' with {
                        path: meta.image|default('img/mentions-legales.webp'),
                        alt: page.title,
                        width: 900,
                        height: 600
                    } %}
                    <figcaption><small>Source: Unsplash.</small></figcaption>
                </figure>
            </div>
        </div>
    </div>
</section>

<main id="main-content" class="max-w-7xl mx-auto px-4 py-12" role="main" aria-label="Contenu de la page">
    <article class="legal-content prose" aria-labelledby="legal-page-title">
        {{ page.content|markdown_to_html|raw }}
    </article>
</main>
{% endblock %}
