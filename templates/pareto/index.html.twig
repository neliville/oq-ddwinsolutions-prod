{% extends (app.user ? 'base_with_sidebar.html.twig' : 'base.html.twig') %}

{% block title %}Diagramme de Pareto en Ligne — Analyse 80/20 Gratuite | Outils-Qualité{% endblock %}

{% block meta_description %}Créez votre diagramme de Pareto en ligne gratuitement. Visualisez la loi 80/20, graphique interactif, export PDF pour vos revues qualité.{% endblock %}

{% block meta_keywords %}pareto, diagramme pareto, 80 20, amélioration continue, analyse des causes, outil qualité{% endblock %}

{% block og_title %}Diagramme de Pareto - Outil Gratuit | OUTILS-QUALITÉ{% endblock %}

{% block og_description %}Visualisez vos données, calculez le % cumulatif et identifiez les causes prioritaires avec l'outil Pareto en ligne.{% endblock %}

{% block schema_type %}{{ parent() }},SoftwareApplication{% endblock %}

{% block schema_data %}
{
    "name": "Outil Diagramme de Pareto",
    "description": "Analyse 80/20 interactive pour prioriser vos actions qualité.",
    "url": "{{ absolute_url(path('app_pareto_index')) }}",
    "screenshot": "{{ app.request.schemeAndHttpHost ~ asset('img/og-default.jpg') }}"
}
{% endblock %}

{% block schema_webapp_json %}
{"@context":"https://schema.org","@type":"WebApplication","name":"Diagramme de Pareto en ligne","url":{{ absolute_url(path('app_pareto_index'))|json_encode|raw }},"applicationCategory":"BusinessApplication","operatingSystem":"Web","offers":{"@type":"Offer","price":"0","priceCurrency":"EUR"},"description":"Créez votre diagramme de Pareto en ligne gratuitement. Visualisez la loi 80/20, graphique interactif, export PDF pour vos revues qualité.","featureList":["Loi 80/20","Graphique interactif","Export PDF","Revues qualité"]}
{% endblock %}

{% block schema_breadcrumb_json %}
{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Accueil","item":{{ absolute_url(path('app_home_index'))|json_encode|raw }}},{"@type":"ListItem","position":2,"name":"Outils","item":{{ absolute_url(path('app_outils_index'))|json_encode|raw }}},{"@type":"ListItem","position":3,"name":"Diagramme de Pareto","item":{{ absolute_url(path('app_pareto_index'))|json_encode|raw }}}]}
{% endblock %}

{% block content %}
<main class="pareto-page{% if not app.user %} pareto-page--guest{% endif %}">
    <div class="container">
        {% include 'components/tool_breadcrumb.html.twig' with { tool_name: "Diagramme de Pareto" } %}
        {% include 'components/tool_page_header.html.twig' with {
            tool_icon: 'bar-chart-2',
            tool_name: 'Diagramme de Pareto',
            tool_tagline: 'Identifiez les 20 % de causes responsables de 80 % des effets',
            tool_color: 'info',
            tool_seo_route: 'app_tool_seo_pareto'
        } %}
        <input type="hidden" id="paretoAnalysisId" value="{{ analysisId ?? '' }}">

        <div class="page-header tool-page-header--compact">
            <h1 class="page-title">Diagramme de Pareto</h1>
            <p class="lead">Identifiez les causes les plus impactantes (Principe 80/20) et concentrez vos efforts d'amélioration là où ils comptent le plus.</p>
            {% include 'components/tool_meta_hints.html.twig' with {
                tool_slug: 'pareto',
                hint_id_prefix: 'pareto',
                meta_intro: 'Survolez ou mettez le focus sur une pastille pour un court descriptif. L’aide détaillée est dans l’encadré juste en dessous ; le graphique et la saisie suivent.',
                tag_hints: {
                    'Priorisation': 'Classer les causes ou dysfonctionnements avant d’allouer des moyens.',
                    'Reporting': 'Support visuel pour revues, comités et suivi d’indicateurs.',
                    'Lean': 'Complément des démarches 5S, flux et élimination des gaspillages.',
                    '80/20': 'Rappel heuristique : concentrez-vous sur les quelques causes dominantes.',
                },
            } %}
        </div>

        {% if not app.user %}
        <div class="flex items-center justify-center gap-2 rounded-lg border border-yellow-200 bg-yellow-50 text-yellow-800 px-4 py-3 mb-3" role="alert" aria-live="polite">
            <i data-lucide="info" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
            <span><strong>Vous n'êtes pas connecté.</strong>
            <a href="{{ path('app_login') }}" class="font-semibold underline text-yellow-900">Connectez-vous</a> pour sauvegarder vos analyses et les réutiliser facilement.</span>
        </div>
        {% endif %}

        {% include 'components/tool_help/pareto_accordion.html.twig' %}

        <section class="pareto-controls tool-actions-bar flex flex-wrap items-center gap-2 mb-3" role="toolbar" aria-label="Actions disponibles">
            <button class="inline-flex items-center justify-center gap-1.5 bg-primary text-primary-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="newParetoAnalysis()" aria-label="Initialiser une nouvelle analyse Pareto">
                <i class="fas fa-sync-alt mr-2"></i>Nouvelle analyse
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 bg-sky-500 text-white px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="generateParetoChart()" aria-label="Générer le diagramme de Pareto">
                <i class="fas fa-chart-line mr-2"></i>Générer le diagramme
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 bg-destructive text-destructive-foreground px-3 py-1.5 text-sm rounded-md hover:opacity-90 transition-opacity" type="button" onclick="resetParetoForm()" aria-label="Réinitialiser le formulaire Pareto">
                <i class="fas fa-eraser mr-2"></i>Réinitialiser
            </button>
            {% if app.user %}
            <button class="inline-flex items-center justify-center gap-1.5 bg-green-600 text-white px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="savePareto()" aria-label="Sauvegarder l'analyse Pareto">
                <i class="fas fa-save mr-2"></i>Sauvegarder
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors" type="button" onclick="openParetoSaved()" aria-label="Charger une analyse Pareto">
                <i class="fas fa-folder-open mr-2"></i>Mes analyses
            </button>
            {% include 'components/tool_export_dropdown.html.twig' with {
                button_id: 'paretoExportDropdown',
                items: [
                    { icon: 'fas fa-image', label: 'Exporter en PNG', onclick: 'exportPareto("png")' },
                    { icon: 'fas fa-file-pdf', label: 'Exporter en PDF', onclick: 'exportPareto("pdf")' },
                    { icon: 'fas fa-file-code', label: 'Exporter en JSON', onclick: 'exportPareto("json")' },
                ],
            } %}
            {% else %}
            {% include 'components/tool_actions_login.html.twig' %}
            {% endif %}
        </section>

        <section class="pareto-form">
            <h2>Saisissez vos causes et occurrences</h2>
            <div class="grid gap-4 md:grid-cols-2 mb-6">
                <div>
                    <label class="form-label font-semibold" for="paretoTitle">Titre de l'analyse</label>
                    <input type="text"
                           id="paretoTitle"
                           class="form-control"
                           placeholder="Ex : Pannes production Semaine 38"
                           oninput="updateParetoTitle(this.value)">
                </div>
                <div>
                    <label class="form-label font-semibold" for="paretoDescription">Description courte</label>
                    <input type="text"
                           id="paretoDescription"
                           class="form-control"
                           placeholder="Contexte, périmètre..."
                           oninput="updateParetoDescription(this.value)">
                </div>
            </div>
            <div class="pareto-data-list" id="paretoEntries" aria-live="polite"></div>
            <button class="inline-flex items-center justify-center gap-1.5 border border-green-600 text-green-600 px-3 py-1.5 text-sm rounded-md hover:bg-green-50 transition-colors mt-3" type="button" onclick="addParetoEntry()" aria-label="Ajouter une cause">
                <i class="fas fa-plus mr-2"></i>Ajouter une cause
            </button>
        </section>

        <section id="paretoResults" class="pareto-results" style="display:none;">
            <div class="pareto-chart-container">
                <canvas id="paretoChart" role="img" aria-label="Diagramme de Pareto"></canvas>
            </div>

            <div class="pareto-table">
                <table>
                    <thead>
                        <tr>
                            <th>Rang</th>
                            <th>Cause</th>
                            <th>Fréquence</th>
                            <th>% du total</th>
                            <th>% cumulé</th>
                        </tr>
                    </thead>
                    <tbody id="paretoTableBody"></tbody>
                </table>
            </div>

            <div class="pareto-insights" id="paretoInsights"></div>
        </section>

        {% include 'components/qse/capa_soft_cta.html.twig' with { tool: 'pareto' } %}

        {% include 'components/cta_ddwin.html.twig' %}

        <section class="seo-content">
            <h2>Qu'est-ce que le diagramme de Pareto ?</h2>
            <p>Outil de visualisation basé sur le principe de Pareto (loi des 80/20), attribué à Vilfredo Pareto et popularisé par Joseph Juran. Permet de hiérarchiser les causes d'un problème en montrant que ~20 % des causes génèrent ~80 % des effets.</p>

            <h2>Comment utiliser le diagramme de Pareto ?</h2>
            <p>(1) Collecter les données par catégorie. (2) Classer par ordre décroissant. (3) Calculer les pourcentages cumulés. (4) Tracer le diagramme (barres + courbe cumulative). (5) Identifier la zone des 80 % pour prioriser les actions.</p>

            <h2>Quand utiliser le diagramme de Pareto ?</h2>
            <p>Analyse des types de défauts les plus fréquents, priorisation des réclamations, ciblage des causes principales d'arrêt machine.</p>

            <h2>Pourquoi utiliser notre outil en ligne ?</h2>
            <p>Gratuit, sans installation, graphique interactif, export PDF pour vos revues qualité.</p>
        </section>
    </div>

    {# Modal pour afficher les analyses Pareto sauvegardées #}
    {% component ParetoAnalysesModal with {
        id: 'paretoLoadModal'
    } %}
    {% endcomponent %}
</main>
{% endblock %}

{% block stylesheets %}
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<link rel="stylesheet" href="{{ asset('styles/tools/pareto.css') }}" data-turbo-track="reload">
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="{{ asset('js/export-branding.js') }}"></script>
<script src="{{ asset('js/main.js') }}"></script>
<script src="{{ asset('js/pareto.js') }}"></script>
<script>
    window.paretoAppConfig = {
        isAuthenticated: {{ app.user ? 'true' : 'false' }},
        analysisId: {{ analysisId is defined and analysisId ? analysisId : 'null' }},
        currentAnalysisId: null,
    };

    window.paretoRoutes = {
        save: '{{ path('app_api_pareto_save') }}',
        list: '{{ path('app_api_pareto_list') }}',
        get: '{{ path('app_api_pareto_get', {id: 0}) }}',
        delete: '{{ path('app_api_pareto_delete', {id: 0}) }}',
        login: '{{ path('app_login') }}'
    };
</script>
{% endblock %}


