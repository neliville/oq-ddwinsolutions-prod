{% extends 'base_with_sidebar.html.twig' %}

{% block title %}CAPA #{{ capa.id }} | OUTILS-QUALITÉ{% endblock %}

{% block content %}
{% set status = capa.status.value %}
{% set primaryActions = {
    'brouillon': { value: 'submit_validation', label: 'Soumettre en validation' },
    'a_valider': { value: 'validate', label: 'Valider' },
    'validee': { value: 'start', label: 'Démarrer' },
    'en_cours': { value: 'implementation_done', label: 'Mise en œuvre terminée' },
    'reouverte': { value: 'implementation_done', label: 'Mise en œuvre terminée' },
    'en_attente_de_verification': { value: 'close', label: 'Clôturer' },
    'cloturee': { value: 'reopen', label: 'Rouvrir' },
} %}
{% set primary = primaryActions[status] ?? null %}
<div
    class="capa-cockpit capa-form-page w-full max-w-5xl mx-auto px-4 py-6 sm:py-8 pb-28 lg:pb-8"
    data-controller="capa-form"
>
    <twig:CapaFormHero :capa="capa" />

    <form method="post" id="capa-edit-form" class="space-y-6" novalidate data-capa-form-target="form">
        <input type="hidden" name="_token" value="{{ csrf_token('qse_capa_edit') }}">

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <div class="lg:col-span-8 space-y-6">
                {% include 'qse/capa/_form_sections.html.twig' with { capa: capa, origins: origins } %}
            </div>
            <div class="lg:col-span-4">
                <twig:CapaContextPanel :capa="capa" />
            </div>
        </div>
    </form>

    <twig:CapaSaveActionBar
        formId="capa-edit-form"
        :cancelUrl="path('app_qse_capa_index')"
        :primaryActionValue="primary ? primary.value : null"
        :primaryActionLabel="primary ? primary.label : null"
    />

    <div class="mt-6">
        {% include 'qse/capa/_origin_quick_add.html.twig' %}
    </div>
</div>
{% endblock %}
