{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Actions CAPA | OUTILS-QUALITÉ{% endblock %}

{% block content %}
<div class="w-full max-w-5xl mx-auto px-4 py-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <h1 class="text-2xl font-bold m-0">Actions CAPA</h1>
        <twig:Button as="a" href="{{ path('app_qse_audit_index') }}" variant="outline" class="no-underline w-full sm:w-auto shrink-0">Voir les audits</twig:Button>
    </div>
    {% if capas is empty %}
        <twig:Empty>
            <twig:Empty:Header>
                <twig:Empty:Title>Aucune action CAPA</twig:Empty:Title>
                <twig:Empty:Description>Créez une CAPA depuis un audit (note 1 ou 2) ou depuis vos outils d’analyse.</twig:Empty:Description>
            </twig:Empty:Header>
            <twig:Empty:Content>
                <twig:Button as="a" href="{{ path('app_qse_audit_pick_standard') }}" variant="default" class="no-underline">Nouvel audit</twig:Button>
            </twig:Empty:Content>
        </twig:Empty>
    {% else %}
        <twig:Card class="border-border/80 shadow-sm overflow-hidden">
            <twig:Card:Content class="p-0 sm:p-0">
                <twig:Table>
                    <twig:Table:Header>
                        <twig:Table:Row>
                            <twig:Table:Head>Titre</twig:Table:Head>
                            <twig:Table:Head>Statut</twig:Table:Head>
                            <twig:Table:Head class="text-end w-[1%] whitespace-nowrap">Voir</twig:Table:Head>
                        </twig:Table:Row>
                    </twig:Table:Header>
                    <twig:Table:Body>
                        {% for c in capas %}
                            <twig:Table:Row>
                                <twig:Table:Cell class="font-medium max-w-[min(28rem,55vw)]">
                                    <a href="{{ path('app_qse_capa_show', { id: c.id }) }}" class="app-inline-link">{{ c.title }}</a>
                                </twig:Table:Cell>
                                <twig:Table:Cell>
                                    <twig:Badge variant="secondary">{{ c.status.value|qse_status_label('capa') }}</twig:Badge>
                                </twig:Table:Cell>
                                <twig:Table:Cell class="text-end">
                                    <twig:Button as="a" href="{{ path('app_qse_capa_show', { id: c.id }) }}" variant="outline" size="sm" class="no-underline">Ouvrir</twig:Button>
                                </twig:Table:Cell>
                            </twig:Table:Row>
                        {% endfor %}
                    </twig:Table:Body>
                </twig:Table>
            </twig:Card:Content>
        </twig:Card>
    {% endif %}
</div>
{% endblock %}
