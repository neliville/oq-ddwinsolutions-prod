{% extends 'base_with_sidebar.html.twig' %}

{% block title %}CAPA Management Board | OUTILS-QUALITÉ{% endblock %}

{% block content %}
<div class="w-full max-w-7xl mx-auto px-4 py-6 sm:py-8">
    <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between mb-8">
        <div class="min-w-0">
            <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-foreground m-0">CAPA Management Board</h1>
            <p class="text-muted-foreground text-sm sm:text-base mt-2 mb-0 max-w-2xl leading-relaxed">
                Pilotage des actions correctives et préventives : workflow, échéances, criticité et traçabilité des sources.
            </p>
        </div>
        <form method="post" action="{{ path('app_qse_capa_new') }}" class="m-0 shrink-0 w-full sm:w-auto">
            <input type="hidden" name="_token" value="{{ csrf_token('qse_capa_new') }}">
            <twig:Button type="submit" variant="default" class="w-full sm:w-auto">
                Nouvelle CAPA
            </twig:Button>
        </form>
    </header>

    <twig:CapaBoard />
</div>
{% endblock %}
