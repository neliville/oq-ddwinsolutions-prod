{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Audit #{{ audit.id }} | OUTILS-QUALITÉ{% endblock %}

{% block content %}
<div
    class="w-full max-w-6xl mx-auto px-4 py-6 pb-28 lg:pb-10"
    data-controller="audit-cockpit chart audit-save-bar audit-save-pulse"
    data-chart-kind-value="audit-cockpit"
    data-chart-config-value="{{ chartConfigJson|e('html_attr') }}"
    data-audit-save-bar-form-id-value="audit-chapter-form"
>
    <div class="mb-6">
        <a href="{{ path('app_qse_audit_index') }}" class="text-sm app-inline-link app-inline-link--muted">← Audits</a>
        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mt-2">
            <div>
                <h1 class="text-2xl font-bold tracking-tight">{{ audit.companyName|default('Audit') }}</h1>
                <p class="text-muted-foreground text-sm mt-1">
                    {{ audit.auditStandard ? audit.auditStandard.name : '—' }}
                    · {{ audit.auditedAt|date('d/m/Y') }} · {{ audit.mainAuditor|default('—') }}
                    {% if audit.concernedSite %}· {{ audit.concernedSite }}{% endif %}
                </p>
            </div>
            <div class="flex flex-wrap items-center gap-2 shrink-0">
                {% include 'collaboration/_share_dialog.html.twig' with { dialog_id: 'collab_share_audit_' ~ audit.id, target_type: 'audit', target_id: audit.id } %}
                {% include 'collaboration/_invite_dialog.html.twig' with { dialog_id: 'collab_invite_audit_' ~ audit.id, source: 'audit', audit_id: audit.id, trigger_label: 'Inviter' } %}
                <details class="relative group">
                    <summary class="list-none cursor-pointer inline-flex items-center gap-1 rounded-md border border-input bg-background px-3 py-2 text-sm font-medium hover:bg-muted/60 [&::-webkit-details-marker]:hidden">
                        Exporter
                        <twig:ux:icon name="lucide:chevron-down" class="size-4 opacity-70" aria-hidden="true" />
                    </summary>
                    <div class="absolute right-0 mt-1 min-w-[12rem] rounded-md border border-border bg-popover text-popover-foreground shadow-md py-1 z-40">
                        <a href="{{ path('app_qse_audit_export_xlsx', { id: audit.id }) }}" class="block px-3 py-2 text-sm hover:bg-muted no-underline text-foreground">Excel (.xlsx)</a>
                        <a href="{{ path('app_qse_audit_export_docx', { id: audit.id, variant: 'direction' }) }}" class="block px-3 py-2 text-sm hover:bg-muted no-underline text-foreground">Word — direction</a>
                        <a href="{{ path('app_qse_audit_export_docx', { id: audit.id, variant: 'terrain' }) }}" class="block px-3 py-2 text-sm hover:bg-muted no-underline text-foreground">Word — terrain</a>
                        <a href="{{ path('app_qse_audit_export_docx', { id: audit.id, variant: 'certification' }) }}" class="block px-3 py-2 text-sm hover:bg-muted no-underline text-foreground">Word — certification</a>
                    </div>
                </details>
            </div>
        </div>
    </div>

    {% if showRequirementsForm %}
        <div class="sticky top-0 z-30 -mx-4 px-4 py-3 mb-4 border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80">
            <div class="flex flex-col gap-3">
                <div class="flex flex-wrap gap-2 lg:gap-3">
                    <twig:Card class="flex-1 min-w-[8rem] border-border/80 py-2 px-3 shadow-none">
                        <p class="text-[10px] font-semibold uppercase tracking-wide text-muted-foreground m-0">Conformité</p>
                        <p class="text-lg font-bold tabular-nums m-0">{{ cockpitMetrics.globalComplianceRate is not null ? cockpitMetrics.globalComplianceRate ~ ' %' : '—' }}</p>
                    </twig:Card>
                    <twig:Card class="flex-1 min-w-[8rem] border-border/80 py-2 px-3 shadow-none">
                        <p class="text-[10px] font-semibold uppercase tracking-wide text-muted-foreground m-0">Progression</p>
                        <p class="text-lg font-bold tabular-nums m-0">{{ cockpitMetrics.answeredRequirements }}/{{ cockpitMetrics.totalRequirements }}</p>
                    </twig:Card>
                    <twig:Card class="flex-1 min-w-[8rem] border-border/80 py-2 px-3 shadow-none">
                        <p class="text-[10px] font-semibold uppercase tracking-wide text-muted-foreground m-0">NC maj. / min.</p>
                        <p class="text-lg font-bold tabular-nums m-0">{{ cockpitMetrics.majorNc }} / {{ cockpitMetrics.minorNc }}</p>
                    </twig:Card>
                    <twig:Card class="flex-1 min-w-[8rem] border-border/80 py-2 px-3 shadow-none">
                        <p class="text-[10px] font-semibold uppercase tracking-wide text-muted-foreground m-0">Preuves manq.</p>
                        <p class="text-lg font-bold tabular-nums m-0">{{ cockpitMetrics.evidenceMissing }}</p>
                    </twig:Card>
                </div>
                <div class="h-2 rounded-full bg-muted overflow-hidden" role="progressbar" aria-valuenow="{{ cockpitMetrics.progressPercent|round }}" aria-valuemin="0" aria-valuemax="100" aria-label="Progression saisie">
                    <div class="h-full rounded-full bg-primary transition-all duration-500" style="width: {{ cockpitMetrics.progressPercent }}%"></div>
                </div>
            </div>
        </div>

        <div class="grid lg:grid-cols-12 gap-6 items-start">
            <aside class="lg:col-span-4 space-y-4 order-2 lg:order-1">
                <twig:Card class="border-border/80">
                    <twig:Card:Header class="pb-2">
                        <twig:Card:Title class="text-base">Pilotage</twig:Card:Title>
                        <twig:Card:Description class="text-xs">Filtrez les exigences du chapitre courant.</twig:Card:Description>
                    </twig:Card:Header>
                    <twig:Card:Content class="space-y-3">
                        <div>
                            <label class="text-xs font-medium text-muted-foreground" for="audit-req-search">Recherche</label>
                            <input id="audit-req-search" type="search" class="mt-1 w-full rounded-md border border-input bg-background px-2 py-2 text-sm" placeholder="Article, texte…" data-audit-cockpit-target="searchInput" data-action="input->audit-cockpit#search" autocomplete="off">
                        </div>
                        <div class="flex flex-wrap gap-1.5" role="toolbar" aria-label="Filtres verdict">
                            <button type="button" class="px-2.5 py-1 rounded-md text-xs border border-primary bg-primary text-primary-foreground" data-audit-cockpit-target="filterBtn" data-filter="all" data-action="audit-cockpit#filter">Tous</button>
                            {% include 'components/audit_verdict_filter_button.html.twig' with { filter: 'not_evaluated', label: 'Non évalué', help_id: 'help.audit.verdict.not_evaluated' } %}
                            {% include 'components/audit_verdict_filter_button.html.twig' with { filter: 'conform', label: 'Conforme', help_id: 'help.audit.verdict.conform' } %}
                            {% include 'components/audit_verdict_filter_button.html.twig' with { filter: 'observation', label: 'Obs.', help_id: 'help.audit.verdict.observation' } %}
                            {% include 'components/audit_verdict_filter_button.html.twig' with { filter: 'to_review', label: 'À revoir', help_id: 'help.audit.verdict.to_review' } %}
                            {% include 'components/audit_verdict_filter_button.html.twig' with { filter: 'minor_nc', label: 'NC min.', help_id: 'help.audit.verdict.minor_nc' } %}
                            {% include 'components/audit_verdict_filter_button.html.twig' with { filter: 'major_nc', label: 'NC maj.', help_id: 'help.audit.verdict.major_nc' } %}
                            {% include 'components/audit_verdict_filter_button.html.twig' with { filter: 'not_applicable', label: 'N/A', help_id: 'help.audit.verdict.not_applicable' } %}
                        </div>
                    </twig:Card:Content>
                </twig:Card>

                <twig:Card class="border-border/80">
                    <twig:Card:Header class="pb-2">
                        <twig:Card:Title class="text-base">Chapitres</twig:Card:Title>
                    </twig:Card:Header>
                    <twig:Card:Content class="space-y-1 max-h-[22rem] overflow-y-auto pr-1">
                        {% for ch in chapters %}
                            {% set sum = cockpitMetrics.chapterSummaries[ch] ?? null %}
                            <a href="{{ path('app_qse_audit_show', { id: audit.id, chapter: ch }) }}"
                               class="flex items-center justify-between gap-2 rounded-md px-2 py-2 text-sm border {{ ch == currentChapter ? 'bg-primary text-primary-foreground border-primary' : 'border-transparent hover:bg-muted' }}">
                                <span class="truncate font-medium">{{ ch }}</span>
                                {% if sum %}
                                    <span class="text-xs tabular-nums shrink-0 opacity-90">{{ sum.answered }}/{{ sum.total }}</span>
                                {% endif %}
                            </a>
                        {% endfor %}
                    </twig:Card:Content>
                </twig:Card>

                {% if cockpitMetrics.timelinePreview is not empty %}
                {% set toneStyles = {
                    success: { dot: 'bg-emerald-500', ring: 'ring-emerald-500/20', icon: 'text-emerald-600 dark:text-emerald-400', bg: 'bg-emerald-50 dark:bg-emerald-950/40' },
                    warning: { dot: 'bg-amber-500', ring: 'ring-amber-500/20', icon: 'text-amber-600 dark:text-amber-400', bg: 'bg-amber-50 dark:bg-amber-950/40' },
                    danger:  { dot: 'bg-rose-500', ring: 'ring-rose-500/20', icon: 'text-rose-600 dark:text-rose-400', bg: 'bg-rose-50 dark:bg-rose-950/40' },
                    info:    { dot: 'bg-sky-500', ring: 'ring-sky-500/20', icon: 'text-sky-600 dark:text-sky-400', bg: 'bg-sky-50 dark:bg-sky-950/40' },
                    neutral: { dot: 'bg-muted-foreground/60', ring: 'ring-muted-foreground/15', icon: 'text-muted-foreground', bg: 'bg-muted' }
                } %}
                <twig:Card class="border-border/80">
                    <twig:Card:Header class="pb-2 flex flex-row items-center justify-between gap-2 space-y-0">
                        <div class="flex flex-col">
                            <twig:Card:Title class="text-base">Activité récente</twig:Card:Title>
                            <twig:Card:Description class="text-[11px]">Dernières actions sur cet audit.</twig:Card:Description>
                        </div>
                        <span class="inline-flex items-center gap-1 rounded-full border border-border bg-muted/40 px-2 py-0.5 text-[10px] font-medium text-muted-foreground tabular-nums">
                            <twig:ux:icon name="lucide:activity" class="size-3" aria-hidden="true" />
                            {{ cockpitMetrics.timelinePreview|length }}
                        </span>
                    </twig:Card:Header>
                    <twig:Card:Content class="pt-1">
                        <ol class="relative ms-3 border-s border-dashed border-border/70 space-y-3" aria-label="Activité récente de l’audit">
                            {% for row in cockpitMetrics.timelinePreview %}
                                {% set tone = toneStyles[row.tone] ?? toneStyles.neutral %}
                                <li class="relative ps-4 group">
                                    <span class="absolute -start-[7px] top-1.5 inline-flex size-3 items-center justify-center">
                                        <span class="absolute inset-0 rounded-full {{ tone.dot }} ring-4 {{ tone.ring }}" aria-hidden="true"></span>
                                    </span>
                                    <div class="flex items-start gap-2.5">
                                        <span class="hidden sm:inline-flex size-7 items-center justify-center rounded-md {{ tone.bg }} {{ tone.icon }} shrink-0 ring-1 ring-inset ring-border/40" aria-hidden="true">
                                            <twig:ux:icon name="{{ row.icon }}" class="size-4" />
                                        </span>
                                        <div class="min-w-0 flex-1">
                                            <div class="flex items-baseline justify-between gap-2">
                                                <p class="m-0 text-sm font-medium text-foreground leading-snug truncate">{{ row.title }}</p>
                                                <time datetime="{{ row.iso8601 }}" title="{{ row.date }} à {{ row.time }}" class="shrink-0 text-[11px] font-medium tabular-nums text-muted-foreground">
                                                    {{ row.time }}
                                                </time>
                                            </div>
                                            {% if row.detail %}
                                                <p class="m-0 mt-0.5 text-xs text-muted-foreground leading-snug">{{ row.detail }}</p>
                                            {% endif %}
                                            {% if row.actor %}
                                                <p class="m-0 mt-1 text-[10.5px] uppercase tracking-wide text-muted-foreground/80">par {{ row.actor }}</p>
                                            {% endif %}
                                        </div>
                                    </div>
                                </li>
                            {% endfor %}
                        </ol>
                    </twig:Card:Content>
                </twig:Card>
                {% endif %}

                <div class="grid grid-cols-1 gap-3">
                    <div class="rounded-lg border border-border bg-card p-2">
                        <p class="text-xs font-medium text-muted-foreground mb-1">Conformité par chapitre</p>
                        <div class="h-48">
                            <canvas data-audit-cockpit-chart-ref="radar" class="max-h-full w-full"></canvas>
                        </div>
                    </div>
                    <div class="rounded-lg border border-border bg-card p-2">
                        <p class="text-xs font-medium text-muted-foreground mb-1">Répartition des verdicts</p>
                        <div class="h-52">
                            <canvas data-audit-cockpit-chart-ref="distribution" class="max-h-full w-full"></canvas>
                        </div>
                    </div>
                </div>
            </aside>

            <div class="lg:col-span-8 space-y-4 order-1 lg:order-2">
                <div class="flex flex-wrap items-center justify-between gap-2">
                    <h2 class="text-lg font-semibold m-0">Chapitre {{ currentChapter }}</h2>
                    <p class="text-xs text-muted-foreground m-0">{{ requirements|length }} exigence(s) affichée(s)</p>
                </div>

                <twig:AuditSaveActionBar placement="desktop" />

                <form method="post" action="{{ path('app_qse_audit_save_chapter', { id: audit.id }) }}" id="audit-chapter-form" class="space-y-4" data-controller="auto-animate">
                    <input type="hidden" name="_token" value="{{ csrf_token('qse_audit_chapter') }}">
                    <input type="hidden" name="chapter" value="{{ currentChapter }}">

                    {% for req in requirements %}
                        {% set ev = evaluationsByReqId[req.id] ?? null %}
                        {% set linkedCapa = ev and ev.id ? (openCapaByEvaluationId[ev.id] ?? null) : null %}
                        <twig:AuditRequirementCard :requirement="req" :evaluation="ev" :linkedCapa="linkedCapa" :audit="audit" :read-only="false" :expanded="loop.first" />
                    {% endfor %}
                </form>

                <twig:AuditSaveActionBar placement="mobile" />
            </div>
        </div>
    {% else %}
        <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950 dark:border-amber-800 dark:bg-amber-950/40 dark:text-amber-50">
            <p class="font-semibold m-0 mb-2">Aucune exigence n’est chargée pour ce référentiel</p>
            <p class="m-0 mb-2 leading-relaxed text-amber-900/95 dark:text-amber-100/90">
                La saisie d’audit repose sur des <strong>exigences</strong> (chapitres / articles) enregistrées en base pour
                <strong>{{ audit.auditStandard.name }}</strong>
                (<code class="rounded bg-background/80 px-1 py-0.5 text-xs">{{ audit.auditStandard.code }}</code>).
                Tant qu’il n’y a aucune ligne pour ce code, les chapitres ne peuvent pas s’afficher — ce n’est pas un bug de l’audit lui-même, seulement un référentiel encore vide pour cette norme.
            </p>
            {% if audit.auditStandard.code == 'iso_9001' %}
                <p class="m-0 mb-2 leading-relaxed text-amber-900/95 dark:text-amber-100/90">
                    Pour <strong>ISO&nbsp;9001</strong>, vous pouvez remplir les exigences avec la commande serveur&nbsp;:
                </p>
                <pre class="mb-3 overflow-x-auto rounded-md border border-amber-200/80 bg-background px-3 py-2 text-xs dark:border-amber-800">php bin/console app:qse:import-iso9001-requirements</pre>
            {% elseif audit.auditStandard.code in ['iso_14001', 'iso_45001'] %}
                <p class="m-0 mb-2 leading-relaxed text-amber-900/95 dark:text-amber-100/90">
                    Pour <strong>ISO&nbsp;14001</strong> et <strong>ISO&nbsp;45001</strong>, les exigences du classeur
                    <code class="rounded bg-background/80 px-1 py-0.5 text-xs">Exigences ISO 9001v2015__en_cours.xlsx</code>
                    (onglets 14001 et 45001) peuvent être chargées en base avec la commande serveur&nbsp;:
                </p>
                <pre class="mb-2 overflow-x-auto rounded-md border border-amber-200/80 bg-background px-3 py-2 text-xs dark:border-amber-800">php bin/console app:qse:import-audit-exigences-workbook</pre>
                <p class="m-0 mb-2 text-xs leading-relaxed text-amber-900/90 dark:text-amber-100/85">
                    Par défaut, seuls les onglets 14001 et 45001 sont importés (l’ISO&nbsp;9001 du même fichier reste gérée par
                    <code class="rounded bg-background/80 px-1">app:qse:import-iso9001-requirements</code>). Utilisez
                    <code class="rounded bg-background/80 px-1">--tabs=9001,14001,45001</code> si vous souhaitez tout réimporter depuis le classeur.
                </p>
            {% else %}
                <p class="m-0 mb-2 leading-relaxed text-amber-900/95 dark:text-amber-100/90">
                    Pour ce référentiel, les exigences doivent être ajoutées via l’<strong>import administrateur</strong>
                    (fichier prévu à cet effet) ou un autre processus interne, en ciblant explicitement cette norme.
                </p>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                <p class="m-0 flex flex-wrap gap-x-3 gap-y-1">
                    <a href="{{ path('app_admin_qse_req_import_index') }}" class="app-inline-link font-medium">Import d’exigences (administration)</a>
                    <a href="{{ path('app_admin_qse_audit_requirements_index', { standard: audit.auditStandard.id }) }}" class="app-inline-link font-medium">Exigences en base pour ce référentiel</a>
                </p>
            {% else %}
                <p class="m-0 text-amber-900/90 dark:text-amber-100/85">Si vous n’êtes pas administrateur, demandez à l’équipe qui gère la plateforme d’importer les exigences pour cette norme.</p>
            {% endif %}
        </div>
    {% endif %}
</div>
{% endblock %}
