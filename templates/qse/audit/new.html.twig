{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Nouvel audit — {{ standard.name }} | OUTILS-QUALITÉ{% endblock %}

{% block content %}
{% set onboarding_origin = app.request.query.get('origin') %}
{% set pickStandardParams = onboarding_origin == 'onboarding' ? { origin: 'onboarding' } : {} %}
<div class="audit-cockpit audit-form-page motion-premium w-full max-w-5xl mx-auto px-4 py-6 sm:py-8 pb-28 lg:pb-8">
    <twig:AuditFormHero :standard="standard" :onboardingOrigin="onboarding_origin == 'onboarding' ? 'onboarding' : null" />

    <form
        method="post"
        id="audit-create-form"
        class="space-y-6"
        data-controller="audit-form-progress"
        novalidate
    >
        <input type="hidden" name="_token" value="{{ csrf_token('qse_audit_new') }}">
        <input type="hidden" name="audit_standard_id" value="{{ standard.id }}">
        {% if onboarding_origin == 'onboarding' %}
            <input type="hidden" name="origin" value="onboarding">
        {% endif %}

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6" data-gsap-reveal>
            <div class="lg:col-span-8 space-y-6 order-1">
                {% include 'qse/audit/_form_sections.html.twig' %}
            </div>
            <div class="lg:col-span-4 order-2" data-gsap-reveal-item>
                {% include 'qse/audit/_aside_helper.html.twig' with { standard: standard } only %}
            </div>
        </div>
    </form>

    <twig:AuditNewSaveActionBar
        formId="audit-create-form"
        :cancelUrl="path('app_qse_audit_pick_standard', pickStandardParams)"
    />
</div>
{% endblock %}
