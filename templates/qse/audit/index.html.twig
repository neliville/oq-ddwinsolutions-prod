{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Audits QSE | OUTILS-QUALITÉ{% endblock %}

{% block content %}
<div
    class="w-full max-w-6xl mx-auto px-4 py-6"
    data-controller="qse-audit-delete"
    data-qse-audit-delete-delete-url-template-value="{{ path('app_qse_audit_delete', { id: 999999001 }) }}"
>
    <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between mb-8">
        <div class="min-w-0">
            <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-foreground m-0">Vos audits QSE</h1>
            <p class="text-muted-foreground text-sm sm:text-base mt-2 mb-0 max-w-2xl leading-relaxed">
                Pilotage par référentiel ISO : conformité globale, statut d’avancement et accès rapide à chaque dossier.
            </p>
        </div>
        <twig:Button as="a" href="{{ path('app_qse_audit_pick_standard') }}" variant="default" class="no-underline w-full sm:w-auto shrink-0">
            Nouvel audit
        </twig:Button>
    </header>

    {% if audits is empty %}
        <twig:Empty>
            <twig:Empty:Header>
                <twig:Empty:Title>Aucun audit</twig:Empty:Title>
                <twig:Empty:Description>Démarrez un audit à partir d’un référentiel ISO chargé dans l’application.</twig:Empty:Description>
            </twig:Empty:Header>
            <twig:Empty:Content>
                <twig:Button as="a" href="{{ path('app_qse_audit_pick_standard') }}" variant="default" class="no-underline">Choisir un référentiel</twig:Button>
            </twig:Empty:Content>
        </twig:Empty>
    {% else %}
        <twig:Card class="border-border/80 shadow-sm overflow-hidden">
            <twig:Card:Content class="p-0 sm:p-0">
                    <twig:Table class="min-w-[42rem]">
                        <caption class="sr-only text-left">Liste de vos audits qualité, triés par date d’audit décroissante.</caption>
                        <twig:Table:Header>
                            <twig:Table:Row>
                                <twig:Table:Head scope="col" class="w-[32%]">Audit</twig:Table:Head>
                                <twig:Table:Head scope="col" class="whitespace-nowrap">Référentiel</twig:Table:Head>
                                <twig:Table:Head scope="col" class="text-center whitespace-nowrap">Conformité</twig:Table:Head>
                                <twig:Table:Head scope="col" class="whitespace-nowrap">Statut</twig:Table:Head>
                                <twig:Table:Head scope="col" class="text-end w-[1%] whitespace-nowrap">Actions</twig:Table:Head>
                            </twig:Table:Row>
                        </twig:Table:Header>
                        <twig:Table:Body>
                            {% for a in audits %}
                                {% set capa_n = audit_capa_counts[a.id] ?? 0 %}
                                {% set audit_label = (a.companyName|default('Audit')) ~ ' — ' ~ a.auditedAt|date('d/m/Y') %}
                                <twig:Table:Row class="align-middle">
                                    <twig:Table:Cell class="font-medium">
                                        <a href="{{ path('app_qse_audit_show', { id: a.id }) }}" class="app-inline-link font-semibold text-foreground">
                                            {{- audit_label -}}
                                        </a>
                                    </twig:Table:Cell>
                                    <twig:Table:Cell>
                                        <twig:Badge variant="outline" class="font-normal tabular-nums">{{ a.auditStandard.code }}</twig:Badge>
                                    </twig:Table:Cell>
                                    <twig:Table:Cell class="text-center">
                                        {% if a.globalComplianceRate is not null %}
                                            <twig:Badge variant="secondary" class="tabular-nums">{{ a.globalComplianceRate }}&nbsp;%</twig:Badge>
                                        {% else %}
                                            <span class="text-muted-foreground text-sm tabular-nums">—</span>
                                        {% endif %}
                                    </twig:Table:Cell>
                                    <twig:Table:Cell>
                                        <twig:Badge variant="secondary" class="font-medium">{{ a.status.value|qse_status_label('audit_exec') }}</twig:Badge>
                                    </twig:Table:Cell>
                                    <twig:Table:Cell class="text-end">
                                        <div class="inline-flex flex-wrap items-center justify-end gap-1.5">
                                            <twig:Button as="a" href="{{ path('app_qse_audit_show', { id: a.id }) }}" variant="outline" size="sm" class="no-underline">
                                                Ouvrir
                                            </twig:Button>
                                            <twig:Button
                                                type="button"
                                                variant="outline"
                                                size="sm"
                                                class="text-destructive border-destructive/40 hover:bg-destructive/10"
                                                data-action="click->qse-audit-delete#open"
                                                data-audit-id="{{ a.id }}"
                                                data-delete-url="{{ path('app_qse_audit_delete', { id: a.id }) }}"
                                                data-capa-count="{{ capa_n }}"
                                                data-audit-label="{{ audit_label }}"
                                                data-csrf-token="{{ csrf_token('delete_qse_audit_' ~ a.id) }}"
                                                aria-label="Supprimer l’audit {{ audit_label }}"
                                            >
                                                <twig:ux:icon name="lucide:trash-2" class="size-4 sm:mr-1" aria-hidden="true" />
                                                <span class="hidden sm:inline">Supprimer</span>
                                            </twig:Button>
                                        </div>
                                    </twig:Table:Cell>
                                </twig:Table:Row>
                            {% endfor %}
                        </twig:Table:Body>
                    </twig:Table>
            </twig:Card:Content>
        </twig:Card>
    {% endif %}

    {% include 'qse/audit/_delete_dialog.html.twig' %}
</div>
{% endblock %}
