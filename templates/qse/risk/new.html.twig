{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Créer un risque | OUTILS-QUALITÉ{% endblock %}

{% block content %}
{% set onboarding_origin = form.origin.vars.data|default(app.request.query.get('origin')) %}
<div class="risk-cockpit risk-form-page motion-premium w-full max-w-5xl mx-auto px-4 py-6 sm:py-8 pb-28 lg:pb-8">
    <twig:RiskFormHero :onboardingOrigin="onboarding_origin == 'onboarding' ? 'onboarding' : null" />

    {{ form_start(form, {
        attr: {
            id: 'risk-create-form',
            class: 'space-y-6',
            novalidate: 'novalidate',
        },
    }) }}
        <div class="sr-only">
            <input type="hidden" name="_token" value="{{ csrf_token('qse_risk_new') }}">
            {{ form_widget(form.action) }}
            {{ form_widget(form.origin) }}
        </div>

        <div
            class="grid grid-cols-1 lg:grid-cols-12 gap-6"
            data-controller="risk-criticality"
            data-risk-criticality-medium-threshold-value="{{ constant('App\\Qse\\Service\\RiskCriticalityCalculator::MEDIUM_SCORE_THRESHOLD') }}"
            data-risk-criticality-critical-threshold-value="{{ constant('App\\Qse\\Service\\RiskCriticalityCalculator::CRITICAL_SCORE_THRESHOLD') }}"
            data-gsap-reveal
        >
            <div class="lg:col-span-8 space-y-6">
                {% include 'qse/risk/_form_sections.html.twig' %}
            </div>

            <div class="lg:col-span-4" data-gsap-reveal-item>
                <twig:RiskCriticalityPanel :calculator="calculator" />
            </div>
        </div>
    {{ form_end(form, { render_rest: false }) }}

    <twig:RiskSaveActionBar
        formId="risk-create-form"
        :cancelUrl="path('app_qse_risk_index')"
    />
</div>
{% endblock %}
