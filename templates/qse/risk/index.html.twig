{% extends 'base_with_sidebar.html.twig' %}

{% block title %}Gestion des Risques QSE | OUTILS-QUALITÉ{% endblock %}

{% block content %}
<div class="risk-cockpit w-full max-w-7xl mx-auto space-y-6 px-4 py-6 sm:py-8">
    <twig:RiskHero :kpis="shell.kpis" />

    <twig:RiskKpiStrip :kpis="shell.kpis" />

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        {# Colonne principale : matrice puis liste (ordre mobile respecté) #}
        <div class="lg:col-span-8 space-y-6 order-1">
            <twig:RiskHeatmapPreview :preview="shell.heatmap" />

            {% if shell.totalRisks == 0 %}
                <twig:RiskEmptyState />
            {% else %}
                <section aria-labelledby="risk-list-heading">
                    <header class="mb-4">
                        <h2 id="risk-list-heading" class="text-lg font-semibold text-foreground m-0">Registre des risques</h2>
                        <p class="text-sm text-muted-foreground m-0 mt-1">Filtrez, triez et ouvrez chaque fiche pour lier des actions CAPA.</p>
                    </header>
                    <twig:RiskBoard />
                </section>
            {% endif %}
        </div>

        {# Sidebar : priorités puis timeline #}
        <aside class="lg:col-span-4 space-y-6 order-2">
            <twig:RiskAttentionPanel :items="shell.priorityItems" />
            <twig:RiskActivityTimeline :activity="shell.activity" />
        </aside>
    </div>
</div>
{% endblock %}
