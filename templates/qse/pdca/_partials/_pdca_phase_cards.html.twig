{# Grille des 4 cartes PDCA stratégiques #}
<section class="space-y-4" aria-labelledby="pdca-phases-heading">
    <h2 id="pdca-phases-heading" class="text-lg font-semibold tracking-tight text-foreground m-0">Cycle PDCA</h2>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4 xl:items-stretch">
        {% include 'qse/pdca/_partials/_pdca_phase_card.html.twig' with {
            phase: 'plan',
            phaseNum: 1,
            title: 'Plan',
            description: 'Structurer l’analyse et la prévention.',
            icon: 'lucide:clipboard-list',
            score: phaseScores.plan ?? null,
            statusLabel: (plan.risks > 0 and cockpit.criticalRisksWithoutCapa > 0) ? 'Risques à couvrir' : null,
            statusTone: 'outline',
            rows: [
                { href: path('app_qqoqccp_index'), icon: 'lucide:messages-square', label: 'QQOQCCP', badge: plan.qqoqccp },
                { href: path('app_amdec_index'), icon: 'lucide:table-2', label: 'AMDEC', badge: plan.amdec },
                { icon: 'lucide:calendar-range', label: 'Programmes d’audit', badge: plan.audit_plans },
                { href: path('app_qse_audit_index'), icon: 'lucide:layout-dashboard', label: 'Pilotage audits', badge: 'Ouvrir', badgeVariant: 'outline' },
                { href: path('app_qse_risk_index'), icon: 'lucide:shield-alert', label: 'Risques', badge: plan.risks },
            ],
        } only %}

        {% include 'qse/pdca/_partials/_pdca_phase_card.html.twig' with {
            phase: 'do',
            phaseNum: 2,
            title: 'Do',
            description: 'Mettre en œuvre les actions correctives.',
            icon: 'lucide:play-circle',
            score: phaseScores.do ?? null,
            statusLabel: cockpit.overdueOpenCapas > 0 ? 'Retards' : null,
            statusTone: 'destructive',
            rows: [
                { href: path('app_qse_capa_index'), icon: 'lucide:list-todo', label: 'CAPA ouvertes', badge: do.capa_open },
                { icon: 'lucide:alarm-clock', label: 'CAPA en retard', badge: cockpit.overdueOpenCapas, badgeVariant: cockpit.overdueOpenCapas > 0 ? 'destructive' : 'secondary' },
                { icon: 'lucide:hourglass', label: 'En attente de vérification d’efficacité', badge: cockpit.capasAwaitingVerification, badgeVariant: cockpit.capasAwaitingVerification > 0 ? 'outline' : 'secondary', badgeClass: cockpit.capasAwaitingVerification > 0 ? 'border-amber-500/50 bg-amber-500/10 text-amber-950 dark:bg-amber-500/15 dark:text-amber-50' : '' },
            ],
        } only %}

        <article class="pdca-phase-card flex h-full flex-col">
            <div class="pdca-phase-card__surface pdca-phase-card__surface--check flex h-full flex-col rounded-2xl">
                <header class="flex flex-row items-start gap-3 px-5 pb-2 pt-5 text-left sm:px-6 sm:pt-6">
                    <div class="flex size-10 shrink-0 items-center justify-center rounded-xl bg-violet-500/12 text-violet-700 dark:text-violet-300" aria-hidden="true">
                        <twig:ux:icon name="lucide:search-check" class="size-5 shrink-0" />
                    </div>
                    <div class="min-w-0 flex-1 space-y-1">
                        <p class="m-0 text-xs font-semibold uppercase tracking-wider text-violet-600 dark:text-violet-400">Phase 3</p>
                        <twig:ContextualHelp helpId="help.pdca.phase.check" variant="inline" trigger="icon" class="inline-flex max-w-full">
                            {% block trigger %}
                            <h3 class="m-0 text-lg font-bold text-foreground">Check</h3>
                            {% endblock %}
                        </twig:ContextualHelp>
                        <p class="m-0 text-xs leading-snug text-muted-foreground sm:text-sm">Contrôler et mesurer les résultats.</p>
                        {% if phaseScores.check is not null %}
                            <twig:Badge variant="secondary" class="tabular-nums text-xs">{{ phaseScores.check }}%</twig:Badge>
                            <twig:Progress value="{{ phaseScores.check }}" class="mt-2 h-1.5" />
                        {% endif %}
                    </div>
                </header>
                <div class="flex flex-1 flex-col gap-2 px-5 pb-5 pt-0 sm:px-6 sm:pb-6">
                    <a href="{{ path('app_qse_audit_index') }}" class="pdca-phase-card__row group flex items-center justify-between gap-3 no-underline">
                        <span class="flex min-w-0 items-center gap-2.5 text-sm font-medium text-foreground">
                            <twig:ux:icon name="lucide:clipboard-list" class="size-4 shrink-0 text-muted-foreground group-hover:text-primary" aria-hidden="true" />
                            <span class="truncate">Audits enregistrés</span>
                        </span>
                        <twig:Badge variant="secondary" class="shrink-0 tabular-nums">{{ check.audits }}</twig:Badge>
                    </a>
                    {% if check.audits_by_standard is defined and check.audits_by_standard|length > 0 %}
                    <div class="pdca-phase-card__standards-block rounded-xl px-3 py-3">
                        <p class="m-0 mb-2 text-[0.65rem] font-semibold uppercase tracking-wide text-muted-foreground">Répartition par norme</p>
                        <div class="space-y-2.5">
                            {% for row in check.audits_by_standard %}
                            <div>
                                <div class="mb-1 flex items-baseline justify-between gap-2 text-xs">
                                    <span class="min-w-0 truncate font-medium text-foreground" title="{{ row.label }} ({{ row.code }})">{{ row.label }}</span>
                                    <span class="shrink-0 tabular-nums text-muted-foreground"><span class="font-semibold text-foreground">{{ row.cnt }}</span>{% if check.audits > 0 %} · {{ (row.cnt * 100 / check.audits)|round }}%{% endif %}</span>
                                </div>
                                {% if check.audits > 0 %}
                                <twig:Progress value="{{ (row.cnt * 100 / check.audits)|round(0, 'common') }}" class="h-1.5" />
                                {% endif %}
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                    <div class="pdca-phase-card__row flex items-center justify-between gap-3">
                        <span class="flex min-w-0 items-center gap-2.5 text-sm font-medium text-foreground">
                            <twig:ux:icon name="lucide:calendar-clock" class="size-4 shrink-0 text-muted-foreground" aria-hidden="true" />
                            <span class="truncate">Plans d’audit en retard</span>
                        </span>
                        <twig:Badge variant="{{ cockpit.overdueAuditPlans > 0 ? 'destructive' : 'secondary' }}" class="shrink-0 tabular-nums">{{ cockpit.overdueAuditPlans }}</twig:Badge>
                    </div>
                    <a href="{{ path('app_pareto_index') }}" class="pdca-phase-card__row group flex items-center justify-between gap-3 no-underline">
                        <span class="flex min-w-0 items-center gap-2.5 text-sm font-medium text-foreground">
                            <twig:ux:icon name="lucide:chart-no-axes-column" class="size-4 shrink-0 text-muted-foreground group-hover:text-primary" aria-hidden="true" />
                            <span class="truncate">Pareto</span>
                        </span>
                        <twig:Badge variant="secondary" class="shrink-0 tabular-nums">{{ check.pareto }}</twig:Badge>
                    </a>
                </div>
            </div>
        </article>

        {% include 'qse/pdca/_partials/_pdca_phase_card.html.twig' with {
            phase: 'act',
            phaseNum: 4,
            title: 'Act',
            description: 'Analyser les causes et agir durablement.',
            icon: 'lucide:refresh-ccw',
            score: phaseScores.act ?? null,
            statusLabel: null,
            rows: [
                { href: path('app_ishikawa_index'), icon: 'lucide:git-branch', label: 'Ishikawa', badge: act.ishikawa },
                { href: path('app_fivewhy_index'), icon: 'lucide:circle-help', label: '5 Pourquoi', badge: act.five_why },
                { href: path('app_eightd_index'), icon: 'lucide:package', label: '8D', badge: act.eight_d },
            ],
        } only %}
    </div>
</section>
