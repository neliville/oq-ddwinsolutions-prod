{% extends 'base.html.twig' %}

{% block title %}Contact — Support et Partenariats | Outils-Qualité{% endblock %}

{% block meta_description %}Contactez l'équipe Outils-Qualité pour vos questions techniques, suggestions d'amélioration ou demandes de partenariat QSE.{% endblock %}

{% block meta_keywords %}contact outils qualité, support technique, assistance qualité, amélioration continue, partenariats{% endblock %}

{% block og_title %}Contact | OUTILS-QUALITÉ{% endblock %}

{% block og_description %}Contactez-nous pour toute question sur nos outils qualité. Support technique, suggestions d'amélioration et partenariats.{% endblock %}

{% block body %}
<div class="contact-page">
    <section class="contact-hero">
        <div class="container">
            <div class="contact-hero__grid">
                <div>
                    <h1 class="contact-hero__title">Contactez-nous</h1>
                    <p class="contact-hero__lead">
                        Une question ? Une suggestion ? Notre équipe est là pour vous aider.
                    </p>
                </div>
                <div>
                    <figure class="contact-hero__figure">
                        {% include 'components/media/responsive_picture.html.twig' with {
                            path: 'img/markus-winkler-contact-unsplash.webp',
                            alt: 'Image de contact',
                            width: 900,
                            height: 600,
                            class: 'w-full h-auto'
                        } %}
                        <figcaption><small>Source&nbsp;: Unsplash · Markus Winkler.</small></figcaption>
                    </figure>
                </div>
            </div>
        </div>
    </section>

    <section class="contact-section">
        <div class="container">
            <div class="flex justify-center">
                <div class="w-full max-w-2xl">
                    <div class="contact-card">
                        <div class="contact-card__inner">
                            <h2 class="contact-card__title">Envoyez-nous un message</h2>

                            {{ form_start(form, {'attr': {'class': 'contact-form', 'id': 'contactForm', 'data-turbo': 'false'}}) }}
                                <div class="visually-hidden-honeypot" aria-hidden="true">
                                    {{ form_widget(form.website, {'attr': {'tabindex': '-1', 'autocomplete': 'off'}}) }}
                                </div>

                                <div class="contact-form__field">
                                    {{ form_label(form.name, null, {'label_attr': {'class': 'contact-form__label'}}) }}
                                    {{ form_widget(form.name, {'attr': {
                                        'class': 'contact-form__input' ~ (form.name.vars.errors|length ? ' is-invalid' : ''),
                                        'placeholder': 'Votre prénom'
                                    }}) }}
                                    {{ form_errors(form.name) }}
                                </div>

                                <div class="contact-form__field">
                                    {{ form_label(form.email, null, {'label_attr': {'class': 'contact-form__label'}}) }}
                                    {{ form_widget(form.email, {'attr': {
                                        'class': 'contact-form__input' ~ (form.email.vars.errors|length ? ' is-invalid' : ''),
                                        'placeholder': 'votre.email@exemple.com'
                                    }}) }}
                                    {{ form_errors(form.email) }}
                                </div>

                                <div class="contact-form__field">
                                    {{ form_label(form.subject, null, {'label_attr': {'class': 'contact-form__label'}}) }}
                                    {{ form_widget(form.subject, {'attr': {
                                        'class': 'contact-form__select' ~ (form.subject.vars.errors|length ? ' is-invalid' : '')
                                    }}) }}
                                    {{ form_errors(form.subject) }}
                                </div>

                                <div class="contact-form__field">
                                    {{ form_label(form.message, null, {'label_attr': {'class': 'contact-form__label'}}) }}
                                    {{ form_widget(form.message, {'attr': {
                                        'class': 'contact-form__input contact-form__input--textarea' ~ (form.message.vars.errors|length ? ' is-invalid' : ''),
                                        'rows': 5,
                                        'placeholder': 'Décrivez votre demande en détail…'
                                    }}) }}
                                    {{ form_errors(form.message) }}
                                </div>

                                <div class="contact-form__actions">
                                    <p class="contact-form__legal mb-0">
                                        En soumettant ce formulaire, vous acceptez notre
                                        <a href="{{ path('app_legal_politique_confidentialite') }}">politique de confidentialité</a>.
                                    </p>
                                    <button type="submit" class="contact-form__submit">
                                        <i data-lucide="send" width="20" height="20" aria-hidden="true"></i>
                                        Envoyer le message
                                    </button>
                                </div>
                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="contact-info">
        <div class="container">
            <div class="contact-info__grid">
                <div class="contact-info__item">
                    <div class="contact-info__icon" aria-hidden="true">
                        <i data-lucide="mail" width="28" height="28"></i>
                    </div>
                    <h3 class="contact-info__title">Email</h3>
                    <p class="contact-info__text">contact@outils-qualite.com</p>
                </div>

                <div class="contact-info__item">
                    <div class="contact-info__icon contact-info__icon--green" aria-hidden="true">
                        <i data-lucide="clock" width="28" height="28"></i>
                    </div>
                    <h3 class="contact-info__title">Support</h3>
                    <p class="contact-info__text">Lun–Ven&nbsp;: 9h00–18h00</p>
                </div>

                <div class="contact-info__item">
                    <div class="contact-info__icon contact-info__icon--sky" aria-hidden="true">
                        <i data-lucide="reply" width="28" height="28"></i>
                    </div>
                    <h3 class="contact-info__title">Réponse</h3>
                    <p class="contact-info__text">Sous 24&nbsp;h en moyenne</p>
                </div>
            </div>
        </div>
    </section>

    <section class="contact-faq">
        <div class="container">
            <div class="contact-faq__header">
                <h2 class="contact-faq__title">Questions fréquentes</h2>
                <p class="contact-faq__lead">Trouvez rapidement les réponses à vos questions</p>
            </div>

            <div class="contact-faq__list">
                <details class="group" open>
                    <summary>
                        <span>Les outils sont-ils vraiment gratuits&nbsp;?</span>
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </summary>
                    <div class="contact-faq__answer">
                        Oui, absolument&nbsp;! Tous nos outils sont 100&nbsp;% gratuits, sans limitation d’usage,
                        sans inscription obligatoire et sans publicité intrusive. Notre mission est de
                        démocratiser l’accès aux outils d’amélioration continue.
                    </div>
                </details>

                <details class="group">
                    <summary>
                        <span>Puis-je utiliser les outils pour un usage commercial&nbsp;?</span>
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </summary>
                    <div class="contact-faq__answer">
                        Oui, vous pouvez utiliser nos outils dans un cadre professionnel et commercial.
                        Les analyses et rapports générés vous appartiennent entièrement. Nous demandons
                        simplement de mentionner la source lors de présentations publiques.
                    </div>
                </details>

                <details class="group">
                    <summary>
                        <span>Mes données sont-elles sauvegardées&nbsp;?</span>
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </summary>
                    <div class="contact-faq__answer">
                        Nos outils fonctionnent entièrement dans votre navigateur. Aucune donnée n’est
                        envoyée sur nos serveurs, garantissant ainsi la confidentialité totale de vos
                        analyses. Pensez à exporter vos travaux pour les sauvegarder.
                    </div>
                </details>

                <details class="group">
                    <summary>
                        <span>Proposez-vous des formations&nbsp;?</span>
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </summary>
                    <div class="contact-faq__answer">
                        Actuellement, nous proposons des guides et articles sur notre blog. Nous étudions
                        la possibilité de proposer des formations en ligne. Contactez-nous si vous êtes
                        intéressé par ce type de service.
                    </div>
                </details>
            </div>
        </div>
    </section>
</div>
{% endblock %}
