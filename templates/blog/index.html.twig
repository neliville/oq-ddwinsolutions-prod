{% extends 'base.html.twig' %}

{% block head %}
    {{ parent() }}
    {% include 'components/turbo_newsletter_no_cache_meta.html.twig' %}
{% endblock %}

{% block title %}Blog Qualité — Guides, Méthodes et Bonnes Pratiques QSE | Outils-Qualité{% endblock %}

{% block meta_description %}Articles, guides et tutoriels sur les outils qualité, l'amélioration continue et les normes ISO 9001. Ressources gratuites pour professionnels QSE.{% endblock %}

{% block meta_keywords %}blog qualité, amélioration continue, méthodes qualité, outils d'analyse, guides pratiques, conseils experts, ISO 9001, Lean, Kaizen{% endblock %}

{% block og_title %}Blog Qualité | Articles et Guides | OUTILS-QUALITÉ{% endblock %}

{% block og_description %}Découvrez nos articles sur l'amélioration continue, les méthodes qualité et les outils d'analyse. Guides pratiques et conseils d'experts.{% endblock %}

{% block body %}
{% set currentCategoryLabel = null %}
{% if currentCategory is defined and currentCategory %}
    {% for cat in categories|default([]) %}
        {% if cat.slug == currentCategory %}
            {% set currentCategoryLabel = cat.name %}
        {% endif %}
    {% endfor %}
{% endif %}

<!-- Hero Section -->
<section class="py-12 bg-gradient-primary text-black" style="margin-top: 76px;">
    <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-12 items-center gap-8">
            <div class="lg:col-span-8" data-aos="fade-right">
                <h1 class="text-5xl font-bold mb-6">Blog Qualité</h1>
                <p class="text-lg mb-6">
                    Découvrez nos articles, guides pratiques et conseils d'experts pour maîtriser
                    les outils d'amélioration continue et optimiser vos processus qualité.
                </p>
            </div>
            <div class="lg:col-span-4" data-aos="fade-left">
                {% include 'components/media/responsive_picture.html.twig' with {
                    path: 'img/blog-5why.webp',
                    alt: 'Blog qualité',
                    width: 900,
                    height: 600
                } %}
            </div>
        </div>
    </div>
</section>

<!-- Category Filters -->
{% if categories|length > 0 %}
<section class="py-4 bg-muted">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex flex-wrap justify-center gap-2" data-aos="fade-up">
            <a href="{{ path('app_blog_index') }}"
               class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-medium transition-colors no-underline {{ not currentCategory ? 'bg-primary text-primary-foreground' : 'border border-border text-foreground hover:bg-accent' }}">
                <i class="fas fa-th-large mr-2"></i>Tous les articles
            </a>
            {% for category in categories %}
            <a href="{{ path('app_blog_index', {category: category.slug}) }}"
               class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-medium transition-colors no-underline {{ currentCategory == category.slug ? 'bg-primary text-primary-foreground' : 'border border-border text-foreground hover:bg-accent' }}">
                {% if category.icon %}<i class="fas fa-{{ category.icon }} mr-2"></i>{% endif %}
                {{ category.name }}
            </a>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<!-- Featured Articles -->
{% if featuredPosts|length > 0 %}
<section class="py-12 bg-primary/10">
    <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-2xl font-bold mb-6">Articles mis en avant{% if currentCategoryLabel %} <span class="text-muted-foreground text-xl font-normal">— {{ currentCategoryLabel }}</span>{% endif %}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {% for featuredPost in featuredPosts %}
            <div data-aos="fade-up" data-aos-delay="{{ loop.index0 * 100 }}">
                <div class="rounded-lg bg-card shadow-sm h-full flex flex-col overflow-hidden">
                    {% if featuredPost.image %}
                        {% include 'components/media/responsive_picture.html.twig' with {
                            path: featuredPost.image,
                            alt: featuredPost.title,
                            class: 'w-full h-48 object-cover',
                            width: 400,
                            height: 300
                        } %}
                    {% endif %}
                    <div class="p-6 flex flex-col grow">
                        {% if featuredPost.category %}
                        <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2.5 py-0.5 text-xs font-semibold mb-3 self-start">{{ featuredPost.category.name }}</span>
                        {% endif %}
                        <h3 class="font-bold mb-2 grow">
                            <a href="{{ path('app_blog_article', {category: featuredPost.category.slug, slug: featuredPost.slug}) }}"
                               class="text-foreground no-underline hover:text-primary transition-colors">
                                {{ featuredPost.title }}
                            </a>
                        </h3>
                        <p class="text-muted-foreground text-sm mb-4">{{ featuredPost.excerpt|striptags|slice(0, 120) }}...</p>
                        <div class="flex items-center justify-between mt-auto">
                            <span class="text-sm text-muted-foreground">{{ featuredPost.readTime }}</span>
                            <a href="{{ path('app_blog_article', {category: featuredPost.category.slug, slug: featuredPost.slug}) }}"
                               class="inline-flex items-center gap-1 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline">
                                Lire la suite
                                <i data-lucide="arrow-right" width="14" height="14" class="ml-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<!-- Articles Section -->
<section class="py-12">
    <div class="max-w-7xl mx-auto px-4">
        {% if blogPosts|length > 0 %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
            {% for post in blogPosts %}
            <div data-aos="fade-up" data-aos-delay="{{ loop.index0 * 50 }}">
                <div class="rounded-lg bg-card shadow-sm h-full flex flex-col overflow-hidden">
                    {% if post.image %}
                        {% include 'components/media/responsive_picture.html.twig' with {
                            path: post.image,
                            alt: post.title,
                            class: 'w-full h-48 object-cover',
                            width: 400,
                            height: 300
                        } %}
                    {% endif %}
                    <div class="p-6 flex flex-col grow">
                        <div class="flex items-start mb-4">
                            {% if post.category %}
                            <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2.5 py-0.5 text-xs font-semibold mr-2">{{ post.category.name }}</span>
                            {% endif %}
                            <span class="text-sm text-muted-foreground ml-auto">{{ post.publishedAt|date('d/m/Y') }}</span>
                        </div>
                        <h3 class="font-bold mb-2 grow">
                            <a href="{{ path('app_blog_article', {category: post.category.slug, slug: post.slug}) }}"
                               class="text-foreground no-underline hover:text-primary transition-colors">
                                {{ post.title }}
                            </a>
                        </h3>
                        <p class="text-muted-foreground text-sm mb-4">{{ post.excerpt|striptags|slice(0, 100) }}...</p>
                        <div class="flex items-center justify-between mt-auto">
                            <span class="text-sm text-muted-foreground">
                                {{ post.readTime }}
                                {% if post.views > 0 %}
                                · <i data-lucide="eye" width="12" height="12" class="mr-1 inline"></i>{{ post.views }}
                                {% endif %}
                            </span>
                            <a href="{{ path('app_blog_article', {category: post.category.slug, slug: post.slug}) }}"
                               class="inline-flex items-center gap-1 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline">
                                Lire
                                <i data-lucide="arrow-right" width="12" height="12" class="ml-1"></i>
                            </a>
                        </div>
                        {% if post.tags|length > 0 %}
                        <div class="mt-4 pt-4 border-t border-border">
                            <div class="flex flex-wrap gap-1">
                                {% for tag in post.tags|slice(0, 3) %}
                                <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">{{ tag.name }}</span>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        <!-- Pagination -->
        {% if totalPages > 1 %}
        <nav aria-label="Pagination des articles" class="flex justify-center">
            <ul class="flex items-center gap-1">
                {% if currentPage > 1 %}
                <li>
                    <a class="inline-flex items-center justify-center w-9 h-9 rounded-md border border-border hover:bg-accent transition-colors no-underline" href="{{ path('app_blog_index', {category: currentCategory, page: currentPage - 1}) }}">
                        <i data-lucide="chevron-left" width="16" height="16"></i>
                    </a>
                </li>
                {% else %}
                <li>
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-md border border-border opacity-40 cursor-not-allowed">
                        <i data-lucide="chevron-left" width="16" height="16"></i>
                    </span>
                </li>
                {% endif %}

                {% for page in 1..totalPages %}
                {% if page == currentPage %}
                <li>
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-md bg-primary text-primary-foreground font-medium">{{ page }}</span>
                </li>
                {% elseif page == 1 or page == totalPages or (page >= currentPage - 2 and page <= currentPage + 2) %}
                <li>
                    <a class="inline-flex items-center justify-center w-9 h-9 rounded-md border border-border hover:bg-accent transition-colors no-underline" href="{{ path('app_blog_index', {category: currentCategory, page: page}) }}">{{ page }}</a>
                </li>
                {% elseif page == currentPage - 3 or page == currentPage + 3 %}
                <li>
                    <span class="inline-flex items-center justify-center w-9 h-9 text-muted-foreground">…</span>
                </li>
                {% endif %}
                {% endfor %}

                {% if currentPage < totalPages %}
                <li>
                    <a class="inline-flex items-center justify-center w-9 h-9 rounded-md border border-border hover:bg-accent transition-colors no-underline" href="{{ path('app_blog_index', {category: currentCategory, page: currentPage + 1}) }}">
                        <i data-lucide="chevron-right" width="16" height="16"></i>
                    </a>
                </li>
                {% else %}
                <li>
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-md border border-border opacity-40 cursor-not-allowed">
                        <i data-lucide="chevron-right" width="16" height="16"></i>
                    </span>
                </li>
                {% endif %}
            </ul>
        </nav>
        {% endif %}
        {% else %}
        <!-- Message si aucun article -->
        <div class="flex justify-center py-12">
            <div class="rounded-lg bg-card shadow-sm max-w-lg w-full">
                <div class="p-12 text-center">
                    <i data-lucide="file-text" width="64" height="64" class="text-muted-foreground mb-4 mx-auto"></i>
                    <h4 class="font-semibold text-muted-foreground text-lg mb-2">Aucun article trouvé</h4>
                    <p class="text-muted-foreground">Aucun article publié pour le moment. Revenez bientôt !</p>
                    {% if currentCategory %}
                    <a href="{{ path('app_blog_index') }}" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline mt-4">
                        Voir tous les articles
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</section>

<!-- Most Viewed Articles -->
{% if mostViewedPosts|length > 0 %}
<section class="py-12 bg-muted">
    <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-2xl font-bold mb-6">Articles les plus lus{% if currentCategoryLabel %} <span class="text-muted-foreground text-xl font-normal">— {{ currentCategoryLabel }}</span>{% endif %}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {% for post in mostViewedPosts %}
            <div data-aos="fade-up" data-aos-delay="{{ loop.index0 * 100 }}">
                <div class="rounded-lg bg-card shadow-sm overflow-hidden">
                    {% if post.image %}
                    <img src="{{ (post.image starts with 'http') ? post.image : asset(post.image) }}" class="w-full h-48 object-cover" alt="{{ post.title }}" loading="lazy" width="400" height="225">
                    {% endif %}
                    <div class="p-6">
                        <div class="flex items-start mb-4">
                            {% if post.category %}
                            <span class="inline-flex items-center rounded-full bg-primary/10 text-primary px-2.5 py-0.5 text-xs font-semibold mr-2">{{ post.category.name }}</span>
                            {% endif %}
                            <span class="text-sm text-muted-foreground ml-auto">
                                <i data-lucide="eye" width="12" height="12" class="mr-1 inline"></i>{{ post.views }} vues
                            </span>
                        </div>
                        <h3 class="font-bold mb-2">
                            <a href="{{ path('app_blog_article', {category: post.category.slug, slug: post.slug}) }}"
                               class="text-foreground no-underline hover:text-primary transition-colors">
                                {{ post.title }}
                            </a>
                        </h3>
                        <p class="text-muted-foreground text-sm mb-4">{{ post.excerpt|striptags|slice(0, 120) }}...</p>
                        <a href="{{ path('app_blog_article', {category: post.category.slug, slug: post.slug}) }}"
                           class="inline-flex items-center gap-1 border border-primary text-primary px-3 py-1.5 text-sm rounded-md hover:bg-primary/5 transition-colors no-underline">
                            Lire la suite
                            <i data-lucide="arrow-right" width="14" height="14" class="ml-1"></i>
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<!-- Newsletter Section -->
<section class="py-12 bg-muted">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex justify-center">
            <div class="w-full lg:max-w-2xl" data-aos="fade-up">
                {% include 'components/newsletter-form.html.twig' %}
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block stylesheets %}
<!-- Font Awesome -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
});
</script>
{% endblock %}
