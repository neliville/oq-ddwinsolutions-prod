{% extends 'base.html.twig' %}

{% set show_sidebar_toggle = app.user is not null %}
{% set show_public_navbar = false %}

{% block body_attributes %}{% if app.user %} class="layout-dashboard"{% endif %}{% endblock %}

{% block body %}
{% if app.user %}
    <header>
        {% include 'components/dashboard_topbar.html.twig' with { show_sidebar_toggle: show_sidebar_toggle } %}
    </header>
{% endif %}
<div class="flex">
    <!-- Overlay pour mobile quand sidebar ouverte -->
    {% if app.user %}
    <div class="sidebar-overlay" id="sidebarOverlay" style="display: none;"></div>
    {% endif %}

    <!-- Sidebar Dashboard pour utilisateurs connectés -->
    {% if app.user %}
        <aside aria-label="Menu d'administration">
            {% include 'components/admin-sidebar.html.twig' %}
        </aside>
    {% endif %}

    {# Colonne de contenu : pas de second <main> (déjà enveloppé par base.html.twig). #}
    <div class="main-content grow{% if app.user %} dashboard-layout{% endif %}" tabindex="-1" {% if app.user %}style="transition: margin-left 0.3s;"{% endif %} role="region" aria-label="Contenu de la page">
        {% block content %}{% endblock %}
    </div>
</div>
{% endblock %}
