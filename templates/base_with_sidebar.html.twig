{% extends 'base.html.twig' %}

{% set show_sidebar_toggle = app.user is not null %}
{% set show_public_navbar = false %}

{% block body_attributes %}{% if app.user %} class="layout-dashboard"{% endif %}{% endblock %}

{% block body %}
{% if app.user %}
    {% include 'components/dashboard_topbar.html.twig' with { show_sidebar_toggle: show_sidebar_toggle } %}
{% endif %}
<div class="flex{% if app.user %} min-h-screen{% endif %} w-full max-w-full overflow-x-hidden">
    <!-- Overlay pour mobile quand sidebar ouverte -->
    {% if app.user %}
    <div class="sidebar-overlay" id="sidebarOverlay" style="display: none;" aria-hidden="true"></div>
    {% endif %}

    <!-- Sidebar utilisateur : components/user_dashboard_sidebar.html.twig -->
    {% if app.user %}
        {% include 'components/user_dashboard_sidebar.html.twig' %}
    {% endif %}

    {# Colonne de contenu : pas de second <main> (déjà enveloppé par base.html.twig). #}
    <div class="main-content grow min-w-0 w-full max-w-full{% if app.user %} dashboard-layout{% endif %}" {% if app.user %}data-sidebar-main-content style="transition: margin-left 0.3s;"{% endif %} tabindex="-1" role="region" aria-label="Contenu de la page">
        {% block content %}{% endblock %}
    </div>
</div>
{% endblock %}
