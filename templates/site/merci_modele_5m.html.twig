{% extends 'base.html.twig' %}

{% block title %}Merci — Modèle 5M | Outils-Qualité{% endblock %}

{% block meta_description %}Merci pour votre intérêt. Un email contenant le lien de téléchargement du modèle 5M vous a été envoyé.{% endblock %}

{% block body %}
<section class="py-12 bg-gradient-primary text-black" style="margin-top: 76px;" role="banner" aria-labelledby="merci-modele-title">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex justify-center">
            <div class="w-full max-w-2xl text-center">
                <h1 id="merci-modele-title" class="text-4xl font-bold mb-4">Merci pour votre intérêt</h1>
                <p class="text-lg mb-4">
                    Un email contenant le lien de téléchargement du modèle 5M (Ishikawa) a été envoyé à votre adresse.
                </p>
                <p class="mb-4">
                    Pensez à vérifier votre boîte de réception et, si besoin, votre dossier <strong>courrier indésirable</strong> ou <strong>spam</strong>. Le message peut parfois y atterrir.
                </p>
                <a href="{{ path('app_ishikawa_index') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline">Découvrir le diagramme Ishikawa</a>
            </div>
        </div>
    </div>
</section>

<section class="py-12" aria-label="Informations complémentaires">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex justify-center">
            <div class="w-full max-w-xl text-center">
                <p class="text-muted-foreground mb-0 text-sm leading-relaxed">
                    Vous n’avez pas reçu l’email ? Vérifiez l’adresse saisie ou réessayez dans quelques minutes.
                </p>
            </div>
        </div>
    </div>
</section>
{% endblock %}
