{% extends (app.user ? 'base_with_sidebar.html.twig' : 'base.html.twig') %}

{% block title %}Ressources QSE Gratuites — Modèles, Guides et Outils | Outils-Qualité{% endblock %}

{% block meta_description %}Téléchargez gratuitement nos ressources QSE : modèle 5M Ishikawa, guides méthode, checklists. Outils pratiques pour vos démarches qualité.{% endblock %}

{% block content %}
<main class="ressources-page">
    <div class="container py-5">
        {% if not app.user %}
        <div class="mb-2">
            <nav aria-label="Fil d'Ariane">
                <ol class="breadcrumb small">
                    <li class="breadcrumb-item"><a href="{{ path('app_home_index') }}" class="text-decoration-none text-muted">Accueil</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Ressources</li>
                </ol>
            </nav>
        </div>
        {% endif %}

        {# En-tête #}
        <div class="text-center mb-5" data-aos="fade-up">
            <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-3 p-3 mb-3">
                <i data-lucide="package-open" width="30" height="30"></i>
            </div>
            <h1 class="h2 fw-bold mb-2">Ressources QSE gratuites</h1>
            <p class="lead text-muted col-lg-7 mx-auto">
                Modèles prêts à l'emploi, guides pratiques et checklists pour vos démarches qualité, sécurité et environnement.
            </p>
        </div>

        {# Grille de ressources #}
        <div class="row g-4">

            {# — Disponible : Modèle 5M #}
            <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="0">
                <div class="card h-100 border shadow-sm resource-card resource-card--available">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="resource-card__icon bg-primary bg-opacity-10 text-primary rounded-3 p-3 flex-shrink-0">
                                <i data-lucide="git-branch" width="22" height="22"></i>
                            </div>
                            <div>
                                <span class="badge bg-success-subtle text-success fw-semibold small">Disponible</span>
                                <h2 class="h6 fw-bold mb-0 mt-1">Modèle 5M (Ishikawa)</h2>
                            </div>
                        </div>
                        <p class="text-muted small flex-grow-1">
                            Tableur Excel structuré pour vos analyses Ishikawa : catégories 5M pré-remplies, mise en forme professionnelle, prêt pour vos revues qualité.
                        </p>
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            <span class="badge bg-light text-muted border">.xlsx</span>
                            <span class="badge bg-light text-muted border">ISO 9001</span>
                            <span class="badge bg-light text-muted border">Gratuit</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 px-4 pb-4">
                        <a href="{{ path('app_telechargement_modele_5m') }}" class="btn btn-primary w-100">
                            <i data-lucide="download" width="15" height="15" class="me-1"></i>
                            Télécharger gratuitement
                        </a>
                    </div>
                </div>
            </div>

            {# — Bientôt : Guide QQOQCCP #}
            <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="80">
                <div class="card h-100 border shadow-sm resource-card resource-card--soon">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="resource-card__icon bg-secondary bg-opacity-10 text-secondary rounded-3 p-3 flex-shrink-0">
                                <i data-lucide="list-checks" width="22" height="22"></i>
                            </div>
                            <div>
                                <span class="badge bg-warning-subtle text-warning fw-semibold small">Bientôt</span>
                                <h2 class="h6 fw-bold mb-0 mt-1">Guide QQOQCCP (5W2H)</h2>
                            </div>
                        </div>
                        <p class="text-muted small flex-grow-1">
                            Guide pratique avec exemples remplis pour cadrer un projet ou analyser un problème complexe avec la méthode 5W2H.
                        </p>
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            <span class="badge bg-light text-muted border">.pdf</span>
                            <span class="badge bg-light text-muted border">Exemples inclus</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-secondary w-100" disabled>
                            <i data-lucide="clock" width="15" height="15" class="me-1"></i>
                            Bientôt disponible
                        </button>
                    </div>
                </div>
            </div>

            {# — Bientôt : Checklist AMDEC #}
            <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="160">
                <div class="card h-100 border shadow-sm resource-card resource-card--soon">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="resource-card__icon bg-danger bg-opacity-10 text-danger rounded-3 p-3 flex-shrink-0">
                                <i data-lucide="alert-triangle" width="22" height="22"></i>
                            </div>
                            <div>
                                <span class="badge bg-warning-subtle text-warning fw-semibold small">Bientôt</span>
                                <h2 class="h6 fw-bold mb-0 mt-1">Checklist AMDEC</h2>
                            </div>
                        </div>
                        <p class="text-muted small flex-grow-1">
                            Modèle Excel d'analyse AMDEC avec calcul automatique NPR, seuils de criticité configurables et plan d'actions intégré.
                        </p>
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            <span class="badge bg-light text-muted border">.xlsx</span>
                            <span class="badge bg-light text-muted border">NPR auto</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-secondary w-100" disabled>
                            <i data-lucide="clock" width="15" height="15" class="me-1"></i>
                            Bientôt disponible
                        </button>
                    </div>
                </div>
            </div>

            {# — Bientôt : Guide 8D #}
            <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="240">
                <div class="card h-100 border shadow-sm resource-card resource-card--soon">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="resource-card__icon bg-warning bg-opacity-10 text-warning rounded-3 p-3 flex-shrink-0">
                                <i data-lucide="layers" width="22" height="22"></i>
                            </div>
                            <div>
                                <span class="badge bg-warning-subtle text-warning fw-semibold small">Bientôt</span>
                                <h2 class="h6 fw-bold mb-0 mt-1">Rapport 8D</h2>
                            </div>
                        </div>
                        <p class="text-muted small flex-grow-1">
                            Modèle de rapport 8D (Eight Disciplines) au format Word, prêt à remplir pour vos clients et fournisseurs.
                        </p>
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            <span class="badge bg-light text-muted border">.docx</span>
                            <span class="badge bg-light text-muted border">Client-ready</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-secondary w-100" disabled>
                            <i data-lucide="clock" width="15" height="15" class="me-1"></i>
                            Bientôt disponible
                        </button>
                    </div>
                </div>
            </div>

            {# — Bientôt : Tableau de bord Pareto #}
            <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="320">
                <div class="card h-100 border shadow-sm resource-card resource-card--soon">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="resource-card__icon bg-info bg-opacity-10 text-info rounded-3 p-3 flex-shrink-0">
                                <i data-lucide="bar-chart-2" width="22" height="22"></i>
                            </div>
                            <div>
                                <span class="badge bg-warning-subtle text-warning fw-semibold small">Bientôt</span>
                                <h2 class="h6 fw-bold mb-0 mt-1">Tableau Pareto Excel</h2>
                            </div>
                        </div>
                        <p class="text-muted small flex-grow-1">
                            Modèle Excel avec diagramme Pareto dynamique, courbe cumulative et mise en évidence automatique des 80 %.
                        </p>
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            <span class="badge bg-light text-muted border">.xlsx</span>
                            <span class="badge bg-light text-muted border">Graphique auto</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-secondary w-100" disabled>
                            <i data-lucide="clock" width="15" height="15" class="me-1"></i>
                            Bientôt disponible
                        </button>
                    </div>
                </div>
            </div>

            {# — CTA Newsletter : être notifié #}
            <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="400">
                <div class="card h-100 border-primary border-opacity-25 shadow-sm bg-primary bg-opacity-5">
                    <div class="card-body p-4 d-flex flex-column justify-content-center text-center">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-3 p-3 mx-auto mb-3">
                            <i data-lucide="bell" width="22" height="22"></i>
                        </div>
                        <h2 class="h6 fw-bold mb-2">Être notifié en avant-première</h2>
                        <p class="text-muted small mb-4">
                            Recevez les nouvelles ressources dès leur sortie + nos astuces QSE par email.
                        </p>
                        {% include 'components/newsletter-form.html.twig' with { compact: true } %}
                    </div>
                </div>
            </div>

        </div>{# /row #}
    </div>
</main>
{% endblock %}
