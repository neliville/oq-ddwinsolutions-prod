{% extends (app.user ? 'base_with_sidebar.html.twig' : 'base.html.twig') %}

{% block title %}Ressources QSE Gratuites — Modèles, Guides et Outils | Outils-Qualité{% endblock %}

{% block meta_description %}Téléchargez gratuitement nos ressources QSE : modèle 5M Ishikawa, guides méthode, checklists. Outils pratiques pour vos démarches qualité.{% endblock %}

{% block content %}
<main class="ressources-page">
    <div class="max-w-7xl mx-auto px-4 py-12">
        {% if not app.user %}
        <div class="mb-2">
            <nav aria-label="Fil d'Ariane">
                <ol class="flex flex-wrap items-center gap-1 text-sm text-muted-foreground list-none p-0 m-0">
                    <li><a href="{{ path('app_home_index') }}" class="no-underline text-muted-foreground hover:text-foreground transition-colors">Accueil</a></li>
                    <li class="mx-1 opacity-50">/</li>
                    <li class="text-foreground" aria-current="page">Ressources</li>
                </ol>
            </nav>
        </div>
        {% endif %}

        {# En-tête #}
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center bg-primary/10 text-primary rounded-xl p-3 mb-3">
                <i data-lucide="package-open" width="30" height="30"></i>
            </div>
            <h1 class="text-2xl font-bold mb-2">Ressources QSE gratuites</h1>
            <p class="text-lg text-muted-foreground max-w-xl mx-auto">
                Modèles prêts à l'emploi, guides pratiques et checklists pour vos démarches qualité, sécurité et environnement.
            </p>
        </div>

        {# Grille de ressources #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            {# — Disponible : Modèle 5M #}
            <div>
                <div class="rounded-lg border bg-card shadow-sm h-full flex flex-col resource-card resource-card--available">
                    <div class="p-6 flex flex-col grow">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="resource-card__icon bg-primary/10 text-primary rounded-xl p-3 shrink-0">
                                <i data-lucide="git-branch" width="22" height="22"></i>
                            </div>
                            <div>
                                <span class="inline-flex items-center rounded-full bg-green-100 text-green-700 px-2 py-0.5 text-xs font-semibold">Disponible</span>
                                <h2 class="text-sm font-bold mb-0 mt-1">Modèle 5M (Ishikawa)</h2>
                            </div>
                        </div>
                        <p class="text-muted-foreground text-sm grow">
                            Tableur Excel structuré pour vos analyses Ishikawa : catégories 5M pré-remplies, mise en forme professionnelle, prêt pour vos revues qualité.
                        </p>
                        <div class="mt-3 flex gap-2 flex-wrap">
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">.xlsx</span>
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">ISO 9001</span>
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">Gratuit</span>
                        </div>
                    </div>
                    <div class="px-6 pb-6 pt-0">
                        <a href="{{ path('app_telechargement_modele_5m') }}" class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-md font-medium hover:opacity-90 transition-opacity no-underline w-full">
                            <i data-lucide="download" width="15" height="15" class="mr-1"></i>
                            Télécharger gratuitement
                        </a>
                    </div>
                </div>
            </div>

            {# — Bientôt : Guide QQOQCCP #}
            <div>
                <div class="rounded-lg border bg-card shadow-sm h-full flex flex-col resource-card resource-card--soon">
                    <div class="p-6 flex flex-col grow">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="resource-card__icon bg-secondary/10 text-secondary-foreground rounded-xl p-3 shrink-0">
                                <i data-lucide="list-checks" width="22" height="22"></i>
                            </div>
                            <div>
                                <span class="inline-flex items-center rounded-full bg-yellow-100 text-yellow-700 px-2 py-0.5 text-xs font-semibold">Bientôt</span>
                                <h2 class="text-sm font-bold mb-0 mt-1">Guide QQOQCCP (5W2H)</h2>
                            </div>
                        </div>
                        <p class="text-muted-foreground text-sm grow">
                            Guide pratique avec exemples remplis pour cadrer un projet ou analyser un problème complexe avec la méthode 5W2H.
                        </p>
                        <div class="mt-3 flex gap-2 flex-wrap">
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">.pdf</span>
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">Exemples inclus</span>
                        </div>
                    </div>
                    <div class="px-6 pb-6 pt-0">
                        <button type="button" class="inline-flex items-center justify-center gap-2 border border-border text-muted-foreground px-4 py-2 rounded-md font-medium opacity-60 cursor-not-allowed w-full" disabled>
                            <i data-lucide="clock" width="15" height="15" class="mr-1"></i>
                            Bientôt disponible
                        </button>
                    </div>
                </div>
            </div>

            {# — Bientôt : Checklist AMDEC #}
            <div>
                <div class="rounded-lg border bg-card shadow-sm h-full flex flex-col resource-card resource-card--soon">
                    <div class="p-6 flex flex-col grow">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="resource-card__icon bg-destructive/10 text-destructive rounded-xl p-3 shrink-0">
                                <i data-lucide="alert-triangle" width="22" height="22"></i>
                            </div>
                            <div>
                                <span class="inline-flex items-center rounded-full bg-yellow-100 text-yellow-700 px-2 py-0.5 text-xs font-semibold">Bientôt</span>
                                <h2 class="text-sm font-bold mb-0 mt-1">Checklist AMDEC</h2>
                            </div>
                        </div>
                        <p class="text-muted-foreground text-sm grow">
                            Modèle Excel d'analyse AMDEC avec calcul automatique NPR, seuils de criticité configurables et plan d'actions intégré.
                        </p>
                        <div class="mt-3 flex gap-2 flex-wrap">
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">.xlsx</span>
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">NPR auto</span>
                        </div>
                    </div>
                    <div class="px-6 pb-6 pt-0">
                        <button type="button" class="inline-flex items-center justify-center gap-2 border border-border text-muted-foreground px-4 py-2 rounded-md font-medium opacity-60 cursor-not-allowed w-full" disabled>
                            <i data-lucide="clock" width="15" height="15" class="mr-1"></i>
                            Bientôt disponible
                        </button>
                    </div>
                </div>
            </div>

            {# — Bientôt : Guide 8D #}
            <div>
                <div class="rounded-lg border bg-card shadow-sm h-full flex flex-col resource-card resource-card--soon">
                    <div class="p-6 flex flex-col grow">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="resource-card__icon bg-yellow-500/10 text-yellow-600 rounded-xl p-3 shrink-0">
                                <i data-lucide="layers" width="22" height="22"></i>
                            </div>
                            <div>
                                <span class="inline-flex items-center rounded-full bg-yellow-100 text-yellow-700 px-2 py-0.5 text-xs font-semibold">Bientôt</span>
                                <h2 class="text-sm font-bold mb-0 mt-1">Rapport 8D</h2>
                            </div>
                        </div>
                        <p class="text-muted-foreground text-sm grow">
                            Modèle de rapport 8D (Eight Disciplines) au format Word, prêt à remplir pour vos clients et fournisseurs.
                        </p>
                        <div class="mt-3 flex gap-2 flex-wrap">
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">.docx</span>
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">Client-ready</span>
                        </div>
                    </div>
                    <div class="px-6 pb-6 pt-0">
                        <button type="button" class="inline-flex items-center justify-center gap-2 border border-border text-muted-foreground px-4 py-2 rounded-md font-medium opacity-60 cursor-not-allowed w-full" disabled>
                            <i data-lucide="clock" width="15" height="15" class="mr-1"></i>
                            Bientôt disponible
                        </button>
                    </div>
                </div>
            </div>

            {# — Bientôt : Tableau de bord Pareto #}
            <div>
                <div class="rounded-lg border bg-card shadow-sm h-full flex flex-col resource-card resource-card--soon">
                    <div class="p-6 flex flex-col grow">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="resource-card__icon bg-sky-500/10 text-sky-600 rounded-xl p-3 shrink-0">
                                <i data-lucide="bar-chart-2" width="22" height="22"></i>
                            </div>
                            <div>
                                <span class="inline-flex items-center rounded-full bg-yellow-100 text-yellow-700 px-2 py-0.5 text-xs font-semibold">Bientôt</span>
                                <h2 class="text-sm font-bold mb-0 mt-1">Tableau Pareto Excel</h2>
                            </div>
                        </div>
                        <p class="text-muted-foreground text-sm grow">
                            Modèle Excel avec diagramme Pareto dynamique, courbe cumulative et mise en évidence automatique des 80 %.
                        </p>
                        <div class="mt-3 flex gap-2 flex-wrap">
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">.xlsx</span>
                            <span class="inline-flex items-center rounded-md bg-muted text-muted-foreground px-2 py-0.5 text-xs">Graphique auto</span>
                        </div>
                    </div>
                    <div class="px-6 pb-6 pt-0">
                        <button type="button" class="inline-flex items-center justify-center gap-2 border border-border text-muted-foreground px-4 py-2 rounded-md font-medium opacity-60 cursor-not-allowed w-full" disabled>
                            <i data-lucide="clock" width="15" height="15" class="mr-1"></i>
                            Bientôt disponible
                        </button>
                    </div>
                </div>
            </div>

            {# — CTA Newsletter : être notifié #}
            <div>
                <div class="rounded-lg border border-primary/25 bg-primary/5 shadow-sm h-full flex flex-col">
                    <div class="p-6 flex flex-col justify-center items-center text-center grow">
                        <div class="inline-flex items-center justify-center bg-primary/10 text-primary rounded-xl p-3 mx-auto mb-3">
                            <i data-lucide="bell" width="22" height="22"></i>
                        </div>
                        <h2 class="text-sm font-bold mb-2">Être notifié en avant-première</h2>
                        <p class="text-muted-foreground text-sm mb-4">
                            Recevez les nouvelles ressources dès leur sortie + nos astuces QSE par email.
                        </p>
                        {% include 'components/newsletter-form.html.twig' with { compact: true } %}
                    </div>
                </div>
            </div>

        </div>{# /grid #}
    </div>
</main>
{% endblock %}
