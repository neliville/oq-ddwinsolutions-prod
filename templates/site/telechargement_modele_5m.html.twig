{# Téléchargement modèle 5M : formulaire Mautic (embed). Ressource gérée dans Mautic — docs/DOWNLOAD_MAUTIC.md #}
{% extends 'base.html.twig' %}

{% block title %}Télécharger le modèle 5M — Diagramme Ishikawa | Outils-Qualité{% endblock %}

{% block meta_description %}Téléchargez gratuitement notre modèle prêt à l'emploi pour l'analyse 5M (Ishikawa) : .xlsx et PDF, avec astuces d'analyse.{% endblock %}

{% block body %}
<section class="py-5 bg-gradient-primary text-black" style="margin-top: 76px;" role="banner" aria-labelledby="telechargement-modele-title">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center" data-aos="fade-up">
                <h1 id="telechargement-modele-title" class="display-5 fw-bold mb-4">Téléchargez le modèle 5M</h1>
                <p class="lead mb-4">
                    Modèle prêt à l'emploi pour vos analyses Ishikawa (5M) : .xlsx / PDF et astuces d'analyse.
                </p>
            </div>
        </div>
    </div>
</section>

<main id="main-content" class="container py-5" role="main">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <p class="text-muted mb-3">
                        Merci de renseigner vos coordonnées pour accéder au téléchargement.
                    </p>

                    <div class="alert alert-info small mb-4" role="status">
                        <strong class="d-block mb-1">Après envoi du formulaire</strong>
                        Vous recevrez un <strong>email contenant le lien pour télécharger le modèle</strong> (.xlsx, PDF) et les astuces d’analyse.
                        Si rien n’apparaît dans votre boîte de réception sous quelques minutes, <strong>pensez à vérifier vos courriers indésirables (spam)</strong>.
                    </div>

                    {% if mauticFormScriptUrl %}
                        <div id="mautic-form-container" aria-label="Formulaire de téléchargement" data-ressource-id="{{ ressourceId|default('ishikawa-5m-template')|e('html_attr') }}">
                            <script type="text/javascript" src="{{ mauticFormScriptUrl }}"></script>
                            <script type="text/javascript">
                            (function() {
                                var container = document.getElementById('mautic-form-container');
                                if (!container) return;
                                var ressourceId = container.getAttribute('data-ressource-id');
                                if (!ressourceId) return;
                                function injectRessourceId() {
                                    try {
                                        if (!container || !container.isConnected) return;
                                        var form = container.querySelector('form');
                                        if (!form || !form.isConnected) return;
                                        if (form.querySelector('input[name="mauticform[ressource_id]"]')) return;
                                        var input = document.createElement('input');
                                        input.type = 'hidden';
                                        input.name = 'mauticform[ressource_id]';
                                        input.value = ressourceId;
                                        form.appendChild(input);
                                    } catch (e) { /* ne pas casser le formulaire Mautic */ }
                                }
                                [500, 1500, 3000].forEach(function(ms) {
                                    setTimeout(injectRessourceId, ms);
                                });
                            })();
                            </script>
                        </div>
                        <p class="small text-muted mt-3 mb-0">
                            Le lien de téléchargement n’est pas affiché sur cette page : il est envoyé uniquement par email pour des raisons de suivi et de qualité de service.
                        </p>
                    {% else %}
                        <div class="alert alert-warning" role="alert">
                            Le formulaire de téléchargement n'est pas configuré. Contactez l'administrateur.
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</main>
{% endblock %}
