{# Téléchargement modèle 5M : formulaire Mautic (embed). Ressource gérée dans Mautic — docs/DOWNLOAD_MAUTIC.md #}
{% extends 'base.html.twig' %}

{% block title %}Télécharger le modèle 5M — Diagramme Ishikawa | Outils-Qualité{% endblock %}

{% block meta_description %}Téléchargez gratuitement notre modèle prêt à l'emploi pour l'analyse 5M (Ishikawa) : .xlsx et PDF, avec astuces d'analyse.{% endblock %}

{% block body %}
<section class="py-12 bg-gradient-primary text-black" style="margin-top: 76px;" role="banner" aria-labelledby="telechargement-modele-title">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex justify-center">
            <div class="w-full max-w-2xl text-center" data-aos="fade-up">
                <h1 id="telechargement-modele-title" class="text-4xl font-bold mb-3">Téléchargez le modèle 5M</h1>
                <p class="text-lg mb-0 opacity-75">
                    .xlsx, PDF et astuces — pour vos analyses Ishikawa (5M).
                </p>
            </div>
        </div>
    </div>
</section>

<main id="main-content" class="max-w-7xl mx-auto px-4 py-12" role="main">
    <div class="flex justify-center px-2">
        <div class="w-full max-w-lg">
            <div class="download-modele-5m">
                <div class="rounded-lg bg-white download-modele-5m__card">
                    <div class="p-6 md:p-10">
                        <h2 class="download-modele-5m__title text-xl mb-3">Vos coordonnées</h2>
                        <p class="download-modele-5m__lead mb-4">
                            On vous envoie le <strong>lien de téléchargement par email</strong> dès que vous cliquez sur Envoyer. Si le message met quelques minutes à arriver, un petit tour dans les <strong>indésirables</strong> suffit souvent.
                        </p>

                        {% if mauticFormScriptUrl %}
                            <div id="mautic-form-container" aria-label="Formulaire de téléchargement" data-ressource-id="{{ ressourceId|default('ishikawa-5m-template')|e('html_attr') }}">
                                <script type="text/javascript" src="{{ mauticFormScriptUrl }}"></script>
                                <script type="text/javascript">
                                (function() {
                                    var container = document.getElementById('mautic-form-container');
                                    if (!container) return;
                                    var ressourceId = container.getAttribute('data-ressource-id');
                                    if (!ressourceId) return;
                                    function injectRessourceId() {
                                        try {
                                            if (!container || !container.isConnected) return;
                                            var form = container.querySelector('form');
                                            if (!form || !form.isConnected) return;
                                            if (form.querySelector('input[name="mauticform[ressource_id]"]')) return;
                                            var input = document.createElement('input');
                                            input.type = 'hidden';
                                            input.name = 'mauticform[ressource_id]';
                                            input.value = ressourceId;
                                            form.appendChild(input);
                                        } catch (e) { /* ne pas casser le formulaire Mautic */ }
                                    }
                                    [500, 1500, 3000].forEach(function(ms) {
                                        setTimeout(injectRessourceId, ms);
                                    });
                                })();
                                </script>
                            </div>
                        {% else %}
                            <div class="flex items-start gap-3 rounded-lg border border-yellow-200 bg-yellow-50 text-yellow-800 px-4 py-3" role="alert">
                                <i class="fas fa-exclamation-triangle mr-2 shrink-0 mt-0.5"></i>
                                <div>Le formulaire de téléchargement n’est pas configuré. Contactez l’administrateur.</div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
{% endblock %}
