{% extends (app.user ? 'base_with_sidebar.html.twig' : 'base.html.twig') %}

{% block head %}
    {{ parent() }}
    {% include 'components/turbo_newsletter_no_cache_meta.html.twig' %}
{% endblock %}

{% block title %}Analyse AMDEC en Ligne — Calcul NPR et Priorisation Gratuit | Outils-Qualité{% endblock %}

{% block meta_description %}Réalisez votre analyse AMDEC en ligne : identification des modes de défaillance, calcul automatique de l'indice NPR, recommandations de priorisation. Gratuit.{% endblock %}

{% block meta_keywords %}amdec, fmeca, analyse de risques, npr, criticité, modes de défaillance, outil qualité{% endblock %}

{% block og_title %}Analyse AMDEC - Outil Gratuit | OUTILS-QUALITÉ{% endblock %}

{% block og_description %}Identifiez les modes de défaillance, calculez l'indice NPR et priorisez vos actions grâce à l'outil AMDEC en ligne.{% endblock %}

{% block schema_type %}{{ parent() }},SoftwareApplication{% endblock %}

{% block schema_data %}
{
    "name": "Outil AMDEC",
    "description": "Analyse FMECA complète avec calcul d'indice NPR et recommandations.",
    "url": "{{ absolute_url(path('app_amdec_index')) }}",
    "screenshot": "{{ app.request.schemeAndHttpHost ~ asset('img/og-default.jpg') }}"
}
{% endblock %}

{% block schema_webapp_json %}
{"@context":"https://schema.org","@type":"WebApplication","name":"Analyse AMDEC en ligne","url":{{ absolute_url(path('app_amdec_index'))|json_encode|raw }},"applicationCategory":"BusinessApplication","operatingSystem":"Web","offers":{"@type":"Offer","price":"0","priceCurrency":"EUR"},"description":"Réalisez votre analyse AMDEC en ligne : identification des modes de défaillance, calcul automatique de l'indice NPR, recommandations de priorisation. Gratuit.","featureList":["Modes de défaillance","Calcul NPR automatique","Priorisation des actions","Gratuit"]}
{% endblock %}

{% block schema_breadcrumb_json %}
{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Accueil","item":{{ absolute_url(path('app_home_index'))|json_encode|raw }}},{"@type":"ListItem","position":2,"name":"Outils","item":{{ absolute_url(path('app_outils_index'))|json_encode|raw }}},{"@type":"ListItem","position":3,"name":"Analyse AMDEC","item":{{ absolute_url(path('app_amdec_index'))|json_encode|raw }}}]}
{% endblock %}

{% block content %}
<main class="amdec-page{% if not app.user %} amdec-page--guest{% endif %}">
    <div class="container">
        {% include 'components/tool_breadcrumb.html.twig' with { tool_name: 'Analyse AMDEC' } %}
        {% include 'components/tool_page_header.html.twig' with {
            tool_icon: 'alert-triangle',
            tool_name: 'Analyse AMDEC',
            tool_tagline: 'Identifiez les modes de défaillance et calculez l\'indice NPR',
            tool_color: 'danger',
            tool_seo_route: 'app_tool_seo_amdec'
        } %}
        <input type="hidden" id="amdecAnalysisId" value="{{ analysisId ?? '' }}">

        <div class="page-header tool-page-header--compact" data-aos="fade-up">
            <h1 class="page-title">Analyse AMDEC</h1>
            <p class="lead">Identifiez les modes de défaillance, mesurez leur criticité (NPR) et priorisez vos actions pour sécuriser vos process.</p>
            {% include 'components/tool_meta_hints.html.twig' with {
                tool_slug: 'amdec',
                hint_id_prefix: 'amdec',
                meta_intro: 'Survolez ou mettez le focus sur une pastille pour un court descriptif. L’aide détaillée est dans l’encadré juste en dessous ; les grilles de notation et la saisie suivent.',
                tag_hints: {
                    'Risques': 'Anticiper les défaillances avant qu’elles n’impactent le client ou la conformité.',
                    'Prévention': 'Prioriser les actions préventives sur les modes les plus critiques.',
                    'Criticité': 'Le NPR synthétise gravité, occurrence et détection.',
                    'Qualité': 'Appui pour dossiers qualité, revues et exigences ISO / IATF.',
                },
            } %}
        </div>

        {% if not app.user %}
        <div class="flex items-center justify-center gap-2 rounded-lg border border-yellow-200 bg-yellow-50 text-yellow-800 px-4 py-3 mb-3" role="alert" aria-live="polite" data-aos="fade-up" data-aos-delay="40">
            <i data-lucide="info" width="18" height="18" class="shrink-0" aria-hidden="true"></i>
            <span><strong>Vous n'êtes pas connecté.</strong>
            <a href="{{ path('app_login') }}" class="font-semibold underline text-yellow-900">Connectez-vous</a> pour sauvegarder vos analyses et les éditer ultérieurement.</span>
        </div>
        {% endif %}

        {% include 'components/tool_help/amdec_accordion.html.twig' %}

        <section class="amdec-controls tool-actions-bar flex flex-wrap items-center gap-2 mb-3" data-aos="fade-up" data-aos-delay="80" role="toolbar" aria-label="Actions disponibles">
            <button class="inline-flex items-center justify-center gap-1.5 bg-primary text-primary-foreground px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="newAmdecAnalysis()" aria-label="Initialiser une nouvelle analyse AMDEC">
                <i class="fas fa-sync-alt mr-2"></i>Nouvelle analyse
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 bg-sky-500 text-white px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="generateAmdecReport()" aria-label="Calculer l'analyse AMDEC">
                <i class="fas fa-chart-bar mr-2"></i>Générer l'analyse
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 bg-destructive text-destructive-foreground px-3 py-1.5 text-sm rounded-md hover:opacity-90 transition-opacity" type="button" onclick="resetAmdecForm()" aria-label="Réinitialiser le formulaire AMDEC">
                <i class="fas fa-eraser mr-2"></i>Réinitialiser
            </button>
            {% if app.user %}
            <button class="inline-flex items-center justify-center gap-1.5 bg-green-600 text-white px-3 py-1.5 text-sm rounded-md font-medium hover:opacity-90 transition-opacity" type="button" onclick="saveAmdec()" aria-label="Sauvegarder l'analyse AMDEC">
                <i class="fas fa-save mr-2"></i>Sauvegarder
            </button>
            <button class="inline-flex items-center justify-center gap-1.5 border border-border text-muted-foreground px-3 py-1.5 text-sm rounded-md hover:bg-accent transition-colors" type="button" onclick="openAmdecSaved()" aria-label="Charger une analyse AMDEC">
                <i class="fas fa-folder-open mr-2"></i>Mes analyses
            </button>
            {% include 'components/tool_export_dropdown.html.twig' with {
                button_id: 'amdecExportDropdown',
                items: [
                    { icon: 'fas fa-image', label: 'Exporter en PNG', onclick: 'exportAmdec("png")' },
                    { icon: 'fas fa-file-pdf', label: 'Exporter en PDF', onclick: 'exportAmdec("pdf")' },
                    { icon: 'fas fa-file-code', label: 'Exporter en JSON', onclick: 'exportAmdec("json")' },
                ],
            } %}
            {% else %}
            {% include 'components/tool_actions_login.html.twig' %}
            {% endif %}
        </section>

        <section class="amdec-scale" data-aos="fade-up" data-aos-delay="120">
            <article class="amdec-scale__card">
                <h3>📊 Gravité (G)</h3>
                <table>
                    <tr><td>1</td><td>Mineure – Aucun effet notable</td></tr>
                    <tr><td>2-3</td><td>Faible – Impact limité, gênes mineures</td></tr>
                    <tr><td>4-6</td><td>Modérée – Insatisfaction client, retouche</td></tr>
                    <tr><td>7-8</td><td>Élevée – Perte de fonction, arrêt de ligne</td></tr>
                    <tr><td>9-10</td><td>Critique – Danger, non-conformité légale</td></tr>
                </table>
            </article>
            <article class="amdec-scale__card">
                <h3>🔄 Occurrence (O)</h3>
                <table>
                    <tr><td>1</td><td>Quasi impossible (≤ 1 / 10 000)</td></tr>
                    <tr><td>2-3</td><td>Rare (≈ 1 / 1 000)</td></tr>
                    <tr><td>4-6</td><td>Occasionnelle (≈ 1 / 100)</td></tr>
                    <tr><td>7-8</td><td>Fréquente (≈ 1 / 10)</td></tr>
                    <tr><td>9-10</td><td>Très fréquente (&gt; 1 / 10)</td></tr>
                </table>
            </article>
            <article class="amdec-scale__card">
                <h3>🔍 Détection (D)</h3>
                <table>
                    <tr><td>1</td><td>Quasi certaine – Détection systématique</td></tr>
                    <tr><td>2-3</td><td>Élevée – Presque toujours détectée</td></tr>
                    <tr><td>4-6</td><td>Moyenne – Détection partielle</td></tr>
                    <tr><td>7-8</td><td>Faible – Détection difficile</td></tr>
                    <tr><td>9-10</td><td>Quasi impossible – Aucune détection</td></tr>
                </table>
            </article>
        </section>

        <section class="amdec-form" data-aos="fade-up" data-aos-delay="160" id="amdecForm">
            <h2>Saisie des modes de défaillance</h2>
            <div class="mb-4">
                <label class="form-label font-semibold" for="amdecSubject">Processus / produit analysé</label>
                <input type="text"
                       id="amdecSubject"
                       class="form-control"
                       placeholder="Ex : Ligne d'assemblage moteur"
                       oninput="updateAmdecSubject(this.value)">
            </div>
            <div class="amdec-entries" id="amdecEntries" aria-live="polite"></div>
            <button class="inline-flex items-center justify-center gap-1.5 border border-green-600 text-green-600 px-3 py-1.5 text-sm rounded-md hover:bg-green-50 transition-colors mt-3" type="button" onclick="addAmdecEntry()" aria-label="Ajouter un mode de défaillance">
                <i class="fas fa-plus mr-2"></i>Ajouter un mode de défaillance
            </button>
        </section>

        <section id="amdecResults" class="amdec-results" style="display: none;" data-aos="fade-up" data-aos-delay="200">
            <div class="amdec-summary">
                <div class="amdec-summary__card">
                    <h4>Modes de défaillance analysés</h4>
                    <div class="value" id="amdecTotalCount">0</div>
                </div>
                <div class="amdec-summary__card">
                    <h4>Risques critiques (NPR &gt; 125)</h4>
                    <div class="value" id="amdecCriticalCount" style="color:#ef4444;">0</div>
                </div>
                <div class="amdec-summary__card">
                    <h4>NPR moyen</h4>
                    <div class="value" id="amdecAverageNpr">0</div>
                </div>
            </div>

            <div class="amdec-table">
                <table>
                    <thead>
                        <tr>
                            <th>Fonction / Processus</th>
                            <th>Mode de défaillance</th>
                            <th>Effet</th>
                            <th>Cause</th>
                            <th>G</th>
                            <th>O</th>
                            <th>D</th>
                            <th>NPR</th>
                            <th>Priorité</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="amdecTableBody"></tbody>
                </table>
            </div>

            <div class="amdec-insights" id="amdecInsights"></div>
        </section>

        {% include 'components/qse/capa_soft_cta.html.twig' with { tool: 'amdec' } %}

        {% include 'components/tool_lead_cta.html.twig' %}
        {% include 'components/cta_ddwin.html.twig' %}

        <section class="seo-content">
            <h2>Qu'est-ce que l'analyse AMDEC ?</h2>
            <p>Analyse des Modes de Défaillance, de leurs Effets et de leur Criticité (FMEA en anglais). Méthode préventive d'analyse des risques qui permet d'identifier les défaillances potentielles d'un produit, processus ou système, d'évaluer leur criticité (indice NPR = Gravité × Occurrence × Détection) et de prioriser les actions correctives.</p>

            <h2>Comment utiliser l'analyse AMDEC ?</h2>
            <p>(1) Identifier les modes de défaillance. (2) Évaluer la gravité, l'occurrence et la détectabilité (échelles 1-10). (3) Calculer le NPR (Note de Priorité du Risque). (4) Prioriser les actions pour les NPR les plus élevés.</p>

            <h2>Quand utiliser l'analyse AMDEC ?</h2>
            <p>Conception de nouveau produit, optimisation de processus existant, plan de maintenance préventive, certification ISO 9001.</p>

            <h2>Pourquoi utiliser notre outil en ligne ?</h2>
            <p>Gratuit, sans installation, export PDF, conforme ISO, RGPD, sauvegarde.</p>
        </section>
    </div>

    {# Modal pour afficher les analyses AMDEC sauvegardées #}
    {% if app.user %}
    {% component AmdecAnalysesModal with {
        id: 'amdecLoadModal'
    } %}
    {% endcomponent %}
    {% endif %}
</main>
{% endblock %}

{% block stylesheets %}
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<link rel="stylesheet" href="{{ asset('styles/tools/amdec.css') }}" data-turbo-track="reload">
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="{{ asset('js/main.js') }}"></script>
<script src="{{ asset('js/amdec.js') }}"></script>
<script>
    window.amdecAppConfig = {
        isAuthenticated: {{ app.user ? 'true' : 'false' }},
        analysisId: {{ analysisId is defined and analysisId ? analysisId : 'null' }},
        currentAnalysisId: null,
    };

    window.amdecRoutes = {
        save: '{{ path('app_api_amdec_save') }}',
        list: '{{ path('app_api_amdec_list') }}',
        get: '{{ path('app_api_amdec_get', {id: 0}) }}',
        delete: '{{ path('app_api_amdec_delete', {id: 0}) }}',
        login: '{{ path('app_login') }}'
    };
</script>
{% endblock %}


