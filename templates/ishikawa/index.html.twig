{% extends (app.user ? 'base_with_sidebar.html.twig' : 'base.html.twig') %}

{% block head %}
    {{ parent() }}
    {% include 'components/turbo_newsletter_no_cache_meta.html.twig' %}
{% endblock %}

{% block title %}Diagramme d'Ishikawa en Ligne Gratuit — Créez et Exportez en PDF | Outils-Qualité{% endblock %}

{% block meta_description %}Créez votre diagramme d'Ishikawa (arête de poisson) en ligne gratuitement. Catégories 5M/6M personnalisables, export PDF professionnel pour vos audits ISO 9001.{% endblock %}

{% block meta_keywords %}diagramme Ishikawa, fishbone diagram, diagramme de causes et effets, analyse des causes, root cause analysis, Kaoru Ishikawa, outil qualité gratuit, amélioration continue{% endblock %}

{% block schema_webapp_json %}
{"@context":"https://schema.org","@type":"WebApplication","name":"Diagramme d'Ishikawa en ligne","url":{{ absolute_url(path('app_ishikawa_index'))|json_encode|raw }},"applicationCategory":"BusinessApplication","operatingSystem":"Web","offers":{"@type":"Offer","price":"0","priceCurrency":"EUR"},"description":"Créez votre diagramme d'Ishikawa (arête de poisson) en ligne. Catégories 5M/6M personnalisables, export PDF professionnel.","featureList":["Catégories 5M/6M personnalisables","Export PDF haute qualité","Sauvegarde automatique","Conforme ISO 9001"]}
{% endblock %}

{% block schema_breadcrumb_json %}
{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Accueil","item":{{ absolute_url(path('app_home_index'))|json_encode|raw }}},{"@type":"ListItem","position":2,"name":"Outils","item":{{ absolute_url(path('app_outils_index'))|json_encode|raw }}},{"@type":"ListItem","position":3,"name":"Diagramme d'Ishikawa","item":{{ absolute_url(path('app_ishikawa_index'))|json_encode|raw }}}]}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/tools/ishikawa.css') }}" data-turbo-track="reload">
{% endblock %}

{% block content %}
<div class="ishikawa-page">
    <div class="container">
        {% include 'components/tool_breadcrumb.html.twig' with { tool_name: "Diagramme d'Ishikawa" } %}
        {% include 'components/tool_page_header.html.twig' with {
            tool_icon: 'git-branch',
            tool_name: "Diagramme d'Ishikawa",
            tool_tagline: 'Analysez les causes racines avec la méthode 5M / 6M',
            tool_color: 'primary',
            tool_seo_route: 'app_tool_seo_ishikawa'
        } %}
    </div>
    {# En-tête compact : le diagramme suit immédiatement pour limiter le scroll avant l'outil #}
    <div class="page-header ishikawa-page-header--compact">
        <h1 class="page-title">Visualisez toutes les causes possibles d'un problème — méthode Ishikawa (5M)</h1>
        {% include 'components/tool_meta_hints.html.twig' with {
            tool_slug: 'ishikawa',
            hint_id_prefix: 'ishikawa',
            meta_intro: 'Survolez ou mettez le focus sur une pastille pour un court descriptif. L’aide détaillée est dans l’encadré juste en dessous ; le diagramme suit.',
            tag_hints: {
                'Analyse des causes': 'Structurer les pistes causes-effet avant de figer un plan d\'actions.',
                'Non-conformité': 'Utile après constat d\'écart, réclamation ou écart audit.',
                'ISO 9001': 'Appui documenté pour revues, audits et démarche qualité.',
                'Amélioration continue': 'Idéal en complément de PDCA ou de revue de direction.',
            },
        } %}
    </div>

    {% include 'components/ishikawa_help_panel.html.twig' %}

    <div class="ishikawa-content">
        {{ include('components/ishikawa_canvas.html.twig', { diagramId: diagramId }) }}
    </div>

    {% include 'components/qse/capa_ishikawa_toolbar.html.twig' %}

    <div class="container ishikawa-lower-stack">
        {% include 'components/tool_lead_cta.html.twig' %}
        {% include 'components/cta_ddwin.html.twig' %}

        <section class="seo-content">
            <h2>Qu'est-ce que le diagramme d'Ishikawa ?</h2>
            <p>Outil d'analyse des causes développé par Kaoru Ishikawa dans les années 1960, aussi appelé diagramme en arête de poisson ou diagramme causes-effets. Utilisé dans les démarches ISO 9001 et Lean Manufacturing pour identifier systématiquement les causes d'un problème.</p>

            <h2>Comment utiliser le diagramme d'Ishikawa ?</h2>
            <p>(1) Définir le problème (l'effet). (2) Identifier les catégories principales (5M ou 6M : Main-d'œuvre, Matières, Méthodes, Machines, Milieu, Management). (3) Lister les causes possibles dans chaque catégorie. (4) Analyser et prioriser les causes racines. (5) Définir un plan d'action.</p>

            <h2>Quand utiliser le diagramme d'Ishikawa ?</h2>
            <p>Analyse de non-conformité en production, investigation d'un défaut qualité client, revue de processus, préparation d'un audit ISO 9001.</p>

            <h2>Pourquoi utiliser notre outil en ligne ?</h2>
            <p>Création visuelle interactive, catégories personnalisables, drag & drop, export PDF prêt pour audit, sauvegarde automatique.</p>
        </section>
    </div>

    {# Modal pour afficher les analyses Ishikawa sauvegardées #}
    {% if app.user %}
    {% component IshikawaAnalysesModal with {
        id: 'ishikawaLoadModal'
    } %}
    {% endcomponent %}

    <twig:Dialog id="ishikawa-share" class="ishikawa-share-dialog-root">
        <button
            type="button"
            id="ishikawaShareDialogOpenStub"
            class="sr-only"
            tabindex="-1"
            data-action="click->ux-dialog#open"
            data-ux-dialog-target="trigger"
        >Ouvrir la fenêtre de partage</button>
        <twig:Dialog:Content class="w-[calc(100%-2rem)] max-w-[min(100%,36rem)] sm:max-w-xl">
            <twig:Dialog:Header>
                <twig:Dialog:Title>Partager le diagramme</twig:Dialog:Title>
                <twig:Dialog:Description class="text-left text-sm leading-relaxed text-slate-700 dark:text-slate-200">
                    Ce lien ouvre une <strong class="font-medium text-foreground">vue publique en lecture seule</strong> de votre diagramme. Il reste valable environ <strong class="font-medium text-foreground">un mois</strong>.
                    <span id="ishikawaShareExpiresLine" class="mt-2 block text-foreground"></span>
                </twig:Dialog:Description>
            </twig:Dialog:Header>
            <div class="mt-2 flex min-w-0 flex-col gap-3">
                <twig:Label for="ishikawaShareUrlInput" class="text-sm font-medium text-foreground">Adresse du lien</twig:Label>
                <twig:Input
                    id="ishikawaShareUrlInput"
                    type="url"
                    name="ishikawa-share-url"
                    readonly
                    value=""
                    autocomplete="off"
                    title="Cliquez pour copier le lien dans le presse-papiers"
                    class="min-w-0 max-w-full font-mono text-sm cursor-pointer transition-shadow hover:ring-2 hover:ring-primary/35 focus-visible:ring-2 focus-visible:ring-primary/45"
                />
                {# Pile verticale : une ligne flex + libellés longs dépassait max-w-lg et provoquait chevauchement. #}
                <div class="ishikawa-share-actions flex w-full min-w-0 flex-col gap-3">
                    <twig:Button type="button" id="ishikawaShareCopyBtn" variant="default" size="default" class="w-full max-w-full justify-center whitespace-normal">Copier le lien</twig:Button>
                    <twig:Button type="button" id="ishikawaShareNativeBtn" variant="outline" size="default" class="w-full max-w-full justify-center whitespace-normal font-semibold text-foreground shadow-sm hover:bg-muted/80" hidden>Partager via le système…</twig:Button>
                    <twig:Button as="a" id="ishikawaShareMailBtn" href="#" variant="outline" size="default" class="no-underline w-full max-w-full justify-center whitespace-normal text-center font-semibold text-foreground shadow-sm hover:bg-muted/80">Ouvrir dans le courriel</twig:Button>
                </div>
                <p id="ishikawaShareCopyFeedback" class="min-h-5 hidden text-sm font-medium text-primary" role="status" aria-live="polite"></p>
            </div>
            <twig:Dialog:Footer class="mt-4 border-t border-border/60 pt-4">
                <twig:Button type="button" variant="secondary" data-action="click->ux-dialog#close">Fermer</twig:Button>
            </twig:Dialog:Footer>
        </twig:Dialog:Content>
    </twig:Dialog>
    {% else %}
    {% include 'components/save_guest_modal.html.twig' with { tool: 'ishikawa' } %}
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}


<!-- Toastify CSS -->
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <!-- Toastify JS -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <!-- Bibliothèques d'export -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <!-- Scripts globaux -->
    <script src="{{ asset('js/export-branding.js') }}" data-turbo-track="reload"></script>
    <script src="{{ asset('js/main.js') }}" data-turbo-track="reload"></script>
    <script>
        window.ishikawaReadonly = false;
        window.ishikawaIsGuest = {{ app.user ? 'false' : 'true' }};
    </script>
    <!-- Ishikawa JS - Chargé après le DOM pour éviter les problèmes d'initialisation -->
    <script src="{{ asset('js/ishikawa.js') }}" data-turbo-track="reload"></script>
    {% if not app.user %}
    <script>
        document.addEventListener('show-save-guest-modal', function () {
            var el = document.getElementById('saveGuestModal');
            if (!el || !window.Stimulus || typeof window.Stimulus.getControllerForElementAndIdentifier !== 'function') {
                return;
            }
            try {
                var c = window.Stimulus.getControllerForElementAndIdentifier(el, 'app-modal');
                if (c && typeof c.show === 'function') {
                    c.show();
                }
            } catch (e) {}
        });
    </script>
    {% endif %}
    {% if app.user %}
    <script>
        // Fonction de sauvegarde via API (similaire à saveFiveWhy)
        async function saveIshikawa() {
            const Toastify = window.Toastify;
            
            if (!Toastify) {
                alert('Erreur : Bibliothèque Toastify non chargée');
                return;
            }
            
            // Récupérer les données du diagramme via la fonction exposée
            let diagramData = {};
            
            if (window.ishikawaApp && typeof window.ishikawaApp.getDiagramData === 'function') {
                diagramData = window.ishikawaApp.getDiagramData();
            } else {
                _showIshikawaToast("Erreur : Impossible de récupérer les données du diagramme.", 'error');
                return;
            }
            
            const problemInput = document.getElementById('problemInput');
            const problem = problemInput ? problemInput.value : '';
            const diagramIdInput = document.getElementById('ishikawaDiagramId');
            const existingId = diagramIdInput && diagramIdInput.value ? parseInt(diagramIdInput.value, 10) : null;
            
            const saveBtn = document.getElementById('saveIshikawaBtn');
            const originalText = saveBtn.innerHTML;
            
            try {
                saveBtn.disabled = true;
                saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Sauvegarde...';
                
                const payload = {
                    title: problem || 'Diagramme Ishikawa - ' + new Date().toLocaleDateString('fr-FR'),
                    problem: problem,
                    content: diagramData
                };

                if (existingId) {
                    payload.id = existingId;
                }

                const response = await fetch('{{ path('app_tool_ishikawa_save') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: JSON.stringify(payload)
                });
                
                const data = await response.json();
                
                if (data.success) {
                    _showIshikawaToast("Diagramme sauvegardé avec succès !", 'success');

                    if (diagramIdInput && data.data && data.data.id) {
                        diagramIdInput.value = data.data.id;
                    }
                } else {
                    throw new Error(data.message || 'Erreur lors de la sauvegarde');
                }
            } catch (error) {
                console.error('Erreur lors de la sauvegarde:', error);
                _showIshikawaToast("Erreur lors de la sauvegarde : " + error.message, 'error');
            } finally {
                saveBtn.disabled = false;
                saveBtn.innerHTML = originalText;
            }
        }

        function ishikawaOpenShareDialog(shareUrl, expiration) {
            var urlInput = document.getElementById('ishikawaShareUrlInput');
            var expiresLine = document.getElementById('ishikawaShareExpiresLine');
            var mailBtn = document.getElementById('ishikawaShareMailBtn');
            var nativeBtn = document.getElementById('ishikawaShareNativeBtn');
            var feedback = document.getElementById('ishikawaShareCopyFeedback');
            var stub = document.getElementById('ishikawaShareDialogOpenStub');
            var dlg = document.getElementById('dialog-ishikawa-share');

            if (!urlInput || !stub || !dlg) {
                window.prompt('Copiez ce lien pour partager votre diagramme :', shareUrl);
                return;
            }

            urlInput.value = shareUrl;
            if (expiresLine) {
                if (expiration && !isNaN(expiration.getTime())) {
                    expiresLine.textContent = 'Valide jusqu’au ' + expiration.toLocaleDateString('fr-FR') + ' (fuseau local).';
                } else {
                    expiresLine.textContent = '';
                }
            }
            if (mailBtn) {
                var subject = encodeURIComponent('Diagramme Ishikawa partagé');
                mailBtn.href = 'mailto:?subject=' + subject + '&body=' + encodeURIComponent(shareUrl);
            }
            if (feedback) {
                feedback.textContent = '';
                feedback.classList.add('hidden');
            }

            if (nativeBtn) {
                nativeBtn.replaceWith(nativeBtn.cloneNode(true));
                nativeBtn = document.getElementById('ishikawaShareNativeBtn');
                if (typeof navigator.share === 'function') {
                    nativeBtn.hidden = false;
                    nativeBtn.addEventListener('click', function () {
                        navigator.share({
                            title: 'Diagramme Ishikawa',
                            text: 'Consultez ce diagramme en lecture seule :',
                            url: shareUrl,
                        }).catch(function () {});
                    });
                } else {
                    nativeBtn.hidden = true;
                }
            }

            stub.click();
            requestAnimationFrame(function () {
                urlInput.focus();
                urlInput.select();
            });
        }

        async function ishikawaShareDialogCopy() {
            var urlInput = document.getElementById('ishikawaShareUrlInput');
            var feedback = document.getElementById('ishikawaShareCopyFeedback');
            var url = urlInput ? urlInput.value : '';
            if (!url || !feedback) return;
            try {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    await navigator.clipboard.writeText(url);
                } else {
                    urlInput.focus();
                    urlInput.select();
                    document.execCommand('copy');
                }
                feedback.classList.add('hidden');
                if (window.Toastify) {
                    _showIshikawaToast('Lien copié dans le presse-papiers.', 'info');
                } else {
                    feedback.textContent = 'Copié dans le presse-papiers.';
                    feedback.classList.remove('hidden');
                    window.setTimeout(function () {
                        feedback.classList.add('hidden');
                    }, 2800);
                }
                if (urlInput) {
                    urlInput.focus();
                    urlInput.select();
                }
            } catch (e) {
                feedback.textContent = 'Copie impossible : sélectionnez le lien puis Ctrl+C (ou Cmd+C).';
                feedback.classList.remove('hidden');
                if (window.Toastify) {
                    _showIshikawaToast('Copie impossible. Sélectionnez le lien puis Ctrl+C (ou Cmd+C).', 'warning');
                }
            }
        }

        document.getElementById('ishikawaShareCopyBtn')?.addEventListener('click', function () {
            ishikawaShareDialogCopy();
        });

        document.getElementById('ishikawaShareUrlInput')?.addEventListener('click', function () {
            ishikawaShareDialogCopy();
        });

        async function shareIshikawa() {
            const Toastify = window.Toastify;
            const shareBtn = document.getElementById('shareIshikawaBtn');
            const diagramIdInput = document.getElementById('ishikawaDiagramId');

            if (!diagramIdInput || !diagramIdInput.value) {
                _showIshikawaToast("Sauvegardez le diagramme avant de le partager.", 'warning');
                return;
            }

            try {
                shareBtn.disabled = true;
                shareBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Partage...';

                const response = await fetch('{{ path('app_api_ishikawa_share') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: JSON.stringify({
                        id: parseInt(diagramIdInput.value, 10)
                    })
                });

                const data = await response.json();

                if (!data.success) {
                    throw new Error(data.message || 'Impossible de générer le lien de partage');
                }

                const shareUrl = data.data.url;
                const expiration = data.data.expiresAt ? new Date(data.data.expiresAt) : null;

                ishikawaOpenShareDialog(shareUrl, expiration);
            } catch (error) {
                console.error('Erreur lors du partage:', error);
                _showIshikawaToast("Erreur lors du partage : " + error.message, 'error');
            } finally {
                shareBtn.disabled = false;
                shareBtn.innerHTML = '<i class="fas fa-share-alt mr-2"></i>Partager';
            }
        }

        function _showIshikawaToast(text, typeOrColor) {
            const value = String(typeOrColor || 'info');
            const normalizedType = value.includes('ff6b6b') || value === 'error'
                ? 'error'
                : value.includes('f97316') || value.includes('ffa500') || value === 'warning'
                ? 'warning'
                : value.includes('00b09b') || value === 'success'
                ? 'success'
                : 'info';

            if (typeof window.appNotify === 'function') {
                window.appNotify(text, normalizedType);
                return;
            }

            if (typeof window.showToast === 'function') {
                window.showToast(text, normalizedType);
                return;
            }

            console.log(`[${normalizedType}]`, text);
        }

        async function _openIshikawaModal(modalElement) {
            let ctrl = null;
            if (window.Stimulus && typeof window.Stimulus.getControllerForElementAndIdentifier === 'function') {
                try { ctrl = window.Stimulus.getControllerForElementAndIdentifier(modalElement, 'app-modal'); } catch (e) {}
            }
            if (ctrl && typeof ctrl.show === 'function') { ctrl.show(); return; }
            var deadline = Date.now() + 3000;
            while (Date.now() < deadline) {
                try { ctrl = window.Stimulus.getControllerForElementAndIdentifier(modalElement, 'app-modal'); } catch (e) { ctrl = null; }
                if (ctrl && typeof ctrl.show === 'function') { ctrl.show(); return; }
                await new Promise(function (r) { setTimeout(r, 50); });
            }
        }

        async function _closeIshikawaModal(modalElement) {
            let ctrl = null;
            if (window.Stimulus && typeof window.Stimulus.getControllerForElementAndIdentifier === 'function') {
                try { ctrl = window.Stimulus.getControllerForElementAndIdentifier(modalElement, 'app-modal'); } catch (e) {}
            }
            if (ctrl && typeof ctrl.hide === 'function') { ctrl.hide(); return; }
            var deadline = Date.now() + 3000;
            while (Date.now() < deadline) {
                try { ctrl = window.Stimulus.getControllerForElementAndIdentifier(modalElement, 'app-modal'); } catch (e) { ctrl = null; }
                if (ctrl && typeof ctrl.hide === 'function') { ctrl.hide(); return; }
                await new Promise(function (r) { setTimeout(r, 50); });
            }
        }

        async function deleteIshikawaAnalysis(id, event) {
            event.stopPropagation();
            const confirmed = await window.ishikawaApp.requestConfirmation(
                { title: 'Supprimer l\'analyse', message: 'Êtes-vous sûr de vouloir supprimer cette analyse ? Cette action est irréversible.', confirmText: 'Supprimer', type: 'danger' },
                'Supprimer cette analyse ?'
            );
            if (!confirmed) return;
            try {
                const baseUrl = '{{ path('app_tool_ishikawa_delete', {id: 0}) }}';
                const url = baseUrl.replace(/\/0$/, '/' + id);
                const response = await fetch(url, {
                    method: 'DELETE',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                });
                const data = await response.json();
                if (!response.ok || !data.success) throw new Error(data.message || 'Erreur lors de la suppression');
                _showIshikawaToast('Analyse supprimée.', 'linear-gradient(to right, #00b09b, #96c93d)');
                const currentDiagramId = document.getElementById('ishikawaDiagramId')?.value;
                if (currentDiagramId && parseInt(currentDiagramId) === parseInt(id)) {
                    document.getElementById('ishikawaDiagramId').value = '';
                }
                // Rafraîchir la liste dans le modal
                openIshikawaSaved();
            } catch (error) {
                _showIshikawaToast('Erreur : ' + error.message, 'linear-gradient(to right, #ff6b6b, #ee5a6f)');
            }
        }

        async function newIshikawaAnalysis() {
            const confirmed = await window.ishikawaApp.requestConfirmation(
                { title: 'Nouvelle analyse', message: 'Créer une nouvelle analyse ? Le diagramme actuel sera réinitialisé (non sauvegardé).', confirmText: 'Créer', type: 'warning' },
                'Créer une nouvelle analyse ?'
            );
            if (!confirmed) return;
            if (window.ishikawaApp && typeof window.ishikawaApp.createNewDiagram === 'function') {
                window.ishikawaApp.createNewDiagram();
            }
            const modalElement = document.getElementById('ishikawaLoadModal');
            if (modalElement) await _closeIshikawaModal(modalElement);
        }

        function ishikawaEscHtml(s) {
            return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
        }
        function ishikawaEscAttr(s) {
            return String(s ?? '').replace(/\\/g, '\\\\').replace(/"/g, '&quot;').replace(/&/g, '&amp;');
        }

        async function openIshikawaSaved() {
            if (!{{ app.user ? 'true' : 'false' }}) {
                _showIshikawaToast('Connectez-vous pour accéder à vos analyses.', 'linear-gradient(to right, #f97316, #ea580c)');
                return;
            }

            try {
                const response = await fetch('{{ path('app_tool_ishikawa_list') }}', {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                });
                const data = await response.json();
                const analyses = data.data || [];

                const modalElement = document.getElementById('ishikawaLoadModal');
                if (!modalElement) {
                    _showIshikawaToast("Le modal n'est pas disponible.", 'linear-gradient(to right, #ff6b6b, #ee5a6f)');
                    return;
                }

                const listContainer = modalElement.querySelector('#ishikawaAnalysesList');
                if (!listContainer) return;

                if (!analyses.length) {
                    listContainer.innerHTML = `
                        <li class="rounded-lg border border-dashed border-border bg-muted/50 px-4 py-8 text-center">
                            <p class="m-0 mb-3 text-base font-medium text-foreground">Aucune analyse sauvegardée.</p>
                            <button type="button" class="inline-flex items-center justify-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground shadow hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2" onclick="newIshikawaAnalysis()">
                                <i class="fas fa-plus" aria-hidden="true"></i>Créer une nouvelle analyse
                            </button>
                        </li>`;
                } else {
                    const baseLoadUrl = {{ path('app_ishikawa_index')|json_encode|raw }};
                    listContainer.innerHTML = analyses.map((analysis) => {
                        const id = parseInt(analysis.id, 10);
                        const title = ishikawaEscHtml(analysis.title || 'Sans titre');
                        const problem = ishikawaEscHtml(analysis.problem || 'Diagramme Ishikawa');
                        const rawDate = analysis.updatedAt || analysis.createdAt;
                        const d = rawDate ? new Date(rawDate) : null;
                        const dateLabel = d && !isNaN(d.getTime()) ? d.toLocaleDateString('fr-FR') : '—';
                        const dateIso = d && !isNaN(d.getTime()) ? d.toISOString().slice(0, 10) : '';
                        const href = baseLoadUrl + (baseLoadUrl.indexOf('?') >= 0 ? '&' : '?') + 'load=' + id;
                        const delLabel = ishikawaEscAttr((analysis.title || 'Sans titre').slice(0, 80));
                        const dateAttr = dateIso ? ' datetime="' + dateIso + '"' : '';
                        return `
                        <li class="rounded-lg border border-border bg-muted/40 shadow-sm transition-colors hover:border-primary/40 hover:bg-muted/70">
                            <div class="flex items-stretch gap-2 p-3 sm:p-4">
                                <a href="${href}" class="flex min-w-0 flex-1 flex-col gap-1 rounded-md no-underline text-foreground outline-none ring-offset-background focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2">
                                    <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
                                        <span class="truncate text-base font-semibold leading-snug text-foreground">${title}</span>
                                        <time class="shrink-0 text-sm font-semibold tabular-nums text-slate-800 dark:text-slate-200"${dateAttr}>${ishikawaEscHtml(dateLabel)}</time>
                                    </div>
                                    <span class="line-clamp-2 text-sm leading-snug text-slate-800 dark:text-slate-200">${problem}</span>
                                </a>
                                <button type="button" class="inline-flex shrink-0 items-center justify-center rounded-md border border-destructive/40 bg-background px-3 py-2 text-destructive shadow-sm hover:bg-destructive/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-destructive focus-visible:ring-offset-2" title="Supprimer cette analyse" aria-label="Supprimer l’analyse « ${delLabel} »" onclick="deleteIshikawaAnalysis(${id}, event)">
                                    <i class="fas fa-trash-alt" aria-hidden="true"></i>
                                </button>
                            </div>
                        </li>`;
                    }).join('');
                }

                // Ajouter un footer "Nouvelle analyse" si pas déjà présent (structure LiveComponent / Tailwind : pas de .modal-content)
                let modalFooter = modalElement.querySelector('.modal-footer');
                if (!modalFooter) {
                    modalFooter = document.createElement('div');
                    modalFooter.className = 'modal-footer px-6 py-3 border-t border-border shrink-0 flex justify-end';
                    modalFooter.innerHTML = `<button type="button" class="inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground shadow hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2" onclick="newIshikawaAnalysis()"><i class="fas fa-plus mr-2" aria-hidden="true"></i>Nouvelle analyse</button>`;
                    const appendTarget = modalElement.querySelector('[role="document"]') || modalElement.firstElementChild;
                    if (appendTarget) {
                        appendTarget.appendChild(modalFooter);
                    }
                }

                if (typeof lucide !== 'undefined') lucide.createIcons();

                await _openIshikawaModal(modalElement);
            } catch (error) {
                console.error(error);
                _showIshikawaToast(error.message || 'Erreur lors du chargement des analyses.', 'linear-gradient(to right, #ff6b6b, #ee5a6f)');
            }
        }

        window.openIshikawaSaved = openIshikawaSaved;
        window.newIshikawaAnalysis = newIshikawaAnalysis;
        window.deleteIshikawaAnalysis = deleteIshikawaAnalysis;
    </script>
    {% endif %}

    {% if diagramId %}
    <script>
        (function() {
            const isAuthenticated = Boolean({{ app.user ? 1 : 0 }});
            const requestUrl = '{{ path('app_tool_ishikawa_get', {id: diagramId}) }}';

            function notify(message, type = 'info') {
                const Toastify = window.Toastify;
                if (Toastify) {
                    const colors = {
                        success: 'linear-gradient(to right, #22c55e, #16a34a)',
                        error: 'linear-gradient(to right, #ef4444, #dc2626)',
                        warning: 'linear-gradient(to right, #f97316, #ea580c)',
                        info: 'linear-gradient(to right, #2563eb, #38bdf8)'
                    };
                    _showIshikawaToast(message, type);
                } else {
                    if (type === 'error') {
                        console.error(message);
                    } else {
                        console.log(message);
                    }
                }
            }

            async function fetchDiagram() {
                try {
                    const response = await fetch(requestUrl, {
                        headers: {
                            'Accept': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        credentials: 'same-origin'
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    const payload = await response.json();
                    if (!payload || payload.success === false) {
                        throw new Error(payload?.message || 'Diagramme introuvable.');
                    }

                    const data = payload.data || {};
                    const content = data.content ? { ...data.content } : {};
                    if (typeof content.problem !== 'string' && typeof data.problem === 'string') {
                        content.problem = data.problem;
                    }
                    if (!Array.isArray(content.categories)) {
                        content.categories = [];
                    }
 
                    if (window.ishikawaApp && typeof window.ishikawaApp.loadDiagramData === 'function') {
                        window.ishikawaApp.loadDiagramData(content);
                        const diagramIdInput = document.getElementById('ishikawaDiagramId');
                        if (diagramIdInput) {
                            diagramIdInput.value = data.id ?? '';
                        }
                        notify('Diagramme chargé avec succès.', 'success');
                    }
                } catch (error) {
                    console.error('Ishikawa: erreur lors du chargement du diagramme', error);
                    notify('Impossible de charger le diagramme sauvegardé.', 'error');
                }
            }

            function bootstrapLoading() {
                if (!isAuthenticated) {
                    notify('Connectez-vous pour charger vos diagrammes sauvegardés.', 'warning');
                    return;
                }

                if (window.ishikawaApp && typeof window.ishikawaApp.loadDiagramData === 'function' && window.ishikawaApp.isReady) {
                    fetchDiagram();
                } else {
                    const handler = () => {
                        window.removeEventListener('ishikawa:ready', handler);
                        fetchDiagram();
                    };
                    window.addEventListener('ishikawa:ready', handler, { once: true });
                }
            }

            if (typeof window.requestAnimationFrame === 'function') {
                window.requestAnimationFrame(bootstrapLoading);
            } else {
                bootstrapLoading();
            }
        })();
    </script>
    {% endif %}
{% endblock %}
