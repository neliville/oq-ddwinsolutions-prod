{% extends 'base.html.twig' %}

{% block title %}Audit partagé (lecture seule) | OUTILS-QUALITÉ{% endblock %}
{% block meta_description %}Vue lecture seule d’un audit partagé — OUTILS-QUALITÉ{% endblock %}

{% block content %}
<div
    class="w-full max-w-6xl mx-auto px-4 py-8 pb-24"
    data-controller="audit-cockpit"
    data-audit-cockpit-chart-config-value="{{ chartConfigJson|e('html_attr') }}"
>
    <twig:Alert variant="info" class="mb-6">
        <twig:Alert:Title>Vue invitée — lecture seule</twig:Alert:Title>
        <twig:Alert:Description class="text-sm">Ce lien ne permet pas de modifier les données. Niveau enregistré : {{ accessLevel }}.</twig:Alert:Description>
    </twig:Alert>
    <div class="mb-6">
        <h1 class="text-2xl font-bold">{{ audit.companyName|default('Audit') }}</h1>
        <p class="text-muted-foreground text-sm mt-1">{{ audit.auditStandard ? audit.auditStandard.name : '—' }} · {{ audit.auditedAt|date('d/m/Y') }}</p>
    </div>

    <div class="sticky top-0 z-20 -mx-4 px-4 py-3 mb-6 border-b border-border bg-background/95 backdrop-blur">
        <div class="flex flex-wrap gap-2">
            <twig:Card class="flex-1 min-w-[7rem] border-border/80 py-2 px-3 shadow-none">
                <p class="text-[10px] font-semibold uppercase text-muted-foreground m-0">Conformité</p>
                <p class="text-base font-bold tabular-nums m-0">{{ cockpitMetrics.globalComplianceRate is not null ? cockpitMetrics.globalComplianceRate ~ ' %' : '—' }}</p>
            </twig:Card>
            <twig:Card class="flex-1 min-w-[7rem] border-border/80 py-2 px-3 shadow-none">
                <p class="text-[10px] font-semibold uppercase text-muted-foreground m-0">Réponses</p>
                <p class="text-base font-bold tabular-nums m-0">{{ cockpitMetrics.answeredRequirements }}/{{ cockpitMetrics.totalRequirements }}</p>
            </twig:Card>
        </div>
    </div>

    <div class="grid lg:grid-cols-12 gap-6">
        <aside class="lg:col-span-4 space-y-4 order-2 lg:order-1">
            <div class="rounded-lg border border-border bg-card p-2">
                <p class="text-xs font-medium text-muted-foreground mb-1">Conformité par chapitre</p>
                <div class="h-48">
                    <canvas data-audit-cockpit-chart-ref="radar" class="max-h-full w-full"></canvas>
                </div>
            </div>
            <div class="rounded-lg border border-border bg-card p-2">
                <p class="text-xs font-medium text-muted-foreground mb-1">Verdicts</p>
                <div class="h-52">
                    <canvas data-audit-cockpit-chart-ref="distribution" class="max-h-full w-full"></canvas>
                </div>
            </div>
        </aside>
        <div class="lg:col-span-8 space-y-6 order-1 lg:order-2">
            {% for block in chapterBlocks %}
                <h2 class="text-lg font-semibold border-b border-border pb-2">{{ block.chapter }}</h2>
                <div class="space-y-4">
                    {% for req in block.requirements %}
                        {% set ev = evaluationsByReqId[req.id] ?? null %}
                        <twig:AuditRequirementCard :requirement="req" :evaluation="ev" :audit="audit" :read-only="true" />
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-muted-foreground">Aucune exigence à afficher.</p>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
