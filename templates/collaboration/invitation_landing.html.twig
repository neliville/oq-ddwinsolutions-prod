{% extends 'base.html.twig' %}

{% block title %}Accepter une invitation | OUTILS-QUALITÉ{% endblock %}

{% block content %}
<section class="border-b border-border/50 bg-gradient-to-b from-primary/[0.07] via-background to-muted/40" aria-labelledby="collab-invite-title">
    <div class="mx-auto flex min-h-[min(72vh,52rem)] w-full max-w-6xl flex-col items-center justify-center px-4 py-10 sm:px-6 sm:py-14">
        <twig:Card class="w-full max-w-lg border-border/80 text-center shadow-md ring-1 ring-border/40">
            <twig:Card:Header class="flex flex-col items-center space-y-4 pb-2 pt-8 sm:pt-10">
                <div class="flex size-14 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary ring-1 ring-primary/20" aria-hidden="true">
                    <twig:ux:icon name="lucide:user-plus" class="size-7 shrink-0" />
                </div>
                <div class="space-y-2">
                    <twig:Card:Title id="collab-invite-title" class="text-xl font-bold tracking-tight text-foreground sm:text-2xl">
                        Invitation à collaborer
                    </twig:Card:Title>
                    <twig:Card:Description class="mx-auto max-w-md text-base leading-relaxed text-muted-foreground">
                        <span class="font-medium text-foreground">{{ invitation.owner.email }}</span>
                        vous invite sur OUTILS-QUALITÉ à rejoindre son espace de pilotage QHSE partagé.
                    </twig:Card:Description>
                </div>
                <twig:Badge variant="secondary" class="text-xs font-medium">
                    Rôle attribué : {{ invitation.role.label() }}
                </twig:Badge>
            </twig:Card:Header>

            <twig:Card:Content class="space-y-5 px-6 pb-2 pt-0 text-left sm:px-8">
                <twig:Alert variant="warning" class="px-3 py-3 shadow-sm sm:px-4">
                    <twig:ux:icon name="lucide:mail" class="size-4 shrink-0" aria-hidden="true" />
                    <twig:Alert:Title>Adresse e-mail imposée pour cette invitation</twig:Alert:Title>
                    <twig:Alert:Description class="space-y-2 text-sm leading-snug">
                        <p class="m-0">
                            À l’inscription ou à la connexion, vous devez utiliser <strong class="text-foreground">exactement</strong> l’adresse suivante (sinon l’invitation ne pourra pas être validée) :
                        </p>
                        <p class="m-0 rounded-md border border-amber-500/30 bg-background/80 px-3 py-2 font-mono text-sm font-semibold tracking-tight text-foreground break-all">
                            {{ invitation.email }}
                        </p>
                    </twig:Alert:Description>
                </twig:Alert>

                <ol class="m-0 list-none space-y-2.5 p-0 text-sm text-muted-foreground">
                    <li class="flex gap-3">
                        <span class="flex size-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-xs font-bold text-primary" aria-hidden="true">1</span>
                        <span class="pt-0.5 leading-snug">Créez un compte ou connectez-vous avec le bouton ci-dessous.</span>
                    </li>
                    <li class="flex gap-3">
                        <span class="flex size-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-xs font-bold text-primary" aria-hidden="true">2</span>
                        <span class="pt-0.5 leading-snug">Après connexion, votre accès collaborateur sera activé automatiquement si l’e-mail correspond.</span>
                    </li>
                </ol>
            </twig:Card:Content>

            <twig:Card:Footer class="flex flex-col gap-3 px-6 pb-8 pt-4 sm:flex-row sm:justify-stretch sm:px-8">
                <twig:Button as="a" href="{{ register_url }}" variant="default" size="default" class="no-underline w-full justify-center gap-2 sm:flex-1" data-turbo="false">
                    <twig:ux:icon name="lucide:user-plus" class="size-4 shrink-0" aria-hidden="true" />
                    Créer mon compte
                </twig:Button>
                <twig:Button as="a" href="{{ login_url }}" variant="outline" size="default" class="no-underline w-full justify-center gap-2 sm:flex-1" data-turbo="false">
                    <twig:ux:icon name="lucide:log-in" class="size-4 shrink-0" aria-hidden="true" />
                    J’ai déjà un compte
                </twig:Button>
            </twig:Card:Footer>
        </twig:Card>

        <p class="mt-6 max-w-lg text-center text-xs text-muted-foreground">
            Besoin d’aide ? Contactez la personne qui vous a envoyé le lien ou utilisez notre
            <a href="{{ path('app_contact_index') }}" class="font-medium text-primary underline-offset-4 hover:underline">formulaire de contact</a>.
        </p>
    </div>
</section>
{% endblock %}
