###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=ChangeMePlease
APP_DEBUG=1
# Base de données locale (MySQL/MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=oqddwinsolutions
DB_USER=root
DB_PASSWORD=
DATABASE_URL="mysql://root:@127.0.0.1:3306/oqddwinsolutions?serverVersion=10.6&charset=utf8mb4"
APP_URL=https://localhost
DEFAULT_URI=https://localhost
# Même adresse que le compte SMTP si l’hébergeur l’exige (o2switch, etc.)
APP_EMAIL=contact@outils-qualite.com
# Mail : null (pas d'envoi) ou SMTP / Brevo (voir ci-dessous)
MAILER_DSN=null://null
###< symfony/framework-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/brevo-mailer ###
# Pour tester Brevo : créer une clé API (Brevo → SMTP & API → API keys), puis :
# BREVO_API_KEY=votre-cle-api-brevo
# MAILER_DSN=brevo+api://${BREVO_API_KEY}@default
###< symfony/brevo-mailer ###

###> mautic ###
# URL de l'instance Mautic (ex. https://mautic.outils-qualite.com)
# CORS (embed + mtc.js → POST vers ce domaine) : dans l’admin Mautic, Configuration →
# « CORS » / domaines autorisés, ajouter l’URL exacte du site public (ex. https://outils-qualite.com
# sans slash final). Sinon la préflight OPTIONS vers /mtc/event échoue et le tracking / formulaires AJAX ne partent pas.
MAUTIC_URL=https://mautic.outils-qualite.com
# Authentification Basic Auth API Mautic
MAUTIC_USER=api_symfony
MAUTIC_PASSWORD=y0vmyLiSRf51
# ID du formulaire Mautic pour la page /telechargement-modele-5m (embed generate.js).
# Ressource et téléchargement : configurés dans Mautic — voir docs/DOWNLOAD_MAUTIC.md
MAUTIC_FORM_DOWNLOAD_5M_ID=3
# ID du formulaire Mautic embarqué pour la newsletter (form/generate.js)
MAUTIC_FORM_NEWSLETTER_ID=4

###< mautic ###

###> download authorize (n8n) ###
# Clé API pour sécuriser POST /api/download/authorize (appelé par n8n). En-tête X-Api-Key
# Si vide, l'endpoint accepte toute requête (à éviter en prod)
DOWNLOAD_AUTHORIZE_API_KEY=36b8c21b1fde9f5f58b52aede333816a
###< download authorize ###

###> download sécurisé (GET /ressources/download, token HMAC) ###
# Secret pour HMAC-SHA256 (token = hash_hmac('sha256', file . expires, DOWNLOAD_SECRET))
DOWNLOAD_SECRET=36b8c21b1fde9f5f58b52aede333816a
# Répertoire des fichiers (ex. /home/iwob6566/ressources_qse)
DOWNLOAD_BASE_PATH=/home/iwob6566/ressources_qse
###< download sécurisé ###
